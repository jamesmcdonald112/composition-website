---
import { booking } from "../../config/booking";
import CtaLink from "../ui/CtaLink.astro";
import Eyebrow from "../ui/Eyebrow.astro";
---

<div class="not-found">
	<div class="not-found__inner wrapper wrapper--wide">
		<Eyebrow text="404 — page not found" />

		<h1 class="not-found__heading">
			We can't find<br /><em>the page you're looking for.</em>
		</h1>

		<p class="not-found__body">
			The page may have been moved, or the address may have been mistyped. The links below should take you where you need to go.
		</p>

		<nav class="not-found__nav" aria-label="Where would you like to go?">
			<CtaLink href="/" label="Back to Home" variant="primary" icon="arrow" />
			<CtaLink
				href={booking.href}
				label={booking.label}
				variant="outline-dark"
				calLink={booking.calLink}
				calNamespace={booking.calNamespace}
				calConfig={booking.calConfig}
			/>
		</nav>

		<p class="not-found__contact">
			If you reached this page from a link elsewhere on the web, please <a href="/contact">let us know</a> and we'll fix it.
		</p>
	</div>
</div>

<style>
	.not-found {
		min-height: 100svh;
		background: var(--color-bg-page);
		display: flex;
		align-items: center;
		justify-content: center;
		padding-block: var(--space-5xl);
	}

	.not-found__inner {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		max-width: 65ch;
	}

	.not-found__heading {
		font-family: var(--font-serif);
		font-size: clamp(var(--font-size-3xl), 5vw, var(--font-size-5xl));
		font-weight: var(--font-weight-light);
		line-height: var(--line-height-tight);
		letter-spacing: var(--letter-spacing-tight);
		color: var(--color-fg-default);
		margin-block-start: var(--space-lg);
		margin-block-end: var(--space-xl);

		em {
			font-style: italic;
			color: var(--color-fg-accent);
		}
	}

	.not-found__body {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		line-height: var(--line-height-relaxed);
		color: var(--color-fg-muted);
		margin-block-end: var(--space-3xl);
	}

	.not-found__nav {
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: stretch;
		gap: var(--space-md);
		margin-block-end: var(--space-4xl);
		width: 100%;

		@media (min-width: 640px) {
			flex-direction: row;
			align-items: center;
			width: auto;
		}
	}

	.not-found__contact {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed);
		color: var(--color-fg-muted);

		a {
			color: var(--color-fg-accent);
			text-decoration: none;
			border-block-end: 1px solid currentColor;

			&:hover {
				color: var(--color-fg-default);
			}
		}
	}
</style>
