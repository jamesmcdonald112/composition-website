---
import { Image } from "astro:assets";
import type { Solicitor } from "../../../../config/team";

interface Props {
	text: string;
	solicitor: Solicitor;
	class?: string;
}

const { text, solicitor, class: className } = Astro.props;
const attribution = `${solicitor.name}, ${solicitor.role}`;
---

<figure class:list={["quote-card", className]} data-sa-quote>
	<blockquote class="quote-card__text">
		<p>{text}</p>
	</blockquote>
	<figcaption class="quote-card__attribution">
		<div class="quote-card__portrait">
			<Image src={solicitor.photo} alt={attribution} class="quote-card__img" widths={[80, 160]} sizes="80px" />
		</div>
		<p class="quote-card__name">{attribution}</p>
	</figcaption>
</figure>

<style>
	.quote-card {
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
		padding-block: var(--space-xl);
		padding-inline: var(--space-2xl);
		border-radius: var(--radius-lg);
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border-brand);
		box-shadow: var(--shadow-sm);
		position: relative;
		cursor: default;
		transition:
			transform 0.35s var(--ease-out),
			box-shadow 0.35s var(--ease-out),
			border-color 0.35s var(--ease-out);

		&:hover {
			transform: translateY(-6px);
			border-color: var(--color-border-accent);
			box-shadow:
				0 0 0 1px var(--color-border-accent),
				0 24px 48px color-mix(in srgb, var(--color-bg-brand) 8%, transparent);
		}

		&::before {
			content: "\201C";
			font-family: var(--font-serif);
			font-size: 72px;
			color: var(--color-fg-accent-on-brand);
			opacity: 0.5;
			position: absolute;
			top: var(--space-sm);
			right: var(--space-lg);
			line-height: var(--line-height-none);
			pointer-events: none;
			transition: opacity 0.35s var(--ease-out);
		}

		&:hover::before {
			opacity: 0.8;
		}
	}

	.quote-card__text {
		margin: 0;
		padding: 0;
		border: none;
		flex: 1;
		font-family: var(--font-serif);
		font-style: italic;
		font-size: var(--font-size-lg);
		line-height: 1.7;
		color: var(--color-fg-on-surface);
		margin-block-end: var(--space-lg);
	}

	.quote-card__text p {
		margin: 0;
	}

	.quote-card__attribution {
		display: flex;
		align-items: center;
		gap: var(--space-sm);
		padding-block-start: var(--space-lg);
		border-top: 1px solid var(--color-border-default);
	}

	.quote-card__portrait {
		width: var(--size-10);
		height: var(--size-10);
		flex-shrink: 0;
		overflow: hidden;
		border-radius: var(--radius-full);
		border: 1px solid var(--color-border-default);
	}

	.quote-card__img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center top;
	}

	.quote-card__name {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		font-weight: var(--font-weight-semibold);
		color: var(--color-fg-on-surface);
	}
</style>
