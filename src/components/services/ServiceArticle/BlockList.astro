---
type ListItem = { label: string; text: string };

type Block =
	| { type: "heading"; text: string }
	| { type: "paragraph"; text: string }
	| { type: "list"; items: readonly ListItem[] };

interface Props {
	blocks: readonly Block[];
}

const { blocks } = Astro.props;

function pad(n: number) {
	return String(n + 1).padStart(2, "0");
}
---

{
	blocks.map((block: Block) => {
		if (block.type === "heading") return <h3 class="svc-article__subheading">{block.text}</h3>;
		if (block.type === "paragraph") return <p class="svc-article__para">{block.text}</p>;
		if (block.type === "list")
			return (
				<ol class="svc-article__list" data-sva-list>
					{block.items.map((item: ListItem, i: number) => (
						<li class="svc-article__list-item" data-sva-list-item>
							<span class="svc-article__list-index" aria-hidden="true">
								{pad(i)}
							</span>
							<span class="svc-article__list-label">{item.label}</span>
							<span class="svc-article__list-text">{item.text}</span>
						</li>
					))}
				</ol>
			);
	})
}

<style>
	/* ── Subheading ──────────────────────────────────────────────────────────── */
	.svc-article__subheading {
		font-family: var(--font-serif);
		font-size: clamp(var(--font-size-xl), 2.5vw, var(--font-size-2xl));
		font-weight: var(--font-weight-light);
		line-height: var(--line-height-snug);
		letter-spacing: var(--letter-spacing-tight);
		color: var(--color-accent-on-light);
		padding-block-start: var(--space-sm);
	}

	/* ── Body paragraph ──────────────────────────────────────────────────────── */
	.svc-article__para {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		line-height: var(--line-height-relaxed);
		color: var(--color-text-muted);
		max-width: 65ch;
	}

	/* ── Premium list ────────────────────────────────────────────────────────── */
	.svc-article__list {
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
	}

	.svc-article__list-item {
		display: grid;
		grid-template-columns: 2.5rem 1fr;
		grid-template-rows: auto auto;
		column-gap: var(--space-md);
		row-gap: var(--space-sm);
		padding-block: var(--space-xl);
		padding-inline: var(--space-xl);
		border-radius: var(--radius-lg);
		background: var(--color-bg-subtle);
		border: 1px solid color-mix(in srgb, var(--color-text) 20%, transparent);
		border-left: 3px solid var(--color-accent-on-light);
		transition:
			border-color var(--duration-normal) var(--ease-out),
			background var(--duration-normal) var(--ease-out);

		&:hover {
			border-color: var(--color-accent);
			border-left-color: var(--color-accent);
			background: var(--color-bg-surface);
		}
	}

	/* col 1, row 1 — italic gold number */
	.svc-article__list-index {
		grid-column: 1;
		grid-row: 1;
		font-family: var(--font-serif);
		font-size: var(--font-size-lg);
		font-weight: var(--font-weight-light);
		font-style: italic;
		color: var(--color-accent-on-light);
		line-height: var(--line-height-tight);
	}

	/* col 2, row 1 — navy serif label */
	.svc-article__list-label {
		grid-column: 2;
		grid-row: 1;
		font-family: var(--font-serif);
		font-size: var(--font-size-lg);
		font-weight: var(--font-weight-light);
		letter-spacing: var(--letter-spacing-tight);
		color: var(--color-accent-on-light);
		line-height: var(--line-height-tight);
	}

	/* col 2, row 2 — muted body text */
	.svc-article__list-text {
		grid-column: 2;
		grid-row: 2;
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		line-height: var(--line-height-relaxed);
		color: var(--color-text-muted);
		font-weight: var(--font-weight-light);
	}
</style>
