---
type ListItem = { label: string; text: string };

type Block =
	| { type: "heading"; text: string }
	| { type: "paragraph"; text: string }
	| { type: "list"; items: readonly ListItem[] };

interface Props {
	blocks: readonly Block[];
}

const { blocks } = Astro.props;
---

{
	blocks.map((block: Block) => {
		if (block.type === "heading") return <h3 class="service-article__subheading" data-sa-block>{block.text}</h3>;
		if (block.type === "paragraph") return <p class="service-article__para" data-sa-block>{block.text}</p>;
		if (block.type === "list")
			return (
				<ol class="service-article__list" data-sa-block data-sa-list>
					{block.items.map((item: ListItem) => (
						<li class="service-article__list-item" data-sa-list-item>
							<span class="service-article__list-index" aria-hidden="true">✓</span>
							<span class="service-article__list-label">{item.label}</span>
							<span class="service-article__list-text">{item.text}</span>
						</li>
					))}
				</ol>
			);
	})
}

<style>
	/* ── Subheading ──────────────────────────────────────────────────────────── */
	.service-article__subheading {
		font-family: var(--font-serif);
		font-size: clamp(var(--font-size-xl), 2.5vw, var(--font-size-2xl));
		font-weight: var(--font-weight-light);
		line-height: var(--line-height-snug);
		letter-spacing: var(--letter-spacing-tight);
		color: var(--color-fg-default);
		padding-block-start: var(--space-sm);
	}

	/* ── Body paragraph ──────────────────────────────────────────────────────── */
	.service-article__para {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		line-height: var(--line-height-relaxed);
		color: var(--color-fg-muted);
		max-width: 65ch;
	}

	/* ── List ───────────────────────────────────────────────────────────────── */
	.service-article__list {
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
		counter-reset: list-item;
	}

	.service-article__list-item {
		display: grid;
		grid-template-columns: var(--size-6) 1fr;
		grid-template-rows: auto auto;
		column-gap: var(--space-lg);
		row-gap: var(--space-2xs);
		align-items: start;
		counter-increment: list-item;
	}

	/* Tick mark — baseline of label */
	.service-article__list-index {
		grid-column: 1;
		grid-row: 1;
		align-self: end;
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		font-weight: var(--font-weight-bold);
		color: var(--color-fg-accent);
		line-height: var(--line-height-snug);
		flex-shrink: 0;
	}

	/* Label — serif, strong foreground */
	.service-article__list-label {
		grid-column: 2;
		grid-row: 1;
		font-family: var(--font-serif);
		font-size: var(--font-size-lg);
		font-weight: var(--font-weight-light);
		letter-spacing: var(--letter-spacing-tight);
		color: var(--color-fg-default);
		line-height: var(--line-height-snug);
	}

	/* Body text — sans, muted */
	.service-article__list-text {
		grid-column: 2;
		grid-row: 2;
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		line-height: var(--line-height-relaxed);
		color: var(--color-fg-muted);
		font-weight: var(--font-weight-light);
	}
</style>
