---
import type { ImageMetadata } from "astro";
import ArticleQuote from "./ArticleQuote/ArticleQuote.astro";
import BlockList from "./BlockList/BlockList.astro";
import Eyebrow from "../../ui/Eyebrow.astro";

type Block =
	| { type: "heading"; text: string }
	| { type: "paragraph"; text: string }
	| { type: "list"; items: readonly { label: string; text: string }[] };

interface Quote {
	readonly text: string;
	readonly attribution: string;
	readonly image: ImageMetadata;
}

interface Props {
	eyebrow: string;
	title: string;
	intro: string;
	quote: Quote;
	blocks: readonly Block[];
}

const { eyebrow, title, intro, quote, blocks } = Astro.props;
---

<section class="service-article" data-service-article>
	<div class="service-article__inner wrapper wrapper--wide">
		<!-- Left: article content -->
		<div class="service-article__content">
			<!-- Section label -->
			<Eyebrow text={eyebrow} colorToken="--color-accent-on-light" animateAttr="sa-eyebrow" />

			<!-- Heading -->
			<h2 class="service-article__title" data-sa-title>{title}</h2>

			<!-- Gold rule -->
			<div class="service-article__rule" data-sa-rule aria-hidden="true"></div>

			<!-- Intro paragraph -->
			<p class="service-article__intro" data-sa-intro>{intro}</p>

			<!-- Quote — mobile only (hidden on desktop) -->
			<div class="service-article__quote-mobile">
				<ArticleQuote text={quote.text} attribution={quote.attribution} image={quote.image} />
			</div>

			<BlockList blocks={blocks} />
		</div>

		<!-- Right: sticky pull-quote — desktop only -->
		<aside class="service-article__quote-col">
			<ArticleQuote text={quote.text} attribution={quote.attribution} image={quote.image} />
		</aside>
	</div>
</section>

<script>
	import "./service-article.gsap.ts";
</script>

<style>
	/* ── Shell ──────────────────────────────────────────────────────────────── */
	.service-article {
		padding-block: var(--space-section);
	}

	/* ── Two-column grid ─────────────────────────────────────────────────────── */
	.service-article__inner {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-3xl);

		@media (min-width: 1024px) {
			grid-template-columns: 5fr 3fr;
			gap: var(--space-4xl);
			align-items: start;
		}
	}

	/* ── Left content column ─────────────────────────────────────────────────── */
	.service-article__content {
		display: flex;
		flex-direction: column;
		gap: var(--space-lg);
		min-width: 0;
		max-width: var(--width-narrow);

		@media (min-width: 1024px) {
			max-width: none;
		}
	}

	/* ── Title ───────────────────────────────────────────────────────────────── */
	.service-article__title {
		font-family: var(--font-serif);
		font-weight: var(--font-weight-light);
		font-size: clamp(var(--font-size-2xl), 4vw, var(--font-size-4xl));
		line-height: var(--line-height-tight);
		letter-spacing: var(--letter-spacing-tight);
		color: var(--color-text);
		max-width: 28ch;
		text-wrap: pretty;
	}

	/* ── Gold rule ───────────────────────────────────────────────────────────── */
	.service-article__rule {
		width: 0;
		height: 1px;
		background-color: var(--color-accent-on-light);
		margin-block-end: var(--space-sm);
	}

	/* ── Intro ───────────────────────────────────────────────────────────────── */
	.service-article__intro {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		line-height: var(--line-height-relaxed);
		color: var(--color-text-muted);
		max-width: 65ch;
		font-weight: var(--font-weight-light);
	}

	/* ── Quote visibility ────────────────────────────────────────────────────── */
	.service-article__quote-mobile {
		display: block;

		@media (min-width: 1024px) {
			display: none;
		}
	}

	.service-article__quote-col {
		display: none;

		@media (min-width: 1024px) {
			display: block;
			position: sticky;
			top: var(--space-4xl);
		}
	}
</style>
