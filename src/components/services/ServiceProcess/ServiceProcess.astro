---
import type { Heading, HeadingPart } from "../../../types/heading";
import SectionHeader from "../../ui/SectionHeader/SectionHeader.astro";

interface Step {
	title: string;
	description: string;
}

interface Props {
	steps: readonly Step[];
	processDescription: string;
	heading?: Heading;
}

const defaultHeading: HeadingPart[] = [{ text: "How We " }, { text: "Work", em: true }];
const { steps, processDescription, heading = defaultHeading } = Astro.props;
---

<section class="service-process section">
	<div class="service-process__inner wrapper wrapper--wide">
		<div class="service-process__layout">
			<!-- Left: section header -->
			<aside class="service-process__left" data-sp-left>
				<SectionHeader
					eyebrow="Our Process"
					heading={heading}
					headingColor="--color-fg-on-brand"
					eyebrowColor="--color-fg-accent-on-brand"
					ruleColor="--color-fg-accent-on-brand"
					intro={processDescription}
					introColor="--color-fg-on-brand-muted"
					gsapAttr="sp-header"
				/>
			</aside>

			<!-- Right: numbered steps -->
			<ol class="service-process__list" data-sp-list>
				{
					steps.map((step, i) => (
						<li class="service-process__step" data-sp-step>
							<span class="service-process__number" aria-hidden="true" data-sp-number>
								{String(i + 1).padStart(2, "0")}
							</span>
							<div class="service-process__body" data-sp-body>
								<h3 class="service-process__title">{step.title}</h3>
								<p class="service-process__text">{step.description}</p>
							</div>
						</li>
					))
				}
			</ol>
		</div>
	</div>
</section>

<script>
	import "./service-process.gsap.ts";
</script>

<style>
	/* ── Component tokens ──────────────────────────────────── */
	.service-process {
		--sp-circle: 2.75rem;
		--sp-circle-md: var(--size-14);
		--sp-line-x: calc(var(--sp-circle) / 2);
		--sp-line-x-md: calc(var(--sp-circle-md) / 2);
		--sp-num-half: calc(var(--sp-circle) / 2);
		--sp-num-half-md: calc(var(--sp-circle-md) / 2);
		--sp-transition: var(--duration-slow) var(--ease-out);
	}

	/* ── Section shell ─────────────────────────────────────── */
	.service-process {
		background-color: var(--color-bg-brand-muted);
	}

	/* ── Two-column layout ─────────────────────────────────── */
	.service-process__layout {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-4xl);

		@media (min-width: 1024px) {
			grid-template-columns: 2fr 3fr;
			gap: var(--space-5xl);
			align-items: start;
		}
	}

	/* ── Left column ───────────────────────────────────────── */
	.service-process__left {
		@media (min-width: 1024px) {
			position: sticky;
			top: var(--space-4xl);
		}
	}

	.service-process__left :global(.section-header) {
		--section-header-em-color: var(--color-fg-accent-on-brand);
	}

	/* ── Step list ─────────────────────────────────────────── */
	.service-process__list {
		position: relative;
	}

	/* Vertical connecting line — amber */
	.service-process__list::before {
		content: "";
		position: absolute;
		inset-block-start: var(--sp-num-half);
		inset-block-end: 0;
		inset-inline-start: var(--sp-line-x);
		width: 1px;
		transform: translateX(-50%);
		background-color: var(--color-bg-interactive);

		@media (min-width: 768px) {
			inset-inline-start: var(--sp-line-x-md);
			inset-block-start: var(--sp-num-half-md);
		}
	}

	/* ── Individual step ───────────────────────────────────── */
	.service-process__step {
		display: grid;
		grid-template-columns: var(--sp-circle) 1fr;
		gap: var(--space-xl);
		padding-block-end: var(--space-3xl);
		align-items: start;
		position: relative;

		@media (min-width: 768px) {
			grid-template-columns: var(--sp-circle-md) 1fr;
			gap: var(--space-2xl);
			padding-block-end: var(--space-4xl);
		}
	}

	.service-process__step:last-child {
		padding-block-end: 0;
	}

	/* Cover the line below the last circle */
	.service-process__step:last-child::after {
		content: "";
		position: absolute;
		inset-block-start: var(--sp-num-half);
		inset-block-end: 0;
		inset-inline-start: 0;
		width: var(--sp-circle);
		background-color: var(--color-bg-brand-muted);

		@media (min-width: 768px) {
			inset-block-start: var(--sp-num-half-md);
			width: var(--sp-circle-md);
		}
	}

	/* ── Step number — amber circle, white numeral ─────────── */
	.service-process__number {
		width: var(--sp-circle);
		height: var(--sp-circle);
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		border-radius: var(--radius-full);
		background-color: var(--color-bg-interactive);
		font-family: var(--font-serif);
		font-size: var(--font-size-base);
		font-weight: var(--font-weight-light);
		font-style: italic;
		line-height: var(--line-height-none);
		letter-spacing: var(--letter-spacing-tight);
		color: var(--color-absolute-white);
		position: relative;
		z-index: 1;
		transition: background-color var(--sp-transition);

		@media (min-width: 768px) {
			width: var(--sp-circle-md);
			height: var(--sp-circle-md);
			font-size: var(--font-size-lg);
		}

		.service-process__step:hover & {
			background-color: var(--color-bg-interactive-hover);
		}
	}

	/* ── Step body ─────────────────────────────────────────── */
	.service-process__body {
		padding-block-start: var(--space-xs);

		@media (min-width: 768px) {
			padding-block-start: var(--space-sm);
		}
	}

	.service-process__title {
		font-family: var(--font-serif);
		font-size: var(--font-size-xl);
		font-weight: var(--font-weight-light);
		line-height: var(--line-height-snug);
		letter-spacing: var(--letter-spacing-tight);
		color: var(--color-fg-accent-on-brand);
		margin-block-end: var(--space-md);

		@media (min-width: 768px) {
			font-size: var(--font-size-2xl);
		}
	}

	.service-process__text {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		line-height: var(--line-height-relaxed);
		color: var(--color-fg-on-brand-muted);
		max-width: 55ch;
	}
</style>
