---
import Eyebrow from "../../ui/Eyebrow.astro";
import { faqSection } from "../../../config/faq";
import plusIcon from "../../../assets/icons/plusIcon.svg?raw";
import minusIcon from "../../../assets/icons/minusIcon.svg?raw";

interface Faq {
	question: string;
	answer: string;
}

interface Props {
	faqs: readonly Faq[];
	eyebrow?: string;
	heading?: string;
	intro?: string;
}

const {
	faqs,
	eyebrow = faqSection.eyebrow,
	heading = faqSection.heading,
	intro = faqSection.intro,
} = Astro.props;
---

<section class="service-faqs section" aria-label="Frequently Asked Questions">
	<div class="service-faqs__inner wrapper wrapper--wide">
		<header class="service-faqs__header" data-sf-header>
			<Eyebrow text={eyebrow} colorToken="--color-accent-on-light" animateAttr="sf-eyebrow" />
			<h2 class="service-faqs__heading" data-sf-heading>{heading}</h2>
			<p class="service-faqs__intro" data-sf-intro>{intro}</p>
		</header>

		<dl class="service-faqs__list" data-sf-list>
			{
				faqs.map((faq, i) => (
					<div class="service-faqs__item" data-sf-item>
						<dt class="service-faqs__question">
							<button
								class="service-faqs__trigger"
								data-sf-trigger
								aria-expanded="false"
								type="button"
							>
								<span class="service-faqs__num" aria-hidden="true">
									{String(i + 1).padStart(2, "0")}
								</span>
								<span class="service-faqs__question-text">{faq.question}</span>
								<span class="service-faqs__icon" aria-hidden="true">
									<span class="service-faqs__icon-plus" set:html={plusIcon} />
									<span class="service-faqs__icon-minus" set:html={minusIcon} />
								</span>
							</button>
						</dt>
						<dd class="service-faqs__answer" data-sf-answer hidden>
							<p class="service-faqs__answer-text">{faq.answer}</p>
						</dd>
					</div>
				))
			}
		</dl>
	</div>
</section>

<script>
	import "./service-faqs.gsap.ts";
</script>

<style>
	/* ── Shell ──────────────────────────────────────────────────────────────── */
	.service-faqs {
		background-color: var(--color-bg);
	}

	/* ── Inner layout — stacked, full-width list ────────────────────────────── */
	.service-faqs__inner {
		display: flex;
		flex-direction: column;
		gap: var(--space-4xl);
	}

	/* ── Header ──────────────────────────────────────────────────────────────── */
	.service-faqs__header {
		max-width: 48ch;
	}

	.service-faqs__heading {
		font-family: var(--font-serif);
		font-size: clamp(var(--font-size-2xl), 3.5vw, var(--font-size-4xl));
		font-weight: var(--font-weight-light);
		line-height: var(--line-height-tight);
		letter-spacing: var(--letter-spacing-tight);
		color: var(--color-text);
		margin-block-end: var(--space-md);
	}

	.service-faqs__intro {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		line-height: var(--line-height-relaxed);
		color: var(--color-text-muted);
		max-width: 56ch;
	}

	/* ── FAQ list ────────────────────────────────────────────────────────────── */
	.service-faqs__list {
		border-block-start: 1px solid var(--color-border);
	}

	/* ── Individual item ─────────────────────────────────────────────────────── */
	.service-faqs__item {
		border-block-end: 1px solid var(--color-border);
		position: relative;
		/* Gold left accent — grows in when open */
		--sf-accent-scale: 0;
		transition: --sf-accent-scale var(--duration-normal) var(--ease-out);
	}

	.service-faqs__item::before {
		content: "";
		position: absolute;
		inset-block: 0;
		inset-inline-start: 0;
		width: 2px;
		background-color: var(--color-accent-on-light);
		transform: scaleY(var(--sf-accent-scale));
		transform-origin: top center;
		transition: transform var(--duration-slow) var(--ease-out);
	}

	.service-faqs__item--open::before {
		transform: scaleY(1);
	}

	/* ── Trigger button ──────────────────────────────────────────────────────── */
	.service-faqs__trigger {
		display: grid;
		grid-template-columns: 2.5rem 1fr auto;
		align-items: center;
		gap: var(--space-lg);
		width: 100%;
		padding-block: var(--space-xl);
		padding-inline: var(--space-lg);
		background: none;
		border: none;
		cursor: pointer;
		text-align: left;
		color: var(--color-text);
		transition: color var(--duration-fast) var(--ease-out);

		@media (min-width: 768px) {
			grid-template-columns: 3rem 1fr auto;
			padding-block: var(--space-2xl);
			padding-inline: var(--space-xl);
		}
	}

	.service-faqs__trigger:hover {
		color: var(--color-accent-on-light);
	}

	.service-faqs__trigger:focus-visible {
		outline: 2px solid var(--color-focus);
		outline-offset: -2px;
		border-radius: var(--radius-sm);
	}

	/* ── Question number ─────────────────────────────────────────────────────── */
	.service-faqs__num {
		font-family: var(--font-serif);
		font-size: var(--font-size-lg);
		font-weight: var(--font-weight-light);
		line-height: var(--line-height-none);
		letter-spacing: var(--letter-spacing-tight);
		color: var(--color-accent-on-light);
		opacity: 0.65;
		transition: opacity var(--duration-fast) var(--ease-out);

		@media (min-width: 768px) {
			font-size: var(--font-size-xl);
		}
	}

	.service-faqs__trigger:hover .service-faqs__num,
	.service-faqs__item--open .service-faqs__num {
		opacity: 1;
	}

	/* ── Question text ───────────────────────────────────────────────────────── */
	.service-faqs__question-text {
		font-family: var(--font-serif);
		font-size: var(--font-size-lg);
		font-weight: var(--font-weight-light);
		line-height: var(--line-height-snug);
		letter-spacing: var(--letter-spacing-tight);
		color: inherit;
		transition: color var(--duration-fast) var(--ease-out);

		@media (min-width: 768px) {
			font-size: var(--font-size-xl);
		}
	}

	.service-faqs__item--open .service-faqs__question-text {
		color: var(--color-text);
	}

	/* ── Plus / minus icon ───────────────────────────────────────────────────── */
	.service-faqs__icon {
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		color: var(--color-accent-on-light);
	}

	.service-faqs__icon-plus,
	.service-faqs__icon-minus {
		display: flex;
		align-items: center;
		justify-content: center;
		width: var(--space-xl);
		height: var(--space-xl);

		:global(svg) {
			width: 100%;
			height: 100%;
		}
	}

	/* Default: show plus, hide minus */
	.service-faqs__icon-minus {
		display: none;
	}

	/* Open: swap to minus */
	.service-faqs__item--open .service-faqs__icon-plus {
		display: none;
	}

	.service-faqs__item--open .service-faqs__icon-minus {
		display: flex;
	}

	/* ── Answer panel ────────────────────────────────────────────────────────── */
	.service-faqs__answer {
		display: block;
		overflow: hidden;
		padding-inline: var(--space-lg);
		padding-inline-start: calc(var(--space-lg) + 2.5rem + var(--space-lg));

		@media (min-width: 768px) {
			padding-inline: var(--space-xl);
			padding-inline-start: calc(var(--space-xl) + 3rem + var(--space-xl));
		}
	}

	.service-faqs__answer[hidden] {
		display: block;
		visibility: hidden;
		height: 0;
		padding-block: 0;
	}

	.service-faqs__answer-text {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		line-height: var(--line-height-relaxed);
		color: var(--color-text-muted);
		max-width: 72ch;
		padding-block-end: var(--space-2xl);
	}
</style>
