---
interface Props {
	label?: string;
}

const { label = "Scroll" } = Astro.props;
---

<button
	class="scroll-indicator"
	aria-label="Scroll down"
	onclick="window.scrollBy({top: window.innerHeight * 0.9, behavior: 'smooth'})"
>
	<span class="scroll-indicator__label">{label}</span>
	<span class="scroll-indicator__track" aria-hidden="true">
		<span class="scroll-indicator__thumb"></span>
	</span>
</button>

<style>
	.scroll-indicator {
		/* Component-level tokens */
		--si-text-muted: var(--color-text-inverse-muted);
		--si-track-width: 1.75rem; /* 28px — structural geometry */
		--si-track-height: 1px;

		display: flex;
		align-items: center;
		gap: var(--space-sm);
		cursor: pointer;
		color: var(--si-text-muted);
		transition: color var(--duration-normal) var(--ease-smooth);
	}

	.scroll-indicator:hover {
		color: var(--color-text-inverse);
	}

	.scroll-indicator__label {
		font-size: var(--font-size-xs);
		font-weight: var(--font-weight-medium);
		letter-spacing: var(--letter-spacing-wider);
		text-transform: uppercase;
	}

	.scroll-indicator__track {
		display: block;
		width: var(--si-track-width);
		height: var(--si-track-height);
		background: currentColor;
		position: relative;
		overflow: hidden;
	}

	.scroll-indicator__thumb {
		position: absolute;
		left: -100%;
		top: 0;
		width: 100%;
		height: 100%;
		background: var(--color-accent);
	}
</style>
