---
interface Props {
	/** data-animate attribute for GSAP targeting. Optional. */
	animateAttr?: string;
	/** Token name without var() — e.g. "--color-accent-on-light". Defaults to --color-accent. */
	colorToken?: string;
}

const { animateAttr, colorToken } = Astro.props;
---

<hr
	class="section-rule"
	data-animate={animateAttr}
	style={colorToken ? `background-color: var(${colorToken})` : undefined}
	aria-hidden="true"
/>

<style>
	.section-rule {
		border: none;
		width: var(--size-14);
		height: var(--size-0-5);
		background-color: var(--color-fg-accent);
		margin: 0;
		transform-origin: left center;
	}
</style>
