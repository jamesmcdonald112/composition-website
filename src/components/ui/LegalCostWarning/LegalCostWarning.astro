---
import { legalCostNotice } from "../../../config/legal/legal-cost-notice";

interface Props {
	class?: string;
}

const { class: className } = Astro.props;
---

<aside class:list={["legal-cost-warning", className]} aria-label="Legal cost notice">
	<div class="legal-cost-warning__inner wrapper wrapper--wide">
		<p class="legal-cost-warning__label" aria-hidden="true">Legal Notice</p>
		<p class="legal-cost-warning__text">
			{legalCostNotice.text} See{" "}
			<a
				class="legal-cost-warning__link"
				href={legalCostNotice.linkHref}
				target="_blank"
				rel="noopener noreferrer"
			>{legalCostNotice.linkText}</a>.
		</p>
	</div>
</aside>

<style>
	.legal-cost-warning {
		border-block: 1px solid var(--color-border-default);
		padding-block: var(--space-lg);
	}

	.legal-cost-warning__inner {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);

		@media (min-width: 768px) {
			flex-direction: row;
			align-items: baseline;
			gap: var(--space-xl);
		}
	}

	.legal-cost-warning__label {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: var(--font-weight-semibold);
		letter-spacing: var(--letter-spacing-widest);
		text-transform: uppercase;
		color: var(--color-fg-accent);
		white-space: nowrap;
		flex-shrink: 0;
		margin: 0;
	}

	.legal-cost-warning__text {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed);
		color: var(--color-fg-muted);
		max-width: 72ch;
		margin: 0;
	}

	.legal-cost-warning__link {
		color: var(--color-fg-link);
		text-decoration: underline;
		transition: color var(--duration-fast) var(--ease-out);

		&:hover {
			color: var(--color-fg-link-hover);
		}

		&:focus-visible {
			outline: 2px solid var(--color-border-focus);
			outline-offset: 2px;
			border-radius: var(--radius-xs);
		}
	}
</style>
