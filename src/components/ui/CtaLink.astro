---
import arrowIcon from "../../assets/icons/chevronRightIcon.svg?raw";
import phoneIcon from "../../assets/icons/phoneIcon.svg?raw";

type Variant = "primary" | "outline-light" | "outline-dark";
type Icon = "phone" | "arrow";

interface Props {
	href: string;
	label: string;
	variant?: Variant;
	icon?: Icon;
}

const { href, label, variant = "primary", icon } = Astro.props;
---

<a href={href} class:list={["cta-link", `cta-link--${variant}`]}>
	{
		icon === "phone" && (
			<span class="cta-link__icon cta-link__icon--phone" set:html={phoneIcon} aria-hidden="true" />
		)
	}
	<span>{label}</span>
	{
		icon === "arrow" && (
			<span class="cta-link__icon cta-link__icon--arrow" set:html={arrowIcon} aria-hidden="true" />
		)
	}
</a>

<style>
	.cta-link {
		--cta-glow: 0 0 0 0 color-mix(in srgb, var(--color-fg-accent) 0%, transparent);
		--cta-glow-active: 0 0 var(--space-xl) var(--space-xs) color-mix(in srgb, var(--color-fg-accent) 35%, transparent);

		display: inline-flex;
		justify-content: center;
		align-items: center;
		gap: var(--space-xs);
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		font-weight: var(--font-weight-medium);
		letter-spacing: var(--letter-spacing-wide);
		text-transform: uppercase;
		text-decoration: none;
		padding-block: var(--space-md);
		padding-inline: var(--space-xl);
		border: 1px solid transparent;
		box-shadow: var(--cta-glow);
		transition:
			background-color var(--duration-normal) var(--ease-smooth),
			color var(--duration-normal) var(--ease-smooth),
			border-color var(--duration-normal) var(--ease-smooth),
			box-shadow var(--duration-slow) var(--ease-smooth);

		@media (min-width: 640px) {
			justify-content: flex-start;
		}
	}

	/* Primary — gold fill */
	.cta-link--primary {
		background-color: var(--color-bg-interactive);
		color: var(--color-fg-interactive);
		border-color: var(--color-border-accent);
	}

	.cta-link--primary:hover {
		background-color: var(--color-bg-interactive-hover);
		border-color: var(--color-border-accent);
		box-shadow: var(--cta-glow-active);
	}

	/* Outline light — for use on dark backgrounds */
	.cta-link--outline-light {
		background-color: transparent;
		color: var(--color-fg-on-brand);
		border-color: color-mix(in srgb, var(--color-fg-on-brand) 40%, transparent);
	}

	.cta-link--outline-light:hover {
		border-color: var(--color-fg-on-brand);
		box-shadow: var(--cta-glow-active);
	}

	/* Outline dark — for use on light backgrounds */
	.cta-link--outline-dark {
		background-color: transparent;
		color: var(--color-fg-default);
		border-color: var(--color-border-strong);
	}

	.cta-link--outline-dark:hover {
		border-color: var(--color-border-accent);
		color: var(--color-fg-accent);
		box-shadow: var(--cta-glow-active);
	}

	.cta-link__icon {
		width: var(--space-md);
		height: var(--space-md);
		flex-shrink: 0;
	}

	.cta-link__icon--phone {
		display: inline-flex;
	}

	.cta-link__icon--phone :global(svg) {
		width: 100%;
		height: 100%;
	}

	.cta-link__icon--phone {
		@media (prefers-reduced-motion: no-preference) {
			.cta-link:hover & {
				animation: phone-shake var(--duration-slow) var(--ease-smooth);
			}
		}
	}

	.cta-link__icon--arrow {
		display: inline-flex;
		transition: transform var(--duration-normal) var(--ease-spring);

		@media (prefers-reduced-motion: no-preference) {
			.cta-link:hover & {
				transform: translateX(4px);
			}
		}
	}

	.cta-link__icon--arrow :global(svg) {
		width: 100%;
		height: 100%;
	}
</style>
