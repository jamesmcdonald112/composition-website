---
import Eyebrow from "../Eyebrow.astro";
import SectionRule from "../SectionRule.astro";

interface Props {
	eyebrow: string;
	heading: string;
	headingEmphasis?: string;
	headingColor?: string;
	eyebrowColor?: string;
	ruleColor?: string;
	level?: 1 | 2 | 3;
	gsapAttr?: string;
}

const {
	eyebrow,
	heading,
	headingEmphasis,
	headingColor = "--color-text",
	eyebrowColor,
	ruleColor,
	level = 2,
	gsapAttr,
} = Astro.props;

const Tag = `h${level}` as "h1" | "h2" | "h3";

const [headingBefore, headingAfter] = headingEmphasis
	? heading.split(headingEmphasis)
	: [heading, ""];
---

<header class="section-header" data-section-header={gsapAttr ?? undefined}>
	<Eyebrow text={eyebrow} colorToken={eyebrowColor} />
	<Tag class="section-header__heading" style={`--heading-color: var(${headingColor})`}>
		{headingBefore}{headingEmphasis && <em class="section-header__em">{headingEmphasis}</em>}{
			headingAfter
		}
	</Tag>
	<SectionRule colorToken={ruleColor} />
</header>

<style>
	.section-header {
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
	}

	.section-header__heading {
		font-family: var(--font-serif);
		font-size: clamp(var(--font-size-2xl), 4vw, var(--font-size-4xl));
		font-weight: var(--font-weight-light);
		line-height: var(--line-height-tight);
		letter-spacing: var(--letter-spacing-tight);
		color: var(--heading-color);
	}

	.section-header__em {
		font-style: italic;
		color: var(--color-accent);
	}
</style>
