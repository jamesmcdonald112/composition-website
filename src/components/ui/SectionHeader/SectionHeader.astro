---
import Eyebrow from "../Eyebrow.astro";
import SectionRule from "../SectionRule.astro";

interface Props {
	eyebrow: string;
	heading: string;
	/** The word or phrase within heading to italicise in accent colour. */
	headingEmphasis?: string;
	/** Token name without var() — e.g. "--color-text-inverse". Defaults to --color-text. */
	headingColor?: string;
	/** Rendered as an <h1> on unique pages (e.g. inner page heroes), h2 everywhere else. */
	level?: 1 | 2 | 3;
	/** data- attribute placed on the root <header> for GSAP targeting. e.g. "cta-panel-header" → data-cta-panel-header */
	gsapAttr?: string;
}

const {
	eyebrow,
	heading,
	headingEmphasis,
	headingColor = "--color-text",
	level = 2,
	gsapAttr,
} = Astro.props;

const Tag = `h${level}` as "h1" | "h2" | "h3";

const [headingBefore, headingAfter] = headingEmphasis
	? heading.split(headingEmphasis)
	: [heading, ""];
---

<header class="section-header" data-section-header={gsapAttr ?? undefined}>
	<Eyebrow text={eyebrow} />
	<Tag class="section-header__heading" style={`--heading-color: var(${headingColor})`}>
		{headingBefore}{headingEmphasis && <em class="section-header__em">{headingEmphasis}</em>}{
			headingAfter
		}
	</Tag>
	<SectionRule />
</header>

<style>
	.section-header {
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
	}

	.section-header__heading {
		font-family: var(--font-serif);
		font-size: clamp(var(--font-size-2xl), 4vw, var(--font-size-4xl));
		font-weight: var(--font-weight-light);
		line-height: var(--line-height-tight);
		letter-spacing: var(--letter-spacing-tight);
		color: var(--heading-color);
	}

	.section-header__em {
		font-style: italic;
		color: var(--color-accent);
	}
</style>
