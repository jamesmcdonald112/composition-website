---
import Eyebrow from "../Eyebrow.astro";
import SectionRule from "../SectionRule.astro";

import type { Heading, HeadingPart } from "../../../types/heading";

interface Props {
	eyebrow: string;
	heading: Heading;
	headingColor?: string;
	emColor?: string;
	eyebrowColor?: string;
	ruleColor?: string;
	level?: 1 | 2 | 3;
	gsapAttr?: string;
	intro?: string;
	introColor?: string;
	noMargin?: boolean;
}

const {
	eyebrow,
	heading,
	headingColor = "--color-fg-default",
	emColor,
	eyebrowColor,
	ruleColor,
	level = 2,
	gsapAttr,
	intro,
	introColor = "--color-fg-muted",
	noMargin = false,
} = Astro.props;

const Tag = `h${level}` as "h1" | "h2" | "h3";

const parts: HeadingPart[] = typeof heading === "string" ? [{ text: heading }] : [...heading];
---

<header
	class:list={["section-header", { "section-header--no-margin": noMargin }]}
	data-section-header={gsapAttr ?? undefined}
>
	<Eyebrow text={eyebrow} colorToken={eyebrowColor} />
	<Tag
		class="section-header__heading"
		style={`--heading-color: var(${headingColor})${emColor ? `; --section-header-em-color: var(${emColor})` : ""}`}
	>
		{parts.map((part) => (part.em ? <em class="section-header__em">{part.text}</em> : part.text))}
	</Tag>
	<SectionRule colorToken={ruleColor} />
	{
		intro && (
			<p class="section-header__intro" style={`--intro-color: var(${introColor})`}>
				{intro}
			</p>
		)
	}
</header>

<style>
	.section-header {
		--section-header-em-color: var(--color-fg-accent);
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
		margin-block-end: var(--space-3xl);

		&.section-header--no-margin {
			margin-block-end: 0;
		}
	}

	.section-header__heading {
		font-family: var(--font-serif);
		font-size: clamp(var(--font-size-2xl), 4vw, var(--font-size-4xl));
		font-weight: var(--font-weight-light);
		line-height: var(--line-height-tight);
		letter-spacing: var(--letter-spacing-tight);
		color: var(--heading-color);
	}

	.section-header__em {
		font-style: italic;
		color: var(--section-header-em-color);
	}

	.section-header__intro {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		line-height: var(--line-height-relaxed);
		color: var(--intro-color);
		max-width: 60ch;
		margin-block-start: var(--space-xs);
	}
</style>
