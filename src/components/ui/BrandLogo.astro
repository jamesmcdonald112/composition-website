---
import logo from "../../assets/logo/companyLogo.svg?raw";
import { firm } from "../../config/firm";

interface Props {
  class?: string;
}

const { class: className, ...rest } = Astro.props;
---

<a
  href="/"
  class:list={["brand-logo", className]}
  aria-label={`${firm.companyName} — home`}
  {...rest}
>
  <span class="brand-logo__img" aria-hidden="true" set:html={logo} />
</a>

<style>
  .brand-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
    transform-origin: left center;
    transition: transform var(--duration-slow) var(--ease-smooth);

    &:hover {
      transform: scale(1.05);
    }
  }

  .brand-logo__img {
    color: var(--color-accent);
    transition:
      color var(--duration-slow) var(--ease-smooth),
      filter var(--duration-slow) var(--ease-smooth);
    filter: drop-shadow(0 0 0px color-mix(in srgb, var(--color-accent) 0%, transparent));

    .brand-logo:hover & {
      color: var(--color-accent-light);
      filter: drop-shadow(0 0 var(--space-md) color-mix(in srgb, var(--color-accent) 35%, transparent));
    }
  }

  .brand-logo__img :global(svg) {
    display: block;
    height: var(--size-14);
    width: auto;
  }
</style>
