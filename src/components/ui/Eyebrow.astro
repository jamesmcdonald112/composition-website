---
interface Props {
	text: string;
	/** Token name without "var()" — e.g. "--color-text-inverse". Defaults to --color-accent. */
	colorToken?: string;
	animateAttr?: string;
	class?: string;
}

const { text, colorToken, animateAttr, class: className } = Astro.props;
---

<span
	class:list={["eyebrow", className]}
	style={colorToken ? `--eyebrow-color: var(${colorToken})` : undefined}
	data-animate={animateAttr}
	aria-hidden="true"
>
	{text}
</span>

<style>
	.eyebrow {
		--eyebrow-color: var(--color-accent);
		display: block;
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: var(--font-weight-medium);
		line-height: var(--line-height-none);
		letter-spacing: var(--letter-spacing-widest);
		text-transform: uppercase;
		color: var(--eyebrow-color);
	}
</style>
