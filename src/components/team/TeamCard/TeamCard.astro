---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
	name: string;
	role: string;
	bio: string;
	photo: ImageMetadata;
}

const { name, role, bio, photo } = Astro.props;
---

<li class="team-card" data-team-card>
	<details class="team-card__details">
		<summary class="team-card__summary">
			<div class="team-card__photo-wrap">
				<Image src={photo} alt={name} width={400} height={533} class="team-card__portrait" />
			</div>
			<div class="team-card__strip">
				<div class="team-card__strip-peek">
					<p class="team-card__role">{role}</p>
					<h3 class="team-card__name">{name}</h3>
				</div>
				<p class="team-card__bio">{bio}</p>
			</div>
		</summary>
	</details>
</li>

<style>
	.team-card {
		border-radius: var(--radius-lg);
		overflow: hidden;
		box-shadow: var(--shadow-xl);
		height: 100%;
	}

	.team-card__details {
		height: 100%;
	}

	.team-card__summary {
		display: flex;
		flex-direction: column;
		list-style: none;
		cursor: pointer;
		height: 100%;
		-webkit-tap-highlight-color: transparent;
		user-select: none;

		&::-webkit-details-marker {
			display: none;
		}
		&::marker {
			display: none;
		}
	}

	.team-card__photo-wrap {
		flex: 1;
		overflow: hidden;
		min-height: 0;
	}

	.team-card__portrait {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: top center;
		display: block;
		transition: transform var(--duration-slow) var(--ease-smooth);

		.team-card__details[open] & {
			transform: scale(1.04);
		}

		@media (min-width: 640px) {
			.team-card:hover & {
				transform: scale(1.04);
			}
		}
	}

	.team-card__strip {
		background: var(--color-bg-brand);
		flex-shrink: 0;
	}

	.team-card__strip-peek {
		padding: var(--space-lg) var(--space-lg) var(--space-md);
		border-block-start: 2px solid var(--color-fg-accent-on-brand);

		@media (min-width: 640px) {
			padding: var(--space-lg) var(--space-xl) var(--space-md);
		}
	}

	.team-card__role {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		letter-spacing: var(--letter-spacing-widest);
		text-transform: uppercase;
		color: var(--color-fg-accent-on-brand);
		margin-block-end: var(--space-xs);
	}

	.team-card__name {
		font-family: var(--font-serif);
		font-size: var(--font-size-xl);
		font-weight: var(--font-weight-light);
		font-style: italic;
		color: var(--color-fg-on-brand);
		letter-spacing: var(--letter-spacing-tight);
	}

	.team-card__bio {
		display: none;
		padding: var(--space-md) var(--space-lg) var(--space-lg);
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed);
		color: var(--color-fg-on-brand-muted);
		margin: 0;

		@media (min-width: 640px) {
			padding: var(--space-md) var(--space-xl) var(--space-xl);
		}

		.team-card__details[open] & {
			display: block;
		}
	}
</style>
