---
import { contactPageContent } from "../../config/contact";
import { firm } from "../../config/firm";
import clockIcon from "../../assets/icons/clockIcon.svg?raw";
import phoneIcon from "../../assets/icons/phoneIcon.svg?raw";
import mapPinIcon from "../../assets/icons/mapPinIcon.svg?raw";
---

<div class="contact-panel">
	<p class="contact-panel__eyebrow">
		<span class="contact-panel__eyebrow-icon" aria-hidden="true" set:html={mapPinIcon} />
		Kilkenny, Ireland
	</p>

	<h1 class="contact-panel__heading">
		Let&rsquo;s talk about<br />your <em>matter.</em>
	</h1>

	<p class="contact-panel__intro">{contactPageContent.intro}</p>

	<hr class="contact-panel__divider" />

	<ul class="contact-panel__details" role="list">
		<li class="contact-panel__item">
			<span class="contact-panel__icon" aria-hidden="true" set:html={clockIcon} />
			<div class="contact-panel__text">
				<span class="contact-panel__label">Office Hours</span>
				<span class="contact-panel__value">{firm.officeHours.display}</span>
			</div>
		</li>

		<li class="contact-panel__item">
			<span class="contact-panel__icon" aria-hidden="true" set:html={phoneIcon} />
			<div class="contact-panel__text">
				<span class="contact-panel__label">Phone</span>
				<a href={`tel:${firm.phone.phoneHref}`} class="contact-panel__value">{firm.phone.display}</a
				>
			</div>
		</li>

		<li class="contact-panel__item">
			<span class="contact-panel__icon" aria-hidden="true" set:html={mapPinIcon} />
			<div class="contact-panel__text">
				<span class="contact-panel__label">Address</span>
				<a
					href={firm.address.googleMapDirectionsHref}
					target="_blank"
					rel="noopener noreferrer"
					class="contact-panel__value"
				>
					<span class="contact-panel__address-line">{firm.address.line1}</span>
					<span class="contact-panel__address-line">{firm.address.city}</span>
					<span class="contact-panel__address-line">{firm.address.eircode}</span>
				</a>
			</div>
		</li>
	</ul>
</div>

<style>
	/* ── Eyebrow ──────────────────────────────────────────────────────────── */
	.contact-panel__eyebrow {
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: var(--space-md);
		margin-block-end: var(--space-xl);
		font-size: var(--font-size-xs);
		font-weight: var(--font-weight-medium);
		letter-spacing: var(--letter-spacing-widest);
		text-transform: uppercase;
		color: var(--color-accent);
	}

	.contact-panel__eyebrow-icon {
		line-height: 0;
		color: var(--color-accent);
	}

	.contact-panel__eyebrow-icon :global(svg) {
		width: var(--size-5);
		height: var(--size-5);
	}

	/* ── Heading ──────────────────────────────────────────────────────────── */
	.contact-panel__heading {
		font-weight: var(--font-weight-light);
		font-size: clamp(var(--font-size-3xl), 4vw, var(--font-size-5xl));
		color: var(--color-text-inverse);
		margin-block-end: var(--space-xl);
	}

	.contact-panel__heading em {
		font-style: italic;
		color: var(--color-accent);
	}

	/* ── Intro paragraph ──────────────────────────────────────────────────── */
	.contact-panel__intro {
		font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed);
		color: var(--color-text-inverse-muted);
		max-width: 38ch;
		margin-block-end: var(--space-3xl);
	}

	/* ── Divider ──────────────────────────────────────────────────────────── */
	.contact-panel__divider {
		border: none;
		border-block-start: 1px solid color-mix(in srgb, var(--color-text-inverse) 15%, transparent);
		margin-block: var(--space-2xl);
	}

	/* ── Contact detail list ──────────────────────────────────────────────── */
	.contact-panel__details {
		display: flex;
		flex-direction: column;
		gap: var(--space-xl);
	}

	.contact-panel__item {
		display: flex;
		flex-direction: row;
		align-items: flex-start;
		gap: var(--space-lg);
	}

	/* ── Icon ────────────────────────────────────────────────────────────── */
	.contact-panel__icon {
		flex-shrink: 0;
		color: var(--color-accent);
		line-height: 0;
	}

	.contact-panel__icon :global(svg) {
		width: var(--size-5);
		height: var(--size-5);
	}

	/* ── Text block ───────────────────────────────────────────────────────── */
	.contact-panel__text {
		display: flex;
		flex-direction: column;
		gap: var(--space-2xs);
	}

	.contact-panel__label {
		font-size: var(--font-size-xs);
		font-weight: var(--font-weight-medium);
		letter-spacing: var(--letter-spacing-widest);
		text-transform: uppercase;
		color: var(--color-text-inverse-subtle);
	}

	.contact-panel__value {
		font-size: var(--font-size-sm);
		color: var(--color-text-inverse);
		text-decoration: none;
		transition: color var(--duration-fast) var(--ease-out);
	}

	a.contact-panel__value:hover {
		color: var(--color-accent);
	}

	.contact-panel__address-line {
		display: block;
	}
</style>
