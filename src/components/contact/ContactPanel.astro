---
import { contactPageContent } from "../../config/contact";
import { studio } from "../../config/studio";
---

<div class="contact-panel" data-contact-panel>
	<p class="contact-panel__eyebrow" data-contact-panel-eyebrow>
		{studio.location.display}
	</p>

	<h1 class="contact-panel__heading" data-contact-panel-heading>
		Let&rsquo;s talk about<br />your <em>composing.</em>
	</h1>

	<p class="contact-panel__intro" data-contact-panel-intro>{contactPageContent.intro}</p>

	<div class="contact-panel__divider" data-contact-panel-divider aria-hidden="true"></div>

	<ul class="contact-panel__details" role="list">
		<li class="contact-panel__item" data-contact-panel-item>
			<div class="contact-panel__text">
				<span class="contact-panel__label">Email</span>
				<a
					href={`mailto:${studio.email.primary}`}
					class="contact-panel__value"
				>{studio.email.primary}</a>
			</div>
		</li>
	</ul>
</div>

<script>
	import "./contact-panel.gsap";
</script>

<style>
	/* ── Eyebrow ──────────────────────────────────────────────────────────── */
	.contact-panel__eyebrow {
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: var(--space-md);
		margin-block-end: var(--space-xl);
		font-size: var(--font-size-xs);
		font-weight: var(--font-weight-medium);
		letter-spacing: var(--letter-spacing-widest);
		text-transform: uppercase;
		color: var(--color-fg-accent-on-brand);
	}

	.contact-panel__eyebrow-icon {
		line-height: 0;
		color: var(--color-fg-accent-on-brand);
	}

	.contact-panel__eyebrow-icon :global(svg) {
		width: var(--size-5);
		height: var(--size-5);
	}

	/* ── Heading ──────────────────────────────────────────────────────────── */
	.contact-panel__heading {
		font-weight: var(--font-weight-light);
		font-size: clamp(var(--font-size-3xl), 4vw, var(--font-size-5xl));
		color: var(--color-fg-on-brand);
		margin-block-end: var(--space-xl);
	}

	.contact-panel__heading em {
		font-style: italic;
		color: var(--color-fg-accent-on-brand);
	}

	/* ── Intro paragraph ──────────────────────────────────────────────────── */
	.contact-panel__intro {
		font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed);
		color: var(--color-fg-on-brand-muted);
		max-width: 38ch;
		margin-block-end: var(--space-3xl);
	}

	/* ── Divider ──────────────────────────────────────────────────────────── */
	.contact-panel__divider {
		height: 1px;
		background: color-mix(in srgb, var(--color-fg-on-brand) 15%, transparent);
		margin-block: var(--space-2xl);
		transform-origin: left center;
		will-change: transform;
	}

	/* ── Contact detail list ──────────────────────────────────────────────── */
	.contact-panel__details {
		display: flex;
		flex-direction: column;
		gap: var(--space-xl);
	}

	.contact-panel__item {
		display: flex;
		flex-direction: row;
		align-items: flex-start;
		gap: var(--space-lg);
	}

	/* ── Icon ────────────────────────────────────────────────────────────── */
	.contact-panel__icon {
		flex-shrink: 0;
		color: var(--color-fg-accent-on-brand);
		line-height: 0;
	}

	.contact-panel__icon :global(svg) {
		width: var(--size-5);
		height: var(--size-5);
	}

	/* ── Text block ───────────────────────────────────────────────────────── */
	.contact-panel__text {
		display: flex;
		flex-direction: column;
		gap: var(--space-2xs);
	}

	.contact-panel__label {
		font-size: var(--font-size-xs);
		font-weight: var(--font-weight-medium);
		letter-spacing: var(--letter-spacing-widest);
		text-transform: uppercase;
		color: var(--color-fg-on-brand-subtle);
	}

	.contact-panel__value {
		font-size: var(--font-size-sm);
		color: var(--color-fg-on-brand);
		text-decoration: none;
		transition: color var(--duration-fast) var(--ease-out);
	}

	a.contact-panel__value:hover {
		color: var(--color-fg-accent-on-brand);
	}

	.contact-panel__address-line {
		display: block;
	}
</style>
