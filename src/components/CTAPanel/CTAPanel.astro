---
import { firm } from "../../config/firm";
import CtaLink from "../ui/CtaLink.astro";

interface Props {
	variant?: "light" | "dark";
	title?: string;
	body?: string;
}

const {
	variant = "light",
	title = "Need legal advice you can rely on?",
	body = "Our solicitors in Kilkenny are here to help. Call us or send a message and we will get back to you promptly.",
} = Astro.props;

const phone = firm.phone;
const secondaryVariant = variant === "light" ? "outline-dark" : "outline-light";
---

<section class={`cta-panel${variant === "light" ? " cta-panel--light" : ""}`} data-cta-panel>
	<div class="cta-panel__inner">
		<div class="cta-panel__text">
			<span class="cta-panel__rule" aria-hidden="true"></span>
			<p class="cta-panel__eyebrow">Get in touch</p>
			<h2 class="cta-panel__heading">{title}</h2>
			<p class="cta-panel__body">{body}</p>
		</div>

		<div class="cta-panel__actions">
			<CtaLink
				href={`tel:${phone.phoneHref}`}
				label={phone.display}
				variant="primary"
				icon="phone"
			/>
			<CtaLink href="/contact" label="Contact Us" variant={secondaryVariant} icon="arrow" />
		</div>
	</div>
</section>

<style>
	/* ── Shell — full viewport width ────────────────────────── */
	.cta-panel {
		--_bg: var(--color-bg-brand);
		--_text: var(--color-text-inverse);
		--_text-muted: var(--color-text-inverse-muted);
		--_rule: var(--color-accent);

		background-color: var(--_bg);
		padding-block: var(--space-5xl);
	}

	/* Light variant overrides */
	.cta-panel--light {
		--_bg: var(--color-bg-subtle);
		--_text: var(--color-text);
		--_text-muted: var(--color-text-muted);
		--_rule: var(--color-accent);
	}

	/* ── Inner container — constrained ─────────────────────── */
	.cta-panel__inner {
		max-width: var(--width-content);
		margin-inline: auto;
		padding-inline: var(--gutter);
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-3xl);

		@media (min-width: 768px) {
			padding-inline: var(--gutter-md);
		}

		@media (min-width: 1024px) {
			padding-inline: var(--gutter-lg);
			grid-template-columns: 3fr 2fr;
			align-items: center;
			gap: var(--space-5xl);
		}
	}

	/* ── Text column ────────────────────────────────────────── */
	.cta-panel__text {
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
	}

	.cta-panel__rule {
		display: block;
		width: var(--space-3xl);
		height: 2px;
		background-color: var(--_rule);
		margin-block-end: var(--space-xs);
		flex-shrink: 0;
	}

	.cta-panel__eyebrow {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: var(--font-weight-medium);
		letter-spacing: var(--letter-spacing-widest);
		text-transform: uppercase;
		color: var(--_rule);
		margin: 0;
	}

	.cta-panel__heading {
		font-family: var(--font-serif);
		font-size: clamp(var(--font-size-2xl), 4vw, var(--font-size-4xl));
		font-weight: var(--font-weight-light);
		line-height: var(--line-height-tight);
		letter-spacing: var(--letter-spacing-tight);
		color: var(--_text);
		margin: 0;

		@media (min-width: 768px) {
			font-size: clamp(var(--font-size-3xl), 4vw, var(--font-size-4xl));
		}
	}

	.cta-panel__body {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		line-height: var(--line-height-relaxed);
		color: var(--_text-muted);
		max-width: 52ch;
		margin: 0;
		padding-block-start: var(--space-xs);
	}

	/* ── Actions column ─────────────────────────────────────── */
	.cta-panel__actions {
		display: flex;
		flex-direction: column;
		gap: var(--space-lg);

		@media (min-width: 768px) {
			flex-direction: row;
			flex-wrap: wrap;
			align-items: center;
		}

		@media (min-width: 1024px) {
			justify-content: flex-end;
		}
	}
</style>

<script>
	import { initCtaPanel } from "./cta-panel.gsap.ts";
	initCtaPanel();
</script>
