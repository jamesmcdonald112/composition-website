---
import { defaultCtaPanel } from "../../config/ctas";
import { firm } from "../../config/firm";
import CtaLink from "../ui/CtaLink.astro";
import SectionHeader from "../ui/SectionHeader/SectionHeader.astro";

interface Props {
	variant?: "light" | "dark";
	eyebrow?: string;
	heading?: string;
	body?: string;
}

const {
	variant = "light",
	eyebrow = defaultCtaPanel.eyebrow,
	heading = defaultCtaPanel.title,
	body = defaultCtaPanel.body,
} = Astro.props;

const phone = firm.phone;
const secondaryVariant = variant === "light" ? "outline-dark" : "outline-light";
const headingColor = variant === "light" ? "--color-text" : "--color-text-inverse";
const eyebrowColor = variant === "light" ? "--color-accent-on-light" : undefined;
const ruleColor = variant === "light" ? "--color-accent-on-light" : undefined;
---

<section class={`cta-panel${variant === "light" ? " cta-panel--light" : ""}`} data-cta-panel>
	<div class="cta-panel__inner wrapper wrapper--wide">
		<div class="cta-panel__text">
			<SectionHeader
				eyebrow={eyebrow}
				heading={heading}
				headingColor={headingColor}
				eyebrowColor={eyebrowColor}
				ruleColor={ruleColor}
				gsapAttr="cta-panel"
			/>
			<p class="cta-panel__body" data-cta-body>{body}</p>
		</div>

		<div class="cta-panel__ctas" data-cta-ctas>
			<CtaLink
				href={`tel:${phone.phoneHref}`}
				label={phone.display}
				variant="primary"
				icon="phone"
			/>
			<CtaLink href="/contact" label="Contact Us" variant={secondaryVariant} icon="arrow" />
		</div>
	</div>
</section>

<style>
	/* ── Shell — full viewport width ────────────────────────── */
	.cta-panel {
		--_bg: var(--color-bg-brand-mid);
		--_text: var(--color-text-inverse);
		--_text-muted: var(--color-text-inverse-muted);

		background-color: var(--_bg);
		padding-block: var(--space-5xl);
	}

	/* Light variant overrides */
	.cta-panel--light {
		--_bg: var(--color-bg-subtle);
		--_text: var(--color-text);
		--_text-muted: var(--color-text-muted);
	}

	/* ── Inner container — .wrapper handles max-width, centring, gutters ── */
	.cta-panel__inner {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-3xl);

		@media (min-width: 1024px) {
			grid-template-columns: 1fr 1fr;
			align-items: center;
			gap: var(--space-4xl);
		}
	}

	/* ── Text column ────────────────────────────────────────── */
	.cta-panel__text {
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
	}

	.cta-panel__body {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		line-height: var(--line-height-relaxed);
		color: var(--_text-muted);
		max-width: 52ch;
		padding-block-start: var(--space-xs);
	}

	/* ── Actions column ─────────────────────────────────────── */
	.cta-panel__ctas {
		display: flex;
		flex-direction: column;
		gap: var(--space-lg);

		@media (min-width: 640px) {
			flex-direction: row;
			flex-wrap: wrap;
			align-items: center;
		}

		@media (min-width: 1024px) {
			justify-content: flex-end;
		}
	}
</style>

<script>
	import { initCtaPanel } from "./cta-panel.gsap.ts";
	initCtaPanel();
</script>
