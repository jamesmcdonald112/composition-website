---
import { defaultCtaPanel } from "../../config/ctas";
import { firm } from "../../config/firm";
import CtaLink from "../ui/CtaLink.astro";
import SectionHeader from "../ui/SectionHeader/SectionHeader.astro";

import type { Heading } from "../../types/heading";

interface Props {
	eyebrow?: string;
	heading?: Heading;
	body?: string;
}

const {
	eyebrow = defaultCtaPanel.eyebrow,
	heading = defaultCtaPanel.title,
	body = defaultCtaPanel.body,
} = Astro.props;

const phone = firm.phone;
---

<section class="cta-panel" data-cta-panel>
	<div class="cta-panel__inner wrapper wrapper--wide">
		<div class="cta-panel__text">
			<SectionHeader
				eyebrow={eyebrow}
				heading={heading}
				intro={body}
				eyebrowColor="--color-fg-accent"
				ruleColor="--color-fg-accent"
				gsapAttr="cta-panel"
			/>
		</div>

		<div class="cta-panel__ctas" data-cta-ctas>
			<CtaLink
				href={`tel:${phone.phoneHref}`}
				label={phone.display}
				variant="primary"
				icon="phone"
			/>
			<CtaLink href="/contact" label="Contact Us" variant="outline-dark" icon="arrow" />
		</div>
	</div>
</section>

<style>
	/* ── Shell — full viewport width ────────────────────────── */
	.cta-panel {
		background-color: var(--color-bg-accent);
		padding-block: var(--space-4xl);
	}

	/* ── Inner container — .wrapper handles max-width, centring, gutters ── */
	.cta-panel__inner {
		display: grid;
		grid-template-columns: 1fr;

		@media (min-width: 1024px) {
			grid-template-columns: 1fr 1fr;
			align-items: center;
		}
	}

	/* ── Text column ────────────────────────────────────────── */
	.cta-panel__text {
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
	}

	/* ── Actions column ─────────────────────────────────────── */
	.cta-panel__ctas {
		display: flex;
		flex-direction: column;
		gap: var(--space-lg);

		@media (min-width: 640px) {
			flex-direction: row;
			flex-wrap: wrap;
			align-items: center;
		}

		@media (min-width: 1024px) {
			justify-content: flex-end;
		}
	}
</style>

<script>
	import { initCtaPanel } from "./cta-panel.gsap.ts";
	initCtaPanel();
</script>
