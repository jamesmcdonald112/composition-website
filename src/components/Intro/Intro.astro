---
import companyLogo from "../../assets/logo/companyLogo.svg";
import { firm } from "../../config/firm";
---

<div data-intro class="intro" aria-hidden="true">
	<div data-intro-overlay class="intro__overlay"></div>

	<div class="intro__stage">
		<img data-intro-mark class="intro__mark" src={companyLogo.src} alt="" />

		<div class="intro__rule-wrap">
			<div data-intro-rule class="intro__rule"></div>
		</div>

		<div class="intro__text">
			<p data-intro-name class="intro__name">{firm.companyName.split(" ").slice(0, 2).join(" ")}</p>
			<p data-intro-sub class="intro__sub">Solicitor &middot; {firm.county}</p>
		</div>
	</div>
</div>

<style>
	:global(.intro-done) [data-intro] {
		display: none !important;
	}


	.intro {
		position: fixed;
		inset: 0;
		z-index: 1000;
		pointer-events: all;
	}

	.intro__overlay {
		position: absolute;
		inset: 0;
		background-color: var(--color-bg-brand);
		/* clip-path defines the visible area of this element as a shape.
		   This starting value is a rectangle covering the full screen — nothing hidden.
		   GSAP animates it to a zero-height rectangle (all four points on the top edge),
		   which wipes the overlay upward off the screen like a blind being raised.
		   will-change hints to the GPU to prepare for this animation. */
		will-change: clip-path;
		clip-path: polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%);
	}

	.intro__stage {
		position: absolute;
		inset: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: var(--space-lg);
		pointer-events: none;
	}

	.intro__mark {
		width: clamp(var(--size-32), 20vw, var(--size-48));
		height: auto;
		/* Logo is black SVG — invert to white so it reads on the dark navy overlay */
		filter: invert(1);
		opacity: 0;
		visibility: hidden;
	}

	.intro__rule-wrap {
		width: min(var(--width-narrow), 80vw);
		height: 1px;
		overflow: hidden;
	}

	.intro__rule {
		width: 100%;
		height: 100%;
		background: var(--color-fg-accent-on-brand);
		transform: scaleX(0);
		transform-origin: left center;
		opacity: 0.9;
	}

	.intro__text {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-sm);
	}

	.intro__name {
		font-family: var(--font-serif);
		font-size: clamp(var(--font-size-2xl), 6vw, var(--font-size-5xl));
		font-weight: var(--font-weight-light);
		letter-spacing: var(--letter-spacing-tight);
		line-height: var(--line-height-none);
		color: var(--color-fg-on-brand);
		opacity: 0;
		visibility: hidden;
	}

	.intro__sub {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: var(--font-weight-medium);
		letter-spacing: var(--letter-spacing-widest);
		text-transform: uppercase;
		color: var(--color-fg-accent-on-brand);
		opacity: 0;
		visibility: hidden;
	}
</style>

<script>
	import "./intro.anim.ts";
</script>
