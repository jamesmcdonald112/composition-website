---
import { booking } from "../../config/booking";
import { legalNav, nav } from "../../config/nav";
import { studio } from "../../config/studio";
import BrandLogo from "../ui/BrandLogo.astro";
import CtaLink from "../ui/CtaLink.astro";
---

<footer class="footer" aria-label="Site footer">
	<div class="wrapper wrapper--wide">
		<div class="footer__main">
			<!-- Brand block -->
			<div class="footer__brand" data-footer-animate="brand">
				<div class="footer__logo-row">
					<BrandLogo />
					<span class="footer__name">{studio.name}</span>
				</div>

				<div class="footer__ctas">
					<CtaLink
						href={booking.href}
						label={booking.label}
						variant="primary"
						calLink={booking.calLink}
						calNamespace={booking.calNamespace}
						calConfig={booking.calConfig}
					/>
				</div>
			</div>

			<!-- Navigation column -->
			<div class="footer__col" data-footer-animate="col">
				<p class="footer__col-heading" id="footer-nav-heading">Navigation</p>
				<ul class="footer__links" aria-labelledby="footer-nav-heading">
					{
						nav.map((item) => (
							<li>
								<a href={item.href} class="footer__link">
									{item.navLabel}
								</a>
							</li>
						))
					}
				</ul>
			</div>

			<!-- Legal column -->
			<div class="footer__col" data-footer-animate="col">
				<p class="footer__col-heading" id="footer-legal-heading">Legal</p>
				<ul class="footer__links" aria-labelledby="footer-legal-heading">
					{
						legalNav.map((item) => (
							<li>
								<a href={item.href} class="footer__link">
									{item.label}
								</a>
							</li>
						))
					}
				</ul>
			</div>
		</div>

		<!-- Bottom bar -->
		<div class="footer__bottom" data-footer-animate="bottom">
			<p class="footer__copyright">
				© {new Date().getFullYear()}
				{studio.name}. All rights reserved.
			</p>
		</div>
	</div>
</footer>

<script>
	import "./footer.anim.ts";
</script>

<style>
	/* ── Shell ─────────────────────────────────────────────────── */
	.footer {
		background: var(--color-bg-brand);
		padding-block-start: var(--space-section);
	}

	/* ── Main grid ──────────────────────────────────────────────── */
	.footer__main {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-3xl) var(--space-xl);
		padding-block-end: var(--space-3xl);

		@media (min-width: 768px) {
			grid-template-columns: 2fr 1fr 1fr;
			gap: var(--space-3xl);
		}
	}

	/* Brand block — spans full width on mobile, first col on tablet+ */
	.footer__brand {
		grid-column: 1 / -1;

		@media (min-width: 768px) {
			grid-column: auto;
		}
	}

	/* ── Logo row ───────────────────────────────────────────────── */
	.footer__logo-row {
		display: flex;
		align-items: center;
		gap: var(--space-md);
		margin-block-end: var(--space-2xl);
	}

	.footer__name {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		font-weight: var(--font-weight-semibold);
		color: var(--color-fg-on-brand);
	}

	/* ── CTAs ───────────────────────────────────────────────────── */
	.footer__ctas {
		display: flex;
		flex-direction: column;
		gap: var(--space-md);

		@media (min-width: 1024px) {
			flex-direction: row;
		}
	}

	.footer__ctas :global(.cta-link) {
		@media (min-width: 1024px) {
			width: auto;
			white-space: nowrap;
		}
	}

	/* ── Nav columns ────────────────────────────────────────────── */
	.footer__col-heading {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: var(--font-weight-semibold);
		letter-spacing: var(--letter-spacing-widest);
		text-transform: uppercase;
		color: var(--color-fg-on-brand);
		margin-block-end: var(--space-xl);
	}

	.footer__links {
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
	}

	.footer__link {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		color: var(--color-fg-on-brand-muted);
		text-decoration: none;
		transition: color var(--duration-fast) var(--ease-out);

		&:hover {
			color: var(--color-fg-on-brand);
		}
	}


	/* ── Bottom bar ─────────────────────────────────────────────── */
	.footer__bottom {
		display: flex;
		flex-direction: column;
		gap: var(--space-lg);
		padding-block: var(--space-xl);
		border-block-start: 1px solid var(--color-border-brand);

		@media (min-width: 640px) {
			flex-direction: row;
			justify-content: space-between;
			align-items: center;
		}
	}

	.footer__copyright {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		color: var(--color-fg-on-brand-muted);
	}
</style>
