---
import clockIcon from "../../assets/icons/clockIcon.svg?raw";
import mapPinIcon from "../../assets/icons/mapPinIcon.svg?raw";
import { firm } from "../../config/firm";
import { legalNav, nav } from "../../config/nav";
import BrandLogo from "../ui/BrandLogo.astro";
import CtaLink from "../ui/CtaLink.astro";
import FooterLegalNotice from "./FooterLegalNotice.astro";
---

<footer class="footer" aria-label="Site footer">
	<div class="wrapper wrapper--wide">
		<div class="footer__main">
			<!-- Brand block -->
			<div class="footer__brand" data-footer-animate="brand">
				<div class="footer__logo-row">
					<BrandLogo />
					<span class="footer__name">{firm.companyName}</span>
				</div>

				<div class="footer__details">
					<div class="footer__detail-row">
						<span class="footer__detail-icon" set:html={mapPinIcon} aria-hidden="true" />
						<address class="footer__address" aria-label="Office address">
							<span>{firm.address.line1}</span>
							<span>{firm.address.city}</span>
							<span>{firm.address.eircode}</span>
							<span>{firm.address.country}</span>
						</address>
					</div>

					<div class="footer__detail-row">
						<span class="footer__detail-icon" set:html={clockIcon} aria-hidden="true" />
						<span class="footer__hours" aria-label={`Office hours: ${firm.officeHours.display}`}
							>{firm.officeHours.display}</span
						>
					</div>
				</div>

				<div class="footer__ctas">
					<CtaLink
						href={`tel:${firm.phone.phoneHref}`}
						label={firm.phone.display}
						variant="primary"
						icon="phone"
					/>
					<CtaLink
						href={firm.address.googleMapDirectionsHref}
						label="Get directions"
						variant="outline-light"
						icon="arrow"
					/>
				</div>
			</div>

			<!-- Navigation column -->
			<div class="footer__col" data-footer-animate="col">
				<p class="footer__col-heading" id="footer-nav-heading">Navigation</p>
				<ul class="footer__links" aria-labelledby="footer-nav-heading">
					{
						nav.map((item) => (
							<li>
								<a href={item.href} class="footer__link">
									{item.navLabel}
								</a>
							</li>
						))
					}
				</ul>
			</div>

			<!-- Legal column -->
			<div class="footer__col" data-footer-animate="col">
				<p class="footer__col-heading" id="footer-legal-heading">Legal</p>
				<ul class="footer__links" aria-labelledby="footer-legal-heading">
					{
						legalNav.map((item) => (
							<li>
								<a href={item.href} class="footer__link">
									{item.label}
								</a>
							</li>
						))
					}
				</ul>
			</div>
		</div>

		<!-- Legal cost notice -->
		<FooterLegalNotice />

		<!-- Bottom bar -->
		<div class="footer__bottom" data-footer-animate="bottom">
			<a
				href="https://www.lawsociety.ie"
				target="_blank"
				rel="noopener noreferrer"
				class="footer__regulated"
				aria-label="Regulated by the Law Society of Ireland (opens in new tab)"
			>
				Regulated by the Law Society of Ireland
			</a>
			<p class="footer__copyright">
				© {new Date().getFullYear()}
				{firm.companyName}. All rights reserved.
			</p>
		</div>
	</div>
</footer>

<script>
	import "./footer.anim.ts";
</script>

<style>
	/* ── Shell ─────────────────────────────────────────────────── */
	.footer {
		background: var(--color-bg-brand);
		padding-block-start: var(--space-section);
	}

	/* ── Main grid ──────────────────────────────────────────────── */
	.footer__main {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-3xl) var(--space-xl);
		padding-block-end: var(--space-3xl);

		@media (min-width: 768px) {
			grid-template-columns: 2fr 1fr 1fr;
			gap: var(--space-3xl);
		}
	}

	/* Brand block — spans full width on mobile, first col on tablet+ */
	.footer__brand {
		grid-column: 1 / -1;

		@media (min-width: 768px) {
			grid-column: auto;
		}
	}

	/* ── Logo row ───────────────────────────────────────────────── */
	.footer__logo-row {
		display: flex;
		align-items: center;
		gap: var(--space-md);
		margin-block-end: var(--space-2xl);
	}

	.footer__name {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		font-weight: var(--font-weight-semibold);
		color: var(--color-fg-on-brand);
	}

	/* ── Detail rows ────────────────────────────────────────────── */
	.footer__details {
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
		margin-block-end: var(--space-xl);
	}

	.footer__detail-row {
		display: flex;
		align-items: flex-start;
		gap: var(--space-sm);
	}

	.footer__detail-icon {
		flex-shrink: 0;
		color: var(--color-fg-accent-on-brand);
		display: inline-flex;
		margin-block-start: var(--size-0-5);

		:global(svg) {
			width: var(--size-4);
			height: var(--size-4);
		}
	}

	.footer__address {
		font-style: normal;
		display: flex;
		flex-direction: column;
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed);
		color: var(--color-fg-on-brand-subtle);
	}

	.footer__hours {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed);
		color: var(--color-fg-on-brand-subtle);
	}

	/* ── CTAs ───────────────────────────────────────────────────── */
	.footer__ctas {
		display: flex;
		flex-direction: column;
		gap: var(--space-md);

		@media (min-width: 1024px) {
			flex-direction: row;
		}
	}

	.footer__ctas :global(.cta-link) {
		@media (min-width: 1024px) {
			width: auto;
			white-space: nowrap;
		}
	}

	/* ── Nav columns ────────────────────────────────────────────── */
	.footer__col-heading {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: var(--font-weight-semibold);
		letter-spacing: var(--letter-spacing-widest);
		text-transform: uppercase;
		color: var(--color-fg-on-brand);
		margin-block-end: var(--space-xl);
	}

	.footer__links {
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
	}

	.footer__link {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		color: var(--color-fg-on-brand-muted);
		text-decoration: none;
		transition: color var(--duration-fast) var(--ease-out);

		&:hover {
			color: var(--color-fg-on-brand);
		}
	}


	/* ── Bottom bar ─────────────────────────────────────────────── */
	.footer__bottom {
		display: flex;
		flex-direction: column;
		gap: var(--space-lg);
		padding-block: var(--space-xl);
		border-block-start: 1px solid var(--color-border-brand);

		@media (min-width: 640px) {
			flex-direction: row;
			justify-content: space-between;
			align-items: center;
		}
	}

	.footer__regulated {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		color: var(--color-fg-on-brand-subtle);
		text-decoration: underline;
		text-underline-offset: 3px;
		border-left: 2px solid var(--color-border-accent);
		padding-inline-start: var(--space-sm);
		transition: color var(--duration-fast) var(--ease-out);

		&:hover {
			color: var(--color-fg-on-brand);
		}
	}

	.footer__copyright {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		color: var(--color-fg-on-brand-muted);
	}
</style>
