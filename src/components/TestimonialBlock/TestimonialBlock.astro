---
import { testimonials, testimonialsSection } from "../../config/testimonials";
import SectionHeader from "../ui/SectionHeader/SectionHeader.astro";

interface Props {
	dark?: boolean;
}

const { dark = false } = Astro.props;
---

<section class:list={["section testimonials", { "testimonials--dark": dark }]}>
	<div class="wrapper wrapper--wide">
		<header class="t-header" data-testimonial-header>
			<SectionHeader
				eyebrow={testimonialsSection.eyebrow}
				heading={testimonialsSection.heading}
				intro={testimonialsSection.intro}
				headingColor={dark ? "--color-fg-on-brand" : "--color-fg-default"}
				eyebrowColor={dark ? undefined : "--color-fg-accent"}
				ruleColor={dark ? undefined : "--color-fg-accent"}
			/>
		</header>

		<div class="t-grid">
			{
				testimonials.map((t, i) => (
					<article class="t-card" data-testimonial-card data-card-index={i}>
						<span class="t-card__stars" aria-label="Five stars">
							★★★★★
						</span>
						<blockquote class="t-card__quote">{t.quote}</blockquote>
						<hr class="t-card__divider" />
						<div class="t-card__attribution">
							<div class="t-card__avatar" aria-hidden="true">
								{t.name[0]}
								{t.name.split(" ").at(-1)![0]}
							</div>
							<p class="t-card__name">{t.name}</p>
						</div>
					</article>
				))
			}
		</div>

	</div>
</section>

<style>
	/* ── Dark variant — navy background ─────────────────────────────────────── */
	.testimonials--dark {
		background-color: var(--color-bg-brand);
		--section-header-em-color: var(--color-fg-accent-on-brand);
	}

	/* ── Section header intro colour ────────────────────────────────────────── */
	.testimonials--dark :global(.section-header__intro) {
		color: var(--color-fg-on-brand-muted);
	}

	/* ── Grid ───────────────────────────────────────────────────────────────── */
	.t-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-lg);

		@media (min-width: 768px) {
			grid-template-columns: repeat(2, 1fr);
		}

		@media (min-width: 1024px) {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	/* 1-col: show only 3 cards */
	.t-card:nth-child(n + 4) {
		display: none;
	}

	/* 2-col: show 4 cards, hide 5 & 6 */
	@media (min-width: 768px) {
		.t-card:nth-child(n + 4) {
			display: flex;
		}

		.t-card:nth-child(n + 5) {
			display: none;
		}
	}

	/* 3-col: show all 6 cards */
	@media (min-width: 1024px) {
		.t-card:nth-child(n + 5) {
			display: flex;
		}
	}

	/* ── Card base (light / default) ────────────────────────────────────────── */
	.t-card {
		display: flex;
		flex-direction: column;
		padding: var(--space-xl);
		border-radius: var(--radius-lg);
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border-brand);
		box-shadow: var(--shadow-sm);
		position: relative;
		cursor: default;
		transition:
			transform 0.35s var(--ease-out),
			box-shadow 0.35s var(--ease-out),
			border-color 0.35s var(--ease-out),
			background 0.35s var(--ease-out);

		&:hover {
			transform: translateY(-6px);
			border-color: var(--color-border-accent);
			background: var(--color-bg-surface);
			box-shadow:
				0 0 0 1px var(--color-border-accent),
				0 24px 48px color-mix(in srgb, var(--color-bg-brand) 8%, transparent);
		}

		/* Decorative quote mark */
		&::before {
			content: "\201C";
			font-family: var(--font-serif);
			font-size: 72px;
			color: var(--color-fg-accent);
			position: absolute;
			top: var(--space-sm);
			right: var(--space-lg);
			line-height: 1;
			pointer-events: none;
			opacity: 0.6;
			transition: opacity 0.35s var(--ease-out);
		}

		&:hover::before {
			opacity: 0.8;
		}
	}

	/* ── Card — dark variant overrides ─────────────────────────────────────── */
	.testimonials--dark .t-card {
		background: color-mix(in srgb, var(--color-fg-on-brand) 4%, transparent);
		border: 1px solid color-mix(in srgb, var(--color-fg-on-brand) 9%, transparent);
		box-shadow: none;

		&::before {
			opacity: 1;
		}

		&:hover {
			background: color-mix(in srgb, var(--color-fg-on-brand) 8%, transparent);
			box-shadow:
				0 0 0 1px var(--color-border-accent),
				0 24px 48px color-mix(in srgb, var(--color-bg-brand) 40%, transparent);
		}
	}

	/* ── Stars ──────────────────────────────────────────────────────────────── */
	.t-card__stars {
		font-size: var(--font-size-base);
		letter-spacing: 2px;
		margin-block-end: var(--space-md);
		display: block;
		color: var(--color-fg-accent);
		opacity: 0.8;
		transition: opacity var(--duration-fast) var(--ease-out);
	}

	.t-card:hover .t-card__stars {
		opacity: 1;
	}

	.testimonials--dark .t-card__stars {
		color: var(--color-fg-accent-on-brand);
		opacity: 1;
	}

	.testimonials--dark .t-card::before {
		color: var(--color-fg-accent-on-brand);
	}

	/* ── Quote ──────────────────────────────────────────────────────────────── */
	.t-card__quote {
		flex: 1;
		margin: 0;
		padding: 0;
		border: none;
		font-family: var(--font-serif);
		font-style: italic;
		font-size: var(--font-size-lg);
		line-height: 1.7;
		color: var(--color-fg-on-surface);
		margin-block-end: var(--space-lg);
	}

	.testimonials--dark .t-card__quote {
		color: var(--color-fg-on-brand);
	}

	/* ── Divider ────────────────────────────────────────────────────────────── */
	.t-card__divider {
		border: none;
		border-top: 1px solid color-mix(in oklch, var(--color-fg-on-surface) 20%, transparent);
		margin-block-end: var(--space-lg);
	}

	.testimonials--dark .t-card__divider {
		border-top: 1px solid color-mix(in srgb, var(--color-fg-on-brand) 20%, transparent);
	}

	/* ── Attribution ────────────────────────────────────────────────────────── */
	.t-card__attribution {
		display: flex;
		align-items: center;
		gap: var(--space-sm);
	}

	.t-card__avatar {
		width: var(--size-10);
		height: var(--size-10);
		border-radius: var(--radius-full);
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		font-weight: var(--font-weight-semibold);
		background: var(--color-bg-brand-muted);
		color: var(--color-fg-on-brand);
	}

	.testimonials--dark .t-card__avatar {
		background: color-mix(in srgb, var(--color-fg-on-brand) 20%, transparent);
	}

	.t-card__name {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		font-weight: var(--font-weight-bold);
		color: var(--color-fg-on-surface);
	}

	.testimonials--dark .t-card__name {
		color: var(--color-fg-on-brand-muted);
	}

	/* ── Footer link ────────────────────────────────────────────────────────── */
	.t-footer {
		margin-block-start: var(--space-3xl);
		display: flex;
		justify-content: center;
	}

	.t-footer__link {
		display: inline-flex;
		align-items: center;
		gap: var(--space-xs);
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		font-weight: var(--font-weight-semibold);
		color: var(--color-fg-accent);
		text-decoration: none;
		letter-spacing: var(--letter-spacing-wide);
		transition: color 0.25s var(--ease-out);

		&:hover {
			color: var(--color-fg-accent);
		}

		&:hover .t-footer__arrow {
			transform: translateX(var(--space-xs));
		}
	}

	.testimonials--dark .t-footer__link {
		color: var(--color-fg-accent-on-brand);

		&:hover {
			color: var(--color-fg-on-brand);
		}
	}

	.t-footer__arrow {
		display: inline-flex;
		width: var(--size-4);
		height: var(--size-4);
		transition: transform 0.25s var(--ease-out);
	}

	.t-footer__arrow :global(svg) {
		width: 100%;
		height: 100%;
	}
</style>

<script>
	import "./testimonial-block.gsap";
</script>
