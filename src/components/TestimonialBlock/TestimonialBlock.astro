---
/*
  COMPONENT: TestimonialBlock
  PURPOSE:   A grid of student testimonials — quote, attribution, role.
  CONTENT:   Reads src/config/testimonials.ts.

  ⚠️  The testimonials in the config are FABRICATED placeholders.
      They must be replaced with real, consented quotes before launch.

  VARIANT:   `dark` renders on the brand background (e.g. between two
             light sections that need a tonal break).
*/
import { testimonials, testimonialsSection } from "../../config/testimonials";
import SectionHeader from "../ui/SectionHeader/SectionHeader.astro";

interface Props {
	dark?: boolean;
}

const { dark = false } = Astro.props;
---

<section class:list={["testimonials", { "testimonials--dark": dark }]}>
	<div class="testimonials__inner wrapper wrapper--wide">
		<header data-testimonial-header>
			<SectionHeader
				eyebrow={testimonialsSection.eyebrow}
				heading={testimonialsSection.heading}
				intro={testimonialsSection.intro}
				headingColor={dark ? "--color-fg-on-brand" : "--color-fg-default"}
				eyebrowColor={dark ? "--color-fg-accent-on-brand" : "--color-fg-accent"}
				ruleColor={dark ? "--color-fg-accent-on-brand" : "--color-fg-accent"}
			/>
		</header>

		<ul class="testimonials__grid" role="list">
			{
				testimonials.map((t) => (
					<li class="t-card" data-testimonial-card>
						<blockquote class="t-card__quote">{t.quote}</blockquote>
						<hr class="t-card__divider" />
						<figcaption class="t-card__attribution">
							<span class="t-card__avatar" aria-hidden="true">
								{t.name.charAt(0)}
							</span>
							<span class="t-card__person">
								<span class="t-card__name">{t.name}</span>
								<span class="t-card__role">{t.role}</span>
							</span>
						</figcaption>
					</li>
				))
			}
		</ul>
	</div>
</section>

<style>
	/* ── Section shell ──────────────────────────────────────────────────────── */
	.testimonials {
		padding-block: var(--space-section);
		background-color: var(--color-bg-subtle);
	}

	.testimonials--dark {
		background-color: var(--color-bg-brand);
	}

	.testimonials--dark :global(.section-header__intro) {
		color: var(--color-fg-on-brand-muted);
	}

	/* ── Grid ───────────────────────────────────────────────────────────────── */
	.testimonials__grid {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-lg);

		@media (min-width: 768px) {
			grid-template-columns: repeat(2, 1fr);
		}

		@media (min-width: 1024px) {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	/* ── Card ───────────────────────────────────────────────────────────────── */
	.t-card {
		display: flex;
		flex-direction: column;
		padding: var(--space-xl);
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border-brand);
		position: relative;
		transition:
			border-color var(--duration-normal) var(--ease-out),
			transform var(--duration-normal) var(--ease-out);

		&:hover {
			transform: translateY(-4px);
			border-color: var(--color-border-accent);
		}

		/* Decorative opening quote mark */
		&::before {
			content: "\201C";
			font-family: var(--font-serif);
			font-size: 64px;
			line-height: 1;
			color: var(--color-fg-accent);
			opacity: 0.5;
			position: absolute;
			top: var(--space-sm);
			right: var(--space-lg);
			pointer-events: none;
		}
	}

	.testimonials--dark .t-card {
		background: color-mix(in srgb, var(--color-fg-on-brand) 4%, transparent);
		border-color: color-mix(in srgb, var(--color-fg-on-brand) 12%, transparent);

		&:hover {
			border-color: var(--color-fg-accent-on-brand);
		}

		&::before {
			color: var(--color-fg-accent-on-brand);
			opacity: 0.7;
		}
	}

	/* ── Quote ──────────────────────────────────────────────────────────────── */
	.t-card__quote {
		flex: 1;
		margin-inline-end: var(--space-md);
		padding: 0;
		border: none;
		font-family: var(--font-serif);
		font-size: var(--font-size-base);
		line-height: var(--line-height-relaxed);
		color: var(--color-fg-on-surface);
	}

	.testimonials--dark .t-card__quote {
		color: var(--color-fg-on-brand);
	}

	/* ── Divider ────────────────────────────────────────────────────────────── */
	.t-card__divider {
		width: 100%;
		border: none;
		border-top: 1px solid var(--color-border-brand);
		margin-block: var(--space-lg);
	}

	.testimonials--dark .t-card__divider {
		border-top-color: color-mix(
			in srgb,
			var(--color-fg-on-brand) 14%,
			transparent
		);
	}

	/* ── Attribution ────────────────────────────────────────────────────────── */
	.t-card__attribution {
		display: flex;
		align-items: center;
		gap: var(--space-sm);
	}

	.t-card__avatar {
		width: var(--size-10);
		height: var(--size-10);
		flex-shrink: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: var(--radius-full);
		font-family: var(--font-serif);
		font-size: var(--font-size-base);
		background: var(--color-bg-brand-muted);
		color: var(--color-fg-on-brand);
	}

	.testimonials--dark .t-card__avatar {
		background: color-mix(in srgb, var(--color-fg-on-brand) 16%, transparent);
	}

	.t-card__person {
		display: flex;
		flex-direction: column;
		gap: var(--space-2xs);
	}

	.t-card__name {
		font-family: var(--font-serif);
		font-size: var(--font-size-base);
		color: var(--color-fg-default);
	}

	.t-card__role {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		color: var(--color-fg-muted);
	}

	.testimonials--dark .t-card__name {
		color: var(--color-fg-on-brand);
	}

	.testimonials--dark .t-card__role {
		color: var(--color-fg-on-brand-muted);
	}
</style>

<script>
	import "./testimonial-block.gsap";
</script>
