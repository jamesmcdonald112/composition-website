---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import mapPinIcon from "../../assets/icons/mapPinIcon.svg?raw";
import { firm } from "../../config/firm";
import CtaLink from "../ui/CtaLink.astro";
import Eyebrow from "../ui/Eyebrow.astro";
import ScrollIndicator from "./ScrollIndicator.astro";

interface Props {
	eyebrow: string;
	title: string;
	subtitle: string;
	primaryCta?: { label: string; href: string };
	secondaryCta?: { label: string; href: string };
	image: ImageMetadata;
	imageAlt: string;
}

const { eyebrow, title, subtitle, primaryCta, secondaryCta, image, imageAlt } =
	Astro.props;
---

<section class="hero-home">

	<!-- Background: photograph -->
	<div class="hero-home__bg" aria-hidden="true">
		<Image
			src={image}
			alt={imageAlt}
			class="hero-home__image"
			data-animate="h-image"
			widths={[768, 1280, 1920]}
			sizes="100vw"
			loading="eager"
			fetchpriority="high"
		/>
	</div>

	<!-- Overlay layer 1: navy gradient wash -->
	<div class="hero-home__wash" aria-hidden="true"></div>

	<!-- Overlay layer 2: edge vignette -->
	<div class="hero-home__vignette" aria-hidden="true"></div>

	<!-- Decorative: vertical gold rule -->
	<div class="hero-home__v-rule" aria-hidden="true"></div>

	<!-- Decorative: scan lines -->
	<div class="hero-home__scanlines" aria-hidden="true"></div>

	<!-- Content -->
	<div class="hero-home__inner wrapper wrapper--wide">

		<!-- Child 1: Badge -->
		<div class="hero-home__badge" data-animate="h-badge" aria-hidden="true">
			<span class="hero-home__badge-dot"></span>
			<span class="hero-home__badge-text">Est. {firm.established}</span>
		</div>

		<!-- Child 2: Copy -->
		<div class="hero-home__copy">

			<Eyebrow
				text={eyebrow}
				colorToken="--color-accent"
				animateAttr="h-eyebrow"
				class="hero-home__eyebrow"
			/>

			<h1 class="hero-home__title" data-animate="h-title">
				{title}
			</h1>

			<hr class="hero-home__rule" data-animate="h-rule" />

			<p class="hero-home__subtitle" data-animate="h-subtitle">
				{subtitle}
			</p>

			<div class="hero-home__ctas" data-animate="h-ctas">
				{primaryCta && (
					<CtaLink
						href={primaryCta.href}
						label={primaryCta.label}
						variant="primary"
						icon="phone"
					/>
				)}
				{secondaryCta && (
					<CtaLink
						href={secondaryCta.href}
						label={secondaryCta.label}
						variant="outline-light"
						icon="arrow"
					/>
				)}
			</div>

		</div>

		<!-- Child 3: Bottom bar -->
		<div class="hero-home__bottom" data-animate="h-bottom">
			<div class="hero-home__location">
				<span class="hero-home__location-icon" set:html={mapPinIcon} aria-hidden="true" />
				<span class="hero-home__location-text">
					{firm.address.line1}, {firm.address.city}
				</span>
			</div>
			<ScrollIndicator />
		</div>

	</div>

</section>

<script>
	import "./hero-home.anim.ts";
</script>

<style>
	/* ── Section shell ─────────────────────────────────────────────────────── */
	.hero-home {
		position: relative;
		height: 100svh;
		display: flex;
		align-items: stretch;
		overflow: hidden;
	}

	/* ── Background photograph ─────────────────────────────────────────────── */
	.hero-home__bg {
		position: absolute;
		inset: 0;
		z-index: 1;
	}

	.hero-home__image {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: 70% center;
	}

	/* ── Overlay 1: navy gradient wash ─────────────────────────────────────── */
	.hero-home__wash {
		position: absolute;
		inset: 0;
		z-index: 2;
		pointer-events: none;

		/* Mobile: top-to-bottom wash — heavy at top, lighter at bottom */
		background: linear-gradient(
			to bottom,
			color-mix(in srgb, var(--color-bg-brand) 92%, transparent) 0%,
			color-mix(in srgb, var(--color-bg-brand) 65%, transparent) 100%
		);

		@media (min-width: 768px) {
			/* Tablet: angled sweep from left */
			background: linear-gradient(
				105deg,
				color-mix(in srgb, var(--color-bg-brand) 97%, transparent) 0%,
				color-mix(in srgb, var(--color-bg-brand) 20%, transparent) 100%
			);
		}

		@media (min-width: 1024px) {
			/* Desktop: sculpted gradient — opens fully to the right */
			background: linear-gradient(
				105deg,
				color-mix(in srgb, var(--color-bg-brand) 97%, transparent) 0%,
				color-mix(in srgb, var(--color-bg-brand) 94%, transparent) 30%,
				color-mix(in srgb, var(--color-bg-brand) 82%, transparent) 50%,
				color-mix(in srgb, var(--color-bg-brand) 45%, transparent) 68%,
				color-mix(in srgb, var(--color-bg-brand) 12%, transparent) 82%,
				color-mix(in srgb, var(--color-bg-brand) 0%, transparent) 100%
			);
		}
	}

	/* ── Overlay 2: edge vignette ──────────────────────────────────────────── */
	.hero-home__vignette {
		position: absolute;
		inset: 0;
		z-index: 3;
		pointer-events: none;
		background:
			radial-gradient(
				ellipse at 0% 0%,
				color-mix(in srgb, var(--color-bg-brand) 40%, transparent) 0%,
				transparent 60%
			),
			radial-gradient(
				ellipse at 100% 100%,
				color-mix(in srgb, var(--color-bg-brand) 35%, transparent) 0%,
				transparent 55%
			),
			radial-gradient(
				ellipse at 0% 100%,
				color-mix(in srgb, var(--color-bg-brand) 30%, transparent) 0%,
				transparent 50%
			);
	}

	/* ── Decorative: vertical gold rule ────────────────────────────────────── */
	.hero-home__v-rule {
		position: absolute;
		top: 0;
		bottom: 0;
		left: clamp(var(--space-xs), 2.8vw, var(--size-14));
		width: 1px;
		z-index: 4;
		pointer-events: none;
		background: linear-gradient(
			to bottom,
			transparent 0%,
			color-mix(in srgb, var(--color-accent) 30%, transparent) 20%,
			color-mix(in srgb, var(--color-accent) 30%, transparent) 80%,
			transparent 100%
		);
	}

	/* ── Decorative: scan lines ─────────────────────────────────────────────── */
	.hero-home__scanlines {
		position: absolute;
		inset: 0;
		z-index: 3;
		pointer-events: none;
		background: repeating-linear-gradient(
			0deg,
			transparent 0px,
			transparent 3px,
			color-mix(in srgb, var(--color-text-inverse) 1.5%, transparent) 3px,
			color-mix(in srgb, var(--color-text-inverse) 1.5%, transparent) 4px
		);
	}

	/* ── Inner content container ───────────────────────────────────────────── */
	/* .wrapper.wrapper--wide handles max-width, margin-inline, padding-inline */
	.hero-home__inner {
		position: relative;
		z-index: 5;
		display: flex;
		flex-direction: column;
		min-height: 100svh;
		padding-block: var(--space-5xl) var(--space-3xl);
	}

	/* ── Badge ─────────────────────────────────────────────────────────────── */
	.hero-home__badge {
		display: flex;
		align-items: center;
		gap: var(--space-sm);
		visibility: hidden;
	}

	.hero-home__badge-dot {
		width: 5px;
		height: 5px;
		border-radius: var(--radius-full);
		background-color: var(--color-accent);
		opacity: 0.7;
		flex-shrink: 0;
	}

	.hero-home__badge-text {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: var(--font-weight-medium);
		letter-spacing: var(--letter-spacing-wider);
		text-transform: uppercase;
		color: var(--color-text-inverse-muted);
	}

	/* ── Copy block ─────────────────────────────────────────────────────────── */
	.hero-home__copy {
		max-width: 100%;
		margin-block: var(--space-3xl) auto;
		display: flex;
		flex-direction: column;

		@media (min-width: 768px) {
			max-width: 60%;
		}
	}

	/* ── Eyebrow ────────────────────────────────────────────────────────────── */
	/* margin unreachable here due to Astro scope — gap lives on h1 instead */
	.hero-home__eyebrow {
		visibility: hidden;
	}

	/* ── Heading ────────────────────────────────────────────────────────────── */
	.hero-home__title {
		font-family: var(--font-serif);
		font-weight: var(--font-weight-light);
		font-size: clamp(var(--font-size-5xl), 6vw, var(--font-size-6xl));
		line-height: var(--line-height-tight);
		letter-spacing: var(--letter-spacing-tight);
		color: var(--color-text-inverse);
		max-width: 18ch;
		margin-block-start: var(--space-lg);
		margin-block-end: var(--space-xl);
		text-wrap: pretty;
		visibility: hidden;
	}

	/* ── Gold rule ──────────────────────────────────────────────────────────── */
	.hero-home__rule {
		border: none;
		width: var(--size-14);
		height: var(--size-0-5);
		background-color: var(--color-accent);
		margin: 0;
		margin-block-end: var(--space-lg);
		transform-origin: left center;
		visibility: hidden;
	}

	/* ── Subtitle ───────────────────────────────────────────────────────────── */
	.hero-home__subtitle {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed);
		color: color-mix(in srgb, var(--color-text-inverse) 85%, transparent);
		max-width: 44ch;
		margin-block-end: var(--space-3xl);
		visibility: hidden;

		@media (min-width: 768px) {
			font-size: var(--font-size-base);
		}
	}

	/* ── CTA buttons ────────────────────────────────────────────────────────── */
	.hero-home__ctas {
		display: flex;
		flex-direction: column;
		gap: var(--space-lg);
		visibility: hidden;

		@media (min-width: 640px) {
			flex-direction: row;
		}
	}

	/* ── Bottom bar ─────────────────────────────────────────────────────────── */
	.hero-home__bottom {
		margin-block-start: auto;
		display: flex;
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		padding-block-start: var(--space-lg);
		border-top: 1px solid color-mix(in srgb, var(--color-text-inverse) 15%, transparent);
		visibility: hidden;
	}

	/* ── Location ────────────────────────────────────────────────────────────── */
	.hero-home__location {
		display: flex;
		align-items: center;
		gap: var(--space-xs);
	}

	.hero-home__location-icon {
		display: inline-flex;
		flex-shrink: 0;
		width: var(--space-md);
		height: var(--space-md);
		color: var(--color-text-inverse-subtle);
	}

	.hero-home__location-icon :global(svg) {
		width: 100%;
		height: 100%;
	}

	.hero-home__location-text {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: var(--font-weight-medium);
		letter-spacing: var(--letter-spacing-wider);
		text-transform: uppercase;
		color: var(--color-text-inverse-subtle);
	}
</style>
