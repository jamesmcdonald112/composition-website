---
/*
  COMPONENT: CurriculumPath
  PURPOSE:   The eight-module training path, grouped into four pedagogical
             phases. Each phase reads like the opening of a chapter — a
             small uppercase kicker, an italic prose sentence, then the
             modules as supporting detail underneath.
  LAYOUT:    Section header (eyebrow + title + intro), then a stack of
             phases. Each phase is divided from the next by a thin rule.
             Cards inside the phase grid use a quiet resting state and
             take a brass tint on hover/focus.
*/
import { phasesWithOffsets, toRomanNumeral } from "../../../config/curriculum";
import Eyebrow from "../../ui/Eyebrow.astro";

interface Props {
	eyebrow: string;
	title: string;
	intro: string;
}

const { eyebrow, title, intro } = Astro.props;
---

<section id="curriculum" class="curriculum-path" data-curriculum-path>
	<div class="curriculum-path__inner wrapper wrapper--wide">

		<header class="curriculum-path__header" data-curriculum-path-header>
			<Eyebrow text={eyebrow} colorToken="--color-fg-accent" />
			<h2 class="curriculum-path__title">{title}</h2>
			<p class="curriculum-path__intro">{intro}</p>
		</header>

		{phasesWithOffsets.map(({ phase, startIndex }) => (
			<section class="curriculum-path__phase" data-curriculum-path-phase>
				<header class="curriculum-path__phase-head" data-curriculum-path-phase-head>
					<div class="curriculum-path__phase-rule-row" aria-hidden="true">
						<span class="curriculum-path__phase-rule"></span>
						<h3 class="curriculum-path__phase-name">{phase.label}</h3>
						<span class="curriculum-path__phase-rule"></span>
					</div>
					<h3 class="curriculum-path__visually-hidden">{phase.label}</h3>
					<p class="curriculum-path__phase-intro">{phase.intro}</p>
				</header>

				<div
					class="curriculum-path__grid"
					style={`--curriculum-path-n: ${phase.modules.length}`}
				>
					{phase.modules.map((m, i) => (
						<article class="curriculum-path__card" tabindex="0" data-curriculum-path-card>
							<header class="curriculum-path__card-head">
								<span class="curriculum-path__card-num">
									{toRomanNumeral(startIndex + i)}
								</span>
								<h4 class="curriculum-path__card-name">{m.name}</h4>
							</header>
							<p class="curriculum-path__card-sub">{m.subtitle}</p>
							<p class="curriculum-path__card-body">{m.body}</p>
							<p class="curriculum-path__card-out">{m.outcome}</p>
						</article>
					))}
				</div>
			</section>
		))}

	</div>
</section>

<script>
	import { initCurriculumPath } from "./curriculum-path.gsap";
	initCurriculumPath();
</script>

<style>
	.curriculum-path {
		background-color: var(--color-bg-page);
		padding-block: var(--space-section);
	}

	/* ── Section header ──────────────────────────────────────────────────── */
	.curriculum-path__header {
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
		max-width: 60ch;
		margin-block-end: var(--space-3xl);
		/* Hidden initially — GSAP timeline reveals on scroll. */
		visibility: hidden;
	}

	@media (prefers-reduced-motion: reduce) {
		.curriculum-path__header,
		.curriculum-path__phase {
			visibility: visible;
		}
	}

	.curriculum-path__title {
		font-family: var(--font-serif);
		font-weight: var(--font-weight-light);
		font-size: clamp(var(--font-size-2xl), 3.5vw, var(--font-size-3xl));
		line-height: var(--line-height-tight);
		letter-spacing: var(--letter-spacing-tight);
		color: var(--color-fg-default);
		margin: 0;
	}

	.curriculum-path__intro {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		line-height: var(--line-height-relaxed);
		color: var(--color-fg-muted);
		margin: 0;
	}

	/* ── Phase block ─────────────────────────────────────────────────────── */
	.curriculum-path__phase {
		margin-block-end: var(--space-4xl);
		/* Hidden initially — each phase has its own ScrollTrigger that
		   reveals it as the visitor scrolls past it. */
		visibility: hidden;
	}

	.curriculum-path__phase:first-of-type {
		padding-block-start: 0;
		border-block-start: 0;
	}

	.curriculum-path__phase:last-of-type {
		margin-block-end: 0;
	}

	.curriculum-path__phase-head {
		margin-block-end: var(--space-xl);
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
	}

	.curriculum-path__phase-rule-row {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		gap: var(--space-lg);
	}

	.curriculum-path__phase-rule {
		height: 1px;
		background-color: var(--color-fg-accent);
	}

	.curriculum-path__phase-name {
		font-family: var(--font-serif);
		font-style: italic;
		font-weight: var(--font-weight-light);
		font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-3xl));
		line-height: 1;
		color: var(--color-fg-default);
		margin: 0;
		padding-inline: var(--space-sm);
	}

	.curriculum-path__phase-intro {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		line-height: var(--line-height-relaxed);
		color: var(--color-fg-muted);
		margin: 0 auto;
		max-width: 60ch;
		text-align: center;
	}

	.curriculum-path__visually-hidden {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	/* ── Phase grid ──────────────────────────────────────────────────────── */
	.curriculum-path__grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-lg);

		@media (min-width: 768px) {
			grid-template-columns: repeat(min(var(--curriculum-path-n), 2), 1fr);
		}

		@media (min-width: 1024px) {
			grid-template-columns: repeat(min(var(--curriculum-path-n), 3), 1fr);
		}
	}

	/* Single-module phase: cap the grid at half-width and centre it,
	   so a lone card sits composed in the middle of the row rather than
	   stretching across the full width like a banner. */
	@media (min-width: 768px) {
		.curriculum-path__grid[style*="--curriculum-path-n: 1"] {
			max-width: 50%;
		}
	}

	/* ── Card ────────────────────────────────────────────────────────────── */
	.curriculum-path__card {
		background-color: var(--color-bg-surface);
		border: 1px solid var(--color-border-default);
		padding: var(--space-xl);
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
		outline: none;
		transition:
			background-color var(--duration-normal) var(--ease-out),
			border-color var(--duration-normal) var(--ease-out);
	}

	.curriculum-path__card:hover,
	.curriculum-path__card:focus-visible {
		background-color: var(--color-accent-50);
		border-color: var(--color-fg-accent);
	}

	.curriculum-path__card-head {
		display: flex;
		align-items: baseline;
		gap: var(--space-md);
		margin-block-end: var(--space-xs);
	}

	.curriculum-path__card-num {
		font-family: var(--font-serif);
		font-style: italic;
		font-weight: var(--font-weight-light);
		font-size: var(--font-size-3xl);
		line-height: 1;
		color: var(--color-fg-accent);
		transition: color var(--duration-normal) var(--ease-out);
	}

	.curriculum-path__card:hover .curriculum-path__card-num,
	.curriculum-path__card:focus-visible .curriculum-path__card-num {
		color: var(--color-accent-700);
	}

	.curriculum-path__card-name {
		font-family: var(--font-serif);
		font-weight: var(--font-weight-normal);
		font-size: var(--font-size-xl);
		line-height: var(--line-height-tight);
		color: var(--color-fg-default);
		margin: 0;
	}

	.curriculum-path__card-sub {
		font-family: var(--font-serif);
		font-style: italic;
		font-size: var(--font-size-sm);
		color: var(--color-fg-muted);
		margin: 0;
	}

	.curriculum-path__card-body {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		line-height: var(--line-height-relaxed);
		color: var(--color-fg-default);
		margin: 0;
	}

	.curriculum-path__card-out {
		font-family: var(--font-serif);
		font-style: italic;
		font-size: var(--font-size-sm);
		color: var(--color-fg-muted);
		margin: auto 0 0;
		padding-block-start: var(--space-md);
		border-block-start: 1px solid var(--color-border-default);
	}
</style>
