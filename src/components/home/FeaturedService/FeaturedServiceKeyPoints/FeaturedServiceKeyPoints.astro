---
interface KeyPoint {
	heading: string;
	body: string;
}

interface Props {
	keyPoints: readonly KeyPoint[];
}

const { keyPoints } = Astro.props;
---

<div class="fs-keypoints">
	{keyPoints.map((kp) => (
		<div class="fs-keypoints__item">
			<p class="fs-keypoints__heading">{kp.heading}</p>
			<p class="fs-keypoints__body">{kp.body}</p>
		</div>
	))}
</div>

<style>
	.fs-keypoints {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-xl);
		width: 100%;

		@media (min-width: 640px) {
			grid-template-columns: repeat(2, 1fr);
		}

		@media (min-width: 1024px) {
			grid-template-columns: 1fr;
		}
	}

	.fs-keypoints__item {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
	}

	.fs-keypoints__heading {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		font-weight: var(--font-weight-medium);
		color: var(--color-fg-accent-on-brand);
		letter-spacing: var(--letter-spacing-wide);
		text-transform: uppercase;
		line-height: var(--line-height-snug);
	}

	.fs-keypoints__body {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed);
		color: var(--color-fg-on-brand-muted);
	}
</style>
