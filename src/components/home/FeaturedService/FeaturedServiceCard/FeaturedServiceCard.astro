---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import chevronIcon from "../../../../assets/icons/chevronRightIcon.svg?raw";

interface Props {
	tag: string;
	title: string;
	body: string;
	cta: { label: string; href: string };
	image: ImageMetadata;
}

const { tag, title, body, cta, image } = Astro.props;
---

<a href={cta.href} class="featured-card">
	<div class="featured-card__img-wrap">
		<Image src={image} alt="" width={600} height={400} class="featured-card__img" />
	</div>
	<div class="featured-card__body">
		<p class="featured-card__tag">{tag}</p>
		<h3 class="featured-card__title">{title}</h3>
		<p class="featured-card__desc">{body}</p>
		<span class="featured-card__cta" aria-hidden="true">
			{cta.label}
			<span class="featured-card__arrow" set:html={chevronIcon} />
		</span>
	</div>
</a>

<style>
	.featured-card {
		background: var(--color-bg-brand);
		border-radius: var(--radius-lg);
		overflow: hidden;
		box-shadow: var(--shadow-xl);
		display: flex;
		flex-direction: column;
		height: 100%;
		text-decoration: none;
		color: inherit;
		transition:
			box-shadow var(--duration-slow) var(--ease-smooth),
			border-color var(--duration-slow) var(--ease-smooth);

		&:hover {
			box-shadow:
				0 0 0 1px var(--color-border-accent),
				0 24px 48px color-mix(in srgb, var(--color-bg-brand) 8%, transparent);
		}

		&:focus-visible {
			outline: 2px solid var(--color-border-focus);
			outline-offset: 3px;
		}
	}

	.featured-card__img-wrap {
		overflow: hidden;
		flex-shrink: 0;
		aspect-ratio: 3 / 2;

		@media (min-width: 640px) {
			aspect-ratio: 2 / 1;
		}

		@media (min-width: 1024px) {
			aspect-ratio: 16 / 14;
		}

		@media (min-width: 1280px) {
			aspect-ratio: 20 / 11;
		}
	}

	.featured-card__img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center 90%;
		display: block;
		transition: transform 0.7s var(--ease-smooth);

		.featured-card:hover & {
			transform: scale(1.03);
		}
	}

	.featured-card__body {
		padding: var(--space-xl);
		display: flex;
		flex-direction: column;
		flex: 1;
		gap: var(--space-sm);
		align-items: flex-start;
	}

	.featured-card__tag {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		letter-spacing: var(--letter-spacing-widest);
		text-transform: uppercase;
		color: var(--color-fg-accent-on-brand);
	}

	.featured-card__title {
		font-family: var(--font-serif);
		font-size: var(--font-size-xl);
		font-weight: var(--font-weight-light);
		font-style: italic;
		color: var(--color-fg-on-brand);
		line-height: var(--line-height-snug);
	}

	.featured-card__desc {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed);
		color: var(--color-fg-on-brand-muted);
		flex: 1;
		margin-block-end: var(--space-sm);
	}

	.featured-card__cta {
		display: inline-flex;
		align-items: center;
		gap: var(--space-xs);
		font-size: var(--font-size-xs);
		font-weight: var(--font-weight-medium);
		letter-spacing: var(--letter-spacing-wide);
		text-transform: uppercase;
		color: var(--color-fg-accent-on-brand);
		margin-block-start: auto;
	}

	.featured-card__arrow {
		display: flex;
		align-items: center;
		width: var(--size-3);
		height: var(--size-3);
		flex-shrink: 0;
		transition: transform var(--duration-slow) var(--ease-out);

		.featured-card:hover & {
			transform: translateX(4px);
		}
	}

	.featured-card__arrow :global(svg) {
		width: 100%;
		height: 100%;
	}
</style>
