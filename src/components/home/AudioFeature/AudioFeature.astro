---
/*
  COMPONENT: AudioFeature
  PURPOSE:   Renders the "a taste of the music" section on the homepage
             as a single YouTube embed. If youtubeId is null, the entire
             section is omitted from the page — no placeholder, no
             empty container, no chrome.
  REGISTER:  Single embed, framed simply — recital programme, not media carousel.
*/
import SectionHeader from "../../ui/SectionHeader/SectionHeader.astro";

interface Props {
	eyebrow: string;
	title: string;
	youtubeId: string | null;
	caption: string;
	watchUrl: string;
}

const { eyebrow, title, youtubeId, caption, watchUrl } = Astro.props;
---

{youtubeId && (
	<section class="audio-feature" data-audio-feature>
		<div class="audio-feature__inner wrapper wrapper--wide">

			<SectionHeader eyebrow={eyebrow} heading={title} gsapAttr="audio-feature-header" />

			<figure class="audio-feature__embed" data-audio-feature-figure>
				{/*
				  Production: Cookiebot-gated embed. The iframe stays inert
				  until the visitor accepts the Marketing category.
				  data-cookieblock-src holds the URL; data-cookieconsent
				  declares the category. On consent, Cookiebot rewrites
				  data-cookieblock-src to src and the iframe loads.
				  Ref: support.cookiebot.com → "Iframe cookie consent with YouTube example"

				  Alongside it sits a fallback panel for visitors who decline
				  marketing cookies: a plain link out to YouTube, where the
				  recording plays with no consent required on this site.
				  audio-feature.gsap hides the fallback once marketing consent
				  is granted, so the two are never both visible.

				  Dev: plain src so the embed is visible while working.
				  Cookiebot is also skipped in dev (BaseLayout) because the
				  dev CBID isn't authorised against localhost; without this
				  twin gate, the iframe would stay forever blank in dev with
				  nothing to rewrite the placeholder back to src.
				*/}
				<div class="audio-feature__frame">
					{import.meta.env.PROD ? (
						<>
							<iframe
								class="audio-feature__iframe"
								data-cookieconsent="marketing"
								data-cookieblock-src={`https://www.youtube-nocookie.com/embed/${youtubeId}`}
								title={`${title} — performance recording`}
								loading="lazy"
								allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
								allowfullscreen
							></iframe>
							<div class="audio-feature__fallback" data-audio-feature-fallback>
								<p class="audio-feature__fallback-text">
									Playing the recording here requires marketing cookies,
									which embed it from YouTube. If you would rather not
									accept those, you can watch it on YouTube instead.
								</p>
								<a
									class="audio-feature__fallback-link"
									href={watchUrl}
									target="_blank"
									rel="noopener noreferrer"
								>
									Watch on YouTube
								</a>
							</div>
						</>
					) : (
						<iframe
							class="audio-feature__iframe"
							src={`https://www.youtube-nocookie.com/embed/${youtubeId}`}
							title={`${title} — performance recording`}
							loading="lazy"
							allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
							allowfullscreen
						></iframe>
					)}
				</div>
				{caption && (
					<figcaption class="audio-feature__caption">{caption}</figcaption>
				)}
			</figure>

		</div>
	</section>
)}

<script>
	import { initAudioFeature } from "./audio-feature.gsap";
	initAudioFeature();
</script>

<style>
	.audio-feature {
		background-color: var(--color-bg-page);
		padding-block: var(--space-section);
	}

	.audio-feature__inner {
		display: flex;
		flex-direction: column;
	}

	/* ── Figure (the iframe frame + its caption) ───────────────────────────── */
	.audio-feature__embed {
		width: 100%;
		max-width: 56rem;
		margin-inline: auto;
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
		/* Hidden initially — the GSAP timeline reveals it on scroll.
		   Reduced-motion users see the @media override below (immediate visible). */
		visibility: hidden;
	}

	@media (prefers-reduced-motion: reduce) {
		.audio-feature__embed {
			visibility: visible;
		}
	}

	/* The frame that actually holds the iframe — keeps the 16:9 aspect ratio
	   so the iframe inside sizes correctly. The caption sits below the frame,
	   not constrained by the aspect-ratio container. */
	.audio-feature__frame {
		position: relative;
		width: 100%;
		aspect-ratio: 16 / 9;
		background-color: var(--color-bg-surface);
		border: 1px solid var(--color-border-default);
	}

	.audio-feature__iframe {
		width: 100%;
		height: 100%;
		border: 0;
		display: block;
	}

	/* ── Fallback (declined / no marketing consent) ────────────────────────── */
	/* Shown by default; covers the inert iframe. audio-feature.gsap sets the
	   --consented modifier once marketing consent is granted, which hides it. */
	.audio-feature__fallback {
		position: absolute;
		inset: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: var(--space-md);
		padding: var(--space-lg);
		text-align: center;
		background-color: var(--color-bg-surface);
	}

	.audio-feature--consented .audio-feature__fallback {
		display: none;
	}

	.audio-feature__fallback-text {
		max-width: 36ch;
		margin: 0;
		font-family: var(--font-serif);
		font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed);
		color: var(--color-fg-muted);
	}

	.audio-feature__fallback-link {
		font-family: var(--font-serif);
		font-size: var(--font-size-base);
		color: var(--color-accent-fg);
		text-decoration: underline;
		text-underline-offset: 0.2em;
	}

	.audio-feature__fallback-link:hover {
		color: var(--color-interactive-bg-hover);
	}

	.audio-feature__caption {
		font-family: var(--font-serif);
		font-style: italic;
		font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed);
		color: var(--color-fg-muted);
		text-align: center;
		margin: 0;
	}
</style>
