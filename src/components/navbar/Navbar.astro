---
import { firm } from "../../config/firm";
import { nav } from "../../config/nav";
import BrandLogo from "../ui/BrandLogo.astro";
import CtaLink from "../ui/CtaLink.astro";
import NavMobile from "./NavMobile.astro";
import hamburgerIcon from "../../assets/navbar/hambugerMenu.svg?raw";
import closeIcon from "../../assets/navbar/closeMenuIcon.svg?raw";

const currentPath = Astro.url.pathname;
---

<!-- Navbar shell — fixed to top, full width -->
<div class="navbar" id="navbar">
	<!-- Inner container — max-width + centred via wrapper -->
	<div class="navbar__inner wrapper wrapper--wide">
		<!-- Logo -->
		<BrandLogo />

		<!-- Desktop nav links — hidden on mobile -->
		<nav class="navbar__nav" aria-label="Primary navigation">
			<ul class="navbar__nav-list">
				{
					nav.map((item) => (
						<li class="navbar__nav-item">
							<a
								href={item.href}
								class="navbar__nav-link"
								aria-current={currentPath === item.href ? "page" : undefined}
							>
								{item.navLabel}
							</a>
						</li>
					))
				}
			</ul>
		</nav>

		<!-- Phone CTA — hidden on mobile -->
		<div class="navbar__cta">
			<CtaLink
				href={`tel:${firm.phone.phoneHref}`}
				label={firm.phone.display}
				variant="outline-light"
				icon="phone"
			/>
		</div>

		<!-- Hamburger toggle — mobile only -->
		<button
			class="navbar__toggle"
			data-navbar-toggle
			aria-expanded="false"
			aria-controls="navbar-overlay"
			aria-label="Open navigation menu"
		>
			<span
				class="navbar__toggle-icon navbar__toggle-icon--open"
				aria-hidden="true"
				set:html={hamburgerIcon}
			/>
			<span
				class="navbar__toggle-icon navbar__toggle-icon--close"
				aria-hidden="true"
				set:html={closeIcon}
			/>
		</button>
	</div>
</div>

<!-- Mobile menu — rendered as a <dialog> -->
<NavMobile />

<script>
	import "./navbar.gsap.ts";
</script>

<style>
	/* ── Navbar shell ────────────────────────────────────────────────────────── */
	.navbar {
		position: fixed;
		inset-block-start: 0;
		inset-inline: 0;
		height: var(--size-20);
		z-index: 100;
		background: transparent;
		border-bottom: 1px solid transparent;
		transition:
			background var(--duration-slow) var(--ease-out),
			border-color var(--duration-slow) var(--ease-out);

		&.is-scrolled {
			background: var(--color-bg-brand);
			border-color: var(--color-border-brand);
		}

		&.is-open {
			@media (max-width: 1023px) {
				opacity: 0;
				pointer-events: none;
			}
		}
	}

	/* ── Inner container ─────────────────────────────────────────────────────── */
	.navbar__inner {
		display: flex;
		justify-content: space-between;
		align-items: center;
		height: 100%;

		@media (min-width: 1024px) {
			display: grid;
			grid-template-columns: 1fr auto 1fr;
		}
	}

	/* ── Desktop nav ─────────────────────────────────────────────────────────── */
	.navbar__nav-list {
		display: none;

		@media (min-width: 1024px) {
			display: flex;
			align-items: center;
			gap: var(--space-2xl);
			list-style: none;
			margin: 0;
			padding: 0;
		}
	}

	.navbar__nav-item {
		list-style: none;
	}

	.navbar__nav-link {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		font-weight: var(--font-weight-medium);
		letter-spacing: var(--letter-spacing-wide);
		text-transform: uppercase;
		color: var(--color-text-inverse);
		text-decoration: none;
		position: relative;
		padding-block-end: var(--space-2xs);
		transition: color var(--duration-fast) var(--ease-out);

		&::after {
			content: "";
			position: absolute;
			inset-block-end: 0;
			inset-inline-start: 0;
			width: 0;
			height: 1px;
			background: var(--color-accent);
			transition: width var(--duration-normal) var(--ease-out);
		}

		&:hover {
			color: var(--color-accent);

			&::after {
				width: 100%;
			}
		}

		&[aria-current="page"] {
			&::after {
				width: 100%;
			}
		}
	}

	/* ── Phone CTA ───────────────────────────────────────────────────────────── */
	.navbar__cta {
		display: none;

		@media (min-width: 1024px) {
			display: flex;
			justify-content: flex-end;
		}
	}

	/* ── Hamburger ───────────────────────────────────────────────────────────── */
	.navbar__toggle {
		display: flex;
		align-items: center;
		width: var(--size-10);
		height: var(--size-10);
		background: none;
		border: none;
		cursor: pointer;
		padding: var(--space-xs);

		@media (min-width: 1024px) {
			display: none;
		}
	}

	.navbar__toggle-icon {
		display: flex;
		color: var(--color-text-inverse);
		transition: color var(--duration-fast) var(--ease-out);

		svg {
			width: var(--size-6);
			height: var(--size-6);
		}

		.navbar__toggle:hover & {
			color: var(--color-accent);
		}
	}

	.navbar__toggle-icon--close {
		display: none;
	}

	.navbar__toggle[aria-expanded="true"] {
		.navbar__toggle-icon--open {
			display: none;
		}
		.navbar__toggle-icon--close {
			display: flex;
		}
	}
</style>
