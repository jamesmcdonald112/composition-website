---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { booking } from "../../../config/booking";
import { studio } from "../../../config/studio";
import type { Heading } from "../../../types/heading";
import CtaLink from "../../ui/CtaLink.astro";
import Eyebrow from "../../ui/Eyebrow.astro";
import ScrollIndicator from "../../ui/ScrollIndicator/ScrollIndicator.astro";

interface ImageFocusResponsive {
	mobile: string;
	desktop: string;
}

interface Props {
	title: Heading;
	subtitle: string;
	image: ImageMetadata;
	imageFocus?: string | ImageFocusResponsive;
}

const {
	title,
	subtitle,
	image,
	imageFocus = "center 50%",
} = Astro.props;
const titleParts = typeof title === "string" ? [{ text: title }] : [...title];

const focusMobile =
	typeof imageFocus === "string" ? imageFocus : imageFocus.mobile;
const focusDesktop =
	typeof imageFocus === "string" ? imageFocus : imageFocus.desktop;
---

<section class="page-hero" data-page-hero>
	<!-- Background image -->
	<div class="page-hero__bg" aria-hidden="true">
		<Image
			src={image}
			alt=""
			class="page-hero__image"
			style={`--focus-mobile: ${focusMobile}; --focus-desktop: ${focusDesktop};`}
			widths={[640, 768, 1280, 1920]}
			sizes="100vw"
			loading="eager"
			fetchpriority="high"
		/>
	</div>

	<!-- Overlay wash -->
	<div class="page-hero__wash" aria-hidden="true"></div>
	<div class="page-hero__vignette" aria-hidden="true"></div>

	<!-- Decorative vertical rule -->
	<div class="page-hero__v-rule" aria-hidden="true"></div>

	<!-- Content -->
	<div class="page-hero__inner wrapper wrapper--wide">
		<div class="page-hero__copy" data-ph-copy>
			<Eyebrow
				text={studio.name}
				colorToken="--color-fg-accent-on-brand"
				showRule={false}
				animateAttr="page-hero-eyebrow"
				class="page-hero__eyebrow-wrap"
			/>
			<h1 class="page-hero__title" data-page-hero-title>
				{titleParts.map((part) => part.em ? <em class="page-hero__title-em">{part.text}</em> : part.text)}
			</h1>
			<div class="page-hero__rule" data-page-hero-rule aria-hidden="true"></div>
			<p class="page-hero__subtitle" data-page-hero-subtitle>{subtitle}</p>
			<div class="page-hero__ctas" data-page-hero-ctas>
				<CtaLink
					href={booking.href}
					label={booking.label}
					variant="primary"
					calLink={booking.calLink}
					calNamespace={booking.calNamespace}
					calConfig={booking.calConfig}
				/>
				<CtaLink href="/contact" label="Get in touch" variant="outline-light" icon="arrow" />
			</div>
		</div>

		<!-- Bottom location bar -->
		<div class="page-hero__bottom" data-page-hero-bottom>
			<span class="page-hero__lineage">{studio.location.display}</span>
			<ScrollIndicator />
		</div>
	</div>
</section>

<script>
	import "./page-hero.gsap.ts";
</script>

<style>
	/* ── Shell ──────────────────────────────────────────────────────────────── */
	.page-hero {
		position: relative;
		min-height: 85svh;
		display: flex;
		align-items: stretch;
		overflow: hidden;

		@media (min-width: 1024px) {
			min-height: 90svh;
		}
	}

	/* ── Background photograph ──────────────────────────────────────────────── */
	.page-hero__bg {
		position: absolute;
		inset: 0;
		z-index: 1;
	}

	.page-hero__image {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: var(--focus-mobile);

		@media (min-width: 768px) {
			object-position: var(--focus-desktop);
		}
	}

	/* ── Wash ───────────────────────────────────────────────────────────────── */
	.page-hero__wash {
		position: absolute;
		inset: 0;
		z-index: 2;
		pointer-events: none;
		/* Fallback for Safari < 16.2 (no color-mix support): rgb() with slash-alpha
		   driven by --color-bg-brand-rgb so the gradient stays token-driven */
		background: linear-gradient(
			to bottom,
			rgb(var(--color-bg-brand-rgb) / 0.94) 0%,
			rgb(var(--color-bg-brand-rgb) / 0.72) 100%
		);
		background: linear-gradient(
			to bottom,
			color-mix(in srgb, var(--color-bg-brand) 94%, transparent) 0%,
			color-mix(in srgb, var(--color-bg-brand) 72%, transparent) 100%
		);

		@media (min-width: 768px) {
			/* Fallback for Safari < 16.2 */
			background: linear-gradient(
				108deg,
				rgb(var(--color-bg-brand-rgb) / 0.97) 0%,
				rgb(var(--color-bg-brand-rgb) / 0.90) 40%,
				rgb(var(--color-bg-brand-rgb) / 0.60) 65%,
				rgb(var(--color-bg-brand-rgb) / 0.20) 84%,
				rgb(var(--color-bg-brand-rgb) / 0) 100%
			);
			background: linear-gradient(
				108deg,
				color-mix(in srgb, var(--color-bg-brand) 97%, transparent) 0%,
				color-mix(in srgb, var(--color-bg-brand) 90%, transparent) 40%,
				color-mix(in srgb, var(--color-bg-brand) 60%, transparent) 65%,
				color-mix(in srgb, var(--color-bg-brand) 20%, transparent) 84%,
				color-mix(in srgb, var(--color-bg-brand) 0%, transparent) 100%
			);
		}
	}

	/* ── Vignette ────────────────────────────────────────────────────────────── */
	.page-hero__vignette {
		position: absolute;
		inset: 0;
		z-index: 3;
		pointer-events: none;
		/* Fallback for Safari < 16.2 */
		background:
			radial-gradient(
				ellipse at 0% 0%,
				rgb(var(--color-bg-brand-rgb) / 0.45) 0%,
				transparent 55%
			),
			radial-gradient(
				ellipse at 0% 100%,
				rgb(var(--color-bg-brand-rgb) / 0.35) 0%,
				transparent 50%
			);
		background:
			radial-gradient(
				ellipse at 0% 0%,
				color-mix(in srgb, var(--color-bg-brand) 45%, transparent) 0%,
				transparent 55%
			),
			radial-gradient(
				ellipse at 0% 100%,
				color-mix(in srgb, var(--color-bg-brand) 35%, transparent) 0%,
				transparent 50%
			);
	}

	/* ── Vertical gold rule ──────────────────────────────────────────────────── */
	.page-hero__v-rule {
		position: absolute;
		top: 0;
		bottom: 0;
		left: clamp(var(--space-xs), 2.8vw, var(--size-14));
		width: 1px;
		z-index: 4;
		pointer-events: none;
		background: linear-gradient(
			to bottom,
			transparent 0%,
			color-mix(in srgb, var(--color-fg-accent-on-brand) 28%, transparent) 15%,
			color-mix(in srgb, var(--color-fg-accent-on-brand) 28%, transparent) 85%,
			transparent 100%
		);
	}

	/* ── Inner container ─────────────────────────────────────────────────────── */
	.page-hero__inner {
		position: relative;
		z-index: 5;
		display: flex;
		flex-direction: column;
		flex: 1;
		padding-block: var(--space-5xl) var(--space-xl);
	}

	/* ── Copy block ──────────────────────────────────────────────────────────── */
	.page-hero__copy {
		margin-block: auto;
		display: flex;
		flex-direction: column;
		max-width: 100%;

		@media (min-width: 768px) {
			max-width: 62%;
		}

		@media (min-width: 1280px) {
			max-width: 55%;
		}
	}

	/* ── Eyebrow ─────────────────────────────────────────────────────────────── */
	.page-hero__eyebrow-wrap {
		margin-block-end: var(--space-lg);
	}

	/* :global() needed because .page-hero__eyebrow-wrap lives on the
	   <Eyebrow> child component's root — without :global() Astro scopes the
	   selector and it never matches, so the eyebrow paints visible and blinks
	   when GSAP takes over. Same pattern as HeroHome's eyebrow hide. */
	:global(.page-hero__eyebrow-wrap) {
		visibility: hidden;
	}

	/* ── Animated elements — hidden until GSAP is ready ─────────────────────── */
	[data-page-hero-title],
	[data-page-hero-subtitle],
	[data-page-hero-ctas],
	[data-page-hero-bottom] {
		visibility: hidden;
	}

	/* ── Reduced motion — always show content, skip animation ───────────────── */
	@media (prefers-reduced-motion: reduce) {
		:global(.page-hero__eyebrow-wrap),
		[data-page-hero-title],
		[data-page-hero-subtitle],
		[data-page-hero-ctas],
		[data-page-hero-bottom] {
			visibility: visible;
		}
	}

	/* ── Title ───────────────────────────────────────────────────────────────── */
	.page-hero__title {
		font-family: var(--font-serif);
		font-weight: var(--font-weight-light);
		font-size: clamp(var(--font-size-4xl), 5.5vw, var(--font-size-5xl));
		line-height: var(--line-height-tight);
		letter-spacing: var(--letter-spacing-tight);
		color: var(--color-fg-on-brand);
		max-width: 20ch;
		text-wrap: pretty;
		margin-block-end: var(--space-xl);
	}

	/* ── Title emphasis ─────────────────────────────────────────────────────── */
	.page-hero__title-em {
		font-style: italic;
		color: var(--color-fg-accent-on-brand);
	}

	/* ── Decorative rule ─────────────────────────────────────────────────────── */
	.page-hero__rule {
		width: 0;
		height: 1px;
		background-color: var(--color-fg-accent-on-brand);
		margin-block-end: var(--space-xl);
	}

	/* ── Subtitle ────────────────────────────────────────────────────────────── */
	.page-hero__subtitle {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed);
		color: var(--color-fg-on-brand-muted);
		max-width: 46ch;
		margin-block-end: var(--space-3xl);

		@media (min-width: 768px) {
			font-size: var(--font-size-base);
		}
	}

	/* ── CTAs ────────────────────────────────────────────────────────────────── */
	.page-hero__ctas {
		display: flex;
		flex-direction: column;
		gap: var(--space-lg);

		@media (min-width: 640px) {
			flex-direction: row;
			align-items: center;
		}
	}

	/* ── Bottom bar ──────────────────────────────────────────────────────────── */
	.page-hero__bottom {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-block-start: var(--space-3xl);
		padding-block-start: var(--space-lg);
		border-top: 1px solid color-mix(in srgb, var(--color-fg-on-brand) 12%, transparent);
	}

	.page-hero__lineage {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: var(--font-weight-medium);
		letter-spacing: var(--letter-spacing-wider);
		text-transform: uppercase;
		/* 55% — intentionally dimmer than --color-fg-on-brand-subtle (65%) */
		color: color-mix(in srgb, var(--color-fg-on-brand) 55%, transparent);
	}
</style>
