---
import heroImage from "../assets/images/new/kilkenny-castle-from-johns-bridge.webp";
import CTAPanel from "../components/CTAPanel/CTAPanel.astro";
import HeroHome from "../components/HeroHome/HeroHome.astro";
import TestimonialBlock from "../components/TestimonialBlock/TestimonialBlock.astro";
import FeaturedService from "../components/home/FeaturedService/FeaturedService.astro";
import TrustStrip from "../components/shared/TrustStrip/TrustStrip.astro";
import ServiceCardsGrid from "../components/services/ServiceCards/ServiceCardsGrid/ServiceCardsGrid.astro";
import TeamSection from "../components/team/TeamSection/TeamSection.astro";
import AttributionBlock from "../components/ui/AttributionBlock/AttributionBlock.astro";
import SectionHeader from "../components/ui/SectionHeader/SectionHeader.astro";
import { firm } from "../config/firm";
import { homePageContent } from "../config/home";
import { services } from "../config/services/index";
import { getLawFirmStructuredData } from "../config/structured-data";
import BaseLayout from "../layouts/BaseLayout.astro";

const structuredData = getLawFirmStructuredData();
const { hero, supportingServices, trustStrip, attribution } = homePageContent;
const { solicitor, reviewDate } = attribution;
---

<BaseLayout
	title={`Solicitors in Kilkenny | ${firm.companyName}`}
	description={homePageContent.seo.description}
	canonicalPath={homePageContent.seo.canonicalPath}
	structuredData={structuredData}
>
	<HeroHome
		eyebrow={hero.eyebrow}
		title={hero.title}
		titleEmphasis={hero.titleEmphasis}
		subtitle={hero.subtitle}
		primaryCta={hero.ctas.primary}
		secondaryCta={hero.ctas.secondary}
		image={heroImage}
		imageAlt="View of Kilkenny Castle from John's Bridge"
	/>

	<TrustStrip
		eyebrow={trustStrip.eyebrow}
		title={trustStrip.title}
		paragraphs={trustStrip.paragraphs}
		stats={trustStrip.stats}
	/>

	<FeaturedService />

	<section class="section">
		<div class="wrapper wrapper--wide home-services__header">
			<SectionHeader
				eyebrow={supportingServices.eyebrow}
				heading={supportingServices.title}
				intro={supportingServices.intro}
			/>
		</div>
		<ServiceCardsGrid services={services.slice(1, 4)} />
	</section>

	{/* <TestimonialBlock /> */}
	<TeamSection />
	<AttributionBlock solicitor={solicitor} reviewDate={reviewDate} />
	<CTAPanel />
</BaseLayout>
