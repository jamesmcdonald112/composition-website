---
import heroImage from "../assets/images/new/kilkenny-castle-from-johns-bridge.webp";
import CTAPanel from "../components/CTAPanel/CTAPanel.astro";
import HeroHome from "../components/HeroHome/HeroHome.astro";
import ServiceCardsGrid from "../components/services/ServiceCardsGrid/ServiceCardsGrid.astro";
import TestimonialBlock from "../components/TestimonialBlock/TestimonialBlock.astro";
import { firm } from "../config/firm";
import { homePageContent } from "../config/home";
import { services } from "../config/services/index";
import { getLawFirmStructuredData } from "../config/structured-data";
import BaseLayout from "../layouts/BaseLayout.astro";

const structuredData = getLawFirmStructuredData();
const { hero } = homePageContent;
---

<BaseLayout
	title={`Solicitors in Kilkenny | ${firm.companyName}`}
	description={homePageContent.seo.description}
	canonicalPath={homePageContent.seo.canonicalPath}
	structuredData={structuredData}
>
	<HeroHome
		eyebrow={hero.eyebrow}
		title={hero.title}
		titleEmphasis={hero.titleEmphasis}
		subtitle={hero.subtitle}
		primaryCta={hero.ctas.primary}
		secondaryCta={hero.ctas.secondary}
		image={heroImage}
		imageAlt="View of Kilkenny Castle from John's Bridge"
	/>

	<div class="section">
		<ServiceCardsGrid services={services.slice(1, 4)} />
	</div>

	<TestimonialBlock />
	<CTAPanel />
</BaseLayout>
