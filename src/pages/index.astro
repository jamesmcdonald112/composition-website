---
/*
  PAGE: index.astro — Pozdnyakov Composition Studio homepage.

  Structure: a single quiet scroll, seven movements.
    1. HeroHome       — name, tagline, primary CTA
    2. TrustStrip     — credentials + 4 stats (first credibility moment)
    3. LeadMagnet     — free resource for visitors not yet ready to enquire
    4. CurriculumPath — the eight-module training path
    5. Pricing        — two offers (lesson, homework correction)
    6. TeacherIntro   — Alex's portrait + compressed bio
    7. AudioFeature   — featured recording (placeholder until Alex picks one)

  Order rationale:
    Pricing sits *between* curriculum and teacher — once the visitor has
    seen what's taught, they can read the cost as a courtesy rather than
    a sales push. Lead magnet sits high (after credibility, before depth)
    so visitors who aren't yet ready to enquire have a soft conversion
    point. See pricing.ts header note for context.

  All content reads from src/config/home.ts and its dependencies.
*/
import heroImage from "../assets/images/antique-score-on-desk-hero.webp";
import HeroHome from "../components/HeroHome/HeroHome.astro";
import TrustStrip from "../components/shared/TrustStrip/TrustStrip.astro";
import AudioFeature from "../components/home/AudioFeature/AudioFeature.astro";
import CurriculumPath from "../components/home/CurriculumPath/CurriculumPath.astro";
import LeadMagnet from "../components/home/LeadMagnet/LeadMagnet.astro";
import Pricing from "../components/home/Pricing/Pricing.astro";
import TeacherIntro from "../components/home/TeacherIntro/TeacherIntro.astro";
import { homePageContent } from "../config/home";
import { studio } from "../config/studio";
import BaseLayout from "../layouts/BaseLayout.astro";

const { hero, trustStrip, curriculum, teacher, music } = homePageContent;
---

<BaseLayout
	title={studio.seo.defaultTitle}
	description={homePageContent.seo.description}
	canonicalPath={homePageContent.seo.canonicalPath}
	ogImage={studio.seo.defaultOgImage}
	ogImageAlt={studio.seo.defaultOgImageAlt}
>
	<HeroHome
		eyebrow={hero.eyebrow}
		title={hero.title}
		titleEmphasis={hero.titleEmphasis}
		subtitle={hero.subtitle}
		primaryCta={hero.ctas.primary}
		secondaryCta={hero.ctas.secondary}
		image={heroImage}
		imageAlt="An antique music manuscript, open at page 25, resting on a wooden writing desk."
	/>

	<TrustStrip
		eyebrow={trustStrip.eyebrow}
		title={trustStrip.title}
		paragraphs={trustStrip.paragraphs}
		stats={trustStrip.stats}
	/>

	<LeadMagnet />

	<CurriculumPath
		eyebrow={curriculum.eyebrow}
		title={curriculum.title}
		intro={curriculum.intro}
	/>

	<Pricing />

	<TeacherIntro
		eyebrow={teacher.eyebrow}
		title={teacher.title}
		paragraphs={teacher.paragraphs}
		linkLabel={teacher.linkLabel}
		linkHref={teacher.linkHref}
	/>

	<AudioFeature
		eyebrow={music.eyebrow}
		title={music.title}
		youtubeId={music.youtubeId}
		caption={music.caption}
	/>
</BaseLayout>
