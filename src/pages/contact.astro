---
import { actions } from "astro:actions";
import ContactPanel from "../components/contact/ContactPanel.astro";
import SplitPage from "../components/layout/SplitPage.astro";
import { contactPageContent } from "../config/contact";
import { studio } from "../config/studio";
import { getStructuredData } from "../config/structured-data";
import ContactForm from "../features/contact-form/components/ContactForm.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

// Redirect to /thank-you on successful contact-form submission.
// Astro Actions return the result on the same URL — we redirect on success here
// so the visitor lands on the dedicated thank-you page.
const result = Astro.getActionResult(actions.contact);
if (result && !result.error) {
	return Astro.redirect("/thank-you");
}

const structuredData = getStructuredData();
---

<BaseLayout
	title={`${contactPageContent.seo.title} | ${studio.name}`}
	description={contactPageContent.seo.description}
	canonicalPath={contactPageContent.seo.canonicalPath}
	structuredData={structuredData}
	solidNav
>
	<SplitPage rightBg="var(--color-bg-page)">
		<ContactPanel slot="left" />
		<ContactForm slot="right" />
	</SplitPage>
</BaseLayout>

<script>
	const hasError = document.querySelector(
		".contact-form__field-error, .contact-form__error-banner",
	);
	if (hasError) {
		const form = document.querySelector(".contact-form");
		if (form) {
			history.scrollRestoration = "manual";
			form.scrollIntoView({ behavior: "instant", block: "start" });
		}
	}
</script>
