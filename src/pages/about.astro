---
import BiographyCv from "../components/about/BiographyCv/BiographyCv.astro";
import Article from "../components/shared/Article/Article.astro";
import CTAPanel from "../components/CTAPanel/CTAPanel.astro";
import PageHero from "../components/shared/PageHero/PageHero.astro";
import TrustStrip from "../components/shared/TrustStrip/TrustStrip.astro";
import { aboutPageContent } from "../config/about";
import { bio } from "../config/alex/bio";
import { studio } from "../config/studio";
import { getStructuredData } from "../config/structured-data";
import BaseLayout from "../layouts/BaseLayout.astro";

const structuredData = getStructuredData();
const { hero, trustStrip, article, cv, cta } = aboutPageContent;

// Flatten the bio's chapter structure into the Article's block list. Each
// chapter heading becomes a `heading` block; each paragraph becomes a
// `paragraph` block — the BlockList renderer handles the typography.
type Block =
	| { type: "heading"; text: string }
	| { type: "paragraph"; text: string };

const articleBlocks: Block[] = bio.full.flatMap((chapter) => [
	{ type: "heading" as const, text: chapter.heading },
	...chapter.paragraphs.map((text) => ({
		type: "paragraph" as const,
		text,
	})),
]);
---

<BaseLayout
	title={`${aboutPageContent.seo.title} | ${studio.name}`}
	description={aboutPageContent.seo.description}
	canonicalPath={aboutPageContent.seo.canonicalPath}
	ogType="website"
	structuredData={structuredData}
>
	<PageHero
		title={hero.title}
		subtitle={hero.subtitle}
		image={hero.image}
		imageFocus={hero.imageFocus}
	/>

	<TrustStrip
		eyebrow={trustStrip.eyebrow}
		title={trustStrip.title}
		paragraphs={trustStrip.paragraphs}
		stats={trustStrip.stats}
	/>

	<Article
		eyebrow={article.eyebrow}
		title={article.title}
		intro={article.intro}
		quote={article.pullQuote}
		blocks={articleBlocks}
	/>

	<BiographyCv
		eyebrow={cv.eyebrow}
		title={cv.title}
		intro={cv.intro}
	/>

	<CTAPanel
		heading={cta.title}
		body={cta.body}
	/>
</BaseLayout>
