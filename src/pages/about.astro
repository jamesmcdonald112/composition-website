---
import { aboutPageContent } from "../config/about";
import { firm } from "../config/firm";
import { getLawFirmStructuredData } from "../config/structured-data";
import BaseLayout from "../layouts/BaseLayout.astro";
import ServiceHero from "../components/shared/ServiceHero/ServiceHero.astro";
import TrustStrip from "../components/shared/TrustStrip/TrustStrip.astro";
import TeamSection from "../components/team/TeamSection/TeamSection.astro";
import TestimonialBlock from "../components/TestimonialBlock/TestimonialBlock.astro";
import CTAPanel from "../components/CTAPanel/CTAPanel.astro";

const structuredData = getLawFirmStructuredData();
---

<BaseLayout
	title={`${aboutPageContent.seo.title} | ${firm.companyName}`}
	description={aboutPageContent.seo.description}
	canonicalPath={aboutPageContent.seo.canonicalPath}
	ogType="website"
	structuredData={structuredData}
>
	<ServiceHero
		title={aboutPageContent.hero.title}
		subtitle={aboutPageContent.hero.subtitle}
		image={aboutPageContent.hero.image}
		phone={firm.phone}
		imageFocus={"top center"}

	/>
	<TrustStrip
		title={aboutPageContent.trustStrip.title}
		paragraphs={aboutPageContent.trustStrip.paragraphs}
		stats={aboutPageContent.trustStrip.stats}
	/>
	<TeamSection />
	<TestimonialBlock />
	<CTAPanel
		heading={aboutPageContent.cta.title}
		body={aboutPageContent.cta.body}
	/>
</BaseLayout>
