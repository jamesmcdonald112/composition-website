---
/*
  PAGE: Thank You
  LAYOUT: BaseLayout
  COMPONENT: src/components/thank-you/ThankYou.astro
  CONNECTED TO: src/middleware/index.ts (redirects here after successful form submission)
*/
import ThankYouSection from "../components/thank-you/ThankYou.astro";
import { firm } from "../config/firm";
import { thankYouContent } from "../config/thank-you";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
	title={`${thankYouContent.seo.title} | ${firm.companyName}`}
	description={thankYouContent.seo.description}
	noIndex={true}
	solidNav={true}
>
	<ThankYouSection />
</BaseLayout>
