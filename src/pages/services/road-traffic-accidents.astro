---
import CTAPanel from "../../components/CTAPanel/CTAPanel.astro";
import ServiceArticle from "../../components/services/ServiceArticle/ServiceArticle.astro";
import RelatedServices from "../../components/services/ServiceCards/RelatedServices/RelatedServices.astro";
import ServiceFaqs from "../../components/services/ServiceFaqs/ServiceFaqs.astro";
import ServiceMidCta from "../../components/services/ServiceMidCta/ServiceMidCta.astro";
import ServiceProcess from "../../components/services/ServiceProcess/ServiceProcess.astro";
import ServiceHero from "../../components/shared/ServiceHero/ServiceHero.astro";
import TrustStrip from "../../components/shared/TrustStrip/TrustStrip.astro";
import TestimonialBlock from "../../components/TestimonialBlock/TestimonialBlock.astro";
import AttributionBlock from "../../components/ui/AttributionBlock/AttributionBlock.astro";
import LegalCostWarning from "../../components/ui/LegalCostWarning/LegalCostWarning.astro";
import { firm } from "../../config/firm";
import { roadTrafficAccidents as service } from "../../config/services";
import { getLawFirmStructuredData } from "../../config/structured-data";
import BaseLayout from "../../layouts/BaseLayout.astro";

const structuredData = getLawFirmStructuredData();
const { solicitor, reviewDate } = service.attribution;
---

<BaseLayout
	title={service.seo.title}
	description={service.seo.description}
	canonicalPath={service.seo.canonicalPath}
	ogType="website"
	structuredData={structuredData}
>
	<ServiceHero
		title={service.hero.title}
		subtitle={service.hero.subtitle}
		image={service.image}
		imageFocus={{ mobile: "center center", desktop: "center 50%" }}
		phone={firm.phone}
	/>
	<TrustStrip
		title={service.trustStrip.title}
		paragraphs={service.trustStrip.paragraphs}
		stats={service.trustStrip.stats}
	/>
	<ServiceMidCta lines={service.midCta} />
	<ServiceArticle
		eyebrow={service.article.eyebrow}
		title={service.article.title}
		intro={service.article.intro}
		quote={service.article.quote}
		blocks={service.article.blocks}
	/>
	<LegalCostWarning />
	<ServiceProcess steps={service.process} processDescription={service.processDescription} />
	<ServiceFaqs faqs={service.faqs} />
	<CTAPanel heading={service.cta.title} body={service.cta.description} />
	{/* <TestimonialBlock /> */}
	<RelatedServices currentHref={service.href} />
	<AttributionBlock solicitor={solicitor} reviewDate={reviewDate} />
</BaseLayout>
