---
import { firm } from "../../config/firm";
import { allServices, servicesIndexContent } from "../../config/services/services-index";
import { getLawFirmStructuredData } from "../../config/structured-data";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ServiceCardsGrid from "../../components/services/ServiceCardsGrid/ServiceCardsGrid.astro";
import SectionHeader from "../../components/ui/SectionHeader/SectionHeader.astro";

const structuredData = getLawFirmStructuredData();
---

<BaseLayout
	title={`${servicesIndexContent.seo.title} | ${firm.companyName}`}
	description={servicesIndexContent.seo.description}
	canonicalPath={servicesIndexContent.seo.canonicalPath}
	ogType="website"
	structuredData={structuredData}
	solidNav={true}
>
	<div class="section services-section">
		<div class="wrapper wrapper--wide">
			<SectionHeader
				eyebrow={servicesIndexContent.hero.eyebrow}
				heading={servicesIndexContent.hero.title}
				level={1}
			/>
		</div>
		<ServiceCardsGrid services={allServices} />
	</div>
</BaseLayout>

<style>
	.services-section {
		padding-block-start: var(--space-5xl);
	}
</style>
