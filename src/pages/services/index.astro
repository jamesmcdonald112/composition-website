---
import { firm } from "../../config/firm";
import { allServices, servicesIndexContent } from "../../config/services/services-index";
import { getLawFirmStructuredData } from "../../config/structured-data";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTAPanel from "../../components/CTAPanel/CTAPanel.astro";
import ServiceCardsGrid from "../../components/services/ServiceCards/ServiceCardsGrid/ServiceCardsGrid.astro";
import TrustStrip from "../../components/shared/TrustStrip/TrustStrip.astro";
import TestimonialBlock from "../../components/TestimonialBlock/TestimonialBlock.astro";
import AttributionBlock from "../../components/ui/AttributionBlock/AttributionBlock.astro";
import SectionHeader from "../../components/ui/SectionHeader/SectionHeader.astro";

const structuredData = getLawFirmStructuredData();
const { solicitor, reviewDate } = servicesIndexContent.attribution;
---

<BaseLayout
	title={`${servicesIndexContent.seo.title} | ${firm.companyName}`}
	description={servicesIndexContent.seo.description}
	canonicalPath={servicesIndexContent.seo.canonicalPath}
	ogType="website"
	structuredData={structuredData}
	solidNav={true}
>
	<div class="section services-section">
		<div class="wrapper wrapper--wide">
			<SectionHeader
				eyebrow={servicesIndexContent.hero.eyebrow}
				heading={servicesIndexContent.hero.title}
				level={1}
			/>
		</div>
		<ServiceCardsGrid services={allServices} />
	</div>

	<TrustStrip
		eyebrow={servicesIndexContent.trustStrip.eyebrow}
		title={servicesIndexContent.trustStrip.title}
		paragraphs={servicesIndexContent.trustStrip.paragraphs}
		stats={servicesIndexContent.trustStrip.stats}
	/>

	<TestimonialBlock />

	<CTAPanel
		heading={servicesIndexContent.cta.title}
		body={servicesIndexContent.cta.body}
	/>
	<AttributionBlock solicitor={solicitor} reviewDate={reviewDate} />
</BaseLayout>

<style>
	.services-section {
		padding-block-start: var(--space-5xl);
	}
</style>
