---
import { studio } from "../config/studio";
import { cookiePolicyPageContent } from "../config/legal/cookie-policy";
import BaseLayout from "../layouts/BaseLayout.astro";

const { seo } = cookiePolicyPageContent;
---

<BaseLayout
	title={`${seo.title} | ${studio.name}`}
	description={seo.description}
	canonicalPath={seo.canonicalPath}
	solidNav={true}
	pageId="cookiebot-inline"
>
	<section class="cookie-policy">
		<div class="cookie-policy__inner wrapper wrapper--wide">
			<h1 class="cookie-policy__title">Cookie Policy</h1>
			<script
				is:inline
				id="CookieDeclaration"
				src="https://consent.cookiebot.com/b1d7f9e4-c04f-43cf-a9a8-84377af4ffd8/cd.js"
				type="text/javascript"
				async></script>
		</div>
	</section>
</BaseLayout>

<style>
	.cookie-policy {
		background-color: var(--color-bg-page);
		padding-block: var(--space-4xl);
	}

	.cookie-policy__title {
		font-family: var(--font-serif);
		font-size: clamp(var(--font-size-3xl), 5vw, var(--font-size-5xl));
		font-weight: var(--font-weight-light);
		letter-spacing: var(--letter-spacing-tight);
		color: var(--color-fg-default);
		margin-block-end: var(--space-3xl);
	}
</style>
