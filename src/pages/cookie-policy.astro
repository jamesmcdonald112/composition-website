---
import { cookiePolicyPageContent } from "../config/legal/cookie-policy";
import { firm } from "../config/firm";
import BaseLayout from "../layouts/BaseLayout.astro";

const { seo } = cookiePolicyPageContent;
---

<BaseLayout
	title={`${seo.title} | ${firm.companyName}`}
	description={seo.description}
	canonicalPath={seo.canonicalPath}
	solidNav={true}
>
</BaseLayout>
