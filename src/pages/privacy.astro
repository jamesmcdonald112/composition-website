---
import LegalPageContent from "../components/ui/LegalPageContent/LegalPageContent.astro";
import { studio } from "../config/studio";
import { privacyPageContent } from "../config/legal/privacy";
import BaseLayout from "../layouts/BaseLayout.astro";

const { seo, title, intro, sections, reviewDate } = privacyPageContent;
---

<BaseLayout
	title={`${seo.title} | ${studio.name}`}
	description={seo.description}
	canonicalPath={seo.canonicalPath}
	pageId="cookiebot-inline"
	solidNav={true}
>
	<LegalPageContent
		title={title}
		intro={intro}
		sections={sections}
		reviewDate={reviewDate}
	/>
</BaseLayout>
