---
import LegalPageContent from "../components/ui/LegalPageContent/LegalPageContent.astro";
import { studio } from "../config/studio";
import { accessibilityPageContent } from "../config/legal/accessibility";
import BaseLayout from "../layouts/BaseLayout.astro";

const { seo, title, intro, sections, footerNote, reviewDate } =
	accessibilityPageContent;
---

<BaseLayout
	title={`${seo.title} | ${studio.name}`}
	description={seo.description}
	canonicalPath={seo.canonicalPath}
	solidNav={true}
>
	<LegalPageContent
		title={title}
		intro={intro}
		sections={sections}
		footerNote={footerNote}
		reviewDate={reviewDate}
	/>
</BaseLayout>
