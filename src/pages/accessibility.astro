---
import { accessibilityPageContent } from "../config/legal/accessibility";
import { firm } from "../config/firm";
import BaseLayout from "../layouts/BaseLayout.astro";
import LegalPageContent from "../components/ui/LegalPageContent/LegalPageContent.astro";

const { seo, title, intro, sections, footerNote, reviewDate } = accessibilityPageContent;
---

<BaseLayout
	title={`${seo.title} | ${firm.companyName}`}
	description={seo.description}
	canonicalPath={seo.canonicalPath}
	solidNav={true}
>
	<LegalPageContent
		title={title}
		intro={intro}
		sections={sections}
		footerNote={footerNote}
		reviewDate={reviewDate}
	/>
</BaseLayout>
