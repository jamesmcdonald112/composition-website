			<div class="wrapper wrapper--wide">
				<p class="dev-label">13 — Gold 3px border-top on card + rules</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="v13">
							<div class="v13__img-wrap">
								<Image src={p.photo} alt={p.name} width={300} height={225} class="v13__img" />
