		</section>

		<!-- 14 — Inset shadow (letterpress) + gold rules -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">14 — Letterpress inset shadow + gold rules (P × M hybrid)</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="v14">
							<div class="v14__img-wrap">
								<Image src={p.photo} alt={p.name} width={300} height={225} class="v14__img" />
							</div>
