			<div class="wrapper wrapper--wide">
				<p class="dev-label">06 — Wide 2-col: portrait left, rules in text col</p>
				<div class="grid-2">
					{m.map((p) => (
						<div class="v06">
							<div class="v06__img-col">
								<Image src={p.photo} alt={p.name} width={240} height={300} class="v06__img" />
							</div>
