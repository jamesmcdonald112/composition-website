			</div>
		</section>

		<!-- 10 — Subtle bg (not surface), gold border bottom of image -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">10 — Subtle bg, gold accent line between image and text</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="v10">
							<div class="v10__img-wrap">
								<Image src={p.photo} alt={p.name} width={300} height={225} class="v10__img" />
								<div class="v10__accent-line" aria-hidden="true"></div>
							</div>
							<div class="v10__body">
								<div class="v10__eyebrow">
									<span class="v10__rule" aria-hidden="true"></span>
									<p class="v10__role">{p.role}</p>
									<span class="v10__rule" aria-hidden="true"></span>
								</div>
								<h3 class="v10__name">{p.name}</h3>
								<p class="v10__bio">{p.bio}</p>
