---
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import maryPhoto from "../../assets/team/maryCropped.webp";
import nicholasPhoto from "../../assets/team/nicholas.webp";
import richardPhoto from "../../assets/team/richard.webp";
import dukePhoto from "../../assets/team/duke.webp";

const m = [
	{ name: "Mary Molloy", role: "Principal Solicitor", bio: "Mary leads the firm with over four decades of experience advising clients on property and private client matters throughout Kilkenny.", photo: maryPhoto },
	{ name: "Nicholas O'Shea", role: "Solicitor", bio: "Nicholas works across property and private client matters, supporting clients with clear communication and efficient case progression.", photo: nicholasPhoto },
	{ name: "Richard O'Shea", role: "Solicitor", bio: "Richard advises clients on buying and selling property, conveyancing and probate matters, with a steady detail-focused approach.", photo: richardPhoto },
	{ name: "Duke", role: "Office Companion", bio: "Providing daily morale support to the team and a warm welcome to all visitors.", photo: dukePhoto },
] as const;
---

<BaseLayout
	title="Team Cards — Round 5 (M1 focus)"
	description="Dev — 20 variations on M1: gold flanked rules, centred name"
	canonicalPath="/dev/team-cards-5"
>
	<div class="dev-page">
		<div class="dev-page__header wrapper wrapper--wide">
			<h1 class="dev-page__title">M1 — 20 Variations</h1>
			<p class="dev-page__sub">Gold flanked rules · centred name · every dimension explored</p>
		</div>

		<!-- 01 — Exact M1 baseline -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">01 — M1 baseline: surface card, 4/3 image, gold rules</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="v01">
							<div class="v01__img-wrap">
								<Image src={p.photo} alt={p.name} width={300} height={225} class="v01__img" />
							</div>
							<div class="v01__body">
								<div class="v01__eyebrow">
									<span class="v01__rule" aria-hidden="true"></span>
									<p class="v01__role">{p.role}</p>
									<span class="v01__rule" aria-hidden="true"></span>
								</div>
								<h3 class="v01__name">{p.name}</h3>
								<p class="v01__bio">{p.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- 02 — 3/4 portrait, rules closer, name larger -->
		<section class="dev-section dev-section--alt">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">02 — 3/4 portrait, large serif name</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="v02">
							<div class="v02__img-wrap">
								<Image src={p.photo} alt={p.name} width={300} height={400} class="v02__img" />
							</div>
							<div class="v02__body">
								<div class="v02__eyebrow">
									<span class="v02__rule" aria-hidden="true"></span>
									<p class="v02__role">{p.role}</p>
									<span class="v02__rule" aria-hidden="true"></span>
								</div>
								<h3 class="v02__name">{p.name}</h3>
								<p class="v02__bio">{p.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- 03 — Square image, compact body -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">03 — Square 1/1 image, compact</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="v03">
							<div class="v03__img-wrap">
								<Image src={p.photo} alt={p.name} width={300} height={300} class="v03__img" />
							</div>
							<div class="v03__body">
								<div class="v03__eyebrow">
									<span class="v03__rule" aria-hidden="true"></span>
