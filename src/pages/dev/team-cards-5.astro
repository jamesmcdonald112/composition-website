			</div>
		</section>

		<!-- 15 — Bio below name centred, name very large -->
		<section class="dev-section dev-section--alt">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">15 — Everything centred: role rules, large name, bio centred</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="v15">
							<div class="v15__img-wrap">
								<Image src={p.photo} alt={p.name} width={300} height={225} class="v15__img" />
							</div>
							<div class="v15__body">
								<div class="v15__eyebrow">
