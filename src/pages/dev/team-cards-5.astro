			</div>
		</section>

		<!-- 05 — No border card, shadow only, rules thicker -->
		<section class="dev-section dev-section--alt">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">05 — Borderless, shadow-only, 2px rules</p>
				<div class="grid-4">
					{m.map((p) => (
