									<span class="v03__rule" aria-hidden="true"></span>
								</div>
								<h3 class="v03__name">{p.name}</h3>
								<p class="v03__bio">{p.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- 04 — Dark brand-muted card, gold rules -->
		<section class="dev-section dev-section--brand">
			<div class="wrapper wrapper--wide">
				<p class="dev-label dev-label--light">04 — Dark brand-muted card, gold rules</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="v04">
							<div class="v04__img-wrap">
