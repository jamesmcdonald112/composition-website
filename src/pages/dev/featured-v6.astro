---
import { Image } from "astro:assets";
import propertyImage from "../../assets/images/new/house-key-and-figurine.webp";
import signingImage from "../../assets/images/new/person-signing-document-at-desk.webp";
import ServiceCard from "../../components/services/ServiceCards/ServiceCard/ServiceCard.astro";
import { homePageContent } from "../../config/home";
import { buyingAndSellingProperty as svc } from "../../config/services";
import BaseLayout from "../../layouts/BaseLayout.astro";

const { featuredService } = homePageContent;
const { aside } = featuredService;
const stats = homePageContent.trustStrip.stats;
const quoteAttribution = `${svc.article.quote.solicitor.name}, ${svc.article.quote.solicitor.role}`;
const quoteImage = svc.article.quote.solicitor.photo;
---

<BaseLayout title="Featured V6 — Card Variants" description="Dev — 20 featured-card layout explorations" canonicalPath="/dev/featured-v6">
<div class="dev-page">

	<!-- ─── 1: Stone / card left / eyebrow + heading + points right ──────────── -->
	<section class="v v1">
		<p class="lbl">1 · Stone / Card left / Eyebrow + heading + key points right</p>
		<div class="wrapper wrapper--wide v1__grid">
			<div class="v1__card">
				<ServiceCard
					title={svc.title}
					href={svc.href}
					image={svc.image}
					imageClass={svc.imageClass}
					description={svc.description}
					level={3}
				/>
			</div>
			<div class="v1__content">
				<p class="eyebrow">{featuredService.eyebrow}</p>
				<h2 class="h-serif">{featuredService.card.title}</h2>
				<p class="body">{aside.intro}</p>
				<div class="kp-stack">
					{aside.keyPoints.map(kp => (
						<div class="kp">
							<strong class="kp__head">{kp.heading}</strong>
							<p class="kp__body">{kp.body}</p>
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<!-- ─── 2: Navy / card right / large eyebrow left + stats below ──────────── -->
	<section class="v v-navy v2">
		<p class="lbl lbl-light">2 · Navy / Large eyebrow left / Card right / Stats below</p>
		<div class="wrapper wrapper--wide">
			<div class="v2__top">
				<div class="v2__text">
					<p class="v2__eyebrow">{featuredService.eyebrow}</p>
					<div class="v2__rule"></div>
					<h2 class="v2__heading">{featuredService.card.title}</h2>
					<p class="body body--brand">{aside.intro}</p>
				</div>
				<div class="v2__card">
					<ServiceCard
						title={svc.title}
						href={svc.href}
						image={svc.image}
						imageClass={svc.imageClass}
						description={svc.description}
						level={3}
					/>
				</div>
			</div>
			<div class="v2__stats">
				{stats.map(s => (
					<div class="stat">
						<span class="stat__val">{s.value}</span>
						<span class="stat__lbl">{s.label}</span>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ─── 3: White / centred eyebrow + heading / card below centred ────────── -->
	<section class="v v-white v3">
		<p class="lbl">3 · White / Centred header / Card below centred / Points flanking</p>
		<div class="wrapper wrapper--wide">
			<div class="v3__header">
				<p class="eyebrow eyebrow--center">{featuredService.eyebrow}</p>
				<h2 class="v3__display">{featuredService.card.title}</h2>
			</div>
			<div class="v3__body">
				<div class="v3__points-left">
					{aside.keyPoints.slice(0,2).map(kp => (
						<div class="kp kp--right-align">
							<strong class="kp__head">{kp.heading}</strong>
							<p class="kp__body">{kp.body}</p>
						</div>
					))}
				</div>
				<div class="v3__card">
					<ServiceCard
						title={svc.title}
						href={svc.href}
						image={svc.image}
						imageClass={svc.imageClass}
						description={svc.description}
						level={3}
					/>
				</div>
				<div class="v3__points-right">
					{aside.keyPoints.slice(2,4).map(kp => (
						<div class="kp">
							<strong class="kp__head">{kp.heading}</strong>
							<p class="kp__body">{kp.body}</p>
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<!-- ─── 4: Amber / card right / serif quote dominant left ────────────────── -->
	<section class="v v-amber v4">
		<p class="lbl">4 · Amber / Serif quote dominant left / Card right</p>
		<div class="wrapper wrapper--wide v4__grid">
			<div class="v4__text">
				<p class="eyebrow">{featuredService.eyebrow}</p>
				<p class="v4__pull">&ldquo;{svc.article.quote.text}&rdquo;</p>
				<p class="v4__attr">— {quoteAttribution}</p>
				<a href={svc.href} class="btn-primary">Our property service</a>
			</div>
			<div class="v4__card">
				<ServiceCard
					title={svc.title}
					href={svc.href}
					image={svc.image}
					imageClass={svc.imageClass}
					description={svc.description}
					level={3}
				/>
			</div>
		</div>
	</section>

	<!-- ─── 5: Stone / card full-width top / 4-col key points below ──────────── -->
	<section class="v v5">
		<p class="lbl">5 · Stone / Card wide top / 4-col key points grid below</p>
		<div class="wrapper wrapper--wide">
			<div class="v5__header">
				<p class="eyebrow">{featuredService.eyebrow}</p>
				<h2 class="h-serif">{featuredService.card.title}</h2>
			</div>
			<div class="v5__card">
				<ServiceCard
					title={svc.title}
					href={svc.href}
					image={svc.image}
					imageClass={svc.imageClass}
					description={svc.description}
					level={3}
				/>
			</div>
			<div class="v5__grid">
				{aside.keyPoints.map(kp => (
					<div class="v5__kp">
						<div class="v5__kp-rule"></div>
						<strong class="v5__kp-head">{kp.heading}</strong>
						<p class="v5__kp-body">{kp.body}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ─── 6: Navy / 3-col: intro | card | stats col ────────────────────────── -->
	<section class="v v-navy v6">
		<p class="lbl lbl-light">6 · Navy / 3-col: intro | card | stats stack</p>
		<div class="wrapper wrapper--wide v6__grid">
			<div class="v6__intro">
				<p class="eyebrow eyebrow--brand">{featuredService.eyebrow}</p>
				<h2 class="v6__heading">{featuredService.card.title}</h2>
				<p class="body body--brand">{aside.intro}</p>
				<a href={svc.href} class="btn-outline-light">Learn more</a>
			</div>
			<div class="v6__card">
				<ServiceCard
					title={svc.title}
					href={svc.href}
					image={svc.image}
					imageClass={svc.imageClass}
					description={svc.description}
					level={3}
				/>
			</div>
			<div class="v6__stats">
				{stats.map(s => (
					<div class="v6__stat">
						<span class="v6__stat-val">{s.value}</span>
						<span class="v6__stat-lbl">{s.label}</span>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ─── 7: White / card + stats band / points below ──────────────────────── -->
	<section class="v v-white v7">
		<p class="lbl">7 · White / Card + inline stats / Points below rule</p>
		<div class="wrapper wrapper--wide v7__grid">
			<div class="v7__card-col">
				<ServiceCard
					title={svc.title}
					href={svc.href}
					image={svc.image}
					imageClass={svc.imageClass}
					description={svc.description}
					level={3}
				/>
				<div class="v7__stats">
					{stats.map(s => (
						<div class="v7__stat">
							<span class="v7__stat-val">{s.value}</span>
							<span class="v7__stat-lbl">{s.label}</span>
						</div>
					))}
				</div>
			</div>
			<div class="v7__text">
				<p class="eyebrow">{featuredService.eyebrow}</p>
				<h2 class="h-serif">{featuredService.card.title}</h2>
				<p class="body">{aside.intro}</p>
				<ul class="points">
					{featuredService.card.points.map(p => <li>{p}</li>)}
				</ul>
				<a href={svc.href} class="btn-primary">Our property service</a>
			</div>
		</div>
	</section>

	<!-- ─── 8: Stone / eyebrow band top / card + process steps side by side ──── -->
	<section class="v v8">
		<p class="lbl">8 · Stone / Eyebrow band top / Card + numbered process right</p>
		<div class="v8__eyebrow-band">
			<div class="wrapper wrapper--wide">
				<p class="v8__eyebrow">{featuredService.eyebrow}</p>
			</div>
		</div>
		<div class="wrapper wrapper--wide v8__grid">
			<div class="v8__card">
				<ServiceCard
					title={svc.title}
					href={svc.href}
					image={svc.image}
					imageClass={svc.imageClass}
					description={svc.description}
					level={3}
				/>
			</div>
			<div class="v8__process">
				<h2 class="h-serif">{featuredService.card.title}</h2>
				<p class="body">{aside.intro}</p>
				<div class="v8__steps">
					{svc.process.slice(0, 4).map((step, i) => (
						<div class="v8__step">
							<span class="v8__step-num" aria-hidden="true">0{i + 1}</span>
							<div class="v8__step-text">
								<strong class="v8__step-head">{step.title}</strong>
								<p class="v8__step-body">{step.description}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<!-- ─── 9: Navy / card left / article quote + key points right ───────────── -->
	<section class="v v-navy v9">
		<p class="lbl lbl-light">9 · Navy / Card left / Article quote + key points right</p>
		<div class="wrapper wrapper--wide v9__grid">
			<div class="v9__card">
				<ServiceCard
					title={svc.title}
					href={svc.href}
					image={svc.image}
					imageClass={svc.imageClass}
					description={svc.description}
					level={3}
				/>
			</div>
			<div class="v9__content">
				<p class="eyebrow eyebrow--brand">{featuredService.eyebrow}</p>
				<h2 class="v9__heading">{featuredService.card.title}</h2>
				<blockquote class="v9__quote">
					<p>&ldquo;{svc.article.quote.text}&rdquo;</p>
					<cite>{quoteAttribution}</cite>
				</blockquote>
				<div class="v9__kps">
					{aside.keyPoints.slice(0,2).map(kp => (
						<div class="v9__kp">
							<strong class="v9__kp-head">{kp.heading}</strong>
							<p class="v9__kp-body">{kp.body}</p>
						</div>
					))}
				</div>
				<a href={svc.href} class="btn-outline-light">Learn more</a>
			</div>
		</div>
	</section>

	<!-- ─── 10: Amber / card centred / stats flanking either side ────────────── -->
	<section class="v v-amber v10">
		<p class="lbl">10 · Amber / Stats columns flanking a centred card</p>
		<div class="wrapper wrapper--wide">
			<div class="v10__header">
				<p class="eyebrow eyebrow--center">{featuredService.eyebrow}</p>
				<h2 class="v10__heading">{featuredService.card.title}</h2>
			</div>
			<div class="v10__layout">
				<div class="v10__stat-col">
					{stats.slice(0,2).map(s => (
						<div class="v10__stat">
							<span class="v10__stat-val">{s.value}</span>
							<span class="v10__stat-lbl">{s.label}</span>
						</div>
					))}
				</div>
				<div class="v10__card">
					<ServiceCard
						title={svc.title}
						href={svc.href}
						image={svc.image}
						imageClass={svc.imageClass}
						description={svc.description}
						level={3}
					/>
				</div>
				<div class="v10__stat-col">
					{aside.keyPoints.slice(0,2).map(kp => (
						<div class="v10__aside-kp">
							<strong class="v10__aside-head">{kp.heading}</strong>
							<p class="v10__aside-body">{kp.body}</p>
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<!-- ─── 11: White / card right / tall eyebrow + process steps left ───────── -->
	<section class="v v-white v11">
		<p class="lbl">11 · White / Eyebrow + 3 process steps left / Card right</p>
		<div class="wrapper wrapper--wide v11__grid">
			<div class="v11__left">
				<p class="v11__eyebrow">{featuredService.eyebrow}</p>
				<div class="v11__rule"></div>
				<h2 class="h-serif">{featuredService.card.title}</h2>
				<div class="v11__steps">
					{svc.process.slice(0, 3).map((step, i) => (
						<div class="v11__step">
							<span class="v11__num">0{i + 1}</span>
							<div>
								<strong class="v11__step-head">{step.title}</strong>
								<p class="v11__step-body">{step.description}</p>
							</div>
						</div>
					))}
				</div>
				<a href={svc.href} class="btn-primary">Our property service</a>
			</div>
			<div class="v11__card">
				<ServiceCard
					title={svc.title}
					href={svc.href}
					image={svc.image}
					imageClass={svc.imageClass}
					description={svc.description}
					level={3}
				/>
			</div>
		</div>
	</section>

	<!-- ─── 12: Navy / card top / 4-col process steps below on dark ──────────── -->
	<section class="v v-navy v12">
		<p class="lbl lbl-light">12 · Navy / Card + eyebrow top / Process steps below</p>
		<div class="wrapper wrapper--wide">
			<div class="v12__top">
				<div class="v12__top-text">
					<p class="eyebrow eyebrow--brand">{featuredService.eyebrow}</p>
					<h2 class="v12__heading">{featuredService.card.title}</h2>
					<p class="body body--brand">{aside.intro}</p>
				</div>
				<div class="v12__card">
					<ServiceCard
						title={svc.title}
						href={svc.href}
						image={svc.image}
						imageClass={svc.imageClass}
						description={svc.description}
						level={3}
					/>
				</div>
			</div>
			<div class="v12__rule"></div>
			<div class="v12__steps">
				{svc.process.slice(0, 4).map((step, i) => (
					<div class="v12__step">
						<span class="v12__step-num">0{i + 1}</span>
						<strong class="v12__step-head">{step.title}</strong>
						<p class="v12__step-body">{step.description}</p>
					</div>
				))}
			</div>
			<a href={svc.href} class="btn-outline-light">See full process</a>
		</div>
	</section>

	<!-- ─── 13: Stone / card right / intro + Mary quote left ────────────────── -->
	<section class="v v13">
		<p class="lbl">13 · Stone / Intro + Mary photo + quote left / Card right</p>
		<div class="wrapper wrapper--wide v13__grid">
			<div class="v13__left">
				<p class="eyebrow">{featuredService.eyebrow}</p>
				<h2 class="h-serif">{featuredService.card.title}</h2>
				<p class="body">{aside.intro}</p>
				<figure class="v13__quote-fig">
					<div class="v13__quote-img">
						<Image src={quoteImage} alt="" width={80} height={80} class="v13__avatar" />
					</div>
					<blockquote class="v13__quote">
						<p>&ldquo;{svc.article.quote.text}&rdquo;</p>
						<cite>{quoteAttribution}</cite>
					</blockquote>
				</figure>
				<a href={svc.href} class="btn-primary">Our property service</a>
			</div>
			<div class="v13__card">
				<ServiceCard
					title={svc.title}
					href={svc.href}
					image={svc.image}
					imageClass={svc.imageClass}
					description={svc.description}
					level={3}
				/>
			</div>
		</div>
	</section>

	<!-- ─── 14: White / 3 cards in a row — featured card enlarged ───────────── -->
	<section class="v v-white v14">
		<p class="lbl">14 · White / Featured card enlarged in a 3-card row</p>
		<div class="wrapper wrapper--wide">
			<div class="v14__header">
				<p class="eyebrow">{featuredService.eyebrow}</p>
				<h2 class="h-serif">{featuredService.card.title}</h2>
			</div>
			<div class="v14__row">
				<div class="v14__secondary">
					<div class="v14__secondary-inner">
						<p class="v14__aside-head">{aside.keyPoints[0].heading}</p>
						<p class="v14__aside-body">{aside.keyPoints[0].body}</p>
					</div>
					<div class="v14__secondary-inner">
						<p class="v14__aside-head">{aside.keyPoints[1].heading}</p>
						<p class="v14__aside-body">{aside.keyPoints[1].body}</p>
					</div>
				</div>
				<div class="v14__featured">
					<ServiceCard
						title={svc.title}
						href={svc.href}
						image={svc.image}
						imageClass={svc.imageClass}
						description={svc.description}
						level={3}
					/>
				</div>
				<div class="v14__secondary">
					<div class="v14__secondary-inner">
						<p class="v14__aside-head">{aside.keyPoints[2].heading}</p>
						<p class="v14__aside-body">{aside.keyPoints[2].body}</p>
					</div>
					<div class="v14__secondary-inner">
						<p class="v14__aside-head">{aside.keyPoints[3].heading}</p>
						<p class="v14__aside-body">{aside.keyPoints[3].body}</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ─── 15: Navy / card left / eyebrow huge + intro + stats right ────────── -->
	<section class="v v-navy v15">
		<p class="lbl lbl-light">15 · Navy / Card left / Huge eyebrow + intro + stats right</p>
		<div class="wrapper wrapper--wide v15__grid">
			<div class="v15__card">
				<ServiceCard
					title={svc.title}
					href={svc.href}
					image={svc.image}
					imageClass={svc.imageClass}
					description={svc.description}
					level={3}
				/>
			</div>
			<div class="v15__content">
				<p class="v15__eyebrow">{featuredService.eyebrow}</p>
				<div class="v15__rule"></div>
				<h2 class="v15__heading">{featuredService.card.title}</h2>
				<p class="body body--brand">{aside.intro}</p>
				<div class="v15__stats">
					{stats.map(s => (
						<div class="v15__stat">
							<span class="v15__stat-val">{s.value}</span>
							<span class="v15__stat-lbl">{s.label}</span>
						</div>
					))}
				</div>
				<a href={svc.href} class="btn-outline-light">Our property service</a>
			</div>
		</div>
	</section>

	<!-- ─── 16: Amber / card bottom / large serif heading + intro top ────────── -->
	<section class="v v-amber v16">
		<p class="lbl">16 · Amber / Large heading + intro top / Card bottom</p>
		<div class="wrapper wrapper--wide">
			<div class="v16__top">
				<div class="v16__top-text">
					<p class="eyebrow">{featuredService.eyebrow}</p>
					<h2 class="v16__display">{featuredService.card.title}</h2>
				</div>
				<div class="v16__top-aside">
					<p class="body">{aside.intro}</p>
					<a href={svc.href} class="btn-primary">Our property service</a>
				</div>
			</div>
			<div class="v16__rule"></div>
			<div class="v16__card">
				<ServiceCard
					title={svc.title}
					href={svc.href}
					image={svc.image}
					imageClass={svc.imageClass}
					description={svc.description}
					level={3}
				/>
			</div>
		</div>
	</section>

	<!-- ─── 17: Stone / card right offset / stats row left / key points below ── -->
	<section class="v v17">
		<p class="lbl">17 · Stone / Stats left + card right / Key points below</p>
		<div class="wrapper wrapper--wide v17__top">
			<div class="v17__left">
				<p class="eyebrow">{featuredService.eyebrow}</p>
				<h2 class="h-serif">{featuredService.card.title}</h2>
				<p class="body">{aside.intro}</p>
				<div class="v17__stats">
					{stats.map(s => (
						<div class="v17__stat">
							<span class="v17__stat-val">{s.value}</span>
							<span class="v17__stat-lbl">{s.label}</span>
						</div>
					))}
				</div>
			</div>
			<div class="v17__card">
				<ServiceCard
					title={svc.title}
					href={svc.href}
					image={svc.image}
					imageClass={svc.imageClass}
					description={svc.description}
					level={3}
				/>
			</div>
		</div>
		<div class="wrapper wrapper--wide v17__kps">
			{aside.keyPoints.map(kp => (
				<div class="v17__kp">
					<strong class="v17__kp-head">{kp.heading}</strong>
					<p class="v17__kp-body">{kp.body}</p>
				</div>
			))}
		</div>
	</section>

	<!-- ─── 18: Navy / eyebrow band / card centred / key points row below ─────── -->
	<section class="v v-navy v18">
		<p class="lbl lbl-light">18 · Navy / Eyebrow band / Card centred / Points below</p>
		<div class="v18__eyebrow-band">
			<div class="wrapper wrapper--wide v18__eyebrow-inner">
				<p class="v18__eyebrow">{featuredService.eyebrow}</p>
				<h2 class="v18__heading">{featuredService.card.title}</h2>
			</div>
		</div>
		<div class="wrapper wrapper--wide v18__card-wrap">
			<div class="v18__card">
				<ServiceCard
					title={svc.title}
					href={svc.href}
					image={svc.image}
					imageClass={svc.imageClass}
					description={svc.description}
					level={3}
