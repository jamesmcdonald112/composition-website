<style>
.dev-page { display: flex; flex-direction: column; }

/* ── Section bases ─────────────────────────────────────────────────────────── */
.v { padding-block: var(--space-5xl); position: relative; }
.v-navy    { background: var(--color-bg-brand); }
.v-stone   { background: var(--color-bg-subtle); }
.v-white   { background: var(--color-bg-surface); }
.v-amber   { background: var(--color-bg-accent); }
.v-charcoal-dark { background: var(--charcoal-900); }

.lbl {
	position: absolute;
	top: var(--space-sm);
	left: var(--space-lg);
	font-family: var(--font-sans);
	font-size: var(--font-size-xs);
	letter-spacing: var(--letter-spacing-wider);
	text-transform: uppercase;
	opacity: 0.4;
	color: var(--color-fg-default);
}
.lbl-light { color: var(--color-fg-on-brand); }

/* ── Grids ─────────────────────────────────────────────────────────────────── */
.split {
	display: grid;
	grid-template-columns: 1fr;
	gap: var(--space-3xl);
	align-items: center;
	@media (min-width: 768px) { grid-template-columns: 1fr 1fr; }
}
.split--45-55 { @media (min-width: 768px) { grid-template-columns: 45fr 55fr; } }
.split--55-45 { @media (min-width: 768px) { grid-template-columns: 55fr 45fr; } }
.split--60-40 { @media (min-width: 768px) { grid-template-columns: 60fr 40fr; } }
.split--40-60 { @media (min-width: 768px) { grid-template-columns: 40fr 60fr; } }

/* ── Text col ──────────────────────────────────────────────────────────────── */
.text-col { display: flex; flex-direction: column; }
.text-col--amber-rule {
	border-inline-start: 2px solid var(--color-fg-accent-on-brand);
	padding-inline-start: var(--space-xl);
}

/* ── Image frames ──────────────────────────────────────────────────────────── */
.img-frame {
	overflow: hidden;
