<BaseLayout title="Featured V3 — Premium Variants" description="Dev — 20 premium layout explorations" canonicalPath="/dev/featured-v3">
<div class="dev-page">

	<!-- 1: Navy bg / text left / image right contained & smaller / amber outline -->
