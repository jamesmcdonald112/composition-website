---
import { Image } from "astro:assets";
import dukePhoto from "../../assets/team/duke.webp";
import maryPhoto from "../../assets/team/maryCropped.webp";
import nicholasPhoto from "../../assets/team/nicholas.webp";
import richardPhoto from "../../assets/team/richard.webp";
import BaseLayout from "../../layouts/BaseLayout.astro";

const m = [
	{
		name: "Mary Molloy",
		role: "Principal Solicitor",
		bio: "Mary leads the firm with over four decades of experience advising clients on property and private client matters throughout Kilkenny. She is known for her practical guidance, straightforward advice and personal approach to each case.",
		photo: maryPhoto,
		initial: "M",
	},
	{
		name: "Nicholas O'Shea",
		role: "Solicitor",
		bio: "Nicholas works across property and private client matters, supporting clients with clear communication and efficient case progression. He focuses on responsiveness, clarity and maintaining consistent contact throughout the legal process.",
		photo: nicholasPhoto,
		initial: "N",
	},
	{
		name: "Richard O'Shea",
		role: "Solicitor",
		bio: "Richard advises clients on buying and selling property, conveyancing and probate matters. He brings a steady, detail-focused approach to ensure each transaction progresses efficiently from first instruction to final completion.",
		photo: richardPhoto,
		initial: "R",
	},
	{
		name: "Duke",
		role: "Office Companion",
		bio: "Providing daily morale support to the team and a friendly welcome to visitors.",
		photo: dukePhoto,
		initial: "D",
	},
] as const;
---

<BaseLayout
	title="Team Cards — Round 2"
	description="Dev page — team card explorations round 2"
	canonicalPath="/dev/team-cards-2"
>
	<div class="dev-page">
		<div class="dev-page__header wrapper wrapper--wide">
			<h1 class="dev-page__title">Team Cards — Round 2</h1>
			<p class="dev-page__sub">Variants on 2, 4, 6, 11, 13 — plus new directions</p>
		</div>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- A. Variant of 13 — initial behind image, card with border + shadow -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">A — 13 variant: initial behind square, brand card bg</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="ca">
							<div class="ca__top">
								<span class="ca__initial" aria-hidden="true">{p.initial}</span>
								<div class="ca__img-wrap">
									<Image src={p.photo} alt={p.name} width={260} height={260} class="ca__img" />
								</div>
							</div>
							<div class="ca__body">
								<p class="ca__role">{p.role}</p>
								<h3 class="ca__name">{p.name}</h3>
								<p class="ca__bio">{p.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- B. Variant of 11 — pill badge top of image, not below -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section dev-section--alt">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">B — 11 variant: badge floats on image, serif name large</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="cb">
							<div class="cb__img-wrap">
								<Image src={p.photo} alt={p.name} width={300} height={280} class="cb__img" />
								<span class="cb__badge">{p.role}</span>
							</div>
							<div class="cb__body">
								<h3 class="cb__name">{p.name}</h3>
								<p class="cb__bio">{p.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- C. Variant of 6 — tall portrait, text panel slides up on hover -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">C — 6 variant: tall portrait, slide-up text panel on hover</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="cc">
							<div class="cc__img-wrap">
								<Image src={p.photo} alt={p.name} width={360} height={460} class="cc__img" />
								<div class="cc__panel">
									<p class="cc__role">{p.role}</p>
									<h3 class="cc__name">{p.name}</h3>
									<p class="cc__bio">{p.bio}</p>
								</div>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- D. Variant of 4 — circle with gold ring, horizontal layout on desktop -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section dev-section--alt">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">D — 4 variant: circle + horizontal text, border card</p>
				<div class="grid-2">
					{m.map((p) => (
						<div class="cd">
							<div class="cd__circle-wrap">
								<div class="cd__ring" aria-hidden="true"></div>
								<div class="cd__circle">
									<Image src={p.photo} alt={p.name} width={140} height={140} class="cd__img" />
								</div>
							</div>
							<div class="cd__text">
								<p class="cd__role">{p.role}</p>
								<h3 class="cd__name">{p.name}</h3>
								<p class="cd__bio">{p.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- E. Variant of 2 — horizontal, photo right, text left, dark bg -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section dev-section--brand">
			<div class="wrapper wrapper--wide">
				<p class="dev-label dev-label--light">E — 2 variant: photo right on dark, gold rule</p>
				<div class="grid-2-brand">
					{m.map((p) => (
						<div class="ce">
							<div class="ce__text">
								<p class="ce__role">{p.role}</p>
								<h3 class="ce__name">{p.name}</h3>
								<div class="ce__rule" aria-hidden="true"></div>
								<p class="ce__bio">{p.bio}</p>
							</div>
							<div class="ce__photo-col">
								<Image src={p.photo} alt={p.name} width={200} height={240} class="ce__img" />
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- F. NEW — Polaroid style: white border, tilted slightly, caption below -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">F — Polaroid: white border frame, subtle tilt</p>
				<div class="grid-4">
					{m.map((p, i) => (
						<div class={`cf cf--tilt-${(i % 3) + 1}`}>
							<div class="cf__frame">
								<Image src={p.photo} alt={p.name} width={280} height={300} class="cf__img" />
							</div>
							<h3 class="cf__name">{p.name}</h3>
							<p class="cf__role">{p.role}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- G. NEW — Accordion/expandable: compact by default, click to expand bio -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section dev-section--alt">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">G — Expandable accordion card</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="cg">
							<div class="cg__top">
								<div class="cg__circle">
									<Image src={p.photo} alt={p.name} width={120} height={120} class="cg__img" />
								</div>
								<div class="cg__meta">
									<h3 class="cg__name">{p.name}</h3>
									<p class="cg__role">{p.role}</p>
								</div>
							</div>
							<div class="cg__bio-wrap">
								<p class="cg__bio">{p.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- H. NEW — Split diagonal: image fills left triangle, text right -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">H — Diagonal split card</p>
				<div class="grid-2">
					{m.map((p) => (
						<div class="ch">
							<div class="ch__img-col">
								<Image src={p.photo} alt={p.name} width={280} height={360} class="ch__img" />
							</div>
							<div class="ch__text-col">
								<span class="ch__accent" aria-hidden="true"></span>
								<p class="ch__role">{p.role}</p>
								<h3 class="ch__name">{p.name}</h3>
								<p class="ch__bio">{p.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- I. NEW — Stamp / credential: dark card, gold border, monogram -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section dev-section--alt">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">I — Credential stamp card, monogram + photo</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="ci">
							<div class="ci__header">
								<div class="ci__monogram">{p.initial}</div>
								<div class="ci__lines">
									<p class="ci__name">{p.name}</p>
									<p class="ci__role">{p.role}</p>
								</div>
							</div>
							<div class="ci__img-wrap">
								<Image src={p.photo} alt={p.name} width={300} height={240} class="ci__img" />
							</div>
							<p class="ci__bio">{p.bio}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- J. NEW — Swiss grid: bold ruled lines, no card bg, pure type + photo -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">J — Swiss editorial: ruled lines, no card bg</p>
				<div class="cj-grid">
					{m.map((p, i) => (
						<div class="cj">
							<div class="cj__number" aria-hidden="true">{String(i + 1).padStart(2, "0")}</div>
							<div class="cj__img-wrap">
								<Image src={p.photo} alt={p.name} width={220} height={280} class="cj__img" />
							</div>
							<div class="cj__text">
								<h3 class="cj__name">{p.name}</h3>
								<p class="cj__role">{p.role}</p>
								<p class="cj__bio">{p.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- K. NEW — Frosted glass on subtle bg, circle photo inset top-right -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section dev-section--alt">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">K — Glass card: circle inset top-right, text left</p>
				<div class="grid-2">
					{m.map((p) => (
						<div class="ck">
							<div class="ck__body">
								<p class="ck__role">{p.role}</p>
								<h3 class="ck__name">{p.name}</h3>
								<div class="ck__rule" aria-hidden="true"></div>
								<p class="ck__bio">{p.bio}</p>
							</div>
							<div class="ck__circle">
								<Image src={p.photo} alt={p.name} width={160} height={160} class="ck__img" />
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- L. NEW — Ink stamp / seal: circular photo, decorative outer ring with text -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">L — Seal card: photo in decorative ring</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="cl">
							<div class="cl__seal-wrap">
								<div class="cl__outer-ring" aria-hidden="true">
									<span class="cl__ring-text">· {p.role} · {p.name} ·</span>
								</div>
								<div class="cl__circle">
									<Image src={p.photo} alt={p.name} width={160} height={160} class="cl__img" />
								</div>
							</div>
							<h3 class="cl__name">{p.name}</h3>
							<p class="cl__role">{p.role}</p>
							<p class="cl__bio">{p.bio}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- M. NEW — Newspaper column: image top half, text with column rule -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section dev-section--alt">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">M — Newspaper column style</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="cm">
							<div class="cm__img-wrap">
								<Image src={p.photo} alt={p.name} width={300} height={260} class="cm__img" />
							</div>
							<div class="cm__body">
								<div class="cm__eyebrow">
									<span class="cm__rule-left" aria-hidden="true"></span>
									<p class="cm__role">{p.role}</p>
									<span class="cm__rule-right" aria-hidden="true"></span>
								</div>
								<h3 class="cm__name">{p.name}</h3>
								<p class="cm__bio">{p.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- N. NEW — Profile card: large photo, bottom bar with gradient -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">N — Profile card: photo dominant, gradient footer bar</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="cn">
							<div class="cn__img-wrap">
								<Image src={p.photo} alt={p.name} width={340} height={420} class="cn__img" />
								<div class="cn__footer">
									<p class="cn__role">{p.role}</p>
									<h3 class="cn__name">{p.name}</h3>
								</div>
							</div>
							<p class="cn__bio">{p.bio}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- O. NEW — Two-tone split: card split horizontally, top brand, bottom light -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section dev-section--alt">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">O — Two-tone horizontal split card</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="co">
							<div class="co__top">
								<p class="co__role">{p.role}</p>
								<div class="co__circle">
									<Image src={p.photo} alt={p.name} width={120} height={120} class="co__img" />
								</div>
							</div>
							<div class="co__bottom">
								<h3 class="co__name">{p.name}</h3>
								<p class="co__bio">{p.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- P. NEW — Letterpress: embossed feel, subtle inset shadow, serif heavy -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">P — Letterpress / embossed card</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="cp">
							<div class="cp__img-wrap">
								<Image src={p.photo} alt={p.name} width={280} height={260} class="cp__img" />
							</div>
							<div class="cp__body">
								<div class="cp__header">
									<div class="cp__accent-line" aria-hidden="true"></div>
									<p class="cp__role">{p.role}</p>
								</div>
								<h3 class="cp__name">{p.name}</h3>
								<p class="cp__bio">{p.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- Q. NEW — Floating label: name huge and faint behind card -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section dev-section--alt">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">Q — Ghost name behind card</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="cq">
							<span class="cq__ghost" aria-hidden="true">{p.name.split(" ")[0]}</span>
							<div class="cq__card">
								<div class="cq__img-wrap">
									<Image src={p.photo} alt={p.name} width={260} height={260} class="cq__img" />
								</div>
								<div class="cq__body">
									<p class="cq__role">{p.role}</p>
									<h3 class="cq__name">{p.name}</h3>
									<p class="cq__bio">{p.bio}</p>
								</div>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- R. NEW — Vertical timeline: cards stacked with connecting line -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">R — Timeline stack with connector line</p>
				<div class="cr-list">
					{m.map((p) => (
						<div class="cr">
							<div class="cr__connector">
								<div class="cr__dot" aria-hidden="true"></div>
								<div class="cr__line" aria-hidden="true"></div>
							</div>
							<div class="cr__card">
								<div class="cr__img-wrap">
									<Image src={p.photo} alt={p.name} width={100} height={100} class="cr__img" />
								</div>
								<div class="cr__text">
									<p class="cr__role">{p.role}</p>
									<h3 class="cr__name">{p.name}</h3>
									<p class="cr__bio">{p.bio}</p>
								</div>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- S. NEW — Minimal name card: almost no chrome, just photo + name + dot -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section dev-section--alt">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">S — Ultra-minimal: photo, name, gold dot</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="cs">
							<div class="cs__img-wrap">
								<Image src={p.photo} alt={p.name} width={300} height={340} class="cs__img" />
							</div>
							<div class="cs__footer">
								<div class="cs__dot" aria-hidden="true"></div>
								<div class="cs__text">
									<h3 class="cs__name">{p.name}</h3>
									<p class="cs__role">{p.role}</p>
								</div>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- T. NEW — Stacked portrait, wide border, offset accent square -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">T — Offset accent square, portrait card</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="ct">
							<div class="ct__img-area">
								<div class="ct__accent-sq" aria-hidden="true"></div>
								<div class="ct__img-wrap">
									<Image src={p.photo} alt={p.name} width={280} height={320} class="ct__img" />
								</div>
							</div>
							<div class="ct__body">
								<p class="ct__role">{p.role}</p>
								<h3 class="ct__name">{p.name}</h3>
								<p class="ct__bio">{p.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

	</div>
</BaseLayout>

<style>
	/* ── Dev page shell ─────────────────────────────────────────────────────── */
	.dev-page { padding-block-start: var(--space-5xl); }

	.dev-page__header { margin-block-end: var(--space-4xl); }

	.dev-page__title {
		font-family: var(--font-serif);
		font-size: clamp(var(--font-size-3xl), 4vw, var(--font-size-5xl));
		font-weight: var(--font-weight-light);
		color: var(--color-fg-default);
		letter-spacing: var(--letter-spacing-tight);
	}

	.dev-page__sub {
		font-family: var(--font-sans); font-size: var(--font-size-sm);
		color: var(--color-fg-muted); margin-block-start: var(--space-sm);
		letter-spacing: var(--letter-spacing-wide);
	}

	.dev-section { padding-block: var(--space-5xl); }
	.dev-section--alt { background: var(--color-bg-subtle); }
	.dev-section--brand { background: var(--color-bg-brand); }

	.dev-label {
		font-family: var(--font-sans); font-size: var(--font-size-xs);
		font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-widest);
		text-transform: uppercase; color: var(--color-fg-subtle);
		margin-block-end: var(--space-3xl);
	}
	.dev-label--light { color: var(--color-fg-on-brand-subtle); }

	.grid-4 {
		display: grid; grid-template-columns: 1fr; gap: var(--space-xl);
		@media (min-width: 640px) { grid-template-columns: 1fr 1fr; }
		@media (min-width: 1024px) { grid-template-columns: repeat(4, 1fr); }
	}

	.grid-2 {
		display: grid; grid-template-columns: 1fr; gap: var(--space-xl);
		@media (min-width: 768px) { grid-template-columns: 1fr 1fr; }
	}

	.grid-2-brand {
		display: grid; grid-template-columns: 1fr; gap: var(--space-xl);
		@media (min-width: 768px) { grid-template-columns: 1fr 1fr; }
	}

	/* ══ A — 13 variant: initial behind square, brand card ══════════════════ */
	.ca {
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border-default);
		border-radius: var(--radius-lg); overflow: visible;
		box-shadow: var(--shadow-sm);
		transition: box-shadow var(--duration-normal) var(--ease-out), transform var(--duration-normal) var(--ease-out);
		&:hover { box-shadow: var(--shadow-md); transform: translateY(-4px); }
	}

	.ca__top {
		position: relative; overflow: hidden;
		border-radius: var(--radius-lg) var(--radius-lg) 0 0;
		background: var(--color-bg-brand-muted);
		display: flex; align-items: center; justify-content: center;
		padding: var(--space-xl) var(--space-xl) 0;
	}

	.ca__initial {
		position: absolute; inset-block-end: 0; inset-inline-end: var(--space-md);
		font-family: var(--font-serif); font-size: 6rem; font-weight: var(--font-weight-light);
		font-style: italic; line-height: 1;
		color: color-mix(in srgb, var(--color-fg-accent-on-brand) 25%, transparent);
		pointer-events: none; user-select: none;
	}

	.ca__img-wrap { position: relative; z-index: 1; }

	.ca__img {
		width: var(--size-32); height: var(--size-32);
		object-fit: cover; display: block;
		border-radius: var(--radius-md);
		border: 2px solid color-mix(in srgb, var(--color-fg-accent-on-brand) 40%, transparent);
	}

	.ca__body { padding: var(--space-lg); }

	.ca__role {
		font-family: var(--font-sans); font-size: var(--font-size-xs);
		letter-spacing: var(--letter-spacing-widest); text-transform: uppercase;
		color: var(--color-fg-accent); margin-block-end: var(--space-xs);
	}

	.ca__name {
		font-family: var(--font-serif); font-size: var(--font-size-xl);
		font-weight: var(--font-weight-light); color: var(--color-fg-on-surface);
		letter-spacing: var(--letter-spacing-tight); margin-block-end: var(--space-md);
	}

	.ca__bio {
		font-family: var(--font-sans); font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed); color: var(--color-fg-on-surface-muted);
	}

	/* ══ B — 11 variant: badge on image ═════════════════════════════════════ */
	.cb {
		background: var(--color-bg-surface); border-radius: var(--radius-lg);
		border: 1px solid var(--color-border-default); overflow: hidden;
		box-shadow: var(--shadow-sm);
		transition: transform var(--duration-normal) var(--ease-out);
		&:hover { transform: translateY(-4px); }
	}

	.cb__img-wrap { position: relative; aspect-ratio: 4 / 3; overflow: hidden; }

	.cb__img {
		width: 100%; height: 100%; object-fit: cover; display: block;
		transition: transform var(--duration-slow) var(--ease-smooth);
		.cb:hover & { transform: scale(1.04); }
	}

	.cb__badge {
		position: absolute; inset-block-start: var(--space-md); inset-inline-end: var(--space-md);
		font-family: var(--font-sans); font-size: var(--font-size-xs);
		font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-wide);
		text-transform: uppercase;
		color: var(--color-fg-accent-on-brand);
		background: var(--color-bg-brand);
		padding: var(--space-xs) var(--space-sm); border-radius: var(--radius-full);
	}

	.cb__body { padding: var(--space-lg); }

	.cb__name {
		font-family: var(--font-serif); font-size: var(--font-size-2xl);
		font-weight: var(--font-weight-light); color: var(--color-fg-on-surface);
		letter-spacing: var(--letter-spacing-tight); margin-block-end: var(--space-sm);
	}

	.cb__bio {
		font-family: var(--font-sans); font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed); color: var(--color-fg-on-surface-muted);
	}

	/* ══ C — 6 variant: slide-up panel ══════════════════════════════════════ */
	.cc { border-radius: var(--radius-lg); overflow: hidden; }

	.cc__img-wrap {
		position: relative; aspect-ratio: 3 / 4; overflow: hidden;
	}

	.cc__img {
		width: 100%; height: 100%; object-fit: cover; display: block;
		transition: transform var(--duration-slow) var(--ease-smooth);
		.cc:hover & { transform: scale(1.04); }
	}

	.cc__panel {
		position: absolute; inset-inline: 0; inset-block-end: 0;
		padding: var(--space-xl);
		background: color-mix(in srgb, var(--color-bg-brand) 92%, transparent);
		transform: translateY(calc(100% - var(--space-4xl)));
		transition: transform var(--duration-slow) var(--ease-smooth);
		.cc:hover & { transform: translateY(0); }
	}

	.cc__role {
		font-family: var(--font-sans); font-size: var(--font-size-xs);
		letter-spacing: var(--letter-spacing-widest); text-transform: uppercase;
		color: var(--color-fg-accent-on-brand); margin-block-end: var(--space-xs);
	}

	.cc__name {
		font-family: var(--font-serif); font-size: var(--font-size-xl);
		font-weight: var(--font-weight-light); color: var(--color-fg-on-brand);
		letter-spacing: var(--letter-spacing-tight); margin-block-end: var(--space-md);
	}

	.cc__bio {
		font-family: var(--font-sans); font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed); color: var(--color-fg-on-brand-muted);
	}

	/* ══ D — 4 variant: circle + horizontal ═════════════════════════════════ */
	.cd {
		display: flex; align-items: center; gap: var(--space-xl);
		padding: var(--space-xl); background: var(--color-bg-surface);
		border: 1px solid var(--color-border-default); border-radius: var(--radius-lg);
		box-shadow: var(--shadow-sm);
	}

	.cd__circle-wrap { position: relative; flex-shrink: 0; }

	.cd__ring {
		position: absolute; inset: calc(-1 * var(--space-xs));
		border-radius: var(--radius-full);
		border: 1px solid var(--color-border-accent);
	}

	.cd__circle {
		width: var(--size-24); height: var(--size-24);
		border-radius: var(--radius-full); overflow: hidden;
		border: 2px solid var(--color-bg-surface);
	}

	.cd__img { width: 100%; height: 100%; object-fit: cover; display: block; }

	.cd__role {
		font-family: var(--font-sans); font-size: var(--font-size-xs);
		letter-spacing: var(--letter-spacing-widest); text-transform: uppercase;
		color: var(--color-fg-accent); margin-block-end: var(--space-xs);
	}

	.cd__name {
		font-family: var(--font-serif); font-size: var(--font-size-lg);
		font-weight: var(--font-weight-light); color: var(--color-fg-on-surface);
		letter-spacing: var(--letter-spacing-tight); margin-block-end: var(--space-sm);
	}

	.cd__bio {
		font-family: var(--font-sans); font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed); color: var(--color-fg-on-surface-muted);
	}

	/* ══ E — 2 variant: dark, photo right ═══════════════════════════════════ */
	.ce {
		display: grid; grid-template-columns: 1fr;
		background: color-mix(in srgb, var(--color-bg-brand-muted) 70%, transparent);
		border: 1px solid color-mix(in srgb, var(--color-fg-on-brand) 10%, transparent);
		border-radius: var(--radius-lg); overflow: hidden;
		@media (min-width: 480px) { grid-template-columns: 1fr 160px; }
	}

	.ce__text { padding: var(--space-xl); display: flex; flex-direction: column; justify-content: center; }

	.ce__role {
		font-family: var(--font-sans); font-size: var(--font-size-xs);
		letter-spacing: var(--letter-spacing-widest); text-transform: uppercase;
		color: var(--color-fg-accent-on-brand); margin-block-end: var(--space-xs);
	}

	.ce__name {
		font-family: var(--font-serif); font-size: var(--font-size-xl);
		font-weight: var(--font-weight-light); color: var(--color-fg-on-brand);
		letter-spacing: var(--letter-spacing-tight); margin-block-end: var(--space-md);
	}

	.ce__rule {
		width: var(--size-10); height: 1px;
		background: var(--color-fg-accent-on-brand); margin-block-end: var(--space-md);
	}

	.ce__bio {
		font-family: var(--font-sans); font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed); color: var(--color-fg-on-brand-muted);
	}

	.ce__photo-col { overflow: hidden; display: none; @media (min-width: 480px) { display: block; } }

	.ce__img { width: 100%; height: 100%; object-fit: cover; display: block; }

	/* ══ F — Polaroid ════════════════════════════════════════════════════════ */
	.cf {
		background: var(--color-bg-surface);
		padding: var(--space-md) var(--space-md) var(--space-xl);
		box-shadow: var(--shadow-md); border-radius: var(--radius-sm);
		display: flex; flex-direction: column; align-items: center;
		transform-origin: center bottom;
		transition: transform var(--duration-slow) var(--ease-smooth);
		&:hover { transform: rotate(0deg) scale(1.03) !important; }
	}

	.cf--tilt-1 { transform: rotate(-1.5deg); }
	.cf--tilt-2 { transform: rotate(1deg); }
	.cf--tilt-3 { transform: rotate(-0.8deg); }

	.cf__frame { width: 100%; overflow: hidden; margin-block-end: var(--space-md); }

	.cf__img { width: 100%; aspect-ratio: 1 / 1; object-fit: cover; display: block; }

	.cf__name {
		font-family: var(--font-serif); font-size: var(--font-size-lg);
		font-weight: var(--font-weight-light); color: var(--color-fg-on-surface);
		letter-spacing: var(--letter-spacing-tight); text-align: center;
	}

	.cf__role {
		font-family: var(--font-sans); font-size: var(--font-size-xs);
		letter-spacing: var(--letter-spacing-wider); text-transform: uppercase;
		color: var(--color-fg-accent); text-align: center; margin-block-start: var(--space-xs);
	}

	/* ══ G — Expandable ══════════════════════════════════════════════════════ */
	.cg {
		background: var(--color-bg-surface); border: 1px solid var(--color-border-default);
		border-radius: var(--radius-lg); padding: var(--space-lg);
		box-shadow: var(--shadow-sm);
		transition: box-shadow var(--duration-normal) var(--ease-out);
		&:hover { box-shadow: var(--shadow-md); }
	}

	.cg__top { display: flex; align-items: center; gap: var(--space-lg); margin-block-end: var(--space-lg); }

	.cg__circle {
		width: var(--size-16); height: var(--size-16);
		border-radius: var(--radius-full); overflow: hidden; flex-shrink: 0;
		border: 1px solid var(--color-border-accent);
	}

	.cg__img { width: 100%; height: 100%; object-fit: cover; display: block; }

	.cg__name {
		font-family: var(--font-serif); font-size: var(--font-size-lg);
		font-weight: var(--font-weight-light); color: var(--color-fg-on-surface);
		letter-spacing: var(--letter-spacing-tight);
	}

	.cg__role {
		font-family: var(--font-sans); font-size: var(--font-size-xs);
		letter-spacing: var(--letter-spacing-widest); text-transform: uppercase;
		color: var(--color-fg-accent); margin-block-start: var(--space-xs);
	}

	.cg__bio-wrap {
		border-block-start: 1px solid var(--color-border-default);
		padding-block-start: var(--space-lg);
	}

	.cg__bio {
		font-family: var(--font-sans); font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed); color: var(--color-fg-on-surface-muted);
	}

	/* ══ H — Diagonal split ══════════════════════════════════════════════════ */
	.ch {
		display: grid; grid-template-columns: 1fr;
		border-radius: var(--radius-lg); overflow: hidden;
		box-shadow: var(--shadow-md); background: var(--color-bg-surface);
		@media (min-width: 640px) { grid-template-columns: 220px 1fr; }
	}

	.ch__img-col {
		clip-path: polygon(0 0, 100% 0, 88% 100%, 0 100%);
		overflow: hidden; position: relative; z-index: 1;
	}

	.ch__img { width: 100%; height: 100%; object-fit: cover; display: block; min-height: var(--size-48); }

	.ch__text-col {
		padding: var(--space-xl) var(--space-xl) var(--space-xl) var(--space-lg);
		display: flex; flex-direction: column; justify-content: center;
		position: relative;
	}

	.ch__accent {
		position: absolute; inset-block: 0; inset-inline-start: 0;
		width: 3px; background: var(--color-fg-accent);
	}

	.ch__role {
		font-family: var(--font-sans); font-size: var(--font-size-xs);
		letter-spacing: var(--letter-spacing-widest); text-transform: uppercase;
		color: var(--color-fg-accent); margin-block-end: var(--space-xs);
	}

	.ch__name {
		font-family: var(--font-serif); font-size: var(--font-size-xl);
		font-weight: var(--font-weight-light); color: var(--color-fg-on-surface);
		letter-spacing: var(--letter-spacing-tight); margin-block-end: var(--space-md);
	}

	.ch__bio {
		font-family: var(--font-sans); font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed); color: var(--color-fg-on-surface-muted);
	}

	/* ══ I — Credential stamp ════════════════════════════════════════════════ */
	.ci {
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border-accent);
		border-radius: var(--radius-lg); overflow: hidden;
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-fg-accent) 8%, transparent);
	}

	.ci__header {
		display: flex; align-items: center; gap: var(--space-md);
		padding: var(--space-lg); background: var(--color-bg-brand-muted);
	}

	.ci__monogram {
		width: var(--size-12); height: var(--size-12);
		border-radius: var(--radius-full); flex-shrink: 0;
		background: var(--color-fg-accent);
		display: flex; align-items: center; justify-content: center;
		font-family: var(--font-serif); font-size: var(--font-size-xl);
		font-weight: var(--font-weight-light); font-style: italic;
		color: var(--color-bg-brand);
	}

	.ci__name {
		font-family: var(--font-serif); font-size: var(--font-size-lg);
		font-weight: var(--font-weight-light); color: var(--color-fg-on-brand);
		letter-spacing: var(--letter-spacing-tight);
	}

	.ci__role {
		font-family: var(--font-sans); font-size: var(--font-size-xs);
		letter-spacing: var(--letter-spacing-widest); text-transform: uppercase;
		color: var(--color-fg-accent-on-brand);
	}

	.ci__img-wrap { aspect-ratio: 4 / 3; overflow: hidden; }

	.ci__img { width: 100%; height: 100%; object-fit: cover; display: block; }

	.ci__bio {
		padding: var(--space-lg);
		font-family: var(--font-sans); font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed); color: var(--color-fg-on-surface-muted);
	}

	/* ══ J — Swiss editorial ═════════════════════════════════════════════════ */
	.cj-grid {
		display: grid; grid-template-columns: 1fr; gap: 0;
		border-block-start: 2px solid var(--color-fg-default);
	}

	.cj {
		display: grid; grid-template-columns: var(--size-16) 1fr;
		gap: var(--space-xl); align-items: start;
		padding-block: var(--space-2xl);
		border-block-end: 1px solid var(--color-border-default);

		@media (min-width: 768px) { grid-template-columns: var(--size-16) 200px 1fr; }
	}

	.cj__number {
		font-family: var(--font-sans); font-size: var(--font-size-xs);
		font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-widest);
		color: var(--color-fg-subtle); padding-block-start: var(--space-xs);
	}

	.cj__img-wrap { overflow: hidden; border-radius: var(--radius-sm); display: none; @media (min-width: 768px) { display: block; } }

	.cj__img { width: 100%; aspect-ratio: 3 / 4; object-fit: cover; display: block; }

	.cj__name {
		font-family: var(--font-serif); font-size: var(--font-size-2xl);
		font-weight: var(--font-weight-light); color: var(--color-fg-default);
		letter-spacing: var(--letter-spacing-tight); margin-block-end: var(--space-xs);
	}

	.cj__role {
		font-family: var(--font-sans); font-size: var(--font-size-xs);
		letter-spacing: var(--letter-spacing-widest); text-transform: uppercase;
		color: var(--color-fg-accent); margin-block-end: var(--space-md);
	}

	.cj__bio {
		font-family: var(--font-sans); font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed); color: var(--color-fg-muted);
	}

	/* ══ K — Glass circle inset ══════════════════════════════════════════════ */
	.ck {
		display: grid; grid-template-columns: 1fr auto;
		gap: var(--space-xl); align-items: start;
		padding: var(--space-xl);
		background: var(--color-bg-surface); border: 1px solid var(--color-border-default);
		border-radius: var(--radius-lg); box-shadow: var(--shadow-sm);
	}

	.ck__role {
		font-family: var(--font-sans); font-size: var(--font-size-xs);
		letter-spacing: var(--letter-spacing-widest); text-transform: uppercase;
		color: var(--color-fg-accent); margin-block-end: var(--space-xs);
	}

	.ck__name {
		font-family: var(--font-serif); font-size: var(--font-size-xl);
		font-weight: var(--font-weight-light); color: var(--color-fg-on-surface);
		letter-spacing: var(--letter-spacing-tight); margin-block-end: var(--space-md);
	}

	.ck__rule {
		width: var(--size-10); height: 1px;
		background: var(--color-fg-accent); margin-block-end: var(--space-md);
	}

	.ck__bio {
		font-family: var(--font-sans); font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed); color: var(--color-fg-on-surface-muted);
	}

	.ck__circle {
		width: var(--size-24); height: var(--size-24);
		border-radius: var(--radius-full); overflow: hidden; flex-shrink: 0;
		border: 2px solid var(--color-border-accent);
	}

	.ck__img { width: 100%; height: 100%; object-fit: cover; display: block; }

	/* ══ L — Seal card ═══════════════════════════════════════════════════════ */
	.cl { text-align: center; }

	.cl__seal-wrap {
		position: relative; width: var(--size-40); height: var(--size-40);
		margin-inline: auto; margin-block-end: var(--space-lg);
		display: flex; align-items: center; justify-content: center;
	}

	.cl__outer-ring {
		position: absolute; inset: 0; border-radius: var(--radius-full);
		border: 1px dashed var(--color-border-accent);
	}

	.cl__ring-text {
		/* decorative only — hidden visually but keeps layout */
		display: none;
	}

	.cl__circle {
		width: var(--size-32); height: var(--size-32);
		border-radius: var(--radius-full); overflow: hidden;
		border: 2px solid var(--color-border-accent);
	}

	.cl__img { width: 100%; height: 100%; object-fit: cover; display: block; }

	.cl__name {
		font-family: var(--font-serif); font-size: var(--font-size-xl);
		font-weight: var(--font-weight-light); color: var(--color-fg-default);
		letter-spacing: var(--letter-spacing-tight);
	}

	.cl__role {
		font-family: var(--font-sans); font-size: var(--font-size-xs);
		letter-spacing: var(--letter-spacing-widest); text-transform: uppercase;
		color: var(--color-fg-accent); margin-block: var(--space-xs) var(--space-md);
	}

	.cl__bio {
		font-family: var(--font-sans); font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed); color: var(--color-fg-muted);
	}

	/* ══ M — Newspaper column ════════════════════════════════════════════════ */
	.cm {
		background: var(--color-bg-surface); border-radius: var(--radius-lg);
		overflow: hidden; border: 1px solid var(--color-border-default);
	}

	.cm__img-wrap { overflow: hidden; }

	.cm__img { width: 100%; aspect-ratio: 4 / 3; object-fit: cover; display: block; }

	.cm__body { padding: var(--space-lg); }

	.cm__eyebrow {
		display: flex; align-items: center; gap: var(--space-md);
		margin-block-end: var(--space-md);
	}

	.cm__rule-left, .cm__rule-right {
		flex: 1; height: 1px; background: var(--color-border-default);
	}

	.cm__role {
		font-family: var(--font-sans); font-size: var(--font-size-xs);
		letter-spacing: var(--letter-spacing-widest); text-transform: uppercase;
		color: var(--color-fg-accent); white-space: nowrap;
	}

	.cm__name {
		font-family: var(--font-serif); font-size: var(--font-size-xl);
		font-weight: var(--font-weight-light); color: var(--color-fg-on-surface);
		letter-spacing: var(--letter-spacing-tight); margin-block-end: var(--space-md);
		text-align: center;
	}

	.cm__bio {
		font-family: var(--font-sans); font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed); color: var(--color-fg-on-surface-muted);
	}

	/* ══ N — Profile card ════════════════════════════════════════════════════ */
	.cn { }

	.cn__img-wrap {
		position: relative; border-radius: var(--radius-lg); overflow: hidden;
		margin-block-end: var(--space-md);
