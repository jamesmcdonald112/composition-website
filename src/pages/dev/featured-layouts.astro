---
import { Image } from "astro:assets";
import { homePageContent } from "../../config/home";
import { buyingAndSellingProperty as svc } from "../../config/services";
import BaseLayout from "../../layouts/BaseLayout.astro";

const { featuredService } = homePageContent;
const { card, aside } = featuredService;
---

<BaseLayout title="Featured Layouts" description="Dev — 20 featured section layout explorations" canonicalPath="/dev/featured-layouts">

<div class="page">
	<div class="page-intro">
		<p>20 layout variations for the Featured Service section. All responsive, no empty space.</p>
	</div>

	<!-- ═══════════════════════════════════════════════════════════════════════
	     V1 — Card top-right, text fills left, kps 4-col below (classic A5)
	     ══════════════════════════════════════════════════════════════════════ -->
	<div class="lbl">1 · Classic: text left / card right / kps 4-col below</div>
	<section class="v v1">
		<div class="wrapper wrapper--wide v1__inner">
			<div class="v1__top">
				<div class="v1__text">
					<p class="ey">{featuredService.eyebrow}</p>
					<div class="ru"></div>
					<h2 class="hd">{card.title}</h2>
					<p class="bd">{aside.intro}</p>
					<a href={svc.href} class="ct ct--ol">Our property service →</a>
				</div>
				<div class="v1__card">
					<div class="fc">
						<div class="fc__img-wrap"><Image src={card.image} alt="" width={600} height={300} class="fc__img" /></div>
						<div class="fc__body">
							<p class="fc__tag">{card.tag}</p>
							<h3 class="fc__title">{card.title}</h3>
							<p class="fc__desc">{card.body}</p>
							<a href={card.cta.href} class="ct ct--fill">{card.cta.label}</a>
						</div>
					</div>
				</div>
			</div>
			<div class="kps kps--4col">
				{aside.keyPoints.map(kp => <div class="kp"><p class="kp__h">{kp.heading}</p><p class="kp__b">{kp.body}</p></div>)}
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════════════════════════════════
	     V2 — Card left, text right (reversed)
	     ══════════════════════════════════════════════════════════════════════ -->
	<div class="lbl">2 · Reversed: card left / text right / kps below</div>
	<section class="v v2">
		<div class="wrapper wrapper--wide v2__inner">
			<div class="v2__top">
				<div class="v2__card">
					<div class="fc">
						<div class="fc__img-wrap"><Image src={card.image} alt="" width={600} height={300} class="fc__img" /></div>
						<div class="fc__body">
							<p class="fc__tag">{card.tag}</p>
							<h3 class="fc__title">{card.title}</h3>
							<p class="fc__desc">{card.body}</p>
							<a href={card.cta.href} class="ct ct--fill">{card.cta.label}</a>
						</div>
					</div>
				</div>
				<div class="v2__text">
					<p class="ey">{featuredService.eyebrow}</p>
					<div class="ru"></div>
					<h2 class="hd">{card.title}</h2>
					<p class="bd">{aside.intro}</p>
					<a href={svc.href} class="ct ct--ol">Our property service →</a>
				</div>
			</div>
			<div class="kps kps--4col">
				{aside.keyPoints.map(kp => <div class="kp"><p class="kp__h">{kp.heading}</p><p class="kp__b">{kp.body}</p></div>)}
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════════════════════════════════
	     V3 — Stacked: eyebrow full-width top, then card+kps side by side
	     ══════════════════════════════════════════════════════════════════════ -->
	<div class="lbl">3 · Eyebrow full-width / card + kps side by side</div>
	<section class="v v3">
		<div class="wrapper wrapper--wide v3__inner">
			<div class="v3__head">
				<p class="ey ey--xl">{featuredService.eyebrow}</p>
				<div class="ru"></div>
				<h2 class="hd hd--lg">{card.title}</h2>
			</div>
			<div class="v3__body">
				<div class="v3__card">
					<div class="fc">
						<div class="fc__img-wrap"><Image src={card.image} alt="" width={600} height={300} class="fc__img" /></div>
						<div class="fc__body">
							<p class="fc__tag">{card.tag}</p>
							<h3 class="fc__title">{card.title}</h3>
							<p class="fc__desc">{card.body}</p>
							<a href={card.cta.href} class="ct ct--fill">{card.cta.label}</a>
						</div>
					</div>
				</div>
				<div class="v3__aside">
					<p class="bd">{aside.intro}</p>
					<div class="kps kps--2col kps--no-border">
						{aside.keyPoints.map(kp => <div class="kp"><p class="kp__h">{kp.heading}</p><p class="kp__b">{kp.body}</p></div>)}
					</div>
					<a href={svc.href} class="ct ct--ol">Our property service →</a>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════════════════════════════════
	     V4 — Card centre, text above, kps below (centred editorial)
	     ══════════════════════════════════════════════════════════════════════ -->
	<div class="lbl">4 · Text above / card centred / kps below</div>
	<section class="v v4">
		<div class="wrapper v4__inner">
			<div class="v4__head">
				<p class="ey">{featuredService.eyebrow}</p>
				<div class="ru"></div>
				<h2 class="hd">{card.title}</h2>
				<p class="bd">{aside.intro}</p>
			</div>
			<div class="v4__card">
				<div class="fc fc--horiz">
					<div class="fc__img-wrap fc__img-wrap--horiz"><Image src={card.image} alt="" width={600} height={400} class="fc__img" /></div>
					<div class="fc__body">
						<p class="fc__tag">{card.tag}</p>
						<h3 class="fc__title">{card.title}</h3>
						<p class="fc__desc">{card.body}</p>
						<a href={card.cta.href} class="ct ct--fill">{card.cta.label}</a>
					</div>
				</div>
			</div>
			<div class="kps kps--4col">
				{aside.keyPoints.map(kp => <div class="kp"><p class="kp__h">{kp.heading}</p><p class="kp__b">{kp.body}</p></div>)}
			</div>
			<a href={svc.href} class="ct ct--ol v4__cta">Our property service →</a>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════════════════════════════════
	     V5 — Three column: kps left / card centre / text right
	     ══════════════════════════════════════════════════════════════════════ -->
	<div class="lbl">5 · Three cols: kps / card / text</div>
	<section class="v v5">
		<div class="wrapper wrapper--wide v5__inner">
			<div class="v5__kps">
				{aside.keyPoints.map(kp => <div class="kp kp--bordered"><p class="kp__h">{kp.heading}</p><p class="kp__b">{kp.body}</p></div>)}
			</div>
			<div class="v5__card">
				<div class="fc">
					<div class="fc__img-wrap"><Image src={card.image} alt="" width={600} height={300} class="fc__img" /></div>
					<div class="fc__body">
						<p class="fc__tag">{card.tag}</p>
						<h3 class="fc__title">{card.title}</h3>
						<p class="fc__desc">{card.body}</p>
						<a href={card.cta.href} class="ct ct--fill">{card.cta.label}</a>
					</div>
				</div>
			</div>
			<div class="v5__text">
				<p class="ey">{featuredService.eyebrow}</p>
				<div class="ru"></div>
				<h2 class="hd">{card.title}</h2>
				<p class="bd">{aside.intro}</p>
				<a href={svc.href} class="ct ct--ol">Our property service →</a>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════════════════════════════════
	     V6 — Full-bleed image banner + text overlay left + kps row
	     ══════════════════════════════════════════════════════════════════════ -->
	<div class="lbl">6 · Full-bleed image / text overlay / kps row below</div>
	<section class="v v6">
		<div class="v6__banner">
			<Image src={card.image} alt="" width={1440} height={560} class="v6__bg" />
			<div class="v6__overlay" aria-hidden="true"></div>
			<div class="wrapper wrapper--wide v6__content">
				<p class="ey">{featuredService.eyebrow}</p>
				<div class="ru"></div>
				<h2 class="hd hd--lg">{card.title}</h2>
				<p class="bd">{aside.intro}</p>
				<a href={svc.href} class="ct ct--ol">Our property service →</a>
			</div>
		</div>
		<div class="wrapper wrapper--wide">
			<div class="kps kps--4col kps--no-border kps--gap-top">
				{aside.keyPoints.map(kp => <div class="kp"><p class="kp__h">{kp.heading}</p><p class="kp__b">{kp.body}</p></div>)}
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════════════════════════════════
	     V7 — Eyebrow huge left / card fills right / kps inside left below CTA
	     ══════════════════════════════════════════════════════════════════════ -->
	<div class="lbl">7 · Huge eyebrow left / card right / kps inside left col</div>
	<section class="v v7">
		<div class="wrapper wrapper--wide v7__inner">
			<div class="v7__left">
				<p class="ey ey--display">{featuredService.eyebrow}</p>
				<div class="ru"></div>
				<h2 class="hd">{card.title}</h2>
				<p class="bd">{aside.intro}</p>
				<div class="kps kps--2col kps--no-border kps--gap-top">
					{aside.keyPoints.map(kp => <div class="kp"><p class="kp__h">{kp.heading}</p><p class="kp__b">{kp.body}</p></div>)}
				</div>
				<a href={svc.href} class="ct ct--ol">Our property service →</a>
			</div>
			<div class="v7__card">
				<div class="fc fc--tall">
					<div class="fc__img-wrap fc__img-wrap--tall"><Image src={card.image} alt="" width={600} height={500} class="fc__img" /></div>
					<div class="fc__body">
						<p class="fc__tag">{card.tag}</p>
						<h3 class="fc__title">{card.title}</h3>
						<p class="fc__desc">{card.body}</p>
						<a href={card.cta.href} class="ct ct--fill">{card.cta.label}</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════════════════════════════════
	     V8 — Horizontal card (image left / text right) + kps below
	     ══════════════════════════════════════════════════════════════════════ -->
	<div class="lbl">8 · Horizontal card / eyebrow above / kps 4-col below</div>
	<section class="v v8">
		<div class="wrapper wrapper--wide v8__inner">
			<div class="v8__head">
				<p class="ey">{featuredService.eyebrow}</p>
				<div class="ru"></div>
			</div>
			<div class="v8__card">
				<div class="fc fc--horiz">
					<div class="fc__img-wrap fc__img-wrap--horiz"><Image src={card.image} alt="" width={600} height={400} class="fc__img" /></div>
					<div class="fc__body">
						<h2 class="hd hd--card">{card.title}</h2>
						<p class="fc__desc">{card.body}</p>
						<p class="bd bd--sm">{aside.intro}</p>
						<a href={card.cta.href} class="ct ct--fill">{card.cta.label}</a>
					</div>
				</div>
			</div>
			<div class="kps kps--4col">
				{aside.keyPoints.map(kp => <div class="kp"><p class="kp__h">{kp.heading}</p><p class="kp__b">{kp.body}</p></div>)}
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════════════════════════════════
	     V9 — Two column: kps 2-col left / card+text stacked right
	     ══════════════════════════════════════════════════════════════════════ -->
	<div class="lbl">9 · kps stack left / card+text right</div>
	<section class="v v9">
		<div class="wrapper wrapper--wide v9__inner">
			<div class="v9__left">
				<p class="ey">{featuredService.eyebrow}</p>
				<div class="ru"></div>
				<h2 class="hd">{card.title}</h2>
				<div class="kps kps--2col kps--no-border kps--gap-top">
					{aside.keyPoints.map(kp => <div class="kp"><p class="kp__h">{kp.heading}</p><p class="kp__b">{kp.body}</p></div>)}
				</div>
				<a href={svc.href} class="ct ct--ol">Our property service →</a>
			</div>
			<div class="v9__right">
				<div class="fc">
					<div class="fc__img-wrap"><Image src={card.image} alt="" width={600} height={300} class="fc__img" /></div>
					<div class="fc__body">
						<p class="fc__tag">{card.tag}</p>
						<h3 class="fc__title">{card.title}</h3>
						<p class="fc__desc">{card.body}</p>
						<a href={card.cta.href} class="ct ct--fill">{card.cta.label}</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════════════════════════════════
	     V10 — Card top full-width / text + kps 2-col below
	     ══════════════════════════════════════════════════════════════════════ -->
	<div class="lbl">10 · Card full-width top / text + kps 2-col below</div>
	<section class="v v10">
		<div class="wrapper wrapper--wide v10__inner">
			<div class="fc fc--horiz">
				<div class="fc__img-wrap fc__img-wrap--horiz"><Image src={card.image} alt="" width={600} height={400} class="fc__img" /></div>
				<div class="fc__body">
					<p class="fc__tag">{card.tag}</p>
					<h3 class="fc__title">{card.title}</h3>
					<p class="fc__desc">{card.body}</p>
					<a href={card.cta.href} class="ct ct--fill">{card.cta.label}</a>
				</div>
			</div>
			<div class="v10__below">
				<div class="v10__text">
					<p class="ey">{featuredService.eyebrow}</p>
					<div class="ru"></div>
					<h2 class="hd">{card.title}</h2>
					<p class="bd">{aside.intro}</p>
					<a href={svc.href} class="ct ct--ol">Our property service →</a>
				</div>
				<div class="kps kps--2col kps--no-border">
					{aside.keyPoints.map(kp => <div class="kp"><p class="kp__h">{kp.heading}</p><p class="kp__b">{kp.body}</p></div>)}
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════════════════════════════════
	     V11 — Eyebrow as giant watermark / card + kps in foreground
	     ══════════════════════════════════════════════════════════════════════ -->
	<div class="lbl">11 · Giant eyebrow watermark / card + kps foreground</div>
	<section class="v v11">
		<div class="wrapper wrapper--wide v11__inner">
			<p class="v11__watermark" aria-hidden="true">{featuredService.eyebrow}</p>
			<div class="v11__content">
				<div class="v11__top">
					<div class="v11__text">
						<div class="ru"></div>
						<h2 class="hd">{card.title}</h2>
						<p class="bd">{aside.intro}</p>
						<a href={svc.href} class="ct ct--ol">Our property service →</a>
					</div>
					<div class="v11__card">
						<div class="fc">
							<div class="fc__img-wrap"><Image src={card.image} alt="" width={600} height={300} class="fc__img" /></div>
							<div class="fc__body">
								<p class="fc__tag">{card.tag}</p>
								<h3 class="fc__title">{card.title}</h3>
								<p class="fc__desc">{card.body}</p>
								<a href={card.cta.href} class="ct ct--fill">{card.cta.label}</a>
							</div>
						</div>
					</div>
				</div>
				<div class="kps kps--4col">
					{aside.keyPoints.map(kp => <div class="kp"><p class="kp__h">{kp.heading}</p><p class="kp__b">{kp.body}</p></div>)}
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════════════════════════════════
	     V12 — Tight: no card image, icon-led card, kps inline left
	     ══════════════════════════════════════════════════════════════════════ -->
	<div class="lbl">12 · No image card / kps stacked left / wider text</div>
	<section class="v v12">
		<div class="wrapper wrapper--wide v12__inner">
			<div class="v12__left">
				<p class="ey">{featuredService.eyebrow}</p>
				<div class="ru"></div>
				<h2 class="hd">{card.title}</h2>
				<p class="bd">{aside.intro}</p>
				<div class="kps kps--2col kps--no-border kps--gap-top">
					{aside.keyPoints.map(kp => <div class="kp"><p class="kp__h">{kp.heading}</p><p class="kp__b">{kp.body}</p></div>)}
				</div>
				<a href={svc.href} class="ct ct--ol">Our property service →</a>
			</div>
			<div class="v12__card">
				<div class="fc fc--no-img">
					<div class="fc__body fc__body--padded">
						<p class="fc__tag">{card.tag}</p>
						<h3 class="fc__title">{card.title}</h3>
						<p class="fc__desc">{card.body}</p>
						<a href={card.cta.href} class="ct ct--fill">{card.cta.label}</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════════════════════════════════
	     V13 — Diagonal split: amber stripe accent / text left / card right
	     ══════════════════════════════════════════════════════════════════════ -->
	<div class="lbl">13 · Amber stripe accent / text + card</div>
	<section class="v v13">
		<div class="v13__stripe" aria-hidden="true"></div>
		<div class="wrapper wrapper--wide v13__inner">
			<div class="v13__text">
				<p class="ey">{featuredService.eyebrow}</p>
				<div class="ru"></div>
				<h2 class="hd">{card.title}</h2>
				<p class="bd">{aside.intro}</p>
				<div class="kps kps--2col kps--no-border kps--gap-top">
					{aside.keyPoints.map(kp => <div class="kp"><p class="kp__h">{kp.heading}</p><p class="kp__b">{kp.body}</p></div>)}
				</div>
				<a href={svc.href} class="ct ct--ol">Our property service →</a>
			</div>
			<div class="v13__card">
				<div class="fc">
					<div class="fc__img-wrap"><Image src={card.image} alt="" width={600} height={300} class="fc__img" /></div>
					<div class="fc__body">
						<p class="fc__tag">{card.tag}</p>
						<h3 class="fc__title">{card.title}</h3>
						<p class="fc__desc">{card.body}</p>
						<a href={card.cta.href} class="ct ct--fill">{card.cta.label}</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════════════════════════════════
	     V14 — Numbered kps as prominent left column / card right
	     ══════════════════════════════════════════════════════════════════════ -->
	<div class="lbl">14 · Numbered key points left / card right</div>
	<section class="v v14">
		<div class="wrapper wrapper--wide v14__inner">
			<div class="v14__left">
				<p class="ey">{featuredService.eyebrow}</p>
				<div class="ru"></div>
				<h2 class="hd">{card.title}</h2>
				<div class="v14__nums">
					{aside.keyPoints.map((kp, i) => (
						<div class="v14__item">
							<span class="v14__num">0{i+1}</span>
							<div>
								<p class="kp__h">{kp.heading}</p>
								<p class="kp__b">{kp.body}</p>
							</div>
						</div>
					))}
				</div>
				<a href={svc.href} class="ct ct--ol">Our property service →</a>
			</div>
			<div class="v14__card">
				<div class="fc">
					<div class="fc__img-wrap"><Image src={card.image} alt="" width={600} height={300} class="fc__img" /></div>
					<div class="fc__body">
						<p class="fc__tag">{card.tag}</p>
						<h3 class="fc__title">{card.title}</h3>
						<p class="fc__desc">{card.body}</p>
						<a href={card.cta.href} class="ct ct--fill">{card.cta.label}</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════════════════════════════════
	     V15 — Card bleeds to edge / text+kps constrained right
	     ══════════════════════════════════════════════════════════════════════ -->
	<div class="lbl">15 · Card bleeds left edge / text+kps right</div>
	<section class="v v15">
		<div class="v15__inner">
			<div class="v15__card">
				<div class="fc fc--tall fc--no-radius">
					<div class="fc__img-wrap fc__img-wrap--tall"><Image src={card.image} alt="" width={600} height={600} class="fc__img" /></div>
					<div class="fc__body">
						<p class="fc__tag">{card.tag}</p>
						<h3 class="fc__title">{card.title}</h3>
						<p class="fc__desc">{card.body}</p>
						<a href={card.cta.href} class="ct ct--fill">{card.cta.label}</a>
					</div>
				</div>
			</div>
			<div class="v15__text">
				<p class="ey">{featuredService.eyebrow}</p>
				<div class="ru"></div>
				<h2 class="hd">{card.title}</h2>
				<p class="bd">{aside.intro}</p>
				<div class="kps kps--1col kps--no-border kps--gap-top">
					{aside.keyPoints.map(kp => <div class="kp"><p class="kp__h">{kp.heading}</p><p class="kp__b">{kp.body}</p></div>)}
				</div>
				<a href={svc.href} class="ct ct--ol">Our property service →</a>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════════════════════════════════
	     V16 — Split background: left navy / right lighter / card bridges
	     ══════════════════════════════════════════════════════════════════════ -->
	<div class="lbl">16 · Split bg / card bridges centre</div>
	<section class="v v16">
		<div class="v16__bg" aria-hidden="true"></div>
		<div class="wrapper wrapper--wide v16__inner">
