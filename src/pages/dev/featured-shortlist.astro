---
import { Image } from "astro:assets";
import { homePageContent } from "../../config/home";
import { buyingAndSellingProperty as svc } from "../../config/services";
import BaseLayout from "../../layouts/BaseLayout.astro";

const { featuredService } = homePageContent;
const { card, aside } = featuredService;
---

<BaseLayout title="Featured Shortlist" description="Dev — layouts 5, 9, 13, 18" canonicalPath="/dev/featured-shortlist">

<div class="page">

	<!-- ═══════════════════════════════════════════════════════════════════════
	     V5 — Three column: kps left / card centre / text right
	     ══════════════════════════════════════════════════════════════════════ -->
	<div class="lbl">5 · Three cols: kps / card / text</div>
	<section class="v v5">
		<div class="wrapper wrapper--wide v5__inner">
			<div class="v5__kps">
				{aside.keyPoints.map(kp => (
					<div class="kp kp--bordered">
						<p class="kp__h">{kp.heading}</p>
						<p class="kp__b">{kp.body}</p>
					</div>
				))}
			</div>
			<div class="v5__card">
				<div class="fc">
					<div class="fc__img-wrap">
						<Image src={card.image} alt="" width={600} height={300} class="fc__img" />
					</div>
					<div class="fc__body">
						<p class="fc__tag">{card.tag}</p>
						<h3 class="fc__title">{card.title}</h3>
						<p class="fc__desc">{card.body}</p>
						<a href={card.cta.href} class="ct ct--fill">{card.cta.label}</a>
					</div>
				</div>
			</div>
			<div class="v5__text">
				<p class="ey">{featuredService.eyebrow}</p>
				<div class="ru"></div>
				<h2 class="hd">{card.title}</h2>
				<p class="bd">{aside.intro}</p>
				<a href={svc.href} class="ct ct--ol">Our property service →</a>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════════════════════════════════
	     V9 — kps left / card right
	     ══════════════════════════════════════════════════════════════════════ -->
	<div class="lbl">9 · kps + text left / card right</div>
	<section class="v v9">
		<div class="wrapper wrapper--wide v9__inner">
			<div class="v9__left">
				<p class="ey">{featuredService.eyebrow}</p>
				<div class="ru"></div>
				<h2 class="hd">{card.title}</h2>
				<p class="bd">{aside.intro}</p>
				<div class="kps kps--2col kps--no-border kps--gap-top">
					{aside.keyPoints.map(kp => (
						<div class="kp">
							<p class="kp__h">{kp.heading}</p>
							<p class="kp__b">{kp.body}</p>
						</div>
					))}
				</div>
				<a href={svc.href} class="ct ct--ol">Our property service →</a>
			</div>
			<div class="v9__card">
				<div class="fc">
					<div class="fc__img-wrap">
						<Image src={card.image} alt="" width={600} height={300} class="fc__img" />
					</div>
					<div class="fc__body">
						<p class="fc__tag">{card.tag}</p>
						<h3 class="fc__title">{card.title}</h3>
						<p class="fc__desc">{card.body}</p>
						<a href={card.cta.href} class="ct ct--fill">{card.cta.label}</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════════════════════════════════
	     V13 — Amber stripe accent / text + kps left / card right
	     ══════════════════════════════════════════════════════════════════════ -->
	<div class="lbl">13 · Amber left stripe / text + kps / card</div>
	<section class="v v13">
		<div class="v13__stripe" aria-hidden="true"></div>
		<div class="wrapper wrapper--wide v13__inner">
			<div class="v13__text">
				<p class="ey">{featuredService.eyebrow}</p>
				<div class="ru"></div>
				<h2 class="hd">{card.title}</h2>
				<p class="bd">{aside.intro}</p>
				<div class="kps kps--2col kps--no-border kps--gap-top">
					{aside.keyPoints.map(kp => (
						<div class="kp">
							<p class="kp__h">{kp.heading}</p>
							<p class="kp__b">{kp.body}</p>
						</div>
					))}
				</div>
				<a href={svc.href} class="ct ct--ol">Our property service →</a>
			</div>
			<div class="v13__card">
				<div class="fc">
					<div class="fc__img-wrap">
						<Image src={card.image} alt="" width={600} height={300} class="fc__img" />
					</div>
					<div class="fc__body">
						<p class="fc__tag">{card.tag}</p>
						<h3 class="fc__title">{card.title}</h3>
						<p class="fc__desc">{card.body}</p>
						<a href={card.cta.href} class="ct ct--fill">{card.cta.label}</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════════════════════════════════════════════
	     V18 — Full text stack left / card right fills height
	     ══════════════════════════════════════════════════════════════════════ -->
	<div class="lbl">18 · Full text + kps left / card right fills height</div>
	<section class="v v18">
		<div class="wrapper wrapper--wide v18__inner">
			<div class="v18__text">
				<p class="ey ey--xl">{featuredService.eyebrow}</p>
				<div class="ru"></div>
				<h2 class="hd">{card.title}</h2>
				<p class="bd">{aside.intro}</p>
				<div class="kps kps--2col kps--no-border kps--gap-top">
					{aside.keyPoints.map(kp => (
						<div class="kp">
							<p class="kp__h">{kp.heading}</p>
							<p class="kp__b">{kp.body}</p>
						</div>
					))}
				</div>
				<a href={svc.href} class="ct ct--ol">Our property service →</a>
			</div>
			<div class="v18__card">
				<div class="fc fc--full-h">
					<div class="fc__img-wrap fc__img-wrap--tall">
						<Image src={card.image} alt="" width={600} height={500} class="fc__img" />
					</div>
					<div class="fc__body">
						<p class="fc__tag">{card.tag}</p>
						<h3 class="fc__title">{card.title}</h3>
						<p class="fc__desc">{card.body}</p>
						<a href={card.cta.href} class="ct ct--fill">{card.cta.label}</a>
					</div>
				</div>
			</div>
		</div>
	</section>

</div>
</BaseLayout>

<style>
/* ── Page chrome ───────────────────────────────────────────────────────────── */
.page { background: var(--color-bg-subtle); }

.lbl {
	font-family: var(--font-sans);
	font-size: var(--font-size-xs);
	letter-spacing: var(--letter-spacing-wider);
	text-transform: uppercase;
	color: var(--color-fg-subtle);
	text-align: center;
	padding-block: var(--space-lg);
	background: var(--color-bg-subtle);
}

.v { background: var(--color-bg-brand-muted); }

/* ── Typography atoms ──────────────────────────────────────────────────────── */
.ey {
	font-family: var(--font-sans);
	font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-4xl));
	font-weight: var(--font-weight-light);
	letter-spacing: var(--letter-spacing-tighter);
	line-height: var(--line-height-none);
	color: var(--color-fg-accent-on-brand);
	margin-block-end: var(--space-lg);
}
.ey--xl { font-size: clamp(var(--font-size-3xl), 4vw, var(--font-size-5xl)); }

.ru {
	width: var(--space-2xl);
	height: 2px;
	background: var(--color-fg-accent-on-brand);
	margin-block-end: var(--space-xl);
}

.hd {
	font-family: var(--font-serif);
	font-size: clamp(var(--font-size-xl), 2.5vw, var(--font-size-3xl));
	font-weight: var(--font-weight-light);
	font-style: italic;
	color: var(--color-fg-on-brand);
	line-height: var(--line-height-tight);
	letter-spacing: var(--letter-spacing-tight);
	margin-block-end: var(--space-xl);
}

.bd {
	font-family: var(--font-sans);
	font-size: var(--font-size-base);
	line-height: var(--line-height-relaxed);
	color: var(--color-fg-on-brand-muted);
	margin-block-end: var(--space-xl);
}

/* ── CTA atoms ─────────────────────────────────────────────────────────────── */
.ct {
	display: inline-flex;
	align-items: center;
	font-family: var(--font-sans);
	font-size: var(--font-size-sm);
	font-weight: var(--font-weight-medium);
	letter-spacing: var(--letter-spacing-wide);
	text-transform: uppercase;
	text-decoration: none;
	padding-block: var(--space-sm);
	padding-inline: var(--space-xl);
}
.ct--ol {
	color: var(--color-fg-on-brand);
	border: 1px solid color-mix(in srgb, var(--color-fg-on-brand) 40%, transparent);
	transition: border-color var(--duration-fast) var(--ease-out);
}
.ct--ol:hover { border-color: var(--color-fg-on-brand); }
.ct--fill {
	background: var(--color-bg-interactive);
	color: var(--color-fg-interactive);
	border: 1px solid var(--color-border-accent);
	justify-content: center;
	transition: background var(--duration-fast) var(--ease-out);
}
.ct--fill:hover { background: var(--color-bg-interactive-hover); }

/* ── Card atom ─────────────────────────────────────────────────────────────── */
.fc {
	background: var(--color-bg-brand);
	border-radius: var(--radius-lg);
	overflow: hidden;
	box-shadow: var(--shadow-xl);
	display: flex;
	flex-direction: column;
	height: 100%;
}
.fc--full-h { height: 100%; }

.fc__img-wrap {
	overflow: hidden;
	flex-shrink: 0;
	aspect-ratio: 2 / 1;
}
.fc__img-wrap--tall { aspect-ratio: 4 / 3; }

.fc__img { width: 100%; height: 100%; object-fit: cover; display: block; }

.fc__body {
	padding: var(--space-lg);
	display: flex;
	flex-direction: column;
	flex: 1;
}

.fc__tag {
	font-family: var(--font-sans);
	font-size: var(--font-size-xs);
	letter-spacing: var(--letter-spacing-widest);
	text-transform: uppercase;
	color: var(--color-fg-accent-on-brand);
	margin-block-end: var(--space-xs);
}
.fc__title {
	font-family: var(--font-serif);
	font-size: clamp(var(--font-size-lg), 1.8vw, var(--font-size-xl));
	font-weight: var(--font-weight-light);
	font-style: italic;
	color: var(--color-fg-on-brand);
	line-height: var(--line-height-snug);
	margin-block-end: var(--space-sm);
}
.fc__desc {
	font-family: var(--font-sans);
	font-size: var(--font-size-sm);
	line-height: var(--line-height-relaxed);
	color: var(--color-fg-on-brand-muted);
	margin-block-end: var(--space-lg);
	flex: 1;
}
.fc__body .ct--fill { margin-block-start: auto; }

/* ── Key point atoms ───────────────────────────────────────────────────────── */
.kps {
	display: grid;
	gap: var(--space-xl);
	border-block-start: 1px solid color-mix(in srgb, var(--color-fg-on-brand) 18%, transparent);
	padding-block-start: var(--space-2xl);
}
.kps--2col {
	grid-template-columns: 1fr;
	@media (min-width: 640px) { grid-template-columns: repeat(2, 1fr); }
}
.kps--no-border { border-block-start: none; padding-block-start: 0; }
.kps--gap-top { margin-block-start: var(--space-xl); }

.kp { display: flex; flex-direction: column; gap: var(--space-xs); }
.kp--bordered {
	border-block-start: 1px solid color-mix(in srgb, var(--color-fg-on-brand) 18%, transparent);
	padding-block-start: var(--space-lg);
}

.kp__h {
	font-family: var(--font-sans);
	font-size: var(--font-size-sm);
	font-weight: var(--font-weight-medium);
	color: var(--color-fg-accent-on-brand);
	letter-spacing: var(--letter-spacing-wide);
	text-transform: uppercase;
	line-height: var(--line-height-snug);
}
.kp__b {
	font-family: var(--font-sans);
	font-size: var(--font-size-sm);
	line-height: var(--line-height-relaxed);
	color: var(--color-fg-on-brand-muted);
}

/* ═══════════════════════════════════════════════════════════════════════════
   V5 — Three column
   ══════════════════════════════════════════════════════════════════════════ */
.v5__inner {
	display: grid;
	grid-template-columns: 1fr;
	gap: var(--space-3xl);
	padding-block: var(--space-section);
	align-items: start;
}
.v5__kps { display: flex; flex-direction: column; gap: var(--space-xl); }
.v5__text { display: flex; flex-direction: column; align-items: start; }

@media (min-width: 768px) {
	.v5__inner { grid-template-columns: 1fr 1fr; }
	.v5__text { grid-column: span 2; order: -1; }
}
@media (min-width: 1024px) {
	.v5__inner { grid-template-columns: 1fr 1fr 1fr; }
	.v5__text { grid-column: auto; order: 0; }
}

/* ═══════════════════════════════════════════════════════════════════════════
   V9 — kps + text left / card right
   ══════════════════════════════════════════════════════════════════════════ */
.v9__inner {
	display: grid;
	grid-template-columns: 1fr;
	gap: var(--space-3xl);
	padding-block: var(--space-section);
	align-items: start;
}
.v9__left { display: flex; flex-direction: column; align-items: start; }

@media (min-width: 1024px) {
	.v9__inner { grid-template-columns: 1fr 380px; align-items: stretch; }
}

/* ═══════════════════════════════════════════════════════════════════════════
   V13 — Amber left stripe
   ══════════════════════════════════════════════════════════════════════════ */
.v13 { position: relative; }
.v13__stripe {
	position: absolute;
	inset-block-start: 0;
	inset-inline-start: 0;
	width: 4px;
	height: 100%;
	background: var(--color-fg-accent-on-brand);
}
.v13__inner {
	display: grid;
	grid-template-columns: 1fr;
	gap: var(--space-3xl);
	padding-block: var(--space-section);
	padding-inline-start: calc(var(--space-2xl) + 4px);
	align-items: start;
}
.v13__text { display: flex; flex-direction: column; align-items: start; }

@media (min-width: 1024px) {
	.v13__inner { grid-template-columns: 1fr 380px; align-items: stretch; }
}

/* ═══════════════════════════════════════════════════════════════════════════
   V18 — Full text left / card right fills height
   ══════════════════════════════════════════════════════════════════════════ */
.v18__inner {
	display: grid;
	grid-template-columns: 1fr;
	gap: var(--space-3xl);
	padding-block: var(--space-section);
	align-items: start;
}
.v18__text { display: flex; flex-direction: column; align-items: start; }
.v18__text .ct--ol { margin-block-start: auto; padding-block-start: var(--space-xl); }

@media (min-width: 1024px) {
	.v18__inner { grid-template-columns: 1fr 380px; align-items: stretch; }
}
</style>
