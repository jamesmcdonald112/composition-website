---
import CtaLink from "../../components/ui/CtaLink.astro";
import SectionHeader from "../../components/ui/SectionHeader/SectionHeader.astro";
import { firm } from "../../config/firm";
import BaseLayout from "../../layouts/BaseLayout.astro";

const heading = [
	{ text: "Need legal advice you can " },
	{ text: "rely on", em: true },
	{ text: "?" },
] as const;

const eyebrow = "Get in touch";
const body =
	"Our solicitors in Kilkenny are here to help. Call us or send a message and we will get back to you promptly.";
const phone = firm.phone;

const variants = [
	{ label: "4 · Amber-50", bg: "var(--amber-50)" },
	{ label: "5 · Amber-100", bg: "var(--amber-100)" },
	{ label: "7 · Navy-100", bg: "var(--navy-100)" },
] as const;
---

<BaseLayout
	title="CTA Panel — Final 3"
	description="Dev — shortlist comparison of CTA panel colour variants 4, 5, 7"
	canonicalPath="/dev/cta-final3"
>
	{variants.map((v) => (
		<section class="cta-variant" style={`background-color: ${v.bg};`}>
			<div class="variant-label">{v.label}</div>
			<div class="cta-variant__inner wrapper wrapper--wide">
				<div class="cta-variant__text">
					<SectionHeader
						eyebrow={eyebrow}
						heading={heading}
						intro={body}
						eyebrowColor="--color-fg-accent"
						ruleColor="--color-fg-accent"
						headingColor="--color-fg-default"
						noMargin
					/>
				</div>
				<div class="cta-variant__ctas">
					<CtaLink href={`tel:${phone.phoneHref}`} label={phone.display} variant="primary" icon="phone" />
					<CtaLink href="/contact" label="Contact Us" variant="outline-dark" icon="arrow" />
				</div>
			</div>
		</section>
	))}
</BaseLayout>

<style>
	.cta-variant {
		padding-block: var(--space-4xl);
		position: relative;
	}

	.variant-label {
		position: absolute;
		top: var(--space-sm);
		left: var(--space-lg);
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		letter-spacing: var(--letter-spacing-wider);
		text-transform: uppercase;
		opacity: 0.4;
		color: currentColor;
	}

	.cta-variant__inner {
		display: grid;
		grid-template-columns: 1fr;

		@media (min-width: 1024px) {
			grid-template-columns: 1fr 1fr;
			align-items: center;
		}
	}

	.cta-variant__text {
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
	}

	.cta-variant__ctas {
		display: flex;
		flex-direction: column;
		gap: var(--space-lg);
		margin-block-start: var(--space-2xl);

		@media (min-width: 640px) {
			flex-direction: row;
			flex-wrap: wrap;
			align-items: center;
		}

		@media (min-width: 1024px) {
			margin-block-start: 0;
			justify-content: flex-end;
		}
	}
</style>
