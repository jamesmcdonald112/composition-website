
---
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import propertyImage from "../../assets/images/new/house-key-and-figurine.webp";
import signingImage from "../../assets/images/new/person-signing-document-at-desk.webp";
import houseKeyImage from "../../assets/images/new/house-key-on-wooden-table.webp";
import { homePageContent } from "../../config/home";

const { featuredService } = homePageContent;
const { card, aside } = featuredService;
---

<BaseLayout title="Featured Section Variants" description="Dev — 20 layout explorations for featured article/service section" canonicalPath="/dev/featured-variants">

<div class="dev-page">

	<!-- ─── 1: SPLIT — image left, text right, light bg ─────────────────────── -->
	<section class="v v1">
		<div class="label">1 · Split: Image left / Text right / Stone bg</div>
		<div class="wrapper wrapper--wide v1__grid">
			<div class="v1__image">
				<Image src={propertyImage} alt="" width={800} height={600} class="v__img" />
			</div>
			<div class="v1__text">
				<p class="v__tag">{card.tag}</p>
				<h2 class="v__heading">{card.title}</h2>
				<p class="v__body">{card.body}</p>
				<ul class="v__points">
					{card.points.map(p => <li class="v__point">{p}</li>)}
				</ul>
				<a href={card.cta.href} class="v__cta">{card.cta.label}</a>
			</div>
		</div>
	</section>

	<!-- ─── 2: SPLIT — text left, image right, light bg ─────────────────────── -->
	<section class="v v2">
		<div class="label">2 · Split: Text left / Image right / Stone bg</div>
		<div class="wrapper wrapper--wide v2__grid">
			<div class="v2__text">
				<p class="v__tag">{card.tag}</p>
				<h2 class="v__heading">{card.title}</h2>
				<p class="v__body">{card.body}</p>
				<ul class="v__points">
					{card.points.map(p => <li class="v__point">{p}</li>)}
				</ul>
				<a href={card.cta.href} class="v__cta">{card.cta.label}</a>
			</div>
			<div class="v2__image">
				<Image src={propertyImage} alt="" width={800} height={600} class="v__img" />
			</div>
		</div>
	</section>

	<!-- ─── 3: FULL-BLEED image bg, text overlay ─────────────────────────────── -->
	<section class="v v3">
		<div class="label label--light">3 · Full-bleed image bg / Text overlay / Dark</div>
		<Image src={signingImage} alt="" width={1600} height={900} class="v3__bg" />
		<div class="wrapper wrapper--wide v3__content">
			<p class="v__tag v__tag--on-brand">{card.tag}</p>
			<h2 class="v__heading v__heading--on-brand">{card.title}</h2>
			<p class="v__body v__body--on-brand">{card.body}</p>
			<a href={card.cta.href} class="v__cta v__cta--light">{card.cta.label}</a>
		</div>
	</section>

	<!-- ─── 4: NAVY brand bg, text only, centred ─────────────────────────────── -->
	<section class="v v4">
		<div class="label label--light">4 · Navy bg / Centred text / No image</div>
		<div class="wrapper wrapper--wide v4__content">
			<p class="v__tag v__tag--on-brand">{card.tag}</p>
			<h2 class="v__heading v__heading--on-brand v__heading--large">{card.title}</h2>
			<p class="v__body v__body--on-brand v__body--wide">{card.body}</p>
			<div class="v4__points">
				{card.points.map(p => (
					<div class="v4__point">
						<span class="v4__point-bullet" aria-hidden="true">—</span>
						<span>{p}</span>
					</div>
				))}
			</div>
			<a href={card.cta.href} class="v__cta v__cta--light">{card.cta.label}</a>
		</div>
	</section>

	<!-- ─── 5: CARD with aside — 2/3 + 1/3 split ────────────────────────────── -->
	<section class="v v5">
		<div class="label">5 · Card + Aside / Stone bg</div>
		<div class="wrapper wrapper--wide v5__grid">
			<div class="v5__card">
				<p class="v__tag">{card.tag}</p>
				<h2 class="v__heading">{card.title}</h2>
				<p class="v__body">{card.body}</p>
				<ul class="v__points">
					{card.points.map(p => <li class="v__point">{p}</li>)}
				</ul>
				<a href={card.cta.href} class="v__cta">{card.cta.label}</a>
			</div>
			<aside class="v5__aside">
				<h3 class="v5__aside-title">{aside.title}</h3>
				<p class="v5__aside-intro">{aside.intro}</p>
			</aside>
		</div>
	</section>

	<!-- ─── 6: IMAGE top, text below — editorial stack ───────────────────────── -->
	<section class="v v6">
		<div class="label">6 · Image top / Text below / Stone bg</div>
		<div class="wrapper wrapper--wide">
			<div class="v6__image">
				<Image src={houseKeyImage} alt="" width={1200} height={500} class="v__img v__img--wide" />
			</div>
			<div class="v6__grid">
				<div>
					<p class="v__tag">{card.tag}</p>
					<h2 class="v__heading">{card.title}</h2>
				</div>
				<div>
					<p class="v__body">{card.body}</p>
					<a href={card.cta.href} class="v__cta">{card.cta.label}</a>
				</div>
			</div>
		</div>
	</section>

	<!-- ─── 7: NAVY split — image right bleeds to edge ───────────────────────── -->
	<section class="v v7">
		<div class="label label--light">7 · Navy bg / Text left / Image bleeds right</div>
		<div class="v7__grid">
			<div class="v7__text">
				<div class="v7__text-inner">
					<p class="v__tag v__tag--on-brand">{card.tag}</p>
					<h2 class="v__heading v__heading--on-brand">{card.title}</h2>
					<p class="v__body v__body--on-brand">{card.body}</p>
					<ul class="v__points v__points--on-brand">
						{card.points.map(p => <li class="v__point">{p}</li>)}
					</ul>
					<a href={card.cta.href} class="v__cta v__cta--light">{card.cta.label}</a>
				</div>
			</div>
			<div class="v7__image">
				<Image src={propertyImage} alt="" width={800} height={900} class="v__img v__img--fill" />
			</div>
		</div>
	</section>

	<!-- ─── 8: KEY POINTS grid — 4 cards ─────────────────────────────────────── -->
	<section class="v v8">
		<div class="label">8 · Key points grid / Stone bg</div>
		<div class="wrapper wrapper--wide">
			<div class="v8__header">
				<p class="v__tag">{card.tag}</p>
				<h2 class="v__heading">{card.title}</h2>
			</div>
			<div class="v8__grid">
				{aside.keyPoints.map(kp => (
					<div class="v8__card">
						<h3 class="v8__card-heading">{kp.heading}</h3>
						<p class="v8__card-body">{kp.body}</p>
					</div>
				))}
			</div>
			<a href={card.cta.href} class="v__cta">{card.cta.label}</a>
		</div>
	</section>

	<!-- ─── 9: NAVY — key points grid dark ───────────────────────────────────── -->
	<section class="v v9">
		<div class="label label--light">9 · Key points grid / Navy bg</div>
		<div class="wrapper wrapper--wide">
			<div class="v8__header">
				<p class="v__tag v__tag--on-brand">{card.tag}</p>
				<h2 class="v__heading v__heading--on-brand">{card.title}</h2>
			</div>
			<div class="v8__grid">
				{aside.keyPoints.map(kp => (
					<div class="v9__card">
						<h3 class="v8__card-heading v9__card-heading">{kp.heading}</h3>
						<p class="v8__card-body v9__card-body">{kp.body}</p>
					</div>
				))}
			</div>
			<a href={card.cta.href} class="v__cta v__cta--light">{card.cta.label}</a>
		</div>
	</section>

	<!-- ─── 10: OVERSIZED heading, minimal text, image accent ────────────────── -->
	<section class="v v10">
		<div class="label">10 · Editorial: Oversized heading / Image accent / Stone bg</div>
		<div class="wrapper wrapper--wide v10__grid">
			<div class="v10__heading-col">
				<p class="v__tag">{card.tag}</p>
				<h2 class="v10__big-heading">{card.title}</h2>
			</div>
			<div class="v10__content-col">
				<Image src={houseKeyImage} alt="" width={600} height={400} class="v10__image" />
				<p class="v__body">{card.body}</p>
				<a href={card.cta.href} class="v__cta">{card.cta.label}</a>
			</div>
		</div>
	</section>

	<!-- ─── 11: STACKED — amber-50 bg, image + text vertical ─────────────────── -->
	<section class="v v11">
		<div class="label">11 · Stacked / Amber-50 bg / Centred</div>
		<div class="wrapper wrapper--wide v11__content">
			<p class="v__tag v__tag--accent">{card.tag}</p>
			<h2 class="v__heading v__heading--large">{card.title}</h2>
			<Image src={propertyImage} alt="" width={1000} height={500} class="v11__image" />
			<p class="v__body v__body--wide">{card.body}</p>
			<a href={card.cta.href} class="v__cta">{card.cta.label}</a>
		</div>
	</section>

	<!-- ─── 12: BORDERED card on navy bg ─────────────────────────────────────── -->
	<section class="v v12">
		<div class="label label--light">12 · Bordered card / Navy bg</div>
		<div class="wrapper wrapper--wide v12__content">
			<div class="v12__card">
				<p class="v__tag">{card.tag}</p>
				<h2 class="v__heading">{card.title}</h2>
				<p class="v__body">{card.body}</p>
				<ul class="v__points">
					{card.points.map(p => <li class="v__point">{p}</li>)}
				</ul>
				<a href={card.cta.href} class="v__cta">{card.cta.label}</a>
			</div>
		</div>
	</section>

	<!-- ─── 13: ASIDE key points — vertical list style ───────────────────────── -->
	<section class="v v13">
		<div class="label">13 · Split: Text + vertical key points / Stone bg</div>
		<div class="wrapper wrapper--wide v13__grid">
			<div class="v13__text">
				<p class="v__tag">{card.tag}</p>
				<h2 class="v__heading">{card.title}</h2>
				<p class="v__body">{card.body}</p>
				<a href={card.cta.href} class="v__cta">{card.cta.label}</a>
			</div>
			<div class="v13__points">
				{aside.keyPoints.map((kp, i) => (
					<div class="v13__point">
						<span class="v13__num">0{i + 1}</span>
						<div>
							<h3 class="v13__point-heading">{kp.heading}</h3>
							<p class="v13__point-body">{kp.body}</p>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ─── 14: IMAGE background, aside overlay ──────────────────────────────── -->
	<section class="v v14">
		<div class="label label--light">14 · Image bg / Aside overlay card / Dark</div>
		<div class="v14__wrap">
			<Image src={signingImage} alt="" width={1600} height={700} class="v14__bg" />
			<div class="wrapper wrapper--wide v14__overlay">
				<div class="v14__card">
					<h3 class="v14__card-title">{aside.title}</h3>
					<p class="v14__card-intro">{aside.intro}</p>
					<a href={card.cta.href} class="v__cta">{card.cta.label}</a>
				</div>
			</div>
		</div>
	</section>

	<!-- ─── 15: MINIMAL — amber accent rule, large quote-style body ───────────── -->
	<section class="v v15">
		<div class="label">15 · Minimal: Accent rule / Large body text / Stone bg</div>
		<div class="wrapper wrapper--wide v15__content">
			<p class="v__tag">{card.tag}</p>
			<div class="v15__rule"></div>
			<p class="v15__quote">{card.body}</p>
			<div class="v15__footer">
				<h2 class="v15__heading">{card.title}</h2>
				<a href={card.cta.href} class="v__cta">{card.cta.label}</a>
			</div>
		</div>
	</section>

	<!-- ─── 16: NAVY — 3-col: text | image | key points ─────────────────────── -->
	<section class="v v16">
		<div class="label label--light">16 · 3-col: Text / Image / Key points / Navy bg</div>
		<div class="wrapper wrapper--wide v16__grid">
			<div>
				<p class="v__tag v__tag--on-brand">{card.tag}</p>
				<h2 class="v__heading v__heading--on-brand">{card.title}</h2>
				<a href={card.cta.href} class="v__cta v__cta--light">{card.cta.label}</a>
			</div>
			<div class="v16__image">
				<Image src={propertyImage} alt="" width={600} height={700} class="v__img v__img--fill" />
			</div>
			<div class="v16__points">
				{aside.keyPoints.map(kp => (
					<div class="v16__point">
						<h3 class="v16__point-heading">{kp.heading}</h3>
						<p class="v16__point-body">{kp.body}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ─── 17: SPLIT — navy left panel, image right ─────────────────────────── -->
	<section class="v v17">
		<div class="label label--light">17 · Navy panel left / Image right / No wrapper</div>
		<div class="v17__grid">
			<div class="v17__panel">
				<p class="v__tag v__tag--on-brand">{card.tag}</p>
				<h2 class="v__heading v__heading--on-brand">{card.title}</h2>
				<p class="v__body v__body--on-brand">{card.body}</p>
				<a href={card.cta.href} class="v__cta v__cta--light">{card.cta.label}</a>
			</div>
			<div class="v17__image">
				<Image src={houseKeyImage} alt="" width={900} height={800} class="v__img v__img--fill" />
			</div>
		</div>
	</section>

	<!-- ─── 18: CHECKLIST — amber-50 bg, large checklist style ──────────────── -->
	<section class="v v18">
		<div class="label">18 · Checklist style / Amber-50 bg</div>
		<div class="wrapper wrapper--wide v18__grid">
			<div class="v18__text">
				<p class="v__tag v__tag--accent">{card.tag}</p>
				<h2 class="v__heading">{card.title}</h2>
				<p class="v__body">{card.body}</p>
			</div>
			<div class="v18__list">
				{card.points.map(p => (
					<div class="v18__item">
						<span class="v18__check" aria-hidden="true">✓</span>
						<span>{p}</span>
					</div>
				))}
				<a href={card.cta.href} class="v__cta">{card.cta.label}</a>
			</div>
		</div>
	</section>

	<!-- ─── 19: NAVY-50 bg — soft cool tint, image + aside ───────────────────── -->
	<section class="v v19">
		<div class="label">19 · Navy-50 bg / Image + Aside / Soft cool</div>
		<div class="wrapper wrapper--wide v19__grid">
			<div class="v19__image">
				<Image src={signingImage} alt="" width={700} height={800} class="v__img v__img--fill" />
			</div>
			<div class="v19__content">
				<p class="v__tag">{card.tag}</p>
				<h2 class="v__heading">{card.title}</h2>
				<p class="v__body">{card.body}</p>
				{aside.keyPoints.slice(0, 2).map(kp => (
					<div class="v19__point">
						<h3 class="v19__point-heading">{kp.heading}</h3>
						<p class="v19__point-body">{kp.body}</p>
					</div>
				))}
				<a href={card.cta.href} class="v__cta">{card.cta.label}</a>
			</div>
		</div>
	</section>

	<!-- ─── 20: EDITORIAL — full width, text over amber strip ────────────────── -->
	<section class="v v20">
		<div class="label">20 · Editorial: Amber strip / Navy text / Asymmetric</div>
		<div class="wrapper wrapper--wide v20__grid">
			<div class="v20__strip"></div>
			<div class="v20__text">
				<p class="v__tag">{card.tag}</p>
				<h2 class="v20__heading">{card.title}</h2>
				<p class="v__body">{card.body}</p>
				<ul class="v__points">
					{card.points.map(p => <li class="v__point">{p}</li>)}
				</ul>
				<a href={card.cta.href} class="v__cta">{card.cta.label}</a>
			</div>
			<div class="v20__image">
				<Image src={propertyImage} alt="" width={600} height={700} class="v__img v__img--fill" />
			</div>
		</div>
	</section>

</div>
</BaseLayout>

<style>
/* ── Dev scaffolding ──────────────────────────────────────────────────────── */
.dev-page { display: flex; flex-direction: column; }

.v {
	padding-block: var(--space-4xl);
	position: relative;
}

.label {
	position: absolute;
	top: var(--space-sm);
	left: var(--space-lg);
	font-family: var(--font-sans);
	font-size: var(--font-size-xs);
	letter-spacing: var(--letter-spacing-wider);
	text-transform: uppercase;
	opacity: 0.45;
	color: var(--color-fg-default);
}
.label--light { color: var(--color-fg-on-brand); }

/* ── Shared element tokens ────────────────────────────────────────────────── */
.v__img { width: 100%; height: 100%; object-fit: cover; display: block; }
.v__img--wide { max-height: 420px; object-fit: cover; }
.v__img--fill { height: 100%; min-height: 400px; }

.v__tag {
	font-family: var(--font-sans);
	font-size: var(--font-size-xs);
	letter-spacing: var(--letter-spacing-widest);
	text-transform: uppercase;
	color: var(--color-fg-accent);
	margin-block-end: var(--space-sm);
}
.v__tag--on-brand { color: var(--color-fg-accent-on-brand); }
.v__tag--accent { color: var(--color-fg-accent); }

.v__heading {
	font-family: var(--font-serif);
	font-size: var(--font-size-3xl);
	font-weight: var(--font-weight-light);
	font-style: italic;
	color: var(--color-fg-default);
	line-height: 1.2;
	margin-block-end: var(--space-lg);
}
.v__heading--on-brand { color: var(--color-fg-on-brand); }
.v__heading--large { font-size: var(--font-size-4xl); }

.v__body {
	font-family: var(--font-sans);
	font-size: var(--font-size-base);
	line-height: var(--line-height-relaxed);
	color: var(--color-fg-muted);
	margin-block-end: var(--space-xl);
}
.v__body--on-brand { color: var(--color-fg-on-brand-muted); }
.v__body--wide { max-width: 60ch; margin-inline: auto; }

.v__points {
	list-style: none;
	padding: 0;
	margin: 0 0 var(--space-xl);
	display: flex;
	flex-direction: column;
	gap: var(--space-sm);
}
.v__point {
	font-family: var(--font-sans);
	font-size: var(--font-size-sm);
	color: var(--color-fg-muted);
	padding-inline-start: var(--space-lg);
	position: relative;

	&::before {
		content: "—";
		position: absolute;
		inset-inline-start: 0;
		color: var(--color-fg-accent);
	}
}
.v__points--on-brand .v__point { color: var(--color-fg-on-brand-muted); }
.v__points--on-brand .v__point::before { color: var(--color-fg-accent-on-brand); }

.v__cta {
	display: inline-flex;
	align-items: center;
	gap: var(--space-xs);
	font-family: var(--font-sans);
	font-size: var(--font-size-sm);
	font-weight: var(--font-weight-medium);
	letter-spacing: var(--letter-spacing-wide);
	text-transform: uppercase;
	text-decoration: none;
	padding-block: var(--space-md);
	padding-inline: var(--space-xl);
	background: var(--color-bg-interactive);
	color: var(--color-fg-interactive);
	border: 1px solid var(--color-border-accent);
}
.v__cta--light {
	background: transparent;
	color: var(--color-fg-on-brand);
	border-color: color-mix(in srgb, var(--color-fg-on-brand) 40%, transparent);
}

/* ── 1 ───────────────────────────────────────────────────────────────────── */
.v1 { background: var(--color-bg-subtle); }
.v1__grid {
	display: grid;
	grid-template-columns: 1fr;
	gap: var(--space-2xl);
	align-items: center;
	@media (min-width: 768px) { grid-template-columns: 1fr 1fr; }
}
.v1__image { border-radius: var(--radius-lg); overflow: hidden; }

/* ── 2 ───────────────────────────────────────────────────────────────────── */
.v2 { background: var(--color-bg-page); }
.v2__grid {
	display: grid;
	grid-template-columns: 1fr;
	gap: var(--space-2xl);
	align-items: center;
	@media (min-width: 768px) { grid-template-columns: 1fr 1fr; }
}
.v2__image { border-radius: var(--radius-lg); overflow: hidden; }

/* ── 3 ───────────────────────────────────────────────────────────────────── */
.v3 { position: relative; padding-block: var(--space-6xl); overflow: hidden; }
.v3__bg {
	position: absolute;
	inset: 0;
	width: 100%;
	height: 100%;
	object-fit: cover;
	filter: brightness(0.35);
}
.v3__content {
	position: relative;
	max-width: 52ch;
}

/* ── 4 ───────────────────────────────────────────────────────────────────── */
.v4 { background: var(--color-bg-brand); }
.v4__content { text-align: center; display: flex; flex-direction: column; align-items: center; }
.v4__points {
	display: flex;
	flex-direction: column;
	gap: var(--space-sm);
	margin-block-end: var(--space-xl);
	text-align: left;
}
.v4__point {
	display: flex;
	gap: var(--space-sm);
	font-family: var(--font-sans);
	font-size: var(--font-size-sm);
	color: var(--color-fg-on-brand-muted);
}
.v4__point-bullet { color: var(--color-fg-accent-on-brand); flex-shrink: 0; }

/* ── 5 ───────────────────────────────────────────────────────────────────── */
.v5 { background: var(--color-bg-subtle); }
.v5__grid {
	display: grid;
	grid-template-columns: 1fr;
	gap: var(--space-2xl);
	@media (min-width: 1024px) { grid-template-columns: 2fr 1fr; }
}
.v5__aside {
	background: var(--color-bg-brand);
