			</div>
			<div class="img-col img-col--rounded">
				<Image src={propertyImage} alt="House key and figurine" width={700} height={800} class="img-fill" />
			</div>
		</div>
	</section>

	<!-- 17: Charcoal-50 / 1:1 / heading split across two lines with em word / points -->
	<section class="v v-charcoal">
		<p class="lbl">17 · Charcoal-50 / 1:1 / Em word in heading / Points</p>
		<div class="wrapper wrapper--wide grid-half">
			<div class="text-col">
				<p class="tag">Buying & Selling Property</p>
				<h2 class="heading">Buying or selling property in <em class="em-accent">Kilkenny?</em></h2>
