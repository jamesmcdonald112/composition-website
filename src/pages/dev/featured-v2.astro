</BaseLayout>

<style>
.dev-page { display: flex; flex-direction: column; }

.v {
	padding-block: var(--space-5xl);
	background: var(--color-bg-subtle);
	position: relative;
}
.v-white { background: var(--color-bg-surface); }
.v-amber { background: var(--color-bg-accent); }
.v-navy { background: var(--color-bg-brand); }
.v-navy-muted { background: var(--color-bg-brand-muted); }
.v-navy-light { background: var(--color-bg-brand-subtle); }
.v-charcoal { background: var(--color-bg-tertiary); }

.lbl {
	position: absolute;
	top: var(--space-sm);
	left: var(--space-lg);
	font-family: var(--font-sans);
	font-size: var(--font-size-xs);
	letter-spacing: var(--letter-spacing-wider);
	text-transform: uppercase;
	opacity: 0.4;
	color: var(--color-fg-default);
}
.lbl-light { color: var(--color-fg-on-brand); }

/* ── Grids ───────────────────────────────────────────────────────────────── */
.grid-half {
	display: grid;
	grid-template-columns: 1fr;
	gap: var(--space-3xl);
	align-items: center;
	@media (min-width: 768px) { grid-template-columns: 1fr 1fr; }
}
.grid-55-45 {
	display: grid;
	grid-template-columns: 1fr;
	gap: var(--space-3xl);
