---
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import maryPhoto from "../../assets/team/maryCropped.webp";
import nicholasPhoto from "../../assets/team/nicholas.webp";
import richardPhoto from "../../assets/team/richard.webp";
import dukePhoto from "../../assets/team/duke.webp";

const m = [
	{ name: "Mary Molloy", role: "Principal Solicitor", bio: "Mary leads the firm with over four decades of experience advising clients on property and private client matters throughout Kilkenny. She is known for her practical guidance, straightforward advice and personal approach to each case.", photo: maryPhoto },
	{ name: "Nicholas O'Shea", role: "Solicitor", bio: "Nicholas works across property and private client matters, supporting clients with clear communication and efficient case progression. He focuses on responsiveness, clarity and maintaining consistent contact throughout the legal process.", photo: nicholasPhoto },
	{ name: "Richard O'Shea", role: "Solicitor", bio: "Richard advises clients on buying and selling property, conveyancing and probate matters. He brings a steady, detail-focused approach to ensure each transaction progresses efficiently from first instruction to final completion.", photo: richardPhoto },
	{ name: "Duke", role: "Office Companion", bio: "Providing daily morale support to the team and a friendly welcome to visitors.", photo: dukePhoto },
] as const;
---

<BaseLayout
	title="Team Card Explorations"
	description="Dev page — team card design explorations"
	canonicalPath="/dev/team-cards"
>
	<div class="dev-page">
		<div class="dev-page__header wrapper wrapper--wide">
			<h1 class="dev-page__title">Team Card Explorations</h1>
			<p class="dev-page__note">20 variations — pick your favourite</p>
		</div>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- 1. Full portrait — name over image, serif italic role -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">01 — Full portrait, name overlay</p>
				<div class="grid-4">
					{m.map((person) => (
						<div class="c1">
							<div class="c1__img-wrap">
								<Image src={person.photo} alt={person.name} width={400} height={520} class="c1__img" />
								<div class="c1__overlay">
									<p class="c1__role">{person.role}</p>
									<h3 class="c1__name">{person.name}</h3>
								</div>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- 2. Horizontal split — photo left, text right -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section dev-section--alt">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">02 — Horizontal split</p>
				<div class="grid-2">
					{m.map((person) => (
						<div class="c2">
							<div class="c2__photo-col">
								<Image src={person.photo} alt={person.name} width={240} height={300} class="c2__img" />
							</div>
							<div class="c2__text-col">
								<p class="c2__role">{person.role}</p>
								<h3 class="c2__name">{person.name}</h3>
								<div class="c2__rule" aria-hidden="true"></div>
								<p class="c2__bio">{person.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- 3. Dark brand card — white text, gold accent -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">03 — Dark brand card</p>
				<div class="grid-4">
					{m.map((person) => (
						<div class="c3">
							<div class="c3__img-wrap">
								<Image src={person.photo} alt={person.name} width={300} height={300} class="c3__img" />
							</div>
							<div class="c3__body">
								<p class="c3__role">{person.role}</p>
								<h3 class="c3__name">{person.name}</h3>
								<p class="c3__bio">{person.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- 4. Circle portrait — editorial magazine feel -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section dev-section--alt">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">04 — Circle portrait, centred editorial</p>
				<div class="grid-4">
					{m.map((person) => (
						<div class="c4">
							<div class="c4__circle">
								<Image src={person.photo} alt={person.name} width={200} height={200} class="c4__img" />
							</div>
							<div class="c4__rule" aria-hidden="true"></div>
							<h3 class="c4__name">{person.name}</h3>
							<p class="c4__role">{person.role}</p>
							<p class="c4__bio">{person.bio}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- 5. Minimal — no photo, typography-only -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">05 — Type-only, numbered index</p>
				<div class="c5-list">
					{m.map((person, i) => (
						<div class="c5">
							<span class="c5__index">{String(i + 1).padStart(2, "0")}</span>
							<div class="c5__divider" aria-hidden="true"></div>
							<div class="c5__body">
								<h3 class="c5__name">{person.name}</h3>
								<p class="c5__role">{person.role}</p>
							</div>
							<p class="c5__bio">{person.bio}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- 6. Tall portrait, left-aligned text below — editorial grid -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section dev-section--alt">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">06 — Tall portrait, left-aligned editorial</p>
				<div class="grid-4">
					{m.map((person) => (
						<div class="c6">
							<div class="c6__img-wrap">
								<Image src={person.photo} alt={person.name} width={360} height={480} class="c6__img" />
								<span class="c6__badge">{person.role}</span>
							</div>
							<h3 class="c6__name">{person.name}</h3>
							<p class="c6__bio">{person.bio}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- 7. Bordered card — subtle surface, gold left accent -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">07 — Bordered surface card, gold left accent</p>
				<div class="grid-4">
					{m.map((person) => (
						<div class="c7">
							<div class="c7__img-wrap">
								<Image src={person.photo} alt={person.name} width={300} height={240} class="c7__img" />
							</div>
							<div class="c7__body">
								<p class="c7__role">{person.role}</p>
								<h3 class="c7__name">{person.name}</h3>
								<p class="c7__bio">{person.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- 8. Staggered asymmetric grid — odd cards offset -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section dev-section--alt">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">08 — Asymmetric offset grid</p>
				<div class="c8-grid">
					{m.map((person, i) => (
						<div class={`c8 ${i % 2 === 1 ? "c8--offset" : ""}`}>
							<Image src={person.photo} alt={person.name} width={400} height={500} class="c8__img" />
							<div class="c8__caption">
								<h3 class="c8__name">{person.name}</h3>
								<p class="c8__role">{person.role}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- 9. Hover reveal bio — name always visible, bio reveals on hover -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">09 — Hover reveal bio</p>
				<div class="grid-4">
					{m.map((person) => (
						<div class="c9">
							<div class="c9__img-wrap">
								<Image src={person.photo} alt={person.name} width={400} height={460} class="c9__img" />
								<div class="c9__reveal">
									<p class="c9__bio">{person.bio}</p>
								</div>
							</div>
							<div class="c9__footer">
								<h3 class="c9__name">{person.name}</h3>
								<p class="c9__role">{person.role}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- 10. Large feature — one per row, photo right -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section dev-section--brand">
			<div class="wrapper wrapper--wide">
				<p class="dev-label dev-label--light">10 — Feature row, photo right, dark bg</p>
				<div class="c10-list">
					{m.map((person, i) => (
						<div class={`c10 ${i % 2 === 1 ? "c10--flip" : ""}`}>
							<div class="c10__text">
								<p class="c10__role">{person.role}</p>
								<h3 class="c10__name">{person.name}</h3>
								<p class="c10__bio">{person.bio}</p>
							</div>
							<div class="c10__img-wrap">
								<Image src={person.photo} alt={person.name} width={480} height={560} class="c10__img" />
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- 11. Pill/badge role, square crop, surface card -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">11 — Square crop, pill role badge</p>
				<div class="grid-4">
					{m.map((person) => (
						<div class="c11">
							<div class="c11__img-wrap">
								<Image src={person.photo} alt={person.name} width={300} height={300} class="c11__img" />
							</div>
							<div class="c11__body">
								<span class="c11__badge">{person.role}</span>
								<h3 class="c11__name">{person.name}</h3>
								<p class="c11__bio">{person.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- 12. Wide card — full bleed image top, text in inset panel -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section dev-section--alt">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">12 — Full-bleed top image, inset panel</p>
				<div class="grid-2">
					{m.map((person) => (
						<div class="c12">
							<div class="c12__img-wrap">
								<Image src={person.photo} alt={person.name} width={600} height={320} class="c12__img" />
							</div>
							<div class="c12__panel">
								<div class="c12__accent" aria-hidden="true"></div>
								<div class="c12__text">
									<p class="c12__role">{person.role}</p>
									<h3 class="c12__name">{person.name}</h3>
									<p class="c12__bio">{person.bio}</p>
								</div>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- 13. Outlined border, serif large initials -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">13 — Large serif initial, outlined card</p>
				<div class="grid-4">
					{m.map((person) => (
						<div class="c13">
							<div class="c13__initial-wrap">
								<span class="c13__initial" aria-hidden="true">{person.name[0]}</span>
								<Image src={person.photo} alt={person.name} width={240} height={240} class="c13__img" />
							</div>
							<div class="c13__body">
								<h3 class="c13__name">{person.name}</h3>
								<p class="c13__role">{person.role}</p>
								<p class="c13__bio">{person.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- 14. Timeline / manifesto row — large number, text alongside -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section dev-section--alt">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">14 — Manifesto list with large index</p>
				<div class="c14-list">
					{m.map((person, i) => (
						<div class="c14">
							<div class="c14__left">
								<span class="c14__num" aria-hidden="true">{String(i + 1).padStart(2, "0")}</span>
								<div class="c14__photo-wrap">
									<Image src={person.photo} alt={person.name} width={160} height={200} class="c14__img" />
								</div>
							</div>
							<div class="c14__right">
								<p class="c14__role">{person.role}</p>
								<h3 class="c14__name">{person.name}</h3>
								<p class="c14__bio">{person.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- 15. Glassmorphism tint on brand bg -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section dev-section--brand">
			<div class="wrapper wrapper--wide">
				<p class="dev-label dev-label--light">15 — Glass tint card on brand bg</p>
				<div class="grid-4">
					{m.map((person) => (
						<div class="c15">
							<div class="c15__img-wrap">
								<Image src={person.photo} alt={person.name} width={300} height={320} class="c15__img" />
							</div>
							<div class="c15__body">
								<p class="c15__role">{person.role}</p>
								<h3 class="c15__name">{person.name}</h3>
								<p class="c15__bio">{person.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- 16. Compact row — photo + name + role only, no bio -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">16 — Compact inline row</p>
				<div class="c16-list">
					{m.map((person) => (
						<div class="c16">
							<Image src={person.photo} alt={person.name} width={80} height={80} class="c16__img" />
							<div class="c16__text">
								<h3 class="c16__name">{person.name}</h3>
								<p class="c16__role">{person.role}</p>
							</div>
							<p class="c16__bio">{person.bio}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- 17. Diagonal split — image angled, text on right -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section dev-section--alt">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">17 — Diagonal clip on image</p>
				<div class="grid-4">
					{m.map((person) => (
						<div class="c17">
							<div class="c17__img-wrap">
								<Image src={person.photo} alt={person.name} width={340} height={400} class="c17__img" />
							</div>
							<div class="c17__body">
								<h3 class="c17__name">{person.name}</h3>
								<p class="c17__role">{person.role}</p>
								<p class="c17__bio">{person.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- 18. Stacked with decorative quote mark -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">18 — Decorative serif quote mark accent</p>
				<div class="grid-4">
					{m.map((person) => (
						<div class="c18">
							<div class="c18__top">
								<Image src={person.photo} alt={person.name} width={280} height={340} class="c18__img" />
								<span class="c18__mark" aria-hidden="true">&ldquo;</span>
							</div>
							<div class="c18__body">
								<h3 class="c18__name">{person.name}</h3>
								<p class="c18__role">{person.role}</p>
								<p class="c18__bio">{person.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- 19. Wide landscape crop, bottom text, minimal -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section dev-section--alt">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">19 — Landscape crop, bottom-anchored minimal text</p>
				<div class="grid-2">
					{m.map((person) => (
						<div class="c19">
							<Image src={person.photo} alt={person.name} width={680} height={360} class="c19__img" />
							<div class="c19__footer">
								<div>
									<h3 class="c19__name">{person.name}</h3>
									<p class="c19__role">{person.role}</p>
								</div>
								<div class="c19__dot" aria-hidden="true"></div>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─────────────────────────────────────────────────────────────────── -->
		<!-- 20. Bento-style — mixed sizes, asymmetric -->
		<!-- ─────────────────────────────────────────────────────────────────── -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">20 — Bento asymmetric grid</p>
				<div class="c20-grid">
					{m.map((person, i) => (
						<div class={`c20 c20--${i + 1}`}>
							<div class="c20__img-wrap">
								<Image src={person.photo} alt={person.name} width={500} height={600} class="c20__img" />
							</div>
							<div class="c20__body">
								<p class="c20__role">{person.role}</p>
								<h3 class="c20__name">{person.name}</h3>
								<p class="c20__bio">{person.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

	</div>
</BaseLayout>

<style>
	/* ── Dev page shell ───────────────────────────────────────────────────────── */
	.dev-page {
		padding-block-start: var(--space-5xl);
	}

	.dev-page__header {
		margin-block-end: var(--space-4xl);
	}

	.dev-page__title {
		font-family: var(--font-serif);
		font-size: clamp(var(--font-size-3xl), 4vw, var(--font-size-5xl));
		font-weight: var(--font-weight-light);
		color: var(--color-fg-default);
		letter-spacing: var(--letter-spacing-tight);
	}

	.dev-page__note {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		color: var(--color-fg-muted);
		letter-spacing: var(--letter-spacing-wide);
		margin-block-start: var(--space-sm);
	}

	.dev-section {
		padding-block: var(--space-5xl);
	}

	.dev-section--alt {
		background: var(--color-bg-subtle);
	}

	.dev-section--brand {
		background: var(--color-bg-brand);
	}

	.dev-label {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: var(--font-weight-medium);
		letter-spacing: var(--letter-spacing-widest);
		text-transform: uppercase;
		color: var(--color-fg-subtle);
		margin-block-end: var(--space-3xl);
	}

	.dev-label--light {
		color: var(--color-fg-on-brand-subtle);
	}

	/* ── Shared grids ─────────────────────────────────────────────────────────── */
	.grid-4 {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-xl);

		@media (min-width: 640px) { grid-template-columns: 1fr 1fr; }
		@media (min-width: 1024px) { grid-template-columns: repeat(4, 1fr); }
	}

	.grid-2 {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-xl);

		@media (min-width: 768px) { grid-template-columns: 1fr 1fr; }
	}

	/* ══════════════════════════════════════════════════════════════════════════
	   CARD 1 — Full portrait, name overlay
	══════════════════════════════════════════════════════════════════════════ */
	.c1 { position: relative; overflow: hidden; border-radius: var(--radius-lg); }

	.c1__img-wrap { position: relative; aspect-ratio: 3 / 4; overflow: hidden; }

	.c1__img {
		width: 100%; height: 100%; object-fit: cover;
		transition: transform var(--duration-slow) var(--ease-smooth);
		.c1:hover & { transform: scale(1.04); }
	}

	.c1__overlay {
		position: absolute; inset-inline: 0; inset-block-end: 0;
		padding: var(--space-xl);
		background: linear-gradient(to top, var(--color-bg-brand) 0%, transparent 100%);
	}

	.c1__role {
		font-family: var(--font-sans); font-size: var(--font-size-xs);
		letter-spacing: var(--letter-spacing-widest); text-transform: uppercase;
		color: var(--color-fg-accent-on-brand); margin-block-end: var(--space-xs);
	}

	.c1__name {
		font-family: var(--font-serif); font-size: var(--font-size-2xl);
		font-weight: var(--font-weight-light); color: var(--color-fg-on-brand);
		letter-spacing: var(--letter-spacing-tight);
	}

	/* ══════════════════════════════════════════════════════════════════════════
	   CARD 2 — Horizontal split
	══════════════════════════════════════════════════════════════════════════ */
	.c2 {
		display: grid; grid-template-columns: 180px 1fr; gap: 0;
		background: var(--color-bg-surface); border-radius: var(--radius-lg);
		border: 1px solid var(--color-border-default); overflow: hidden;
		box-shadow: var(--shadow-sm);
	}

	.c2__photo-col { overflow: hidden; }

	.c2__img { width: 100%; height: 100%; object-fit: cover; display: block; }

	.c2__text-col { padding: var(--space-xl); display: flex; flex-direction: column; justify-content: center; }

	.c2__role {
		font-family: var(--font-sans); font-size: var(--font-size-xs);
		letter-spacing: var(--letter-spacing-widest); text-transform: uppercase;
		color: var(--color-fg-accent); margin-block-end: var(--space-xs);
	}

	.c2__name {
		font-family: var(--font-serif); font-size: var(--font-size-xl);
		font-weight: var(--font-weight-light); color: var(--color-fg-on-surface);
		letter-spacing: var(--letter-spacing-tight); margin-block-end: var(--space-md);
	}

	.c2__rule {
		width: var(--size-10); height: 1px;
		background: var(--color-fg-accent); margin-block-end: var(--space-md);
	}

	.c2__bio {
		font-family: var(--font-sans); font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed); color: var(--color-fg-on-surface-muted);
	}

	/* ══════════════════════════════════════════════════════════════════════════
	   CARD 3 — Dark brand
	══════════════════════════════════════════════════════════════════════════ */
	.c3 {
		background: var(--color-bg-brand-muted); border-radius: var(--radius-lg);
		overflow: hidden;
		transition: transform var(--duration-slow) var(--ease-smooth);
		&:hover { transform: translateY(-var(--space-xs)); }
	}

	.c3__img-wrap { aspect-ratio: 1 / 1; overflow: hidden; }

	.c3__img {
		width: 100%; height: 100%; object-fit: cover; display: block;
		transition: transform var(--duration-slow) var(--ease-smooth);
		.c3:hover & { transform: scale(1.04); }
	}

	.c3__body { padding: var(--space-xl); }

	.c3__role {
		font-family: var(--font-sans); font-size: var(--font-size-xs);
		letter-spacing: var(--letter-spacing-widest); text-transform: uppercase;
		color: var(--color-fg-accent-on-brand); margin-block-end: var(--space-xs);
	}

	.c3__name {
		font-family: var(--font-serif); font-size: var(--font-size-xl);
		font-weight: var(--font-weight-light); color: var(--color-fg-on-brand);
		letter-spacing: var(--letter-spacing-tight); margin-block-end: var(--space-md);
	}

	.c3__bio {
		font-family: var(--font-sans); font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed); color: var(--color-fg-on-brand-muted);
	}

	/* ══════════════════════════════════════════════════════════════════════════
	   CARD 4 — Circle portrait, centred
	══════════════════════════════════════════════════════════════════════════ */
	.c4 {
		display: flex; flex-direction: column; align-items: center;
		text-align: center; padding: var(--space-xl);
	}

	.c4__circle {
		width: var(--size-40); height: var(--size-40);
		border-radius: var(--radius-full); overflow: hidden;
		border: 2px solid var(--color-border-accent);
		margin-block-end: var(--space-lg);
	}

	.c4__img { width: 100%; height: 100%; object-fit: cover; display: block; }

	.c4__rule {
		width: var(--size-10); height: 1px;
		background: var(--color-fg-accent); margin-block-end: var(--space-lg);
	}

	.c4__name {
		font-family: var(--font-serif); font-size: var(--font-size-xl);
		font-weight: var(--font-weight-light); color: var(--color-fg-default);
		letter-spacing: var(--letter-spacing-tight); margin-block-end: var(--space-xs);
	}

	.c4__role {
		font-family: var(--font-sans); font-size: var(--font-size-xs);
		letter-spacing: var(--letter-spacing-widest); text-transform: uppercase;
		color: var(--color-fg-accent); margin-block-end: var(--space-md);
	}

	.c4__bio {
		font-family: var(--font-sans); font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed); color: var(--color-fg-muted);
	}

	/* ══════════════════════════════════════════════════════════════════════════
	   CARD 5 — Type-only
	══════════════════════════════════════════════════════════════════════════ */
	.c5-list {
		display: flex; flex-direction: column; gap: 0;
		border-block-start: 1px solid var(--color-border-default);
	}

	.c5 {
		display: grid;
		grid-template-columns: var(--size-16) 1px 1fr 2fr;
		gap: var(--space-xl); align-items: center;
		padding-block: var(--space-xl);
		border-block-end: 1px solid var(--color-border-default);
		transition: background var(--duration-fast) var(--ease-out);
		padding-inline: var(--space-md);
		&:hover { background: var(--color-bg-subtle); }
	}

	.c5__index {
		font-family: var(--font-serif); font-size: var(--font-size-2xl);
		font-weight: var(--font-weight-light); font-style: italic;
		color: var(--color-fg-accent);
	}

	.c5__divider { height: 100%; width: 1px; background: var(--color-border-default); }

	.c5__name {
		font-family: var(--font-serif); font-size: var(--font-size-xl);
		font-weight: var(--font-weight-light); color: var(--color-fg-default);
		letter-spacing: var(--letter-spacing-tight);
	}

	.c5__role {
		font-family: var(--font-sans); font-size: var(--font-size-xs);
		letter-spacing: var(--letter-spacing-widest); text-transform: uppercase;
		color: var(--color-fg-muted); margin-block-start: var(--space-xs);
	}

	.c5__bio {
		font-family: var(--font-sans); font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed); color: var(--color-fg-muted);
	}

	/* ══════════════════════════════════════════════════════════════════════════
	   CARD 6 — Tall portrait with role badge
	══════════════════════════════════════════════════════════════════════════ */
	.c6 {}

	.c6__img-wrap {
		position: relative; aspect-ratio: 3 / 4; overflow: hidden;
		border-radius: var(--radius-lg); margin-block-end: var(--space-lg);
	}

	.c6__img {
		width: 100%; height: 100%; object-fit: cover; display: block;
		transition: transform var(--duration-slow) var(--ease-smooth);
		.c6:hover & { transform: scale(1.04); }
	}

	.c6__badge {
		position: absolute; inset-block-start: var(--space-md); inset-inline-start: var(--space-md);
		font-family: var(--font-sans); font-size: var(--font-size-xs);
		font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-wide);
		text-transform: uppercase; color: var(--color-fg-on-brand);
		background: var(--color-bg-brand); padding: var(--space-xs) var(--space-sm);
		border-radius: var(--radius-sm);
	}

	.c6__name {
		font-family: var(--font-serif); font-size: var(--font-size-xl);
		font-weight: var(--font-weight-light); color: var(--color-fg-default);
		letter-spacing: var(--letter-spacing-tight); margin-block-end: var(--space-xs);
	}

	.c6__bio {
		font-family: var(--font-sans); font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed); color: var(--color-fg-muted);
	}

	/* ══════════════════════════════════════════════════════════════════════════
	   CARD 7 — Bordered surface, gold left accent
	══════════════════════════════════════════════════════════════════════════ */
	.c7 {
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border-default);
		border-inline-start: 3px solid var(--color-border-accent);
		border-radius: var(--radius-lg); overflow: hidden;
		box-shadow: var(--shadow-sm);
		transition: box-shadow var(--duration-normal) var(--ease-out), transform var(--duration-normal) var(--ease-out);
		&:hover { box-shadow: var(--shadow-md); transform: translateY(-4px); }
	}

	.c7__img-wrap { aspect-ratio: 4 / 3; overflow: hidden; }

	.c7__img { width: 100%; height: 100%; object-fit: cover; display: block; }

	.c7__body { padding: var(--space-lg); }

	.c7__role {
		font-family: var(--font-sans); font-size: var(--font-size-xs);
		letter-spacing: var(--letter-spacing-widest); text-transform: uppercase;
		color: var(--color-fg-accent); margin-block-end: var(--space-xs);
	}

	.c7__name {
		font-family: var(--font-serif); font-size: var(--font-size-lg);
		font-weight: var(--font-weight-light); color: var(--color-fg-on-surface);
		letter-spacing: var(--letter-spacing-tight); margin-block-end: var(--space-md);
	}

	.c7__bio {
		font-family: var(--font-sans); font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed); color: var(--color-fg-on-surface-muted);
	}

	/* ══════════════════════════════════════════════════════════════════════════
	   CARD 8 — Asymmetric offset grid
	══════════════════════════════════════════════════════════════════════════ */
	.c8-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-xl);

		@media (min-width: 1024px) { grid-template-columns: repeat(4, 1fr); }
	}

	.c8 { position: relative; }

	.c8--offset { margin-block-start: var(--space-3xl); }

	.c8__img {
		width: 100%; aspect-ratio: 4 / 5; object-fit: cover; display: block;
		border-radius: var(--radius-lg);
	}

	.c8__caption { padding-block-start: var(--space-lg); }

	.c8__name {
		font-family: var(--font-serif); font-size: var(--font-size-lg);
		font-weight: var(--font-weight-light); color: var(--color-fg-default);
		letter-spacing: var(--letter-spacing-tight);
	}

	.c8__role {
		font-family: var(--font-sans); font-size: var(--font-size-xs);
		letter-spacing: var(--letter-spacing-widest); text-transform: uppercase;
		color: var(--color-fg-accent); margin-block-start: var(--space-xs);
	}

	/* ══════════════════════════════════════════════════════════════════════════
	   CARD 9 — Hover reveal bio
	══════════════════════════════════════════════════════════════════════════ */
	.c9 { border-radius: var(--radius-lg); overflow: hidden; }

	.c9__img-wrap { position: relative; aspect-ratio: 3 / 4; overflow: hidden; }

	.c9__img {
		width: 100%; height: 100%; object-fit: cover; display: block;
		transition: transform var(--duration-slow) var(--ease-smooth);
		.c9:hover & { transform: scale(1.04); }
	}

	.c9__reveal {
		position: absolute; inset: 0;
		background: color-mix(in srgb, var(--color-bg-brand) 88%, transparent);
		display: flex; align-items: center; padding: var(--space-xl);
		opacity: 0; transition: opacity var(--duration-slow) var(--ease-out);
		.c9:hover & { opacity: 1; }
	}

	.c9__bio {
		font-family: var(--font-sans); font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed); color: var(--color-fg-on-brand);
	}

	.c9__footer {
		padding: var(--space-lg); background: var(--color-bg-surface);
	}

	.c9__name {
		font-family: var(--font-serif); font-size: var(--font-size-lg);
		font-weight: var(--font-weight-light); color: var(--color-fg-on-surface);
		letter-spacing: var(--letter-spacing-tight);
	}

	.c9__role {
		font-family: var(--font-sans); font-size: var(--font-size-xs);
		letter-spacing: var(--letter-spacing-widest); text-transform: uppercase;
		color: var(--color-fg-accent); margin-block-start: var(--space-xs);
	}

	/* ══════════════════════════════════════════════════════════════════════════
	   CARD 10 — Feature row
	══════════════════════════════════════════════════════════════════════════ */
	.c10-list { display: flex; flex-direction: column; gap: var(--space-4xl); }

	.c10 {
		display: grid; grid-template-columns: 1fr;
		gap: var(--space-3xl); align-items: center;

		@media (min-width: 768px) { grid-template-columns: 1fr 1fr; }
	}

	.c10--flip .c10__img-wrap { @media (min-width: 768px) { order: -1; } }

	.c10__role {
		font-family: var(--font-sans); font-size: var(--font-size-xs);
		letter-spacing: var(--letter-spacing-widest); text-transform: uppercase;
		color: var(--color-fg-accent-on-brand); margin-block-end: var(--space-sm);
	}

	.c10__name {
		font-family: var(--font-serif);
		font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-4xl));
		font-weight: var(--font-weight-light); color: var(--color-fg-on-brand);
		letter-spacing: var(--letter-spacing-tight); margin-block-end: var(--space-xl);
	}

	.c10__bio {
		font-family: var(--font-sans); font-size: var(--font-size-base);
		line-height: var(--line-height-relaxed); color: var(--color-fg-on-brand-muted);
		max-width: 44ch;
	}

	.c10__img-wrap { border-radius: var(--radius-lg); overflow: hidden; }

	.c10__img { width: 100%; aspect-ratio: 6 / 7; object-fit: cover; display: block; }

	/* ══════════════════════════════════════════════════════════════════════════
	   CARD 11 — Square + pill badge
	══════════════════════════════════════════════════════════════════════════ */
	.c11 {
		background: var(--color-bg-surface); border-radius: var(--radius-lg);
		overflow: hidden; border: 1px solid var(--color-border-default);
		box-shadow: var(--shadow-sm);
	}

	.c11__img-wrap { aspect-ratio: 1 / 1; overflow: hidden; }

	.c11__img { width: 100%; height: 100%; object-fit: cover; display: block; }

	.c11__body { padding: var(--space-lg); }

	.c11__badge {
		display: inline-block;
		font-family: var(--font-sans); font-size: var(--font-size-xs);
		font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-wide);
		text-transform: uppercase; color: var(--color-fg-accent);
		background: var(--color-bg-accent); padding: var(--space-2xs) var(--space-sm);
		border-radius: var(--radius-full); margin-block-end: var(--space-md);
	}

	.c11__name {
		font-family: var(--font-serif); font-size: var(--font-size-xl);
		font-weight: var(--font-weight-light); color: var(--color-fg-on-surface);
		letter-spacing: var(--letter-spacing-tight); margin-block-end: var(--space-md);
	}

	.c11__bio {
		font-family: var(--font-sans); font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed); color: var(--color-fg-on-surface-muted);
	}

	/* ══════════════════════════════════════════════════════════════════════════
	   CARD 12 — Full-bleed image, inset panel
	══════════════════════════════════════════════════════════════════════════ */
	.c12 { border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-md); }

	.c12__img-wrap { aspect-ratio: 16 / 9; overflow: hidden; }

	.c12__img { width: 100%; height: 100%; object-fit: cover; display: block; }

	.c12__panel {
		display: grid; grid-template-columns: var(--space-xs) 1fr;
		background: var(--color-bg-surface);
	}

	.c12__accent { background: var(--color-fg-accent); }

	.c12__text { padding: var(--space-xl); }

	.c12__role {
		font-family: var(--font-sans); font-size: var(--font-size-xs);
		letter-spacing: var(--letter-spacing-widest); text-transform: uppercase;
		color: var(--color-fg-accent); margin-block-end: var(--space-xs);
	}

	.c12__name {
		font-family: var(--font-serif); font-size: var(--font-size-xl);
		font-weight: var(--font-weight-light); color: var(--color-fg-on-surface);
		letter-spacing: var(--letter-spacing-tight); margin-block-end: var(--space-md);
	}

	.c12__bio {
		font-family: var(--font-sans); font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed); color: var(--color-fg-on-surface-muted);
	}

	/* ══════════════════════════════════════════════════════════════════════════
	   CARD 13 — Large initial, outlined
	══════════════════════════════════════════════════════════════════════════ */
	.c13 {
		border: 1px solid var(--color-border-default); border-radius: var(--radius-lg);
		overflow: hidden; background: var(--color-bg-surface);
	}

	.c13__initial-wrap { position: relative; aspect-ratio: 1 / 1; overflow: hidden; }

	.c13__img { width: 100%; height: 100%; object-fit: cover; display: block; }

	.c13__initial {
		position: absolute; inset-block-end: calc(-1 * var(--space-lg));
		inset-inline-end: var(--space-md);
		font-family: var(--font-serif); font-size: 8rem; font-weight: var(--font-weight-light);
		font-style: italic; line-height: 1;
		color: color-mix(in srgb, var(--color-fg-accent) 20%, transparent);
		pointer-events: none;
	}

	.c13__body { padding: var(--space-lg); }

	.c13__name {
		font-family: var(--font-serif); font-size: var(--font-size-xl);
		font-weight: var(--font-weight-light); color: var(--color-fg-on-surface);
		letter-spacing: var(--letter-spacing-tight); margin-block-end: var(--space-xs);
	}

	.c13__role {
		font-family: var(--font-sans); font-size: var(--font-size-xs);
		letter-spacing: var(--letter-spacing-widest); text-transform: uppercase;
		color: var(--color-fg-accent); margin-block-end: var(--space-md);
	}

	.c13__bio {
		font-family: var(--font-sans); font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed); color: var(--color-fg-on-surface-muted);
	}

	/* ══════════════════════════════════════════════════════════════════════════
	   CARD 14 — Manifesto row
	══════════════════════════════════════════════════════════════════════════ */
	.c14-list {
		display: flex; flex-direction: column; gap: 0;
		border-block-start: 1px solid var(--color-border-default);
	}

	.c14 {
		display: grid; grid-template-columns: 1fr; gap: var(--space-xl);
		padding-block: var(--space-2xl);
		border-block-end: 1px solid var(--color-border-default);

		@media (min-width: 768px) { grid-template-columns: 280px 1fr; align-items: start; }
	}

	.c14__left { display: flex; align-items: flex-start; gap: var(--space-xl); }

	.c14__num {
		font-family: var(--font-serif); font-size: var(--font-size-5xl);
		font-weight: var(--font-weight-light); font-style: italic;
		color: var(--color-fg-accent); line-height: var(--line-height-none); flex-shrink: 0;
	}

	.c14__photo-wrap { border-radius: var(--radius-md); overflow: hidden; flex-shrink: 0; }

	.c14__img { width: var(--size-40); height: var(--size-48); object-fit: cover; display: block; }

	.c14__role {
		font-family: var(--font-sans); font-size: var(--font-size-xs);
		letter-spacing: var(--letter-spacing-widest); text-transform: uppercase;
		color: var(--color-fg-accent); margin-block-end: var(--space-xs);
	}

	.c14__name {
		font-family: var(--font-serif); font-size: var(--font-size-2xl);
		font-weight: var(--font-weight-light); color: var(--color-fg-default);
		letter-spacing: var(--letter-spacing-tight); margin-block-end: var(--space-lg);
	}

	.c14__bio {
		font-family: var(--font-sans); font-size: var(--font-size-base);
		line-height: var(--line-height-relaxed); color: var(--color-fg-muted); max-width: 56ch;
	}

	/* ══════════════════════════════════════════════════════════════════════════
	   CARD 15 — Glass tint on brand
	══════════════════════════════════════════════════════════════════════════ */
	.c15 {
		background: color-mix(in srgb, var(--color-bg-brand-muted) 60%, transparent);
		border: 1px solid color-mix(in srgb, var(--color-fg-on-brand) 12%, transparent);
		border-radius: var(--radius-lg); overflow: hidden;
		backdrop-filter: blur(12px);
		transition: transform var(--duration-slow) var(--ease-smooth);
		&:hover { transform: translateY(-6px); }
	}

	.c15__img-wrap { aspect-ratio: 3 / 4; overflow: hidden; }

	.c15__img {
		width: 100%; height: 100%; object-fit: cover; display: block;
		transition: transform var(--duration-slow) var(--ease-smooth);
		.c15:hover & { transform: scale(1.04); }
	}

	.c15__body { padding: var(--space-xl); }

	.c15__role {
		font-family: var(--font-sans); font-size: var(--font-size-xs);
		letter-spacing: var(--letter-spacing-widest); text-transform: uppercase;
		color: var(--color-fg-accent-on-brand); margin-block-end: var(--space-xs);
	}

	.c15__name {
		font-family: var(--font-serif); font-size: var(--font-size-xl);
		font-weight: var(--font-weight-light); color: var(--color-fg-on-brand);
		letter-spacing: var(--letter-spacing-tight); margin-block-end: var(--space-md);
	}

	.c15__bio {
		font-family: var(--font-sans); font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed); color: var(--color-fg-on-brand-muted);
	}

	/* ══════════════════════════════════════════════════════════════════════════
	   CARD 16 — Compact inline row
	══════════════════════════════════════════════════════════════════════════ */
	.c16-list {
		display: flex; flex-direction: column; gap: 0;
		border-block-start: 1px solid var(--color-border-default);
	}

	.c16 {
		display: grid;
		grid-template-columns: var(--size-20) 1fr;
