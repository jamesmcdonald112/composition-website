		<div class="wrapper wrapper--wide b-grid b-grid--flipped">
			<div class="b-card"><ServiceCard {...card} /></div>
			<div class="b-left">
				<p class="b-eyebrow b-eyebrow--navy">{featuredService.eyebrow}</p>
				<div class="b-rule b-rule--navy"></div>
