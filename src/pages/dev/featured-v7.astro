		<p class="lbl">B1 · White / Original reference</p>
		<div class="wrapper wrapper--wide b-grid">
			<div class="b-left">
				<p class="b-eyebrow b-eyebrow--amber">{featuredService.eyebrow}</p>
				<div class="b-rule b-rule--amber"></div>
				<h2 class="b-heading b-heading--default">{featuredService.card.title}</h2>
				<div class="b-steps">
					{svc.process.slice(0, 3).map((step, i) => (
						<div class="b-step">
							<span class="b-num b-num--amber">0{i + 1}</span>
							<div class="b-step-text">
								<strong class="b-step-head b-step-head--default">{step.title}</strong>
								<p class="b-step-body b-step-body--default">{step.description}</p>
							</div>
						</div>
					))}
				</div>
				<a href={svc.href} class="btn-primary">Our property service</a>
			</div>
			<div class="b-card"><ServiceCard {...card} /></div>
		</div>
	</section>

	<!-- B2 · Navy / amber eyebrow / white heading / white steps / card right -->
	<section class="v v-navy">
		<p class="lbl lbl-light">B2 · Navy / Amber eyebrow / White heading + steps</p>
