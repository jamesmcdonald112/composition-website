			</div>
			<div class="b-card"><ServiceCard {...card} /></div>
		</div>
	</section>

	<!-- B3 · Stone / navy eyebrow / navy numbers / card right -->
	<section class="v v-stone">
		<p class="lbl">B3 · Stone / Navy eyebrow / Navy numbers / 4 steps</p>
		<div class="wrapper wrapper--wide b-grid">
			<div class="b-left">
				<p class="b-eyebrow b-eyebrow--navy">{featuredService.eyebrow}</p>
				<div class="b-rule b-rule--navy"></div>
				<h2 class="b-heading b-heading--default">{featuredService.card.title}</h2>
