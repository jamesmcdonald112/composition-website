---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ServiceCard from "../../components/services/ServiceCards/ServiceCard/ServiceCard.astro";
import { homePageContent } from "../../config/home";
import { buyingAndSellingProperty as svc } from "../../config/services";

const { featuredService } = homePageContent;
const { aside } = featuredService;
const stats = homePageContent.trustStrip.stats;

// helper — card props repeated each time
const card = {
	title: svc.title,
	href: svc.href,
	image: svc.image,
	imageClass: svc.imageClass,
	description: svc.description,
	level: 3 as const,
};
---

<BaseLayout title="Featured V7 — Card Variants" description="Dev — 20 variations on patterns A and B" canonicalPath="/dev/featured-v7">
<div class="dev-page">

<!-- ═══════════════════════════════════════════════════════════════════════
     PATTERN A  —  Large eyebrow · Text col · Card col · Stats band below
     ══════════════════════════════════════════════════════════════════════ -->

	<!-- A1 · Navy (original reference) -->
	<section class="v v-navy">
		<p class="lbl lbl-light">A1 · Navy / Original reference</p>
		<div class="wrapper wrapper--wide a-wrap">
			<div class="a-top">
				<div class="a-text">
					<p class="a-eyebrow a-eyebrow--brand">{featuredService.eyebrow}</p>
					<div class="a-rule a-rule--brand"></div>
					<h2 class="a-heading a-heading--brand">{featuredService.card.title}</h2>
					<p class="a-body a-body--brand">{aside.intro}</p>
				</div>
				<div class="a-card"><ServiceCard {...card} /></div>
			</div>
			<div class="a-stats a-stats--brand">
				{stats.map(s => (
					<div class="a-stat">
						<span class="a-stat-val a-stat-val--brand">{s.value}</span>
						<span class="a-stat-lbl a-stat-lbl--brand">{s.label}</span>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- A2 · Stone bg / amber eyebrow / stats on navy band -->
	<section class="v v-stone">
		<p class="lbl">A2 · Stone / Amber eyebrow / Navy stats band</p>
		<div class="wrapper wrapper--wide a-wrap">
			<div class="a-top">
				<div class="a-text">
					<p class="a-eyebrow a-eyebrow--amber">{featuredService.eyebrow}</p>
					<div class="a-rule a-rule--amber"></div>
					<h2 class="a-heading a-heading--default">{featuredService.card.title}</h2>
					<p class="a-body a-body--default">{aside.intro}</p>
				</div>
				<div class="a-card"><ServiceCard {...card} /></div>
			</div>
		</div>
		<div class="a-stats-navy-band">
			<div class="wrapper wrapper--wide a-stats a-stats--brand">
				{stats.map(s => (
					<div class="a-stat">
						<span class="a-stat-val a-stat-val--brand">{s.value}</span>
						<span class="a-stat-lbl a-stat-lbl--brand">{s.label}</span>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- A3 · White bg / navy eyebrow / amber stats band -->
	<section class="v v-white">
		<p class="lbl">A3 · White / Navy eyebrow / Amber stats band</p>
		<div class="wrapper wrapper--wide a-wrap">
			<div class="a-top">
				<div class="a-text">
					<p class="a-eyebrow a-eyebrow--navy">{featuredService.eyebrow}</p>
					<div class="a-rule a-rule--navy"></div>
					<h2 class="a-heading a-heading--default">{featuredService.card.title}</h2>
					<p class="a-body a-body--default">{aside.intro}</p>
				</div>
				<div class="a-card"><ServiceCard {...card} /></div>
			</div>
		</div>
		<div class="a-stats-amber-band">
			<div class="wrapper wrapper--wide a-stats a-stats--on-amber">
				{stats.map(s => (
					<div class="a-stat">
						<span class="a-stat-val a-stat-val--on-amber">{s.value}</span>
						<span class="a-stat-lbl a-stat-lbl--on-amber">{s.label}</span>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- A4 · Amber bg / navy eyebrow / white stats on stone band -->
	<section class="v v-amber">
		<p class="lbl">A4 · Amber / Navy eyebrow / Stone stats band</p>
		<div class="wrapper wrapper--wide a-wrap">
			<div class="a-top">
				<div class="a-text">
					<p class="a-eyebrow a-eyebrow--navy">{featuredService.eyebrow}</p>
