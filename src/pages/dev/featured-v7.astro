			</div>
		</div>
		<div class="a-stats-amber-band">
			<div class="wrapper wrapper--wide a-stats a-stats--on-amber">
				{stats.map(s => (
					<div class="a-stat">
						<span class="a-stat-val a-stat-val--on-amber">{s.value}</span>
						<span class="a-stat-lbl a-stat-lbl--on-amber">{s.label}</span>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- A9 · Amber / white card on amber / eyebrow amber small / navy stats -->
	<section class="v v-amber">
		<p class="lbl">A9 · Amber / Small amber eyebrow / Card right / Navy stats</p>
		<div class="wrapper wrapper--wide a-wrap">
			<div class="a-top">
				<div class="a-text">
					<p class="a-eyebrow a-eyebrow--sm-amber">{featuredService.eyebrow}</p>
					<div class="a-rule a-rule--amber"></div>
					<h2 class="a-heading a-heading--default a-heading--display">{featuredService.card.title}</h2>
					<p class="a-body a-body--default">{aside.intro}</p>
					<a href={svc.href} class="btn-primary">Our property service</a>
				</div>
				<div class="a-card"><ServiceCard {...card} /></div>
			</div>
		</div>
		<div class="a-stats-navy-band">
			<div class="wrapper wrapper--wide a-stats a-stats--brand">
				{stats.map(s => (
					<div class="a-stat">
						<span class="a-stat-val a-stat-val--brand">{s.value}</span>
						<span class="a-stat-lbl a-stat-lbl--brand">{s.label}</span>
					</div>
				))}
			</div>
		</div>
