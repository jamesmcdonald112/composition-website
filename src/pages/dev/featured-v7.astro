					<p class="a-body a-body--brand">{aside.intro}</p>
					<a href={svc.href} class="btn-outline-light">Our property service</a>
				</div>
				<div class="a-card"><ServiceCard {...card} /></div>
			</div>
			<div class="a-kps a-kps--brand a-kps--2col">
				{aside.keyPoints.map(kp => (
					<div class="a-kp">
						<p class="a-kp-head a-kp-head--brand">{kp.heading}</p>
						<p class="a-kp-body a-kp-body--brand">{kp.body}</p>
					</div>
				))}
			</div>
		</div>
	</section>


