					<div class="a-stat">
						<span class="a-stat-val a-stat-val--accent">{s.value}</span>
						<span class="a-stat-lbl a-stat-lbl--muted">{s.label}</span>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- A5 · Navy / amber eyebrow / no stats band — key points instead -->
	<section class="v v-navy">
		<p class="lbl lbl-light">A5 · Navy / Amber eyebrow / Key points grid instead of stats</p>
		<div class="wrapper wrapper--wide a-wrap">
			<div class="a-top">
				<div class="a-text">
					<p class="a-eyebrow a-eyebrow--brand">{featuredService.eyebrow}</p>
					<div class="a-rule a-rule--brand"></div>
					<h2 class="a-heading a-heading--brand">{featuredService.card.title}</h2>
					<p class="a-body a-body--brand">{aside.intro}</p>
					<a href={svc.href} class="btn-outline-light">Our property service</a>
				</div>
				<div class="a-card"><ServiceCard {...card} /></div>
			</div>
			<div class="a-kps a-kps--brand">
				{aside.keyPoints.map(kp => (
					<div class="a-kp">
						<p class="a-kp-head a-kp-head--brand">{kp.heading}</p>
						<p class="a-kp-body a-kp-body--brand">{kp.body}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- A6 · Charcoal / amber eyebrow / amber stats inline (no band) -->
	<section class="v v-charcoal">
		<p class="lbl lbl-light">A6 · Charcoal / Amber eyebrow / Amber stats inline</p>
		<div class="wrapper wrapper--wide a-wrap">
			<div class="a-top">
				<div class="a-text">
					<p class="a-eyebrow a-eyebrow--brand">{featuredService.eyebrow}</p>
					<div class="a-rule a-rule--brand"></div>
					<h2 class="a-heading a-heading--brand">{featuredService.card.title}</h2>
					<p class="a-body a-body--brand">{aside.intro}</p>
					<div class="a-stats a-stats--inline">
						{stats.map(s => (
							<div class="a-stat">
								<span class="a-stat-val a-stat-val--brand">{s.value}</span>
								<span class="a-stat-lbl a-stat-lbl--brand">{s.label}</span>
							</div>
						))}
					</div>
					<a href={svc.href} class="btn-outline-light">Our property service</a>
				</div>
				<div class="a-card"><ServiceCard {...card} /></div>
			</div>
		</div>
	</section>

	<!-- A7 · White / eyebrow + heading wider column / card narrower / navy stats -->
	<section class="v v-white">
