---
/*
  V18 — Hairline grid
  No card shapes at all. Content sits in a strict grid held together by
  hairline rules. Maximum restraint — Swiss typography, almost Vignelli.
*/
import { curriculum } from "../../../config/curriculum";
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="V18 — Hairline grid" noIndex={true}>
	<main class="page">
		<div class="page__inner wrapper wrapper--wide">
			<p class="dev-back"><a href="/dev/curriculum-variations">← All variations</a></p>
			<header class="page__header">
				<p class="eyebrow">The training path</p>
				<h1>Eight modules, one programme of study</h1>
			</header>

			<div class="hair">
				<div class="hair__head">
					<span class="hair__head-label">No.</span>
					<span class="hair__head-label">Module</span>
					<span class="hair__head-label">Subject</span>
					<span class="hair__head-label">Outline</span>
				</div>
				{curriculum.map((m) => (
					<article class="hair__row">
						<span class="hair__num">{m.numeral}</span>
						<h3 class="hair__name">{m.name}</h3>
						<p class="hair__sub">{m.subtitle}</p>
						<p class="hair__body">{m.body}</p>
					</article>
				))}
			</div>
		</div>
	</main>
</BaseLayout>

<style>
	.page { background-color: var(--color-bg-page); padding-block: var(--space-3xl); min-height: 100svh; }
	.page__header { margin-block-end: var(--space-2xl); max-width: 60ch; }
	.page__header h1 { font-family: var(--font-serif); font-weight: var(--font-weight-light); font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-3xl)); margin: var(--space-sm) 0; }
	.eyebrow { font-family: var(--font-sans); font-size: var(--font-size-xs); font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-accent); margin: 0; }
	.dev-back { margin-block-end: var(--space-lg); font-family: var(--font-sans); font-size: var(--font-size-sm); }
	.dev-back a { color: var(--color-fg-muted); text-decoration: none; }

	.hair {
		border-block-start: 1px solid var(--color-fg-default);
		border-block-end: 1px solid var(--color-fg-default);
	}
	.hair__head, .hair__row {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-md);
		padding: var(--space-md) 0;
		border-block-end: 1px solid var(--color-border-default);

		@media (min-width: 768px) {
			grid-template-columns: 80px 1fr 1.4fr 2.4fr;
			gap: var(--space-xl);
			padding: var(--space-lg) 0;
			align-items: start;
		}
	}
	.hair__row:last-child { border-block-end: 0; }
	.hair__head { display: none; @media (min-width: 768px) { display: grid; padding: var(--space-sm) 0; border-block-end: 1px solid var(--color-fg-default); } }
	.hair__head-label { font-family: var(--font-sans); font-size: var(--font-size-xs); font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-subtle); }
	.hair__num { font-family: var(--font-serif); font-style: italic; font-weight: var(--font-weight-light); font-size: var(--font-size-2xl); line-height: 1; color: var(--color-fg-accent); }
	.hair__name { font-family: var(--font-serif); font-weight: var(--font-weight-normal); font-size: var(--font-size-lg); margin: 0; }
	.hair__sub { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-sm); color: var(--color-fg-muted); margin: 0; }
	.hair__body { font-family: var(--font-sans); font-size: var(--font-size-sm); line-height: var(--line-height-relaxed); color: var(--color-fg-default); margin: 0; }
</style>
