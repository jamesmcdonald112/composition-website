---
/*
  V14 — Roman monument numerals
  Huge italic Roman numerals are the dominant visual element. Each numeral
  half-overlaps a small content card. Numerals are the architecture; cards
  are the inhabitants.
*/
import { curriculum } from "../../../config/curriculum";
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="V14 — Roman monument numerals" noIndex={true}>
	<main class="page">
		<div class="page__inner wrapper wrapper--wide">
			<p class="dev-back"><a href="/dev/curriculum-variations">← All variations</a></p>
			<header class="page__header">
				<p class="eyebrow">The training path</p>
				<h1>Eight modules, one programme of study</h1>
			</header>

			<div class="monuments">
				{curriculum.map((m) => (
					<article class="monument">
						<span class="monument__num" aria-hidden="true">{m.numeral}</span>
						<div class="monument__card">
							<h3 class="monument__name">{m.name}</h3>
							<p class="monument__sub">{m.subtitle}</p>
							<p class="monument__body">{m.body}</p>
						</div>
					</article>
				))}
			</div>
		</div>
	</main>
</BaseLayout>

<style>
	.page { background-color: var(--color-bg-page); padding-block: var(--space-3xl); min-height: 100svh; }
	.page__header { margin-block-end: var(--space-2xl); max-width: 60ch; }
	.page__header h1 { font-family: var(--font-serif); font-weight: var(--font-weight-light); font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-3xl)); margin: var(--space-sm) 0; }
	.eyebrow { font-family: var(--font-sans); font-size: var(--font-size-xs); font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-accent); margin: 0; }
	.dev-back { margin-block-end: var(--space-lg); font-family: var(--font-sans); font-size: var(--font-size-sm); }
	.dev-back a { color: var(--color-fg-muted); text-decoration: none; }

	.monuments { display: grid; grid-template-columns: 1fr; gap: var(--space-3xl); @media (min-width: 768px) { grid-template-columns: 1fr 1fr; } @media (min-width: 1280px) { grid-template-columns: 1fr 1fr 1fr 1fr; } }
	.monument { position: relative; padding-block-start: var(--space-3xl); }
	.monument__num {
		font-family: var(--font-serif); font-style: italic; font-weight: var(--font-weight-light);
		font-size: clamp(8rem, 14vw, 12rem); line-height: 0.85;
		color: var(--color-fg-accent);
		opacity: 0.85;
		position: absolute; top: 0; left: 0;
		pointer-events: none;
		letter-spacing: -0.04em;
	}
	.monument__card {
		position: relative;
		background-color: var(--color-bg-surface);
		padding: var(--space-lg);
		border: 1px solid var(--color-border-default);
		margin-block-start: 4rem;
		display: flex; flex-direction: column; gap: var(--space-sm);
	}
	.monument__name { font-family: var(--font-serif); font-weight: var(--font-weight-normal); font-size: var(--font-size-xl); margin: 0; }
	.monument__sub { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-sm); color: var(--color-fg-muted); margin: 0; }
	.monument__body { font-family: var(--font-sans); font-size: var(--font-size-sm); line-height: var(--line-height-relaxed); color: var(--color-fg-default); margin: 0; }
</style>
