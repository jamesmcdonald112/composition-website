---
/*
  V05 — Staggered zigzag
  Cards alternate left/right in a two-column zigzag. Each card sits in
  half the grid. Creates a serpentine reading rhythm.
*/
import { curriculum } from "../../../config/curriculum";
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="V05 — Staggered zigzag" noIndex={true}>
	<main class="page">
		<div class="page__inner wrapper wrapper--wide">
			<p class="dev-back"><a href="/dev/curriculum-variations">← All variations</a></p>
			<header class="page__header">
				<p class="eyebrow">The training path</p>
				<h1>Eight modules, one programme of study</h1>
			</header>

			<div class="zigzag">
				{curriculum.map((m, i) => (
					<article class={`zigzag__card ${i % 2 === 0 ? "zigzag__card--left" : "zigzag__card--right"}`}>
						<span class="zigzag__num">{m.numeral}</span>
						<h3 class="zigzag__name">{m.name}</h3>
						<p class="zigzag__sub">{m.subtitle}</p>
						<p class="zigzag__body">{m.body}</p>
					</article>
				))}
			</div>
		</div>
	</main>
</BaseLayout>

<style>
	.page { background-color: var(--color-bg-page); padding-block: var(--space-3xl); min-height: 100svh; }
	.page__header { margin-block-end: var(--space-2xl); max-width: 60ch; }
	.page__header h1 { font-family: var(--font-serif); font-weight: var(--font-weight-light); font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-3xl)); margin: var(--space-sm) 0; }
	.eyebrow { font-family: var(--font-sans); font-size: var(--font-size-xs); font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-accent); margin: 0; }
	.dev-back { margin-block-end: var(--space-lg); font-family: var(--font-sans); font-size: var(--font-size-sm); }
	.dev-back a { color: var(--color-fg-muted); text-decoration: none; }

	.zigzag {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-md);

		@media (min-width: 768px) {
			grid-template-columns: 1fr 1fr;
			gap: var(--space-lg);
			column-gap: var(--space-3xl);
		}
	}
	.zigzag__card {
		padding: var(--space-xl);
		background-color: var(--color-bg-surface);
		border: 1px solid var(--color-border-default);
		display: flex; flex-direction: column; gap: var(--space-sm);
	}
	@media (min-width: 768px) {
		.zigzag__card--left { grid-column: 1; }
		.zigzag__card--right { grid-column: 2; transform: translateY(var(--space-2xl)); }
	}
	.zigzag__num { font-family: var(--font-serif); font-style: italic; font-weight: var(--font-weight-light); font-size: var(--font-size-3xl); line-height: 1; color: var(--color-fg-accent); }
	.zigzag__name { font-family: var(--font-serif); font-weight: var(--font-weight-normal); font-size: var(--font-size-xl); margin: 0; }
	.zigzag__sub { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-sm); color: var(--color-fg-muted); margin: 0; }
	.zigzag__body { font-family: var(--font-sans); font-size: var(--font-size-sm); line-height: var(--line-height-relaxed); color: var(--color-fg-default); margin: 0; }
</style>
