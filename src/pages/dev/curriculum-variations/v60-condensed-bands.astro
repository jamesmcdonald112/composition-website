---
/*
  V60 — Condensed bands
  All four phases compact enough to be visible on one viewport. Each phase
  is a tighter band: small phase header strip + condensed cards. Useful
  for a "see the whole curriculum at a glance" view.
*/
import { phases } from "../../../config/curriculum";
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="V60 — Condensed bands" noIndex={true}>
	<main class="page">
		<div class="page__inner wrapper wrapper--wide">
			<p class="dev-back"><a href="/dev/curriculum-variations">← All variations</a></p>
			<header class="page__header">
				<p class="eyebrow">The training path</p>
				<h1>Eight modules across four phases</h1>
			</header>

			<div class="bands">
				{phases.map((phase) => (
					<section class="band">
						<header class="band__head">
							<h2 class="band__name">{phase.label}</h2>
							<p class="band__intro">{phase.intro}</p>
						</header>
						<div class="band__grid" style={`--n: ${phase.modules.length}`}>
							{phase.modules.map((m) => (
								<article class="card">
									<span class="card__num">{m.numeral}</span>
									<h3 class="card__name">{m.name}</h3>
									<p class="card__sub">{m.subtitle}</p>
								</article>
							))}
						</div>
					</section>
				))}
			</div>
		</div>
	</main>
</BaseLayout>

<style>
	.page { background-color: var(--color-bg-page); padding-block: var(--space-3xl); min-height: 100svh; }
	.page__header { margin-block-end: var(--space-2xl); max-width: 60ch; }
	.page__header h1 { font-family: var(--font-serif); font-weight: var(--font-weight-light); font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-3xl)); margin: var(--space-sm) 0; }
	.eyebrow { font-family: var(--font-sans); font-size: var(--font-size-xs); font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-accent); margin: 0; }
	.dev-back { margin-block-end: var(--space-lg); font-family: var(--font-sans); font-size: var(--font-size-sm); }
	.dev-back a { color: var(--color-fg-muted); text-decoration: none; }

	.bands { display: flex; flex-direction: column; gap: var(--space-md); }
	.band { display: grid; grid-template-columns: 1fr; gap: var(--space-md); padding: var(--space-md) var(--space-lg); background-color: var(--color-bg-surface); border: 1px solid var(--color-border-default); border-inline-start: 4px solid var(--color-fg-accent); @media (min-width: 1024px) { grid-template-columns: minmax(260px, 1fr) minmax(0, 3fr); gap: var(--space-2xl); align-items: center; } }
	.band__head { display: flex; flex-direction: column; gap: var(--space-2xs); }
	.band__name { font-family: var(--font-serif); font-weight: var(--font-weight-normal); font-size: var(--font-size-lg); margin: 0; line-height: var(--line-height-tight); }
	.band__intro { font-family: var(--font-sans); font-size: var(--font-size-xs); line-height: var(--line-height-normal); color: var(--color-fg-muted); margin: 0; }
	.band__grid { display: grid; grid-template-columns: 1fr; gap: var(--space-sm); @media (min-width: 640px) { grid-template-columns: repeat(min(var(--n), 3), 1fr); } }
	.card { padding: var(--space-sm) var(--space-md); display: flex; flex-direction: column; gap: 2px; background-color: var(--color-bg-page); border: 1px solid var(--color-border-default); }
	.card__num { font-family: var(--font-serif); font-style: italic; font-weight: var(--font-weight-light); font-size: var(--font-size-base); line-height: 1; color: var(--color-fg-accent); }
	.card__name { font-family: var(--font-serif); font-weight: var(--font-weight-normal); font-size: var(--font-size-base); margin: 0; line-height: var(--line-height-tight); }
	.card__sub { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-xs); color: var(--color-fg-muted); margin: 0; }
</style>
