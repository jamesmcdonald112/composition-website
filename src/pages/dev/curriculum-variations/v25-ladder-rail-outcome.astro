---
/*
  V25 — Ladder, outcome on right rail
  Body in the main column; the outcome lifted onto a separate right-rail
  panel with a brand-coloured background. Forces the reader's eye to the
  concrete promise — "by the end you will…"
*/
import { curriculum } from "../../../config/curriculum";
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="V25 — Ladder, outcome rail" noIndex={true}>
	<main class="page">
		<div class="page__inner wrapper wrapper--wide">
			<p class="dev-back"><a href="/dev/curriculum-variations">← All variations</a></p>
			<header class="page__header">
				<p class="eyebrow">The training path</p>
				<h1>Eight modules, one programme of study</h1>
			</header>

			<ol class="ladder">
				{curriculum.map((m) => (
					<li class="ladder__rung">
						<div class="ladder__main">
							<header class="ladder__head">
								<span class="ladder__num">{m.numeral}</span>
								<div class="ladder__title">
									<h3 class="ladder__name">{m.name}</h3>
									<p class="ladder__sub">{m.subtitle}</p>
								</div>
							</header>
							<p class="ladder__body">{m.body}</p>
						</div>
						<aside class="ladder__rail">
							<p class="ladder__rail-label">By the end of the module</p>
							<p class="ladder__rail-text">{m.outcome}</p>
						</aside>
					</li>
				))}
			</ol>
		</div>
	</main>
</BaseLayout>

<style>
	.page { background-color: var(--color-bg-page); padding-block: var(--space-3xl); min-height: 100svh; }
	.page__header { margin-block-end: var(--space-2xl); max-width: 60ch; }
	.page__header h1 { font-family: var(--font-serif); font-weight: var(--font-weight-light); font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-3xl)); margin: var(--space-sm) 0; }
	.eyebrow { font-family: var(--font-sans); font-size: var(--font-size-xs); font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-accent); margin: 0; }
	.dev-back { margin-block-end: var(--space-lg); font-family: var(--font-sans); font-size: var(--font-size-sm); }
	.dev-back a { color: var(--color-fg-muted); text-decoration: none; }

	.ladder { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-md); }
	.ladder__rung {
		display: grid;
		grid-template-columns: 1fr;
		background-color: var(--color-bg-surface);
		border: 1px solid var(--color-border-default);
		@media (min-width: 1024px) { grid-template-columns: minmax(0, 2.4fr) minmax(0, 1fr); }
	}
	.ladder__main { padding: var(--space-xl) var(--space-2xl); display: flex; flex-direction: column; gap: var(--space-lg); }
	.ladder__head { display: flex; align-items: baseline; gap: var(--space-lg); }
	.ladder__num { font-family: var(--font-serif); font-style: italic; font-weight: var(--font-weight-light); font-size: var(--font-size-4xl); line-height: 1; color: var(--color-fg-accent); min-width: 2ch; }
	.ladder__title { display: flex; flex-direction: column; gap: var(--space-2xs); }
	.ladder__name { font-family: var(--font-serif); font-weight: var(--font-weight-normal); font-size: var(--font-size-2xl); margin: 0; line-height: var(--line-height-tight); }
	.ladder__sub { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-base); color: var(--color-fg-muted); margin: 0; }
	.ladder__body { font-family: var(--font-sans); font-size: var(--font-size-base); line-height: var(--line-height-relaxed); color: var(--color-fg-default); margin: 0; }

	.ladder__rail {
		background-color: var(--color-bg-brand);
		color: var(--color-fg-on-brand);
		padding: var(--space-xl);
		display: flex; flex-direction: column; gap: var(--space-sm); justify-content: center;
	}
	.ladder__rail-label { font-family: var(--font-sans); font-size: var(--font-size-xs); font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-accent-on-brand); margin: 0; }
	.ladder__rail-text { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-base); line-height: var(--line-height-relaxed); color: var(--color-fg-on-brand); margin: 0; }
</style>
