---
/*
  V28 — Brand bar right
  Horizontal card; main body on the left, a thin brand-coloured bar on
  the right holds the outcome and numeral. Asymmetric, like an editorial
  page with a coloured marginalia column.
*/
import { curriculum } from "../../../config/curriculum";
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="V28 — Brand bar right" noIndex={true}>
	<main class="page">
		<div class="page__inner wrapper wrapper--wide">
			<p class="dev-back"><a href="/dev/curriculum-variations">← All variations</a></p>
			<header class="page__header">
				<p class="eyebrow">The training path</p>
				<h1>Eight modules, one programme of study</h1>
			</header>

			<div class="cards">
				{curriculum.map((m) => (
					<article class="card">
						<div class="card__main">
							<header class="card__head">
								<span class="card__numeral">{m.numeral}</span>
								<div>
									<h3 class="card__name">{m.name}</h3>
									<p class="card__sub">{m.subtitle}</p>
								</div>
							</header>
							<p class="card__body">{m.body}</p>
						</div>
						<aside class="card__bar">
							<p class="card__bar-label">Outcome</p>
							<p class="card__bar-text">{m.outcome}</p>
							<span class="card__bar-numeral">{m.numeral}</span>
						</aside>
					</article>
				))}
			</div>
		</div>
	</main>
</BaseLayout>

<style>
	.page { background-color: var(--color-bg-page); padding-block: var(--space-3xl); min-height: 100svh; }
	.page__header { margin-block-end: var(--space-2xl); max-width: 60ch; }
	.page__header h1 { font-family: var(--font-serif); font-weight: var(--font-weight-light); font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-3xl)); margin: var(--space-sm) 0; }
	.eyebrow { font-family: var(--font-sans); font-size: var(--font-size-xs); font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-accent); margin: 0; }
	.dev-back { margin-block-end: var(--space-lg); font-family: var(--font-sans); font-size: var(--font-size-sm); }
	.dev-back a { color: var(--color-fg-muted); text-decoration: none; }

	.cards { display: flex; flex-direction: column; gap: var(--space-md); }
	.card {
		display: grid; grid-template-columns: 1fr;
		background-color: var(--color-bg-surface);
		border: 1px solid var(--color-border-default);
		@media (min-width: 768px) { grid-template-columns: minmax(0, 3fr) minmax(0, 1.2fr); }
	}
	.card__main { padding: var(--space-xl) var(--space-2xl); display: flex; flex-direction: column; gap: var(--space-md); }
	.card__head { display: flex; align-items: baseline; gap: var(--space-lg); }
	.card__numeral { font-family: var(--font-serif); font-style: italic; font-weight: var(--font-weight-light); font-size: var(--font-size-4xl); line-height: 1; color: var(--color-fg-accent); min-width: 2ch; }
	.card__name { font-family: var(--font-serif); font-weight: var(--font-weight-normal); font-size: var(--font-size-2xl); margin: 0; line-height: var(--line-height-tight); }
	.card__sub { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-base); color: var(--color-fg-muted); margin: var(--space-2xs) 0 0; }
	.card__body { font-family: var(--font-sans); font-size: var(--font-size-base); line-height: var(--line-height-relaxed); color: var(--color-fg-default); margin: 0; }
	.card__bar {
		background-color: var(--color-bg-brand);
		color: var(--color-fg-on-brand);
		padding: var(--space-xl);
		display: flex; flex-direction: column; gap: var(--space-sm);
		position: relative;
	}
	.card__bar-label { font-family: var(--font-sans); font-size: var(--font-size-xs); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-accent-on-brand); margin: 0; }
	.card__bar-text { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-base); line-height: var(--line-height-relaxed); color: var(--color-fg-on-brand); margin: 0; }
	.card__bar-numeral { font-family: var(--font-serif); font-style: italic; font-weight: var(--font-weight-light); font-size: var(--font-size-5xl); line-height: 1; color: var(--color-fg-accent-on-brand); opacity: 0.25; margin: auto 0 0; align-self: flex-end; }
</style>
