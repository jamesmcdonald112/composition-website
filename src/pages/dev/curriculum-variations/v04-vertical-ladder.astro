---
/*
  V04 — Vertical ladder
  Full-width cards stacked. Each broken into three columns: numeral, name +
  subtitle, body. A "rungs of a ladder" feel — top-to-bottom reading.
*/
import { curriculum } from "../../../config/curriculum";
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="V04 — Vertical ladder" noIndex={true}>
	<main class="page">
		<div class="page__inner wrapper wrapper--wide">
			<p class="dev-back"><a href="/dev/curriculum-variations">← All variations</a></p>
			<header class="page__header">
				<p class="eyebrow">The training path</p>
				<h1>Eight modules, one programme of study</h1>
			</header>

			<ol class="ladder">
				{curriculum.map((m) => (
					<li class="ladder__rung">
						<div class="ladder__num-col"><span class="ladder__num">{m.numeral}</span></div>
						<div class="ladder__name-col">
							<h3 class="ladder__name">{m.name}</h3>
							<p class="ladder__sub">{m.subtitle}</p>
						</div>
						<div class="ladder__body-col">
							<p class="ladder__body">{m.body}</p>
							<p class="ladder__out">{m.outcome}</p>
						</div>
					</li>
				))}
			</ol>
		</div>
	</main>
</BaseLayout>

<style>
	.page { background-color: var(--color-bg-page); padding-block: var(--space-3xl); min-height: 100svh; }
	.page__header { margin-block-end: var(--space-2xl); max-width: 60ch; }
	.page__header h1 { font-family: var(--font-serif); font-weight: var(--font-weight-light); font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-3xl)); margin: var(--space-sm) 0; }
	.eyebrow { font-family: var(--font-sans); font-size: var(--font-size-xs); font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-accent); margin: 0; }
	.dev-back { margin-block-end: var(--space-lg); font-family: var(--font-sans); font-size: var(--font-size-sm); }
	.dev-back a { color: var(--color-fg-muted); text-decoration: none; }

	.ladder { list-style: none; padding: 0; margin: 0; }
	.ladder__rung {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-md);
		padding: var(--space-xl);
		background-color: var(--color-bg-surface);
		border: 1px solid var(--color-border-default);
		margin-block-end: var(--space-sm);

		@media (min-width: 1024px) {
			grid-template-columns: var(--size-20) minmax(0, 1fr) minmax(0, 2fr);
			gap: var(--space-2xl);
			align-items: start;
			padding: var(--space-2xl);
		}
	}
	.ladder__num { font-family: var(--font-serif); font-style: italic; font-weight: var(--font-weight-light); font-size: var(--font-size-4xl); line-height: 1; color: var(--color-fg-accent); }
	.ladder__name { font-family: var(--font-serif); font-weight: var(--font-weight-normal); font-size: var(--font-size-2xl); margin: 0; }
	.ladder__sub { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-base); color: var(--color-fg-muted); margin: var(--space-2xs) 0 0; }
	.ladder__body { font-family: var(--font-sans); font-size: var(--font-size-base); line-height: var(--line-height-relaxed); color: var(--color-fg-default); margin: 0; }
	.ladder__out { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-sm); color: var(--color-fg-muted); margin: var(--space-sm) 0 0; }
</style>
