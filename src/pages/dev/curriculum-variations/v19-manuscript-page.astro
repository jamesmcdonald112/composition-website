---
/*
  V19 — Manuscript page
  Illuminated initial letters. Each module opens with a very large
  decorated initial in the accent colour — the way a medieval manuscript
  opened a chapter. Long-form prose treatment, single column.
*/
import { curriculum } from "../../../config/curriculum";
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="V19 — Manuscript page" noIndex={true}>
	<main class="page">
		<div class="page__inner wrapper wrapper--wide">
			<p class="dev-back"><a href="/dev/curriculum-variations">← All variations</a></p>
			<header class="page__header">
				<p class="eyebrow">The training path</p>
				<h1>Eight modules, one programme of study</h1>
			</header>

			<div class="ms">
				{curriculum.map((m) => (
					<article class="ms__chapter">
						<header class="ms__chapter-head">
							<span class="ms__numeral">{m.numeral}</span>
							<div class="ms__title-block">
								<p class="ms__kicker">Movement {m.numeral}</p>
								<h3 class="ms__name">{m.name} <span class="ms__sub">— {m.subtitle}</span></h3>
							</div>
						</header>
						<p class="ms__body">
							<span class="ms__drop">{m.body.charAt(0)}</span>{m.body.slice(1)}
						</p>
						<p class="ms__out">{m.outcome}</p>
					</article>
				))}
			</div>
		</div>
	</main>
</BaseLayout>

<style>
	.page { background-color: var(--color-bg-subtle); padding-block: var(--space-3xl); min-height: 100svh; }
	.page__header { margin-block-end: var(--space-3xl); max-width: 60ch; }
	.page__header h1 { font-family: var(--font-serif); font-weight: var(--font-weight-light); font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-3xl)); margin: var(--space-sm) 0; }
	.eyebrow { font-family: var(--font-sans); font-size: var(--font-size-xs); font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-accent); margin: 0; }
	.dev-back { margin-block-end: var(--space-lg); font-family: var(--font-sans); font-size: var(--font-size-sm); }
	.dev-back a { color: var(--color-fg-muted); text-decoration: none; }

	.ms { display: flex; flex-direction: column; gap: var(--space-3xl); max-width: 56rem; background-color: var(--color-bg-surface); padding: var(--space-3xl); border: 1px solid var(--color-border-default); }
	.ms__chapter { padding-block-end: var(--space-2xl); border-block-end: 1px solid var(--color-border-default); }
	.ms__chapter:last-child { padding-block-end: 0; border-block-end: 0; }
	.ms__chapter-head { display: grid; grid-template-columns: auto 1fr; gap: var(--space-lg); align-items: center; margin-block-end: var(--space-lg); }
	.ms__numeral {
		font-family: var(--font-serif); font-style: italic; font-weight: var(--font-weight-light);
		font-size: var(--font-size-5xl); line-height: 0.85; color: var(--color-fg-accent);
		min-width: 2ch; text-align: center;
	}
	.ms__title-block { display: flex; flex-direction: column; gap: var(--space-2xs); }
	.ms__kicker { font-family: var(--font-sans); font-size: var(--font-size-xs); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-subtle); margin: 0; }
	.ms__name { font-family: var(--font-serif); font-weight: var(--font-weight-normal); font-size: clamp(var(--font-size-xl), 2.5vw, var(--font-size-2xl)); margin: 0; }
	.ms__sub { font-style: italic; font-weight: var(--font-weight-light); color: var(--color-fg-muted); }
	.ms__body { font-family: var(--font-serif); font-size: var(--font-size-lg); line-height: var(--line-height-relaxed); color: var(--color-fg-default); margin: 0; max-width: 60ch; }
	.ms__drop {
		float: inline-start;
		font-family: var(--font-serif); font-style: italic; font-weight: var(--font-weight-light);
		font-size: 4.5em; line-height: 0.85;
		color: var(--color-fg-accent);
		padding-inline-end: 0.08em;
		padding-block-start: 0.05em;
		margin-block-end: -0.1em;
	}
	.ms__out { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-base); color: var(--color-fg-muted); margin: var(--space-lg) 0 0; max-width: 56ch; }
</style>
