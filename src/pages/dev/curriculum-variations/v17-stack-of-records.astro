---
/*
  V17 — Stack of records
  Cards stacked tightly with only the header strip visible — like a stack
  of LPs in a record-shop bin. Hover (and tap) expands the focused card to
  reveal its full body. Minimal at rest; deep on demand.
*/
import { curriculum } from "../../../config/curriculum";
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="V17 — Stack of records" noIndex={true}>
	<main class="page">
		<div class="page__inner wrapper wrapper--wide">
			<p class="dev-back"><a href="/dev/curriculum-variations">← All variations</a></p>
			<header class="page__header">
				<p class="eyebrow">The training path</p>
				<h1>Eight modules, one programme of study</h1>
				<p class="page__hint">Hover or focus a row to read.</p>
			</header>

			<ol class="stack">
				{curriculum.map((m) => (
					<li class="stack__item">
						<details class="stack__details">
							<summary class="stack__summary">
								<span class="stack__num">{m.numeral}</span>
								<span class="stack__name">{m.name}</span>
								<span class="stack__sub">{m.subtitle}</span>
								<span class="stack__chevron" aria-hidden="true">+</span>
							</summary>
							<div class="stack__panel">
								<p class="stack__body">{m.body}</p>
								<p class="stack__out">{m.outcome}</p>
							</div>
						</details>
					</li>
				))}
			</ol>
		</div>
	</main>
</BaseLayout>

<style>
	.page { background-color: var(--color-bg-page); padding-block: var(--space-3xl); min-height: 100svh; }
	.page__header { margin-block-end: var(--space-2xl); max-width: 60ch; }
	.page__header h1 { font-family: var(--font-serif); font-weight: var(--font-weight-light); font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-3xl)); margin: var(--space-sm) 0; }
	.page__hint { font-family: var(--font-sans); font-size: var(--font-size-sm); color: var(--color-fg-subtle); margin: 0; }
	.eyebrow { font-family: var(--font-sans); font-size: var(--font-size-xs); font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-accent); margin: 0; }
	.dev-back { margin-block-end: var(--space-lg); font-family: var(--font-sans); font-size: var(--font-size-sm); }
	.dev-back a { color: var(--color-fg-muted); text-decoration: none; }

	.stack { list-style: none; padding: 0; margin: 0; max-width: 56rem; }
	.stack__item { margin-block-end: var(--space-xs); }
	.stack__details {
		background-color: var(--color-bg-surface);
		border: 1px solid var(--color-border-default);
		transition: border-color var(--duration-fast) var(--ease-out);
	}
	.stack__details:hover, .stack__details[open] { border-color: var(--color-fg-accent); }
	.stack__summary {
		display: grid;
		grid-template-columns: auto 1fr auto auto;
		gap: var(--space-md);
		align-items: baseline;
		padding: var(--space-md) var(--space-lg);
		cursor: pointer;
		list-style: none;
	}
	.stack__summary::-webkit-details-marker { display: none; }
	.stack__num { font-family: var(--font-serif); font-style: italic; font-weight: var(--font-weight-light); font-size: var(--font-size-xl); color: var(--color-fg-accent); min-width: 2ch; }
	.stack__name { font-family: var(--font-serif); font-weight: var(--font-weight-normal); font-size: var(--font-size-lg); }
	.stack__sub { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-sm); color: var(--color-fg-muted); display: none; @media (min-width: 768px) { display: inline; } }
	.stack__chevron { font-family: var(--font-sans); font-size: var(--font-size-xl); color: var(--color-fg-muted); transition: transform var(--duration-fast) var(--ease-out); }
	.stack__details[open] .stack__chevron { transform: rotate(45deg); }
	.stack__panel { padding: 0 var(--space-lg) var(--space-lg); display: flex; flex-direction: column; gap: var(--space-sm); }
	.stack__body { font-family: var(--font-sans); font-size: var(--font-size-sm); line-height: var(--line-height-relaxed); color: var(--color-fg-default); margin: 0; }
	.stack__out { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-sm); color: var(--color-fg-muted); margin: 0; padding-block-start: var(--space-sm); border-block-start: 1px solid var(--color-border-default); }
</style>
