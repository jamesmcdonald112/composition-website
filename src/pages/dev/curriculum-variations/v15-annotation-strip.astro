---
/*
  V15 — Annotation strip
  Wide left margin holds the numeral and a short kicker (like a marginalia
  annotation in a scholarly text). Right column holds the full card.
  Quiet, scholarly, monograph-style.
*/
import { curriculum } from "../../../config/curriculum";
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="V15 — Annotation strip" noIndex={true}>
	<main class="page">
		<div class="page__inner wrapper wrapper--wide">
			<p class="dev-back"><a href="/dev/curriculum-variations">← All variations</a></p>
			<header class="page__header">
				<p class="eyebrow">The training path</p>
				<h1>Eight modules, one programme of study</h1>
			</header>

			<div class="annotations">
				{curriculum.map((m) => (
					<article class="annotation">
						<aside class="annotation__margin">
							<p class="annotation__num">{m.numeral}</p>
							<p class="annotation__kicker">Module {m.numeral}<br />of eight</p>
						</aside>
						<div class="annotation__card">
							<h3 class="annotation__name">{m.name}</h3>
							<p class="annotation__sub">{m.subtitle}</p>
							<p class="annotation__body">{m.body}</p>
							<p class="annotation__out">{m.outcome}</p>
						</div>
					</article>
				))}
			</div>
		</div>
	</main>
</BaseLayout>

<style>
	.page { background-color: var(--color-bg-page); padding-block: var(--space-3xl); min-height: 100svh; }
	.page__header { margin-block-end: var(--space-2xl); max-width: 60ch; }
	.page__header h1 { font-family: var(--font-serif); font-weight: var(--font-weight-light); font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-3xl)); margin: var(--space-sm) 0; }
	.eyebrow { font-family: var(--font-sans); font-size: var(--font-size-xs); font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-accent); margin: 0; }
	.dev-back { margin-block-end: var(--space-lg); font-family: var(--font-sans); font-size: var(--font-size-sm); }
	.dev-back a { color: var(--color-fg-muted); text-decoration: none; }

	.annotations { display: flex; flex-direction: column; gap: var(--space-2xl); max-width: 68rem; }
	.annotation { display: grid; grid-template-columns: 1fr; gap: var(--space-md); @media (min-width: 768px) { grid-template-columns: 160px 1fr; gap: var(--space-2xl); align-items: start; } }
	.annotation__margin { display: flex; flex-direction: column; gap: var(--space-xs); text-align: end; @media (max-width: 767px) { text-align: start; flex-direction: row; align-items: baseline; gap: var(--space-md); } }
	.annotation__num { font-family: var(--font-serif); font-style: italic; font-weight: var(--font-weight-light); font-size: var(--font-size-5xl); line-height: 0.85; color: var(--color-fg-accent); margin: 0; }
	.annotation__kicker { font-family: var(--font-sans); font-size: var(--font-size-xs); letter-spacing: var(--letter-spacing-wide); text-transform: uppercase; color: var(--color-fg-subtle); margin: 0; line-height: var(--line-height-snug); }
	.annotation__card { padding: var(--space-xl); background-color: var(--color-bg-surface); border-inline-start: 2px solid var(--color-fg-accent); display: flex; flex-direction: column; gap: var(--space-sm); }
	.annotation__name { font-family: var(--font-serif); font-weight: var(--font-weight-normal); font-size: var(--font-size-2xl); margin: 0; }
	.annotation__sub { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-base); color: var(--color-fg-muted); margin: 0; }
	.annotation__body { font-family: var(--font-sans); font-size: var(--font-size-base); line-height: var(--line-height-relaxed); color: var(--color-fg-default); margin: var(--space-xs) 0 0; }
	.annotation__out { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-sm); color: var(--color-fg-muted); margin: var(--space-sm) 0 0; padding-block-start: var(--space-sm); border-block-start: 1px solid var(--color-border-default); }
</style>
