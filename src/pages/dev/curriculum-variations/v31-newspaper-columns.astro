---
/*
  V31 — Newspaper columns
  Three modules per row laid out as newspaper columns with brand-coloured
  byline rules above each. High density; reads like a broadsheet feature.
*/
import { curriculum } from "../../../config/curriculum";
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="V31 — Newspaper columns" noIndex={true}>
	<main class="page">
		<div class="page__inner wrapper wrapper--wide">
			<p class="dev-back"><a href="/dev/curriculum-variations">← All variations</a></p>
			<header class="page__header">
				<p class="eyebrow">The training path</p>
				<h1>Eight modules, one programme of study</h1>
			</header>

			<div class="paper">
				{curriculum.map((m) => (
					<article class="paper__col">
						<header class="paper__head">
							<span class="paper__numeral">{m.numeral}</span>
							<span class="paper__byline">Module {m.numeral}</span>
						</header>
						<h3 class="paper__name">{m.name}</h3>
						<p class="paper__sub">{m.subtitle}</p>
						<p class="paper__body">{m.body}</p>
						<p class="paper__out">{m.outcome}</p>
					</article>
				))}
			</div>
		</div>
	</main>
</BaseLayout>

<style>
	.page { background-color: var(--color-bg-page); padding-block: var(--space-3xl); min-height: 100svh; }
	.page__header { margin-block-end: var(--space-2xl); max-width: 60ch; }
	.page__header h1 { font-family: var(--font-serif); font-weight: var(--font-weight-light); font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-3xl)); margin: var(--space-sm) 0; }
	.eyebrow { font-family: var(--font-sans); font-size: var(--font-size-xs); font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-accent); margin: 0; }
	.dev-back { margin-block-end: var(--space-lg); font-family: var(--font-sans); font-size: var(--font-size-sm); }
	.dev-back a { color: var(--color-fg-muted); text-decoration: none; }

	.paper {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0;
		border-block-start: 4px solid var(--color-fg-accent);
		border-block-end: 1px solid var(--color-fg-default);

		@media (min-width: 768px) { grid-template-columns: 1fr 1fr; }
		@media (min-width: 1280px) { grid-template-columns: 1fr 1fr 1fr 1fr; }
	}
	.paper__col {
		padding: var(--space-xl);
		border-block-end: 1px solid var(--color-border-default);
		border-inline-end: 1px solid var(--color-border-default);
		display: flex; flex-direction: column; gap: var(--space-sm);

		@media (min-width: 768px) { &:nth-child(2n) { border-inline-end: 1px solid var(--color-border-default); } }
		@media (min-width: 1280px) { &:nth-child(4n) { border-inline-end: 0; } }
	}
	.paper__col:last-child { border-inline-end: 0; }
	.paper__head { display: flex; align-items: baseline; gap: var(--space-sm); padding-block-end: var(--space-sm); border-block-end: 1px dotted var(--color-border-default); margin-block-end: var(--space-sm); }
	.paper__numeral { font-family: var(--font-serif); font-style: italic; font-weight: var(--font-weight-light); font-size: var(--font-size-2xl); line-height: 1; color: var(--color-fg-accent); }
	.paper__byline { font-family: var(--font-sans); font-size: var(--font-size-xs); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-subtle); }
	.paper__name { font-family: var(--font-serif); font-weight: var(--font-weight-normal); font-size: var(--font-size-xl); margin: 0; line-height: var(--line-height-tight); }
	.paper__sub { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-sm); color: var(--color-fg-muted); margin: 0; }
	.paper__body { font-family: var(--font-sans); font-size: var(--font-size-sm); line-height: var(--line-height-relaxed); color: var(--color-fg-default); margin: var(--space-xs) 0 0; }
	.paper__out { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-sm); color: var(--color-fg-muted); margin: auto 0 0; padding-block-start: var(--space-md); border-block-start: 1px solid var(--color-border-default); }
</style>
