---
/*
  V50 — Cards as list rows
  Inside each phase, modules are full-width list rows rather than grid
  cards. The "card" is the phase itself; modules are its contents.
*/
import { phases } from "../../../config/curriculum";
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="V50 — List rows" noIndex={true}>
	<main class="page">
		<div class="page__inner wrapper wrapper--wide">
			<p class="dev-back"><a href="/dev/curriculum-variations">← All variations</a></p>
			<header class="page__header">
				<p class="eyebrow">The training path</p>
				<h1>Eight modules across four phases</h1>
			</header>

			{phases.map((phase) => (
				<section class="phase">
					<header class="phase__head">
						<h2 class="phase__name">{phase.label}</h2>
						<p class="phase__intro">{phase.intro}</p>
					</header>
					<ol class="phase__list">
						{phase.modules.map((m) => (
							<li class="row">
								<span class="row__num">{m.numeral}</span>
								<div class="row__title">
									<h3 class="row__name">{m.name}</h3>
									<p class="row__sub">{m.subtitle}</p>
								</div>
								<p class="row__body">{m.body}</p>
								<p class="row__out">{m.outcome}</p>
							</li>
						))}
					</ol>
				</section>
			))}
		</div>
	</main>
</BaseLayout>

<style>
	.page { background-color: var(--color-bg-page); padding-block: var(--space-3xl); min-height: 100svh; }
	.page__header { margin-block-end: var(--space-3xl); max-width: 60ch; }
	.page__header h1 { font-family: var(--font-serif); font-weight: var(--font-weight-light); font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-3xl)); margin: var(--space-sm) 0; }
	.eyebrow { font-family: var(--font-sans); font-size: var(--font-size-xs); font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-accent); margin: 0; }
	.dev-back { margin-block-end: var(--space-lg); font-family: var(--font-sans); font-size: var(--font-size-sm); }
	.dev-back a { color: var(--color-fg-muted); text-decoration: none; }

	.phase { margin-block-end: var(--space-3xl); background-color: var(--color-bg-surface); border: 1px solid var(--color-border-default); padding: var(--space-2xl); }
	.phase__head { padding-block-end: var(--space-lg); margin-block-end: var(--space-md); border-block-end: 2px solid var(--color-fg-accent); display: flex; flex-direction: column; gap: var(--space-sm); max-width: 60ch; }
	.phase__name { font-family: var(--font-serif); font-weight: var(--font-weight-normal); font-size: clamp(var(--font-size-xl), 2.5vw, var(--font-size-2xl)); margin: 0; line-height: var(--line-height-tight); }
	.phase__intro { font-family: var(--font-sans); font-size: var(--font-size-base); line-height: var(--line-height-relaxed); color: var(--color-fg-muted); margin: 0; }
	.phase__list { list-style: none; padding: 0; margin: 0; }
	.row { display: grid; grid-template-columns: 1fr; gap: var(--space-md); padding-block: var(--space-lg); border-block-end: 1px solid var(--color-border-default); @media (min-width: 1024px) { grid-template-columns: 64px minmax(180px, 1fr) minmax(0, 2.4fr) minmax(0, 1.4fr); gap: var(--space-xl); align-items: start; } }
	.row:last-child { border-block-end: 0; padding-block-end: 0; }
	.row__num { font-family: var(--font-serif); font-style: italic; font-weight: var(--font-weight-light); font-size: var(--font-size-3xl); line-height: 1; color: var(--color-fg-accent); }
	.row__title { display: flex; flex-direction: column; gap: var(--space-2xs); }
	.row__name { font-family: var(--font-serif); font-weight: var(--font-weight-normal); font-size: var(--font-size-xl); margin: 0; line-height: var(--line-height-tight); }
	.row__sub { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-sm); color: var(--color-fg-muted); margin: 0; }
	.row__body { font-family: var(--font-sans); font-size: var(--font-size-sm); line-height: var(--line-height-relaxed); color: var(--color-fg-default); margin: 0; }
	.row__out { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-sm); color: var(--color-fg-muted); margin: 0; }
</style>
