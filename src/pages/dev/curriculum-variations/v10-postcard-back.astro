---
/*
  V10 — Postcard back
  Horizontal card divided down the middle. Left side holds the "message"
  (description); right side holds the "address" (name, subtitle, numeral
  stacked like an address block). Vintage correspondence aesthetic.
*/
import { curriculum } from "../../../config/curriculum";
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="V10 — Postcard back" noIndex={true}>
	<main class="page">
		<div class="page__inner wrapper wrapper--wide">
			<p class="dev-back"><a href="/dev/curriculum-variations">← All variations</a></p>
			<header class="page__header">
				<p class="eyebrow">The training path</p>
				<h1>Eight modules, one programme of study</h1>
			</header>

			<div class="cards">
				{curriculum.map((m) => (
					<article class="postcard">
						<div class="postcard__message">
							<p class="postcard__body">{m.body}</p>
							<p class="postcard__out">{m.outcome}</p>
						</div>
						<div class="postcard__divider" aria-hidden="true"></div>
						<div class="postcard__address">
							<p class="postcard__num">{m.numeral}</p>
							<p class="postcard__label">Module</p>
							<h3 class="postcard__name">{m.name}</h3>
							<p class="postcard__sub">{m.subtitle}</p>
						</div>
					</article>
				))}
			</div>
		</div>
	</main>
</BaseLayout>

<style>
	.page { background-color: var(--color-bg-subtle); padding-block: var(--space-3xl); min-height: 100svh; }
	.page__header { margin-block-end: var(--space-2xl); max-width: 60ch; }
	.page__header h1 { font-family: var(--font-serif); font-weight: var(--font-weight-light); font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-3xl)); margin: var(--space-sm) 0; }
	.eyebrow { font-family: var(--font-sans); font-size: var(--font-size-xs); font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-accent); margin: 0; }
	.dev-back { margin-block-end: var(--space-lg); font-family: var(--font-sans); font-size: var(--font-size-sm); }
	.dev-back a { color: var(--color-fg-muted); text-decoration: none; }

	.cards { display: flex; flex-direction: column; gap: var(--space-md); max-width: 64rem; }
	.postcard {
		background-color: var(--color-bg-surface);
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-md);
		padding: var(--space-xl);
		border: 1px solid var(--color-border-default);
		box-shadow: 0 2px 4px hsl(0 0% 0% / 0.06);
		aspect-ratio: auto;

		@media (min-width: 768px) {
			grid-template-columns: 1fr auto 1fr;
			gap: var(--space-2xl);
			align-items: stretch;
			padding: var(--space-2xl);
			min-height: 220px;
		}
	}
	.postcard__message { display: flex; flex-direction: column; gap: var(--space-md); }
	.postcard__body { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-base); line-height: var(--line-height-relaxed); color: var(--color-fg-default); margin: 0; }
	.postcard__out { font-family: var(--font-sans); font-size: var(--font-size-sm); line-height: var(--line-height-relaxed); color: var(--color-fg-muted); margin: 0; }
	.postcard__divider { display: none; @media (min-width: 768px) { display: block; width: 1px; background-color: var(--color-border-default); } }
	.postcard__address { display: flex; flex-direction: column; gap: var(--space-2xs); justify-content: center; }
	.postcard__num { font-family: var(--font-serif); font-style: italic; font-weight: var(--font-weight-light); font-size: var(--font-size-4xl); line-height: 1; color: var(--color-fg-accent); margin: 0; }
	.postcard__label { font-family: var(--font-sans); font-size: var(--font-size-xs); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-subtle); margin: var(--space-xs) 0 0; }
	.postcard__name { font-family: var(--font-serif); font-weight: var(--font-weight-normal); font-size: var(--font-size-2xl); margin: var(--space-2xs) 0 0; }
	.postcard__sub { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-sm); color: var(--color-fg-muted); margin: 0; }
</style>
