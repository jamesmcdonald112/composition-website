---
/*
  V02 — Strict 4×2 grid
  Perfect symmetry. Every card identical in shape and weight. Hairline rules
  between cards rather than borders around them. Chocolate-box discipline.
*/
import { curriculum } from "../../../config/curriculum";
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="V02 — Strict 4×2 grid" noIndex={true}>
	<main class="page">
		<div class="page__inner wrapper wrapper--wide">
			<p class="dev-back"><a href="/dev/curriculum-variations">← All variations</a></p>
			<header class="page__header">
				<p class="eyebrow">The training path</p>
				<h1>Eight modules, one programme of study</h1>
			</header>

			<div class="strict">
				{curriculum.map((m) => (
					<article class="strict__cell">
						<span class="strict__num">{m.numeral}</span>
						<h3 class="strict__name">{m.name}</h3>
						<p class="strict__sub">{m.subtitle}</p>
						<p class="strict__body">{m.body}</p>
					</article>
				))}
			</div>
		</div>
	</main>
</BaseLayout>

<style>
	.page { background-color: var(--color-bg-page); padding-block: var(--space-3xl); min-height: 100svh; }
	.page__header { margin-block-end: var(--space-2xl); max-width: 60ch; }
	.page__header h1 { font-family: var(--font-serif); font-weight: var(--font-weight-light); font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-3xl)); margin: var(--space-sm) 0; }
	.eyebrow { font-family: var(--font-sans); font-size: var(--font-size-xs); font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-accent); margin: 0; }
	.dev-back { margin-block-end: var(--space-lg); font-family: var(--font-sans); font-size: var(--font-size-sm); }
	.dev-back a { color: var(--color-fg-muted); text-decoration: none; }

	.strict {
		display: grid;
		grid-template-columns: 1fr;
		border-inline-start: 1px solid var(--color-border-default);
		border-block-start: 1px solid var(--color-border-default);

		@media (min-width: 640px) { grid-template-columns: 1fr 1fr; }
		@media (min-width: 1024px) { grid-template-columns: repeat(4, 1fr); }
	}
	.strict__cell {
		padding: var(--space-xl);
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
		border-inline-end: 1px solid var(--color-border-default);
		border-block-end: 1px solid var(--color-border-default);
		min-height: 280px;
		background-color: var(--color-bg-surface);
	}
	.strict__num {
		font-family: var(--font-serif); font-style: italic; font-weight: var(--font-weight-light);
		font-size: var(--font-size-3xl); line-height: 1; color: var(--color-fg-accent);
	}
	.strict__name { font-family: var(--font-serif); font-weight: var(--font-weight-normal); font-size: var(--font-size-xl); margin: 0; }
	.strict__sub { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-sm); color: var(--color-fg-muted); margin: 0; }
	.strict__body { font-family: var(--font-sans); font-size: var(--font-size-sm); line-height: var(--line-height-relaxed); color: var(--color-fg-default); margin: 0; }
</style>
