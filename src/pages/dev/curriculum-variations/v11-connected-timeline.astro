---
/*
  V11 — Connected timeline
  A vertical line down the page with circular numeral markers; cards
  branch off to one side. Reading sequence is physically visible.
*/
import { curriculum } from "../../../config/curriculum";
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="V11 — Connected timeline" noIndex={true}>
	<main class="page">
		<div class="page__inner wrapper wrapper--wide">
			<p class="dev-back"><a href="/dev/curriculum-variations">← All variations</a></p>
			<header class="page__header">
				<p class="eyebrow">The training path</p>
				<h1>Eight modules, one programme of study</h1>
			</header>

			<ol class="timeline">
				{curriculum.map((m) => (
					<li class="timeline__node">
						<div class="timeline__marker" aria-hidden="true">
							<span class="timeline__marker-num">{m.numeral}</span>
						</div>
						<article class="timeline__card">
							<h3 class="timeline__name">{m.name}</h3>
							<p class="timeline__sub">{m.subtitle}</p>
							<p class="timeline__body">{m.body}</p>
						</article>
					</li>
				))}
			</ol>
		</div>
	</main>
</BaseLayout>

<style>
	.page { background-color: var(--color-bg-page); padding-block: var(--space-3xl); min-height: 100svh; }
	.page__header { margin-block-end: var(--space-2xl); max-width: 60ch; }
	.page__header h1 { font-family: var(--font-serif); font-weight: var(--font-weight-light); font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-3xl)); margin: var(--space-sm) 0; }
	.eyebrow { font-family: var(--font-sans); font-size: var(--font-size-xs); font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-accent); margin: 0; }
	.dev-back { margin-block-end: var(--space-lg); font-family: var(--font-sans); font-size: var(--font-size-sm); }
	.dev-back a { color: var(--color-fg-muted); text-decoration: none; }

	.timeline { list-style: none; padding: 0; margin: 0; max-width: 56rem; position: relative; }
	.timeline::before {
		content: ""; position: absolute; top: 0; bottom: 0; left: 28px; width: 1px;
		background-color: var(--color-border-default);
	}
	.timeline__node { display: grid; grid-template-columns: 56px 1fr; gap: var(--space-lg); margin-block-end: var(--space-lg); position: relative; }
	.timeline__marker {
		width: 56px; height: 56px; border-radius: 50%;
		background-color: var(--color-bg-page);
		border: 1px solid var(--color-fg-accent);
		display: flex; align-items: center; justify-content: center;
		position: relative; z-index: 1;
	}
	.timeline__marker-num {
		font-family: var(--font-serif); font-style: italic; font-weight: var(--font-weight-light);
		font-size: var(--font-size-lg); line-height: 1; color: var(--color-fg-accent);
	}
	.timeline__card { padding: var(--space-lg) var(--space-xl); background-color: var(--color-bg-surface); border: 1px solid var(--color-border-default); display: flex; flex-direction: column; gap: var(--space-sm); }
	.timeline__name { font-family: var(--font-serif); font-weight: var(--font-weight-normal); font-size: var(--font-size-xl); margin: 0; }
	.timeline__sub { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-sm); color: var(--color-fg-muted); margin: 0; }
	.timeline__body { font-family: var(--font-sans); font-size: var(--font-size-sm); line-height: var(--line-height-relaxed); color: var(--color-fg-default); margin: 0; }
</style>
