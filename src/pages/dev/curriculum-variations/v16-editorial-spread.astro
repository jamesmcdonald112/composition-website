---
/*
  V16 — Editorial spread
  Each module set like a magazine article: three-column body with a heading
  span, a deck (subtitle in larger italic), and justified body text. Most
  density per card; high reading respect.
*/
import { curriculum } from "../../../config/curriculum";
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="V16 — Editorial spread" noIndex={true}>
	<main class="page">
		<div class="page__inner wrapper wrapper--wide">
			<p class="dev-back"><a href="/dev/curriculum-variations">← All variations</a></p>
			<header class="page__header">
				<p class="eyebrow">The training path</p>
				<h1>Eight modules, one programme of study</h1>
			</header>

			<div class="cards">
				{curriculum.map((m) => (
					<article class="ed">
						<header class="ed__head">
							<p class="ed__num">{m.numeral}</p>
							<h3 class="ed__name">{m.name}</h3>
						</header>
						<p class="ed__deck">{m.subtitle}</p>
						<div class="ed__body">
							<p>{m.body}</p>
							<p class="ed__out"><em>{m.outcome}</em></p>
						</div>
					</article>
				))}
			</div>
		</div>
	</main>
</BaseLayout>

<style>
	.page { background-color: var(--color-bg-page); padding-block: var(--space-3xl); min-height: 100svh; }
	.page__header { margin-block-end: var(--space-2xl); max-width: 60ch; }
	.page__header h1 { font-family: var(--font-serif); font-weight: var(--font-weight-light); font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-3xl)); margin: var(--space-sm) 0; }
	.eyebrow { font-family: var(--font-sans); font-size: var(--font-size-xs); font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-accent); margin: 0; }
	.dev-back { margin-block-end: var(--space-lg); font-family: var(--font-sans); font-size: var(--font-size-sm); }
	.dev-back a { color: var(--color-fg-muted); text-decoration: none; }

	.cards { display: flex; flex-direction: column; gap: var(--space-3xl); max-width: 68rem; }
	.ed { padding-block-end: var(--space-2xl); border-block-end: 1px solid var(--color-border-default); }
	.ed__head { display: flex; align-items: baseline; gap: var(--space-md); margin-block-end: var(--space-sm); }
	.ed__num { font-family: var(--font-serif); font-style: italic; font-weight: var(--font-weight-light); font-size: var(--font-size-3xl); line-height: 1; color: var(--color-fg-accent); margin: 0; }
	.ed__name { font-family: var(--font-serif); font-weight: var(--font-weight-light); font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-3xl)); margin: 0; }
	.ed__deck { font-family: var(--font-serif); font-style: italic; font-size: clamp(var(--font-size-lg), 2vw, var(--font-size-xl)); line-height: var(--line-height-snug); color: var(--color-fg-muted); max-width: 56ch; margin: var(--space-md) 0 var(--space-lg); }
	.ed__body { columns: 1; column-gap: var(--space-2xl); font-family: var(--font-sans); font-size: var(--font-size-base); line-height: var(--line-height-relaxed); color: var(--color-fg-default); @media (min-width: 768px) { columns: 2; } }
	.ed__body p { margin: 0 0 var(--space-md); break-inside: avoid; }
	.ed__out { color: var(--color-fg-muted); font-family: var(--font-serif); }
</style>
