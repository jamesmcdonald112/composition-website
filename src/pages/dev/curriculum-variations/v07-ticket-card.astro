---
/*
  V07 — Ticket card
  Theatre programme / concert-ticket aesthetic. A perforated edge on the
  left holds a large numeral; the main body holds the module text. Single
  column with horizontal cards, like a stack of admission tickets.
*/
import { curriculum } from "../../../config/curriculum";
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="V07 — Ticket card" noIndex={true}>
	<main class="page">
		<div class="page__inner wrapper wrapper--wide">
			<p class="dev-back"><a href="/dev/curriculum-variations">← All variations</a></p>
			<header class="page__header">
				<p class="eyebrow">The training path</p>
				<h1>Eight modules, one programme of study</h1>
			</header>

			<div class="tickets">
				{curriculum.map((m) => (
					<article class="ticket">
						<div class="ticket__stub">
							<span class="ticket__num">{m.numeral}</span>
							<span class="ticket__stub-label">Module</span>
						</div>
						<div class="ticket__body">
							<h3 class="ticket__name">{m.name}</h3>
							<p class="ticket__sub">{m.subtitle}</p>
							<p class="ticket__desc">{m.body}</p>
						</div>
					</article>
				))}
			</div>
		</div>
	</main>
</BaseLayout>

<style>
	.page { background-color: var(--color-bg-subtle); padding-block: var(--space-3xl); min-height: 100svh; }
	.page__header { margin-block-end: var(--space-2xl); max-width: 60ch; }
	.page__header h1 { font-family: var(--font-serif); font-weight: var(--font-weight-light); font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-3xl)); margin: var(--space-sm) 0; }
	.eyebrow { font-family: var(--font-sans); font-size: var(--font-size-xs); font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-accent); margin: 0; }
	.dev-back { margin-block-end: var(--space-lg); font-family: var(--font-sans); font-size: var(--font-sm); }
	.dev-back a { color: var(--color-fg-muted); text-decoration: none; }

	.tickets { display: flex; flex-direction: column; gap: var(--space-md); max-width: 56rem; }
	.ticket {
		display: grid;
		grid-template-columns: minmax(120px, 160px) 1fr;
		background-color: var(--color-bg-surface);
		box-shadow: 0 1px 3px hsl(0 0% 0% / 0.08);
	}
	.ticket__stub {
		background-color: var(--color-bg-brand);
		color: var(--color-fg-on-brand);
		padding: var(--space-xl);
		display: flex; flex-direction: column; align-items: center; justify-content: center; gap: var(--space-sm);
		position: relative;
	}
	.ticket__stub::after {
		content: ""; position: absolute; top: 0; bottom: 0; right: -1px;
		border-inline-end: 2px dashed var(--color-bg-page);
	}
	.ticket__num {
		font-family: var(--font-serif); font-style: italic; font-weight: var(--font-weight-light);
		font-size: var(--font-size-5xl); line-height: 1; color: var(--color-fg-accent-on-brand);
	}
	.ticket__stub-label { font-family: var(--font-sans); font-size: var(--font-size-xs); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-on-brand-subtle); }
	.ticket__body { padding: var(--space-xl); display: flex; flex-direction: column; gap: var(--space-sm); }
	.ticket__name { font-family: var(--font-serif); font-weight: var(--font-weight-normal); font-size: var(--font-size-2xl); margin: 0; }
	.ticket__sub { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-base); color: var(--color-fg-muted); margin: 0; }
	.ticket__desc { font-family: var(--font-sans); font-size: var(--font-size-sm); line-height: var(--line-height-relaxed); color: var(--color-fg-default); margin: var(--space-xs) 0 0; }
</style>
