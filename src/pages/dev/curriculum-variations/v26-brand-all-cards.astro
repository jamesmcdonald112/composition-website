---
/*
  V26 — All-brand cards
  Every card is a dark-brand panel with gold numeral and white prose.
  Reads like a set of collector cards or vinyl jacket spines. High
  brand presence; the curriculum becomes a unified set.
*/
import { curriculum } from "../../../config/curriculum";
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="V26 — All-brand cards" noIndex={true}>
	<main class="page">
		<div class="page__inner wrapper wrapper--wide">
			<p class="dev-back"><a href="/dev/curriculum-variations">← All variations</a></p>
			<header class="page__header">
				<p class="eyebrow">The training path</p>
				<h1>Eight modules, one programme of study</h1>
			</header>

			<div class="cards">
				{curriculum.map((m) => (
					<article class="card">
						<header class="card__head">
							<span class="card__num">{m.numeral}</span>
							<span class="card__kicker">Module {m.numeral} / VIII</span>
						</header>
						<h3 class="card__name">{m.name}</h3>
						<p class="card__sub">{m.subtitle}</p>
						<p class="card__body">{m.body}</p>
						<p class="card__out">{m.outcome}</p>
					</article>
				))}
			</div>
		</div>
	</main>
</BaseLayout>

<style>
	.page { background-color: var(--color-bg-page); padding-block: var(--space-3xl); min-height: 100svh; }
	.page__header { margin-block-end: var(--space-2xl); max-width: 60ch; }
	.page__header h1 { font-family: var(--font-serif); font-weight: var(--font-weight-light); font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-3xl)); margin: var(--space-sm) 0; }
	.eyebrow { font-family: var(--font-sans); font-size: var(--font-size-xs); font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-accent); margin: 0; }
	.dev-back { margin-block-end: var(--space-lg); font-family: var(--font-sans); font-size: var(--font-size-sm); }
	.dev-back a { color: var(--color-fg-muted); text-decoration: none; }

	.cards { display: grid; grid-template-columns: 1fr; gap: var(--space-md); @media (min-width: 640px) { grid-template-columns: 1fr 1fr; } @media (min-width: 1024px) { grid-template-columns: 1fr 1fr 1fr 1fr; } }
	.card {
		background-color: var(--color-bg-brand);
		color: var(--color-fg-on-brand);
		padding: var(--space-xl);
		display: flex; flex-direction: column; gap: var(--space-sm);
		min-height: 360px;
	}
	.card__head { display: flex; align-items: baseline; justify-content: space-between; gap: var(--space-sm); margin-block-end: var(--space-sm); padding-block-end: var(--space-md); border-block-end: 1px solid color-mix(in oklch, var(--color-fg-on-brand) 20%, transparent); }
	.card__num { font-family: var(--font-serif); font-style: italic; font-weight: var(--font-weight-light); font-size: var(--font-size-4xl); line-height: 0.9; color: var(--color-fg-accent-on-brand); }
	.card__kicker { font-family: var(--font-sans); font-size: var(--font-size-xs); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-on-brand-subtle); }
	.card__name { font-family: var(--font-serif); font-weight: var(--font-weight-normal); font-size: var(--font-size-2xl); margin: 0; line-height: var(--line-height-tight); }
	.card__sub { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-sm); color: var(--color-fg-on-brand-muted); margin: 0; }
	.card__body { font-family: var(--font-sans); font-size: var(--font-size-sm); line-height: var(--line-height-relaxed); color: var(--color-fg-on-brand-muted); margin: 0; }
	.card__out { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-sm); color: var(--color-fg-on-brand-subtle); margin: auto 0 0; padding-block-start: var(--space-md); border-block-start: 1px solid color-mix(in oklch, var(--color-fg-on-brand) 20%, transparent); }
</style>
