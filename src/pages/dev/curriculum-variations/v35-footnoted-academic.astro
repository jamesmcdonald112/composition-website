---
/*
  V35 — Footnoted academic
  Each module is set like a journal entry: title with footnote-marker
  numeral, body paragraph, footnote at the bottom holding the outcome.
  Scholarly, restrained, very readable.
*/
import { curriculum } from "../../../config/curriculum";
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="V35 — Footnoted academic" noIndex={true}>
	<main class="page">
		<div class="page__inner wrapper wrapper--wide">
			<p class="dev-back"><a href="/dev/curriculum-variations">← All variations</a></p>
			<header class="page__header">
				<p class="eyebrow">The training path</p>
				<h1>Eight modules, one programme of study</h1>
			</header>

			<div class="academic">
				{curriculum.map((m) => (
					<article class="entry">
						<header class="entry__head">
							<sup class="entry__sup">{m.numeral}</sup>
							<h3 class="entry__name">{m.name}<span class="entry__sub"> — {m.subtitle}</span></h3>
						</header>
						<p class="entry__body">{m.body}</p>
						<footer class="entry__foot">
							<span class="entry__foot-marker">{m.numeral}</span>
							<p class="entry__foot-text"><span class="entry__foot-label">By the end of the module:</span> {m.outcome}</p>
						</footer>
					</article>
				))}
			</div>
		</div>
	</main>
</BaseLayout>

<style>
	.page { background-color: var(--color-bg-page); padding-block: var(--space-3xl); min-height: 100svh; }
	.page__header { margin-block-end: var(--space-3xl); max-width: 60ch; }
	.page__header h1 { font-family: var(--font-serif); font-weight: var(--font-weight-light); font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-3xl)); margin: var(--space-sm) 0; }
	.eyebrow { font-family: var(--font-sans); font-size: var(--font-size-xs); font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-accent); margin: 0; }
	.dev-back { margin-block-end: var(--space-lg); font-family: var(--font-sans); font-size: var(--font-size-sm); }
	.dev-back a { color: var(--color-fg-muted); text-decoration: none; }

	.academic { display: flex; flex-direction: column; gap: var(--space-3xl); max-width: 56rem; }
	.entry { padding-block-end: var(--space-2xl); border-block-end: 1px solid var(--color-border-default); }
	.entry:last-child { border-block-end: 0; }
	.entry__head { display: flex; align-items: baseline; gap: var(--space-sm); margin-block-end: var(--space-md); }
	.entry__sup { font-family: var(--font-serif); font-style: italic; font-weight: var(--font-weight-light); font-size: var(--font-size-lg); line-height: 1; color: var(--color-fg-accent); vertical-align: super; }
	.entry__name { font-family: var(--font-serif); font-weight: var(--font-weight-normal); font-size: clamp(var(--font-size-xl), 2.5vw, var(--font-size-2xl)); margin: 0; line-height: var(--line-height-tight); }
	.entry__sub { font-style: italic; font-weight: var(--font-weight-light); color: var(--color-fg-muted); }
	.entry__body { font-family: var(--font-serif); font-size: var(--font-size-lg); line-height: var(--line-height-relaxed); color: var(--color-fg-default); margin: 0 0 var(--space-lg); max-width: 60ch; }
	.entry__foot { display: grid; grid-template-columns: auto 1fr; gap: var(--space-sm); padding-block-start: var(--space-md); border-block-start: 1px solid var(--color-border-default); max-width: 60ch; }
	.entry__foot-marker { font-family: var(--font-serif); font-style: italic; font-weight: var(--font-weight-light); font-size: var(--font-size-base); color: var(--color-fg-accent); }
	.entry__foot-text { font-family: var(--font-sans); font-size: var(--font-size-sm); line-height: var(--line-height-relaxed); color: var(--color-fg-muted); margin: 0; }
	.entry__foot-label { font-weight: var(--font-weight-medium); color: var(--color-fg-default); }
</style>
