---
/*
  V06 — Index card
  Library catalogue cards — slightly off-white, ruled with a horizontal line
  pattern, hand-stamped numeral in the corner, name typed above the rules.
*/
import { curriculum } from "../../../config/curriculum";
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="V06 — Index card" noIndex={true}>
	<main class="page">
		<div class="page__inner wrapper wrapper--wide">
			<p class="dev-back"><a href="/dev/curriculum-variations">← All variations</a></p>
			<header class="page__header">
				<p class="eyebrow">The training path</p>
				<h1>Eight modules, one programme of study</h1>
			</header>

			<div class="cards">
				{curriculum.map((m) => (
					<article class="card">
						<div class="card__header">
							<span class="card__stamp">{m.numeral}</span>
							<div class="card__title">
								<h3 class="card__name">{m.name}</h3>
								<p class="card__sub">{m.subtitle}</p>
							</div>
						</div>
						<div class="card__rules">
							<p class="card__body">{m.body}</p>
							<p class="card__out">{m.outcome}</p>
						</div>
					</article>
				))}
			</div>
		</div>
	</main>
</BaseLayout>

<style>
	.page { background-color: var(--color-bg-subtle); padding-block: var(--space-3xl); min-height: 100svh; }
	.page__header { margin-block-end: var(--space-2xl); max-width: 60ch; }
	.page__header h1 { font-family: var(--font-serif); font-weight: var(--font-weight-light); font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-3xl)); margin: var(--space-sm) 0; }
	.eyebrow { font-family: var(--font-sans); font-size: var(--font-size-xs); font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-accent); margin: 0; }
	.dev-back { margin-block-end: var(--space-lg); font-family: var(--font-sans); font-size: var(--font-size-sm); }
	.dev-back a { color: var(--color-fg-muted); text-decoration: none; }

	.cards { display: grid; grid-template-columns: 1fr; gap: var(--space-lg); @media (min-width: 768px) { grid-template-columns: 1fr 1fr; } }
	.card {
		background-color: var(--color-bg-surface);
		padding: var(--space-xl);
		box-shadow: 0 1px 0 var(--color-border-default), 0 2px 6px hsl(0 0% 0% / 0.04);
		position: relative;
		display: flex; flex-direction: column; gap: var(--space-md);
	}
	.card::before {
		content: ""; position: absolute; left: var(--space-xl); right: var(--space-xl); top: 60px;
		border-block-start: 1px solid var(--color-fg-accent);
		opacity: 0.4;
	}
	.card__header { display: flex; gap: var(--space-md); align-items: flex-start; padding-block-end: var(--space-md); }
	.card__stamp {
		font-family: var(--font-serif); font-style: italic; font-weight: var(--font-weight-light);
		font-size: var(--font-size-3xl); line-height: 1; color: var(--color-fg-accent);
		border: 2px solid var(--color-fg-accent); padding: var(--space-xs) var(--space-md);
		min-width: 3ch; text-align: center;
	}
	.card__title { display: flex; flex-direction: column; gap: var(--space-2xs); flex: 1; padding-block-start: var(--space-xs); }
	.card__name { font-family: var(--font-serif); font-weight: var(--font-weight-normal); font-size: var(--font-size-xl); margin: 0; }
	.card__sub { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-sm); color: var(--color-fg-muted); margin: 0; }
	.card__rules {
		background-image: repeating-linear-gradient(to bottom, transparent 0, transparent 1.5rem, var(--color-border-default) 1.5rem, var(--color-border-default) calc(1.5rem + 1px));
		background-position: 0 0.75rem;
		padding-block-start: var(--space-sm);
		display: flex; flex-direction: column; gap: var(--space-md);
	}
	.card__body { font-family: var(--font-sans); font-size: var(--font-size-sm); line-height: 1.5rem; color: var(--color-fg-default); margin: 0; }
	.card__out { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-sm); line-height: 1.5rem; color: var(--color-fg-muted); margin: 0; }
</style>
