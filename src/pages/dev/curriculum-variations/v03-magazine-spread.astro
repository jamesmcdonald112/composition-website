---
/*
  V03 — Magazine spread
  Module I as a hero quotation card on the left; modules II–VIII in a
  tight grid on the right. Reads like a magazine feature opener.
*/
import { curriculum } from "../../../config/curriculum";
import BaseLayout from "../../../layouts/BaseLayout.astro";

const [featured, ...rest] = curriculum;
---

<BaseLayout title="V03 — Magazine spread" noIndex={true}>
	<main class="page">
		<div class="page__inner wrapper wrapper--wide">
			<p class="dev-back"><a href="/dev/curriculum-variations">← All variations</a></p>
			<header class="page__header">
				<p class="eyebrow">The training path</p>
				<h1>Eight modules, one programme of study</h1>
			</header>

			<div class="mag">
				<aside class="mag__hero">
					<p class="mag__hero-num">{featured.numeral}</p>
					<p class="mag__hero-kicker">First movement</p>
					<h3 class="mag__hero-name">{featured.name}</h3>
					<p class="mag__hero-sub">{featured.subtitle}</p>
					<p class="mag__hero-body">{featured.body}</p>
				</aside>
				<div class="mag__grid">
					{rest.map((m) => (
						<article class="mag__card">
							<span class="mag__num">{m.numeral}</span>
							<h4 class="mag__name">{m.name}</h4>
							<p class="mag__sub">{m.subtitle}</p>
						</article>
					))}
				</div>
			</div>
		</div>
	</main>
</BaseLayout>

<style>
	.page { background-color: var(--color-bg-page); padding-block: var(--space-3xl); min-height: 100svh; }
	.page__header { margin-block-end: var(--space-2xl); max-width: 60ch; }
	.page__header h1 { font-family: var(--font-serif); font-weight: var(--font-weight-light); font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-3xl)); margin: var(--space-sm) 0; }
	.eyebrow { font-family: var(--font-sans); font-size: var(--font-size-xs); font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-accent); margin: 0; }
	.dev-back { margin-block-end: var(--space-lg); font-family: var(--font-sans); font-size: var(--font-size-sm); }
	.dev-back a { color: var(--color-fg-muted); text-decoration: none; }

	.mag {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-2xl);

		@media (min-width: 1024px) {
			grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
			gap: var(--space-3xl);
		}
	}
	.mag__hero {
		background-color: var(--color-bg-brand);
		color: var(--color-fg-on-brand);
		padding: var(--space-2xl);
		display: flex; flex-direction: column; gap: var(--space-sm);
	}
	.mag__hero-num {
		font-family: var(--font-serif); font-style: italic; font-weight: var(--font-weight-light);
		font-size: clamp(var(--font-size-5xl), 10vw, var(--font-size-6xl));
		line-height: 0.85; color: var(--color-fg-accent-on-brand); margin: 0;
	}
	.mag__hero-kicker { font-family: var(--font-sans); font-size: var(--font-size-xs); font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-accent-on-brand); margin: var(--space-lg) 0 0; }
	.mag__hero-name { font-family: var(--font-serif); font-weight: var(--font-weight-light); font-size: var(--font-size-3xl); margin: 0; }
	.mag__hero-sub { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-lg); color: var(--color-fg-on-brand-muted); margin: 0; }
	.mag__hero-body { font-family: var(--font-sans); font-size: var(--font-size-base); line-height: var(--line-height-relaxed); color: var(--color-fg-on-brand-muted); margin: var(--space-md) 0 0; }
	.mag__grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-sm);
		@media (min-width: 640px) { grid-template-columns: 1fr 1fr; }
	}
	.mag__card {
		padding: var(--space-lg);
		background-color: var(--color-bg-surface);
		border: 1px solid var(--color-border-default);
		display: flex; flex-direction: column; gap: var(--space-2xs);
	}
	.mag__num { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-xl); color: var(--color-fg-accent); }
	.mag__name { font-family: var(--font-serif); font-weight: var(--font-weight-normal); font-size: var(--font-size-lg); margin: 0; }
	.mag__sub { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-sm); color: var(--color-fg-muted); margin: 0; }
</style>
