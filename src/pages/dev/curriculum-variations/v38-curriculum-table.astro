---
/*
  V38 — Curriculum table
  True tabular layout — the curriculum as a syllabus document. Brand-
  coloured header row, alternating row tints, every field labelled.
  Maximum scannability.
*/
import { curriculum } from "../../../config/curriculum";
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="V38 — Curriculum table" noIndex={true}>
	<main class="page">
		<div class="page__inner wrapper wrapper--wide">
			<p class="dev-back"><a href="/dev/curriculum-variations">← All variations</a></p>
			<header class="page__header">
				<p class="eyebrow">The training path</p>
				<h1>Eight modules, one programme of study</h1>
			</header>

			<div class="table-wrap">
				<table class="table">
					<thead>
						<tr>
							<th scope="col" class="table__th table__th--num">№</th>
							<th scope="col" class="table__th">Module</th>
							<th scope="col" class="table__th">Subject</th>
							<th scope="col" class="table__th">Outline</th>
							<th scope="col" class="table__th">By the end</th>
						</tr>
					</thead>
					<tbody>
						{curriculum.map((m, i) => (
							<tr class={`table__tr ${i % 2 === 0 ? "table__tr--zebra" : ""}`}>
								<td class="table__td table__td--num"><span class="table__numeral">{m.numeral}</span></td>
								<td class="table__td table__td--name">{m.name}</td>
								<td class="table__td table__td--sub">{m.subtitle}</td>
								<td class="table__td">{m.body}</td>
								<td class="table__td table__td--out">{m.outcome}</td>
							</tr>
						))}
					</tbody>
				</table>
			</div>
		</div>
	</main>
</BaseLayout>

<style>
	.page { background-color: var(--color-bg-page); padding-block: var(--space-3xl); min-height: 100svh; }
	.page__header { margin-block-end: var(--space-2xl); max-width: 60ch; }
	.page__header h1 { font-family: var(--font-serif); font-weight: var(--font-weight-light); font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-3xl)); margin: var(--space-sm) 0; }
	.eyebrow { font-family: var(--font-sans); font-size: var(--font-size-xs); font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-accent); margin: 0; }
	.dev-back { margin-block-end: var(--space-lg); font-family: var(--font-sans); font-size: var(--font-size-sm); }
	.dev-back a { color: var(--color-fg-muted); text-decoration: none; }

	.table-wrap { overflow-x: auto; border: 1px solid var(--color-border-default); }
	.table { width: 100%; border-collapse: collapse; background-color: var(--color-bg-surface); min-width: 920px; }
	.table__th { background-color: var(--color-bg-brand); color: var(--color-fg-on-brand); font-family: var(--font-sans); font-size: var(--font-size-xs); font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; padding: var(--space-md) var(--space-lg); text-align: left; vertical-align: bottom; border-block-end: 2px solid var(--color-fg-accent-on-brand); }
	.table__th--num { width: 60px; text-align: center; }
	.table__tr--zebra { background-color: var(--color-bg-subtle); }
	.table__td { padding: var(--space-lg); vertical-align: top; font-family: var(--font-sans); font-size: var(--font-size-sm); line-height: var(--line-height-relaxed); color: var(--color-fg-default); border-block-end: 1px solid var(--color-border-default); }
	.table__tr:last-child .table__td { border-block-end: 0; }
	.table__td--num { text-align: center; vertical-align: middle; }
	.table__numeral { font-family: var(--font-serif); font-style: italic; font-weight: var(--font-weight-light); font-size: var(--font-size-2xl); color: var(--color-fg-accent); }
	.table__td--name { font-family: var(--font-serif); font-size: var(--font-size-lg); color: var(--color-fg-default); white-space: nowrap; }
	.table__td--sub { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-sm); color: var(--color-fg-muted); }
	.table__td--out { font-family: var(--font-serif); font-style: italic; color: var(--color-fg-muted); }
</style>
