---
/*
  V20 — Awards plinth
  Each module presented as a museum-plaque card on a "plinth" — a colour
  block beneath each card holding the large numeral, like an award placard.
  Cards stand on the page.
*/
import { curriculum } from "../../../config/curriculum";
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="V20 — Awards plinth" noIndex={true}>
	<main class="page">
		<div class="page__inner wrapper wrapper--wide">
			<p class="dev-back"><a href="/dev/curriculum-variations">← All variations</a></p>
			<header class="page__header">
				<p class="eyebrow">The training path</p>
				<h1>Eight modules, one programme of study</h1>
			</header>

			<div class="plinths">
				{curriculum.map((m) => (
					<article class="plinth">
						<header class="plinth__top">
							<span class="plinth__num">{m.numeral}</span>
							<span class="plinth__kicker">Module</span>
						</header>
						<div class="plinth__card">
							<h3 class="plinth__name">{m.name}</h3>
							<p class="plinth__sub">{m.subtitle}</p>
							<p class="plinth__body">{m.body}</p>
							<p class="plinth__out">{m.outcome}</p>
						</div>
					</article>
				))}
			</div>
		</div>
	</main>
</BaseLayout>

<style>
	.page { background-color: var(--color-bg-page); padding-block: var(--space-3xl); min-height: 100svh; }
	.page__header { margin-block-end: var(--space-2xl); max-width: 60ch; }
	.page__header h1 { font-family: var(--font-serif); font-weight: var(--font-weight-light); font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-3xl)); margin: var(--space-sm) 0; }
	.eyebrow { font-family: var(--font-sans); font-size: var(--font-size-xs); font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-accent); margin: 0; }
	.dev-back { margin-block-end: var(--space-lg); font-family: var(--font-sans); font-size: var(--font-size-sm); }
	.dev-back a { color: var(--color-fg-muted); text-decoration: none; }

	.plinths { display: grid; grid-template-columns: 1fr; gap: var(--space-2xl); @media (min-width: 768px) { grid-template-columns: 1fr 1fr; } @media (min-width: 1280px) { grid-template-columns: 1fr 1fr 1fr 1fr; } }
	.plinth { display: flex; flex-direction: column; }
	.plinth__top {
		background-color: var(--color-bg-brand);
		color: var(--color-fg-on-brand);
		padding: var(--space-lg) var(--space-xl);
		display: flex; flex-direction: column; gap: var(--space-2xs); align-items: center;
		text-align: center;
	}
	.plinth__num {
		font-family: var(--font-serif); font-style: italic; font-weight: var(--font-weight-light);
		font-size: var(--font-size-5xl); line-height: 0.9;
		color: var(--color-fg-accent-on-brand);
	}
	.plinth__kicker { font-family: var(--font-sans); font-size: var(--font-size-xs); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-on-brand-subtle); }
	.plinth__card {
		background-color: var(--color-bg-surface);
		padding: var(--space-xl);
		border: 1px solid var(--color-border-default);
		border-block-start: 0;
		display: flex; flex-direction: column; gap: var(--space-sm);
		flex: 1;
	}
	.plinth__name { font-family: var(--font-serif); font-weight: var(--font-weight-normal); font-size: var(--font-size-xl); margin: 0; }
	.plinth__sub { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-sm); color: var(--color-fg-muted); margin: 0; }
	.plinth__body { font-family: var(--font-sans); font-size: var(--font-size-sm); line-height: var(--line-height-relaxed); color: var(--color-fg-default); margin: 0; }
	.plinth__out { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-sm); color: var(--color-fg-muted); margin: auto 0 0; padding-block-start: var(--space-sm); border-block-start: 1px solid var(--color-border-default); }
</style>
