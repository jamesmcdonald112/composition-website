---
/*
  V34 — Programme note
  Recital programme aesthetic — each module is a "movement" in the
  programme, with a brand header strip carrying the numeral and movement
  label. Sits between editorial restraint and concert-hall polish.
*/
import { curriculum } from "../../../config/curriculum";
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="V34 — Programme note" noIndex={true}>
	<main class="page">
		<div class="page__inner wrapper wrapper--wide">
			<p class="dev-back"><a href="/dev/curriculum-variations">← All variations</a></p>
			<header class="page__header">
				<p class="eyebrow">The training path</p>
				<h1>Eight modules, one programme of study</h1>
			</header>

			<ol class="prog">
				{curriculum.map((m) => (
					<li class="prog__item">
						<header class="prog__strip">
							<span class="prog__strip-num">{m.numeral}</span>
							<span class="prog__strip-label">Movement {m.numeral} of VIII</span>
							<span class="prog__strip-name">{m.name}</span>
						</header>
						<div class="prog__body">
							<p class="prog__sub">{m.subtitle}</p>
							<p class="prog__desc">{m.body}</p>
							<p class="prog__out">{m.outcome}</p>
						</div>
					</li>
				))}
			</ol>
		</div>
	</main>
</BaseLayout>

<style>
	.page { background-color: var(--color-bg-page); padding-block: var(--space-3xl); min-height: 100svh; }
	.page__header { margin-block-end: var(--space-2xl); max-width: 60ch; }
	.page__header h1 { font-family: var(--font-serif); font-weight: var(--font-weight-light); font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-3xl)); margin: var(--space-sm) 0; }
	.eyebrow { font-family: var(--font-sans); font-size: var(--font-size-xs); font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-accent); margin: 0; }
	.dev-back { margin-block-end: var(--space-lg); font-family: var(--font-sans); font-size: var(--font-size-sm); }
	.dev-back a { color: var(--color-fg-muted); text-decoration: none; }

	.prog { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-md); max-width: 72rem; }
	.prog__item { background-color: var(--color-bg-surface); border: 1px solid var(--color-border-default); }
	.prog__strip {
		background-color: var(--color-bg-brand);
		color: var(--color-fg-on-brand);
		padding: var(--space-md) var(--space-xl);
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: baseline;
		gap: var(--space-lg);
	}
	.prog__strip-num { font-family: var(--font-serif); font-style: italic; font-weight: var(--font-weight-light); font-size: var(--font-size-3xl); line-height: 1; color: var(--color-fg-accent-on-brand); }
	.prog__strip-label { font-family: var(--font-sans); font-size: var(--font-size-xs); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-on-brand-subtle); }
	.prog__strip-name { font-family: var(--font-serif); font-weight: var(--font-weight-normal); font-size: var(--font-size-xl); }
	.prog__body { padding: var(--space-xl) var(--space-2xl); display: flex; flex-direction: column; gap: var(--space-md); }
	.prog__sub { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-lg); color: var(--color-fg-muted); margin: 0; }
	.prog__desc { font-family: var(--font-sans); font-size: var(--font-size-base); line-height: var(--line-height-relaxed); color: var(--color-fg-default); margin: 0; max-width: 64ch; }
	.prog__out { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-sm); color: var(--color-fg-muted); margin: 0; padding-block-start: var(--space-md); border-block-start: 1px solid var(--color-border-default); }
</style>
