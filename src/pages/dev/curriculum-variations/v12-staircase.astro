---
/*
  V12 — Numbered staircase
  Each card offset diagonally — down and to the right — from the previous,
  building a staircase of cards across the page. Strongly suggests "next
  step, next step" without any line or arrow.
*/
import { curriculum } from "../../../config/curriculum";
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="V12 — Numbered staircase" noIndex={true}>
	<main class="page">
		<div class="page__inner wrapper wrapper--wide">
			<p class="dev-back"><a href="/dev/curriculum-variations">← All variations</a></p>
			<header class="page__header">
				<p class="eyebrow">The training path</p>
				<h1>Eight modules, one programme of study</h1>
			</header>

			<div class="stair">
				{curriculum.map((m, i) => (
					<article class="stair__step" style={`--i: ${i}`}>
						<span class="stair__num">{m.numeral}</span>
						<div class="stair__body">
							<h3 class="stair__name">{m.name}</h3>
							<p class="stair__sub">{m.subtitle}</p>
							<p class="stair__desc">{m.body}</p>
						</div>
					</article>
				))}
			</div>
		</div>
	</main>
</BaseLayout>

<style>
	.page { background-color: var(--color-bg-page); padding-block: var(--space-3xl); min-height: 100svh; }
	.page__header { margin-block-end: var(--space-2xl); max-width: 60ch; }
	.page__header h1 { font-family: var(--font-serif); font-weight: var(--font-weight-light); font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-3xl)); margin: var(--space-sm) 0; }
	.eyebrow { font-family: var(--font-sans); font-size: var(--font-size-xs); font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-accent); margin: 0; }
	.dev-back { margin-block-end: var(--space-lg); font-family: var(--font-sans); font-size: var(--font-size-sm); }
	.dev-back a { color: var(--color-fg-muted); text-decoration: none; }

	.stair { display: flex; flex-direction: column; gap: var(--space-md); }
	.stair__step {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: var(--space-lg);
		padding: var(--space-lg) var(--space-xl);
		background-color: var(--color-bg-surface);
		border: 1px solid var(--color-border-default);
		max-width: 720px;

		@media (min-width: 1024px) {
			margin-inline-start: calc(var(--i) * 32px);
		}
	}
	.stair__num { font-family: var(--font-serif); font-style: italic; font-weight: var(--font-weight-light); font-size: var(--font-size-4xl); line-height: 1; color: var(--color-fg-accent); align-self: center; min-width: 2ch; }
	.stair__body { display: flex; flex-direction: column; gap: var(--space-2xs); }
	.stair__name { font-family: var(--font-serif); font-weight: var(--font-weight-normal); font-size: var(--font-size-xl); margin: 0; }
	.stair__sub { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-sm); color: var(--color-fg-muted); margin: 0; }
	.stair__desc { font-family: var(--font-sans); font-size: var(--font-size-sm); line-height: var(--line-height-relaxed); color: var(--color-fg-default); margin: var(--space-xs) 0 0; }
</style>
