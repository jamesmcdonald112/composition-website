---
/*
  V57 — Sidebar phase summary
  Left column holds the phase name + intro as a sidebar; right column
  holds the module cards. Reads as a two-up scholarly layout. Phase
  remains visible while reading any of its cards.
*/
import { phases } from "../../../config/curriculum";
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="V57 — Sidebar phase" noIndex={true}>
	<main class="page">
		<div class="page__inner wrapper wrapper--wide">
			<p class="dev-back"><a href="/dev/curriculum-variations">← All variations</a></p>
			<header class="page__header">
				<p class="eyebrow">The training path</p>
				<h1>Eight modules across four phases</h1>
			</header>

			{phases.map((phase) => (
				<section class="phase">
					<aside class="phase__side">
						<p class="phase__kicker">Phase</p>
						<h2 class="phase__name">{phase.label}</h2>
						<p class="phase__intro">{phase.intro}</p>
					</aside>
					<div class="phase__grid" style={`--n: ${phase.modules.length}`}>
						{phase.modules.map((m) => (
							<article class="card">
								<header class="card__head">
									<span class="card__num">{m.numeral}</span>
									<h3 class="card__name">{m.name}</h3>
								</header>
								<p class="card__sub">{m.subtitle}</p>
								<p class="card__body">{m.body}</p>
								<p class="card__out">{m.outcome}</p>
							</article>
						))}
					</div>
				</section>
			))}
		</div>
	</main>
</BaseLayout>

<style>
	.page { background-color: var(--color-bg-page); padding-block: var(--space-3xl); min-height: 100svh; }
	.page__header { margin-block-end: var(--space-3xl); max-width: 60ch; }
	.page__header h1 { font-family: var(--font-serif); font-weight: var(--font-weight-light); font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-3xl)); margin: var(--space-sm) 0; }
	.eyebrow { font-family: var(--font-sans); font-size: var(--font-size-xs); font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-accent); margin: 0; }
	.dev-back { margin-block-end: var(--space-lg); font-family: var(--font-sans); font-size: var(--font-size-sm); }
	.dev-back a { color: var(--color-fg-muted); text-decoration: none; }

	.phase { display: grid; grid-template-columns: 1fr; gap: var(--space-lg); margin-block-end: var(--space-3xl); padding-block-start: var(--space-xl); border-block-start: 1px solid var(--color-border-default); @media (min-width: 1024px) { grid-template-columns: minmax(240px, 1fr) minmax(0, 3fr); gap: var(--space-3xl); } }
	.phase:first-of-type { border-block-start: 0; padding-block-start: 0; }
	.phase__side { display: flex; flex-direction: column; gap: var(--space-2xs); position: sticky; top: var(--space-md); align-self: start; }
	.phase__kicker { font-family: var(--font-sans); font-size: var(--font-size-xs); font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-accent); margin: 0; }
	.phase__name { font-family: var(--font-serif); font-weight: var(--font-weight-normal); font-size: clamp(var(--font-size-xl), 2.5vw, var(--font-size-2xl)); margin: 0; line-height: var(--line-height-tight); }
	.phase__intro { font-family: var(--font-sans); font-size: var(--font-size-sm); line-height: var(--line-height-relaxed); color: var(--color-fg-muted); margin: var(--space-sm) 0 0; }
	.phase__grid { display: grid; grid-template-columns: 1fr; gap: var(--space-md); @media (min-width: 768px) { grid-template-columns: repeat(min(var(--n), 3), 1fr); } @media (min-width: 1024px) { grid-template-columns: repeat(min(var(--n), 2), 1fr); } @media (min-width: 1280px) { grid-template-columns: repeat(min(var(--n), 3), 1fr); } }
	.card { background-color: var(--color-bg-surface); border: 1px solid var(--color-border-default); padding: var(--space-xl); display: flex; flex-direction: column; gap: var(--space-sm); }
	.card__head { display: flex; align-items: baseline; gap: var(--space-md); margin-block-end: var(--space-xs); }
	.card__num { font-family: var(--font-serif); font-style: italic; font-weight: var(--font-weight-light); font-size: var(--font-size-3xl); line-height: 1; color: var(--color-fg-accent); }
	.card__name { font-family: var(--font-serif); font-weight: var(--font-weight-normal); font-size: var(--font-size-xl); margin: 0; line-height: var(--line-height-tight); }
	.card__sub { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-sm); color: var(--color-fg-muted); margin: 0; }
	.card__body { font-family: var(--font-sans); font-size: var(--font-size-sm); line-height: var(--line-height-relaxed); color: var(--color-fg-default); margin: 0; }
	.card__out { font-family: var(--font-serif); font-style: italic; font-size: var(--font-size-sm); color: var(--color-fg-muted); margin: auto 0 0; padding-block-start: var(--space-md); border-block-start: 1px solid var(--color-border-default); }
</style>
