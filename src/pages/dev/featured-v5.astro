---
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { homePageContent } from "../../config/home";
import propertyImage from "../../assets/images/new/house-key-and-figurine.webp";
import signingImage from "../../assets/images/new/person-signing-document-at-desk.webp";
import houseKeyImage from "../../assets/images/new/house-key-on-wooden-table.webp";

const { featuredService } = homePageContent;
const { card, aside } = featuredService;
const stats = homePageContent.trustStrip.stats;
---

<BaseLayout title="Featured V5 — Design Variations" description="Dev — 20 more layout explorations" canonicalPath="/dev/featured-v5">
<div class="dev-page">

	<!-- ─── 1: Navy / eyebrow at full width above / split below ─────────────── -->
	<!-- Like v4-14 but eyebrow is a full-width header band above the split -->
	<section class="v v-navy v1">
		<p class="lbl lbl-light">1 · Navy / Full-width eyebrow band / Split below</p>
		<div class="v1__eyebrow-band">
			<div class="wrapper wrapper--wide">
				<p class="v1__eyebrow">{featuredService.eyebrow}</p>
			</div>
		</div>
		<div class="wrapper wrapper--wide v1__grid">
			<div class="v1__text">
				<h2 class="v1__heading">{card.title}</h2>
				<p class="body body--brand">{card.body}</p>
				<ul class="points points--brand">
					{card.points.map(p => <li>{p}</li>)}
				</ul>
				<a href={card.cta.href} class="btn-outline-light">{card.cta.label}</a>
			</div>
			<div class="v1__image">
				<Image src={signingImage} alt="" width={600} height={680} class="img-fill img--rounded" />
			</div>
		</div>
	</section>

	<!-- ─── 2: Amber / eyebrow tracks vertical left edge / split right ───────── -->
	<!-- Eyebrow rotated 90° on the left margin, heading + content to the right -->
	<section class="v v-amber v2">
		<p class="lbl">2 · Amber / Vertical rotated eyebrow / Content right</p>
		<div class="wrapper wrapper--wide v2__layout">
			<div class="v2__rotated-label" aria-hidden="true">
				<span>{featuredService.eyebrow}</span>
			</div>
			<div class="v2__content">
				<div class="v2__split">
					<div class="v2__text">
						<p class="tag tag--amber">{card.tag}</p>
						<h2 class="v2__display">{card.title}</h2>
						<p class="body">{aside.intro}</p>
						<a href={card.cta.href} class="btn-primary">{card.cta.label}</a>
					</div>
					<div class="v2__image">
						<Image src={propertyImage} alt="" width={580} height={660} class="img-fill img--rounded" />
					</div>
				</div>
				<div class="v2__stats">
					{stats.map(s => (
						<div class="v2__stat">
							<span class="v2__stat-val">{s.value}</span>
							<span class="v2__stat-lbl">{s.label}</span>
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<!-- ─── 3: Navy / eyebrow huge + key points grid — no image ─────────────── -->
	<!-- Pure information architecture — scale of eyebrow + structured grid -->
	<section class="v v-navy v3">
		<p class="lbl lbl-light">3 · Navy / Huge eyebrow + 4-col points grid / No image</p>
		<div class="wrapper wrapper--wide">
			<p class="v3__eyebrow">{featuredService.eyebrow}</p>
			<div class="v3__rule"></div>
			<div class="v3__bottom">
				<div class="v3__heading-col">
					<h2 class="v3__heading">{card.title}</h2>
					<p class="body body--brand">{aside.intro}</p>
					<a href={card.cta.href} class="btn-outline-light">{card.cta.label}</a>
				</div>
				<div class="v3__points-grid">
					{aside.keyPoints.map(kp => (
						<div class="v3__point">
							<p class="v3__point-head">{kp.heading}</p>
							<p class="v3__point-body">{kp.body}</p>
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<!-- ─── 4: Stone / serif display + stats band at top / image + points below ─ -->
	<!-- Stats lead — trust established before you read the heading -->
	<section class="v v4">
		<p class="lbl">4 · Stone / Stats band at top / Serif heading + image below</p>
		<div class="v4__stats-band">
			<div class="wrapper wrapper--wide v4__stats-row">
				{stats.map(s => (
					<div class="v4__stat">
						<span class="v4__stat-val">{s.value}</span>
						<span class="v4__stat-lbl">{s.label}</span>
					</div>
				))}
			</div>
		</div>
		<div class="wrapper wrapper--wide v4__grid">
			<div class="v4__text">
				<p class="tag">{card.tag}</p>
				<h2 class="v4__display">{card.title}</h2>
				<p class="body">{card.body}</p>
				<ul class="points">
					{card.points.map(p => <li>{p}</li>)}
				</ul>
				<a href={card.cta.href} class="btn-primary">{card.cta.label}</a>
			</div>
			<div class="v4__image">
				<Image src={propertyImage} alt="" width={580} height={660} class="img-fill img--rounded" />
			</div>
		</div>
	</section>

	<!-- ─── 5: Navy / eyebrow left col / heading + body right col / image bottom ─ -->
	<!-- 3-zone: eyebrow | heading+body | image spanning full width below -->
	<section class="v v-navy v5">
		<p class="lbl lbl-light">5 · Navy / 3-zone: eyebrow col | text col | filmstrip below</p>
		<div class="wrapper wrapper--wide v5__top">
			<div class="v5__eyebrow-col">
				<p class="v5__eyebrow">{featuredService.eyebrow}</p>
				<div class="v5__eyebrow-rule"></div>
			</div>
			<div class="v5__text-col">
				<h2 class="v5__heading">{card.title}</h2>
				<p class="body body--brand">{card.body}</p>
				<a href={card.cta.href} class="btn-outline-light">{card.cta.label}</a>
			</div>
		</div>
		<div class="v5__filmstrip">
			<Image src={houseKeyImage} alt="" width={1400} height={420} class="v5__film-img" />
			<div class="v5__film-overlay">
				<div class="wrapper wrapper--wide v5__film-points">
					{card.points.map(p => (
						<div class="v5__film-point">
							<span class="v5__film-dash">—</span>
							<span>{p}</span>
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<!-- ─── 6: White / heading at display scale left / key points stacked right ─ -->
	<!-- No image — typographic + structured -->
	<section class="v v-white v6">
		<p class="lbl">6 · White / Display heading left / 4 key points stacked right</p>
		<div class="wrapper wrapper--wide v6__grid">
			<div class="v6__left">
				<p class="tag">{card.tag}</p>
				<h2 class="v6__display">{card.title}</h2>
				<a href={card.cta.href} class="btn-primary">{card.cta.label}</a>
			</div>
			<div class="v6__right">
				{aside.keyPoints.map((kp, i) => (
					<div class="v6__kp">
						<span class="v6__kp-num" aria-hidden="true">0{i + 1}</span>
						<div class="v6__kp-text">
							<strong class="v6__kp-head">{kp.heading}</strong>
							<p class="v6__kp-body">{kp.body}</p>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ─── 7: Amber / amber stats band mid / image left / text right ────────── -->
	<!-- Stats interrupt the flow — amber colour makes them land hard -->
	<section class="v v-amber v7">
		<p class="lbl">7 · Amber / Image left / Text right / Stats mid-band</p>
		<div class="wrapper wrapper--wide v7__top">
			<div class="v7__image">
				<Image src={signingImage} alt="" width={580} height={660} class="img-fill img--rounded" />
			</div>
			<div class="v7__text">
				<p class="tag tag--amber">{card.tag}</p>
				<h2 class="h-serif">{card.title}</h2>
				<p class="body">{card.body}</p>
				<ul class="points">
					{card.points.map(p => <li>{p}</li>)}
				</ul>
				<a href={card.cta.href} class="btn-primary">{card.cta.label}</a>
			</div>
		</div>
		<div class="v7__stats-band">
			<div class="wrapper wrapper--wide v7__stats-row">
				{stats.map(s => (
					<div class="v7__stat">
						<span class="v7__stat-val">{s.value}</span>
						<span class="v7__stat-lbl">{s.label}</span>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ─── 8: Navy / two-col: heading block left / 2×2 points grid right ─────── -->
	<!-- Like v4-18 but heading is at display scale and image removed for purity -->
	<section class="v v-navy v8">
		<p class="lbl lbl-light">8 · Navy / Display heading left / 2×2 points grid right</p>
		<div class="wrapper wrapper--wide v8__grid">
			<div class="v8__left">
				<p class="v8__eyebrow">{featuredService.eyebrow}</p>
				<h2 class="v8__display">{card.title}</h2>
				<a href={card.cta.href} class="btn-outline-light">{card.cta.label}</a>
			</div>
			<div class="v8__points-grid">
				{aside.keyPoints.map(kp => (
					<div class="v8__point">
						<p class="v8__point-head">{kp.heading}</p>
						<p class="v8__point-body">{kp.body}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ─── 9: Stone / serif display heading / rule / 3-col body text ───────── -->
	<!-- Magazine editorial — heading above a rule, three columns of text below -->
	<section class="v v9">
		<p class="lbl">9 · Stone / Serif display / Rule / 3-col editorial text</p>
		<div class="wrapper wrapper--wide">
			<div class="v9__header">
				<p class="tag">{card.tag}</p>
				<h2 class="v9__display">{card.title}</h2>
			</div>
			<div class="v9__rule"></div>
			<div class="v9__cols">
				<p class="v9__col-text">{aside.intro}</p>
				<p class="v9__col-text">{card.body}</p>
				<div class="v9__col-aside">
					{aside.keyPoints.slice(0, 2).map(kp => (
						<div class="v9__kp">
							<strong class="v9__kp-head">{kp.heading}</strong>
							<p class="v9__kp-body">{kp.body}</p>
						</div>
					))}
					<a href={card.cta.href} class="btn-primary">{card.cta.label}</a>
				</div>
			</div>
		</div>
	</section>

	<!-- ─── 10: Navy / eyebrow + heading stacked large / image bleeds right ─── -->
	<!-- Like v4-5 but on navy with eyebrow stacked above heading -->
	<section class="v v-navy v10">
		<p class="lbl lbl-light">10 · Navy / Eyebrow stacked on heading / Image bleeds right edge</p>
		<div class="v10__layout">
			<div class="v10__text-side">
				<p class="v10__eyebrow">{featuredService.eyebrow}</p>
				<h2 class="v10__heading">{card.title}</h2>
				<p class="body body--brand">{card.body}</p>
				<ul class="points points--brand">
					{card.points.map(p => <li>{p}</li>)}
				</ul>
				<a href={card.cta.href} class="btn-outline-light">{card.cta.label}</a>
			</div>
			<div class="v10__image-side">
				<Image src={propertyImage} alt="" width={800} height={800} class="img-fill" />
			</div>
		</div>
	</section>

	<!-- ─── 11: Amber / headline + intro / points in amber card / image right ─── -->
	<!-- Points pulled into a navy card that contrasts with amber background -->
	<section class="v v-amber v11">
		<p class="lbl">11 · Amber / Points in navy contrast card / Image right</p>
		<div class="wrapper wrapper--wide v11__grid">
			<div class="v11__left">
				<p class="tag tag--amber">{card.tag}</p>
				<h2 class="h-serif">{card.title}</h2>
				<p class="body">{aside.intro}</p>
				<div class="v11__navy-card">
					<ul class="v11__points">
						{card.points.map(p => <li>{p}</li>)}
					</ul>
					<a href={card.cta.href} class="v11__cta">{card.cta.label}</a>
				</div>
			</div>
			<div class="v11__image">
				<Image src={houseKeyImage} alt="" width={580} height={660} class="img-fill img--rounded" />
			</div>
		</div>
	</section>

	<!-- ─── 12: White / serif display + stats below heading / image right ─────── -->
	<!-- Stats integrated into the text column below the heading — like v4-19 variant -->
	<section class="v v-white v12">
		<p class="lbl">12 · White / Serif display / Inline stats / Image right</p>
		<div class="wrapper wrapper--wide v12__grid">
			<div class="v12__text">
				<p class="tag">{card.tag}</p>
				<h2 class="v12__display">{card.title}</h2>
				<div class="v12__stats">
					{stats.map(s => (
						<div class="v12__stat">
							<span class="v12__stat-val">{s.value}</span>
							<span class="v12__stat-lbl">{s.label}</span>
						</div>
					))}
				</div>
				<p class="body">{card.body}</p>
				<a href={card.cta.href} class="btn-primary">{card.cta.label}</a>
			</div>
			<div class="v12__image">
				<Image src={signingImage} alt="" width={580} height={700} class="img-fill img--rounded" />
			</div>
		</div>
	</section>

	<!-- ─── 13: Navy / 3-col: eyebrow | heading | points — all same height ──── -->
	<!-- Flat editorial grid — all three columns sit at equal level -->
	<section class="v v-navy v13">
		<p class="lbl lbl-light">13 · Navy / 3-col editorial flat grid / Image below</p>
		<div class="wrapper wrapper--wide v13__grid">
			<div class="v13__eyebrow-col">
				<p class="v13__eyebrow">{featuredService.eyebrow}</p>
			</div>
			<div class="v13__heading-col">
				<h2 class="v13__heading">{card.title}</h2>
			</div>
			<div class="v13__points-col">
				{aside.keyPoints.slice(0,3).map(kp => (
					<div class="v13__kp">
						<strong class="v13__kp-head">{kp.heading}</strong>
						<p class="v13__kp-body">{kp.body}</p>
					</div>
				))}
				<a href={card.cta.href} class="btn-outline-light">{card.cta.label}</a>
			</div>
		</div>
		<div class="v13__image-band">
			<Image src={propertyImage} alt="" width={1400} height={380} class="v13__img" />
		</div>
	</section>

	<!-- ─── 14: Stone / amber left col accent / heading + points / image right ── -->
	<!-- Amber accent column acts as the dominant visual element on the left -->
	<section class="v v14">
		<p class="lbl">14 · Stone / Amber accent left column / Heading + points / Image</p>
		<div class="wrapper wrapper--wide v14__grid">
			<div class="v14__amber-col" aria-hidden="true">
				<div class="v14__amber-bar"></div>
				<p class="v14__amber-label">{featuredService.eyebrow}</p>
			</div>
			<div class="v14__text">
				<p class="tag">{card.tag}</p>
				<h2 class="h-serif">{card.title}</h2>
				<p class="body">{card.body}</p>
				<ul class="points">
					{card.points.map(p => <li>{p}</li>)}
				</ul>
				<a href={card.cta.href} class="btn-primary">{card.cta.label}</a>
			</div>
			<div class="v14__image">
				<Image src={houseKeyImage} alt="" width={520} height={640} class="img-fill img--rounded" />
			</div>
		</div>
	</section>

	<!-- ─── 15: Navy / eyebrow oversized / body + stats / image floated ─────── -->
	<!-- v4-14 pushed further: eyebrow even larger, stats woven below body -->
	<section class="v v-navy v15">
		<p class="lbl lbl-light">15 · Navy / Eyebrow at max scale / Stats woven into body</p>
		<div class="wrapper wrapper--wide v15__grid">
			<div class="v15__text">
				<p class="v15__eyebrow">{featuredService.eyebrow}</p>
				<div class="v15__rule"></div>
				<h2 class="v15__heading">{card.title}</h2>
				<p class="body body--brand">{card.body}</p>
				<div class="v15__stats">
					{stats.map(s => (
						<div class="v15__stat">
							<span class="v15__stat-val">{s.value}</span>
							<span class="v15__stat-lbl">{s.label}</span>
						</div>
					))}
				</div>
				<a href={card.cta.href} class="btn-outline-light">{card.cta.label}</a>
			</div>
			<div class="v15__image">
				<Image src={signingImage} alt="" width={560} height={680} class="img-fill img--rounded" />
			</div>
		</div>
	</section>

	<!-- ─── 16: White / serif display centred above / split below ────────────── -->
	<!-- Heading centred and large at the top, then splits to image+points below -->
	<section class="v v-white v16">
		<p class="lbl">16 · White / Centred display heading / Split image+points below</p>
		<div class="wrapper wrapper--wide">
			<div class="v16__header">
				<p class="tag v16__tag">{card.tag}</p>
				<h2 class="v16__display">{card.title}</h2>
			</div>
		</div>
		<div class="wrapper wrapper--wide v16__grid">
			<div class="v16__image">
				<Image src={propertyImage} alt="" width={580} height={560} class="img-fill img--rounded" />
			</div>
			<div class="v16__points">
				{aside.keyPoints.map(kp => (
					<div class="v16__kp">
						<div class="v16__kp-rule"></div>
						<strong class="v16__kp-head">{kp.heading}</strong>
						<p class="v16__kp-body">{kp.body}</p>
					</div>
				))}
				<a href={card.cta.href} class="btn-primary">{card.cta.label}</a>
			</div>
		</div>
	</section>

	<!-- ─── 17: Amber / serif display / amber stats row top / image left ─────── -->
	<!-- v4-19 flipped: stats at top, image left, text right -->
	<section class="v v-amber v17">
		<p class="lbl">17 · Amber / Stats row top / Image left / Serif heading right</p>
		<div class="wrapper wrapper--wide v17__stats-row">
			{stats.map(s => (
				<div class="v17__stat">
					<span class="v17__stat-val">{s.value}</span>
					<span class="v17__stat-lbl">{s.label}</span>
				</div>
			))}
		</div>
		<div class="wrapper wrapper--wide v17__grid">
			<div class="v17__image">
				<Image src={houseKeyImage} alt="" width={580} height={660} class="img-fill img--rounded" />
			</div>
			<div class="v17__text">
				<p class="tag tag--amber">{card.tag}</p>
				<h2 class="v17__display">{card.title}</h2>
				<p class="body">{card.body}</p>
				<ul class="points">
					{card.points.map(p => <li>{p}</li>)}
				</ul>
				<a href={card.cta.href} class="btn-primary">{card.cta.label}</a>
			</div>
		</div>
	</section>

	<!-- ─── 18: Navy / image fills top band / eyebrow + heading + points below ── -->
	<!-- v4-18 pattern: structured content below image — but eyebrow dominates -->
	<section class="v v-navy v18">
		<p class="lbl lbl-light">18 · Navy / Image band top / Eyebrow + points grid below</p>
		<div class="v18__image-band">
			<Image src={signingImage} alt="" width={1400} height={420} class="v18__img" />
		</div>
		<div class="wrapper wrapper--wide v18__body">
			<div class="v18__body-top">
				<p class="v18__eyebrow">{featuredService.eyebrow}</p>
				<h2 class="v18__heading">{card.title}</h2>
			</div>
			<div class="v18__rule"></div>
			<div class="v18__points-grid">
				{aside.keyPoints.map(kp => (
					<div class="v18__point">
						<p class="v18__point-head">{kp.heading}</p>
						<p class="v18__point-body">{kp.body}</p>
					</div>
				))}
			</div>
			<a href={card.cta.href} class="btn-outline-light">{card.cta.label}</a>
		</div>
	</section>

	<!-- ─── 19: Stone / serif display split by an amber horizontal rule ───────── -->
	<!-- Heading split into two halves by an amber rule — typographic drama -->
	<section class="v v19">
		<p class="lbl">19 · Stone / Serif display bisected by amber rule / Image right</p>
		<div class="wrapper wrapper--wide v19__grid">
			<div class="v19__text">
				<p class="tag">{card.tag}</p>
				<h2 class="v19__display-top">Buying or selling</h2>
				<div class="v19__amber-rule"></div>
				<h2 class="v19__display-bot">property in Kilkenny?</h2>
				<p class="body">{card.body}</p>
				<ul class="points">
					{card.points.map(p => <li>{p}</li>)}
				</ul>
				<a href={card.cta.href} class="btn-primary">{card.cta.label}</a>
			</div>
			<div class="v19__image">
				<Image src={propertyImage} alt="" width={580} height={700} class="img-fill img--rounded" />
			</div>
		</div>
	</section>

	<!-- ─── 20: Navy / stats row centred / eyebrow + heading + grid below ─────── -->
	<!-- All three favourite patterns combined: eyebrow scale + points grid + stats -->
	<section class="v v-navy v20">
		<p class="lbl lbl-light">20 · Navy / Stats centred top / Eyebrow + heading + 4-col grid</p>
		<div class="wrapper wrapper--wide">
			<div class="v20__stats-row">
				{stats.map(s => (
					<div class="v20__stat">
						<span class="v20__stat-val">{s.value}</span>
						<span class="v20__stat-lbl">{s.label}</span>
					</div>
				))}
			</div>
			<div class="v20__rule"></div>
			<div class="v20__mid">
				<div class="v20__mid-text">
					<p class="v20__eyebrow">{featuredService.eyebrow}</p>
					<h2 class="v20__heading">{card.title}</h2>
					<p class="body body--brand">{card.body}</p>
					<a href={card.cta.href} class="btn-outline-light">{card.cta.label}</a>
				</div>
				<div class="v20__mid-image">
					<Image src={houseKeyImage} alt="" width={520} height={480} class="img-fill img--rounded" />
				</div>
			</div>
			<div class="v20__rule"></div>
