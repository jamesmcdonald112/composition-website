---
import { Image } from "astro:assets";
import propertyImage from "../../assets/images/new/house-key-and-figurine.webp";
import houseKeyImage from "../../assets/images/new/house-key-on-wooden-table.webp";
import signingImage from "../../assets/images/new/person-signing-document-at-desk.webp";
import { homePageContent } from "../../config/home";
import BaseLayout from "../../layouts/BaseLayout.astro";

const { featuredService } = homePageContent;
const { card, aside } = featuredService;
---

<BaseLayout title="Featured V4 — Design Variations" description="Dev — 20 distinctive layout explorations" canonicalPath="/dev/featured-v4">
<div class="dev-page">

	<!-- ─── 1: Full-bleed image / floating text panel over bottom-left ─────── -->
	<section class="v v1">
		<p class="lbl">1 · Full-bleed image / Floating text panel</p>
		<div class="v1__image-wrap">
			<Image src={propertyImage} alt="" width={1400} height={700} class="v1__img" />
		</div>
		<div class="wrapper wrapper--wide v1__overlay-row">
			<div class="v1__panel">
				<p class="tag">{card.tag}</p>
				<h2 class="h-serif">{card.title}</h2>
				<p class="body">{card.body}</p>
				<a href={card.cta.href} class="btn-primary">{card.cta.label}</a>
			</div>
		</div>
	</section>

	<!-- ─── 2: Pure typography — no image, oversized editorial heading ──────── -->
	<section class="v v-white v2">
		<p class="lbl">2 · Typography-only / Editorial / No image</p>
		<div class="wrapper wrapper--wide">
			<div class="v2__grid">
				<div class="v2__col-left">
					<p class="tag">{card.tag}</p>
					<h2 class="v2__display">{card.title}</h2>
				</div>
				<div class="v2__col-right">
					<p class="body-lead">{aside.intro}</p>
					<ul class="points">
						{card.points.map(p => <li>{p}</li>)}
					</ul>
					<a href={card.cta.href} class="btn-primary">{card.cta.label}</a>
				</div>
			</div>
		</div>
	</section>

	<!-- ─── 3: Diagonal clip split — image right, text left ─────────────────── -->
	<section class="v v-stone v3">
		<p class="lbl">3 · Diagonal clip split / Skewed divider</p>
		<div class="v3__layout">
			<div class="v3__text-side">
				<div class="v3__text-inner">
					<p class="tag">{card.tag}</p>
					<h2 class="h-serif">{card.title}</h2>
					<p class="body">{aside.intro}</p>
					<ul class="points">
						{card.points.map(p => <li>{p}</li>)}
					</ul>
					<a href={card.cta.href} class="btn-primary">{card.cta.label}</a>
				</div>
			</div>
			<div class="v3__image-side">
				<Image src={houseKeyImage} alt="" width={700} height={800} class="img-fill" />
			</div>
		</div>
	</section>

	<!-- ─── 4: Giant number accent / section marker ──────────────────────────── -->
	<section class="v v-navy v4">
		<p class="lbl lbl-light">4 · Navy / Giant italic number behind heading</p>
		<div class="wrapper wrapper--wide v4__grid">
			<div class="v4__text">
				<div class="v4__number-wrap" aria-hidden="true">
					<span class="v4__number">01</span>
				</div>
				<p class="tag tag--brand">{card.tag}</p>
				<h2 class="h-serif h-serif--brand">{card.title}</h2>
				<p class="body body--brand">{card.body}</p>
				<a href={card.cta.href} class="btn-outline-light">{card.cta.label}</a>
			</div>
			<div class="v4__image">
				<Image src={signingImage} alt="" width={600} height={750} class="img-fill img--rounded" />
			</div>
		</div>
	</section>

	<!-- ─── 5: Image column bleeds to viewport edge ──────────────────────────── -->
	<section class="v v5">
		<p class="lbl">5 · Stone / Image bleeds to right viewport edge</p>
		<div class="v5__layout">
			<div class="v5__text">
				<p class="tag">{card.tag}</p>
				<h2 class="h-serif">{card.title}</h2>
				<p class="body">{aside.intro}</p>
				<ul class="points">
					{card.points.map(p => <li>{p}</li>)}
				</ul>
				<a href={card.cta.href} class="btn-primary">{card.cta.label}</a>
			</div>
			<div class="v5__image">
				<Image src={propertyImage} alt="" width={800} height={700} class="img-fill" />
			</div>
		</div>
	</section>

	<!-- ─── 6: White card lifts off navy brand background ───────────────────── -->
	<section class="v v-navy v6">
		<p class="lbl lbl-light">6 · Navy bg / White card panel lifted off surface</p>
		<div class="wrapper wrapper--wide v6__grid">
			<div class="v6__card">
				<p class="tag">{card.tag}</p>
				<h2 class="h-serif">{card.title}</h2>
				<p class="body">{card.body}</p>
				<ul class="points">
					{card.points.map(p => <li>{p}</li>)}
				</ul>
				<a href={card.cta.href} class="btn-primary">{card.cta.label}</a>
			</div>
			<div class="v6__image">
				<Image src={houseKeyImage} alt="" width={600} height={700} class="img-fill img--rounded" />
			</div>
		</div>
	</section>

	<!-- ─── 7: Pull quote dominates / body below / image right ──────────────── -->
	<section class="v v-white v7">
		<p class="lbl">7 · White / Pull quote dominates / Image right</p>
		<div class="wrapper wrapper--wide v7__grid">
			<div class="v7__text">
				<p class="tag">{card.tag}</p>
				<p class="v7__pull">"Buying or selling a home is one of the biggest decisions you will ever make — handled with care."</p>
				<p class="body">{card.body}</p>
				<ul class="points">
					{card.points.map(p => <li>{p}</li>)}
				</ul>
				<a href={card.cta.href} class="btn-primary">{card.cta.label}</a>
			</div>
			<div class="v7__image">
				<Image src={signingImage} alt="" width={600} height={750} class="img-fill img--rounded" />
			</div>
		</div>
	</section>

	<!-- ─── 8: Narrow intro left / main content + image right ───────────────── -->
	<section class="v v-stone v8">
		<p class="lbl">8 · Stone / Narrow left intro / Main + image right</p>
		<div class="wrapper wrapper--wide v8__grid">
			<div class="v8__intro">
				<p class="v8__eyebrow">{featuredService.eyebrow}</p>
				<div class="v8__rule"></div>
				<p class="v8__aside-body">{aside.intro}</p>
			</div>
			<div class="v8__main">
				<div class="v8__main-top">
					<div class="v8__main-text">
						<h2 class="h-serif">{card.title}</h2>
						<p class="body">{card.body}</p>
						<a href={card.cta.href} class="btn-primary">{card.cta.label}</a>
					</div>
					<div class="v8__main-image">
						<Image src={propertyImage} alt="" width={500} height={600} class="img-fill img--rounded" />
					</div>
				</div>
				<div class="v8__key-points">
					{aside.keyPoints.slice(0,3).map(kp => (
						<div class="v8__kp">
							<strong class="v8__kp-head">{kp.heading}</strong>
							<p class="v8__kp-body">{kp.body}</p>
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<!-- ─── 9: Three-image mosaic grid / text column right ──────────────────── -->
	<section class="v v-white v9">
		<p class="lbl">9 · White / Three-image mosaic / Text right</p>
		<div class="wrapper wrapper--wide v9__grid">
			<div class="v9__mosaic">
				<div class="v9__mosaic-large">
					<Image src={propertyImage} alt="" width={600} height={500} class="img-fill img--rounded" />
				</div>
				<div class="v9__mosaic-small-grid">
					<div class="v9__mosaic-small">
						<Image src={houseKeyImage} alt="" width={300} height={240} class="img-fill img--rounded" />
					</div>
					<div class="v9__mosaic-small">
						<Image src={signingImage} alt="" width={300} height={240} class="img-fill img--rounded" />
					</div>
				</div>
			</div>
			<div class="v9__text">
				<p class="tag">{card.tag}</p>
				<h2 class="h-serif">{card.title}</h2>
				<p class="body">{aside.intro}</p>
				<ul class="points">
					{card.points.map(p => <li>{p}</li>)}
				</ul>
				<a href={card.cta.href} class="btn-primary">{card.cta.label}</a>
			</div>
		</div>
	</section>

	<!-- ─── 10: Amber band bisects the section horizontally ─────────────────── -->
	<section class="v v10">
		<p class="lbl">10 · Stone + amber band / Horizontal stripe accent</p>
		<div class="v10__amber-band"></div>
		<div class="wrapper wrapper--wide v10__grid">
			<div class="v10__text">
				<p class="tag">{card.tag}</p>
				<h2 class="h-serif">{card.title}</h2>
				<p class="body">{card.body}</p>
				<ul class="points">
					{card.points.map(p => <li>{p}</li>)}
				</ul>
				<a href={card.cta.href} class="btn-primary">{card.cta.label}</a>
			</div>
			<div class="v10__image-wrap">
				<Image src={houseKeyImage} alt="" width={600} height={700} class="img-fill img--rounded v10__img" />
			</div>
		</div>
	</section>

	<!-- ─── 11: Floating caption strip below image ───────────────────────────── -->
	<section class="v v-white v11">
		<p class="lbl">11 · White / Image with caption strip overlap / Text left</p>
		<div class="wrapper wrapper--wide v11__grid">
			<div class="v11__text">
				<p class="tag">{card.tag}</p>
				<h2 class="h-serif">{card.title}</h2>
				<p class="body">{card.body}</p>
				<a href={card.cta.href} class="btn-primary">{card.cta.label}</a>
			</div>
			<div class="v11__image-wrap">
				<Image src={signingImage} alt="" width={600} height={650} class="img-fill img--rounded" />
				<div class="v11__caption-strip">
					<p class="v11__caption-text">Over 46 years of Kilkenny transactions</p>
					<p class="v11__caption-sub">Established 1979 · Rose Inn Street</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ─── 12: Process steps horizontal / image at right end ───────────────── -->
	<section class="v v-stone v12">
		<p class="lbl">12 · Stone / Horizontal process steps / Image end</p>
		<div class="wrapper wrapper--wide">
			<div class="v12__header">
				<p class="tag">{card.tag}</p>
				<h2 class="h-serif v12__heading">{card.title}</h2>
			</div>
			<div class="v12__steps-row">
				{card.points.map((p, i) => (
					<div class="v12__step">
						<span class="v12__step-num" aria-hidden="true">0{i + 1}</span>
						<p class="v12__step-text">{p}</p>
					</div>
				))}
				<div class="v12__step-image">
					<Image src={propertyImage} alt="" width={280} height={280} class="img-fill img--rounded" />
				</div>
			</div>
			<div class="v12__cta-row">
				<a href={card.cta.href} class="btn-primary">{card.cta.label}</a>
			</div>
		</div>
	</section>

	<!-- ─── 13: Boxed feature callout pulls one key point ───────────────────── -->
	<section class="v v-amber v13">
		<p class="lbl">13 · Amber-50 / Feature callout box / Text + image</p>
		<div class="wrapper wrapper--wide v13__grid">
			<div class="v13__text">
				<p class="tag tag--amber">{card.tag}</p>
				<h2 class="h-serif">{card.title}</h2>
				<p class="body">{card.body}</p>
				<div class="v13__callout">
					<p class="v13__callout-head">{aside.keyPoints[0].heading}</p>
					<p class="v13__callout-body">{aside.keyPoints[0].body}</p>
				</div>
				<ul class="points">
					{card.points.slice(1).map(p => <li>{p}</li>)}
				</ul>
				<a href={card.cta.href} class="btn-primary">{card.cta.label}</a>
			</div>
			<div class="v13__image">
				<Image src={houseKeyImage} alt="" width={600} height={700} class="img-fill img--rounded" />
			</div>
		</div>
	</section>

	<!-- ─── 14: Wide spaced eyebrow dominates / heading secondary ───────────── -->
	<section class="v v-navy v14">
		<p class="lbl lbl-light">14 · Navy / Wide eyebrow dominates / Heading secondary</p>
		<div class="wrapper wrapper--wide v14__grid">
			<div class="v14__text">
				<p class="v14__eyebrow">{featuredService.eyebrow}</p>
				<h2 class="v14__heading">{card.title}</h2>
				<p class="body body--brand">{card.body}</p>
				<ul class="points points--brand">
					{card.points.map(p => <li>{p}</li>)}
				</ul>
				<a href={card.cta.href} class="btn-outline-light">{card.cta.label}</a>
			</div>
			<div class="v14__image">
				<Image src={signingImage} alt="" width={600} height={700} class="img-fill img--rounded" />
			</div>
		</div>
	</section>

	<!-- ─── 15: Icon-forward / property icon large / text + points ──────────── -->
	<section class="v v-white v15">
		<p class="lbl">15 · White / Large property icon / Text + aside key points</p>
		<div class="wrapper wrapper--wide v15__grid">
			<div class="v15__text">
				<div class="v15__icon-wrap" aria-hidden="true">
					<Fragment set:html={card.icon} />
				</div>
				<p class="tag">{card.tag}</p>
				<h2 class="h-serif">{card.title}</h2>
				<p class="body">{aside.intro}</p>
				<a href={card.cta.href} class="btn-primary">{card.cta.label}</a>
			</div>
			<div class="v15__aside">
				{aside.keyPoints.map(kp => (
					<div class="v15__kp">
						<div class="v15__kp-rule"></div>
						<strong class="v15__kp-head">{kp.heading}</strong>
						<p class="v15__kp-body">{kp.body}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ─── 16: Filmstrip — image 100vw / text below in container ───────────── -->
	<section class="v v-stone v16">
		<p class="lbl">16 · Stone / Full-width filmstrip image / Text block below</p>
		<div class="v16__filmstrip">
			<Image src={propertyImage} alt="" width={1400} height={480} class="v16__film-img" />
		</div>
		<div class="wrapper wrapper--wide v16__body">
			<div class="v16__body-grid">
				<div class="v16__body-text">
					<p class="tag">{card.tag}</p>
					<h2 class="h-serif">{card.title}</h2>
					<p class="body">{card.body}</p>
					<a href={card.cta.href} class="btn-primary">{card.cta.label}</a>
				</div>
				<div class="v16__body-points">
					{aside.keyPoints.map(kp => (
						<div class="v16__kp">
							<strong class="v16__kp-head">{kp.heading}</strong>
							<p class="v16__kp-body">{kp.body}</p>
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<!-- ─── 17: Stacked — image top half / text lower half / amber accent line ─ -->
	<section class="v v17">
		<p class="lbl lbl-light">17 · Stacked / Image top / Text lower / Amber line break</p>
		<div class="v17__image-zone">
			<Image src={houseKeyImage} alt="" width={1400} height={560} class="v17__img" />
			<div class="v17__image-caption">
				<span class="v17__img-tag">{card.tag}</span>
			</div>
		</div>
		<div class="v17__text-zone">
			<div class="wrapper wrapper--wide v17__text-grid">
				<div class="v17__rule-col">
					<div class="v17__amber-rule"></div>
				</div>
				<div class="v17__heading-col">
					<h2 class="h-serif">{card.title}</h2>
				</div>
				<div class="v17__body-col">
					<p class="body">{card.body}</p>
					<ul class="points">
						{card.points.map(p => <li>{p}</li>)}
					</ul>
					<a href={card.cta.href} class="btn-primary">{card.cta.label}</a>
				</div>
			</div>
		</div>
	</section>

	<!-- ─── 18: Navy / 2-col key points grid as primary content / image top ─── -->
	<section class="v v-navy v18">
		<p class="lbl lbl-light">18 · Navy / Key points grid primary / Headline + image</p>
		<div class="wrapper wrapper--wide">
			<div class="v18__top">
				<div class="v18__top-text">
					<p class="tag tag--brand">{card.tag}</p>
					<h2 class="h-serif h-serif--brand">{card.title}</h2>
					<p class="body body--brand">{card.body}</p>
					<a href={card.cta.href} class="btn-outline-light">{card.cta.label}</a>
				</div>
				<div class="v18__top-image">
					<Image src={signingImage} alt="" width={540} height={480} class="img-fill img--rounded" />
				</div>
			</div>
			<div class="v18__points-grid">
				{aside.keyPoints.map(kp => (
					<div class="v18__point">
						<p class="v18__point-head">{kp.heading}</p>
						<p class="v18__point-body">{kp.body}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ─── 19: Amber / serif large heading left / image right / stats band ─── -->
	<section class="v v-amber v19">
		<p class="lbl">19 · Amber / Serif display heading / Stats band bottom</p>
		<div class="wrapper wrapper--wide v19__grid">
			<div class="v19__text">
				<p class="tag tag--amber">{card.tag}</p>
				<h2 class="v19__display">{card.title}</h2>
				<p class="body">{aside.intro}</p>
				<a href={card.cta.href} class="btn-primary">{card.cta.label}</a>
			</div>
			<div class="v19__image">
				<Image src={propertyImage} alt="" width={600} height={700} class="img-fill img--rounded" />
			</div>
		</div>
		<div class="wrapper wrapper--wide v19__stats">
			{homePageContent.trustStrip.stats.map(s => (
				<div class="v19__stat">
					<span class="v19__stat-val">{s.value}</span>
					<span class="v19__stat-lbl">{s.label}</span>
				</div>
			))}
		</div>
	</section>

	<!-- ─── 20: Charcoal / text-only left / image right / aside quote overlay ─ -->
	<section class="v v-charcoal v20">
		<p class="lbl lbl-light">20 · Charcoal / Text left / Image + quote strip overlay</p>
		<div class="wrapper wrapper--wide v20__grid">
			<div class="v20__text">
				<p class="tag tag--brand">{card.tag}</p>
				<h2 class="h-serif h-serif--brand">{card.title}</h2>
				<p class="body body--brand">{card.body}</p>
				<ul class="points points--brand">
					{card.points.map(p => <li>{p}</li>)}
				</ul>
				<a href={card.cta.href} class="btn-outline-light">{card.cta.label}</a>
			</div>
			<div class="v20__image-wrap">
				<Image src={houseKeyImage} alt="" width={600} height={700} class="img-fill img--rounded" />
				<div class="v20__quote-strip">
					<p class="v20__quote">&ldquo;{aside.keyPoints[3].heading}&rdquo;</p>
					<p class="v20__quote-sub">{aside.keyPoints[3].body}</p>
				</div>
			</div>
		</div>
	</section>

</div>
</BaseLayout>

<style>
/* ── Page shell ───────────────────────────────────────────────────────────── */
.dev-page { display: flex; flex-direction: column; }

/* ── Section shell ────────────────────────────────────────────────────────── */
.v {
	background: var(--color-bg-subtle);
	position: relative;
	overflow: hidden;
}
.v-white      { background: var(--color-bg-surface); }
.v-stone      { background: var(--color-bg-subtle); }
.v-amber      { background: var(--color-bg-accent); }
.v-navy       { background: var(--color-bg-brand); }
.v-charcoal   { background: var(--color-bg-tertiary); }

/* ── Dev label ────────────────────────────────────────────────────────────── */
.lbl {
	position: absolute;
	top: var(--space-sm);
	left: var(--space-lg);
	font-family: var(--font-sans);
	font-size: var(--font-size-xs);
	letter-spacing: var(--letter-spacing-wider);
	text-transform: uppercase;
	opacity: 0.4;
	color: var(--color-fg-default);
	z-index: 10;
}
.lbl-light { color: var(--color-fg-on-brand); }

/* ── Shared atoms ─────────────────────────────────────────────────────────── */
.tag {
	font-family: var(--font-sans);
	font-size: var(--font-size-xs);
	letter-spacing: var(--letter-spacing-widest);
	text-transform: uppercase;
	color: var(--color-fg-accent);
	margin-block-end: var(--space-sm);
}
.tag--amber { color: var(--color-fg-accent); }
.tag--brand { color: var(--color-fg-accent-on-brand); }

.h-serif {
	font-family: var(--font-serif);
	font-size: var(--font-size-3xl);
	font-weight: var(--font-weight-light);
	font-style: italic;
	color: var(--color-fg-default);
	line-height: var(--line-height-tight);
	margin-block-end: var(--space-lg);
}
.h-serif--brand { color: var(--color-fg-on-brand); }

.body {
	font-family: var(--font-sans);
	font-size: var(--font-size-base);
	line-height: var(--line-height-relaxed);
	color: var(--color-fg-muted);
	margin-block-end: var(--space-lg);
}
.body--brand { color: var(--color-fg-on-brand-muted); }

.body-lead {
	font-family: var(--font-sans);
	font-size: var(--font-size-lg);
	line-height: var(--line-height-relaxed);
	color: var(--color-fg-muted);
	margin-block-end: var(--space-xl);
}

.points {
	list-style: none;
	padding: 0;
	margin: 0 0 var(--space-xl);
	display: flex;
	flex-direction: column;
	gap: var(--space-sm);
}
.points li {
	font-family: var(--font-sans);
	font-size: var(--font-size-sm);
	color: var(--color-fg-muted);
	padding-inline-start: var(--space-lg);
	position: relative;
}
.points li::before {
	content: "—";
	position: absolute;
	inset-inline-start: 0;
	color: var(--color-fg-accent);
}
.points--brand li { color: var(--color-fg-on-brand-muted); }
.points--brand li::before { color: var(--color-fg-accent-on-brand); }

.btn-primary {
	display: inline-flex;
	align-items: center;
	font-family: var(--font-sans);
	font-size: var(--font-size-sm);
	font-weight: var(--font-weight-medium);
	letter-spacing: var(--letter-spacing-wide);
	text-transform: uppercase;
	text-decoration: none;
	padding-block: var(--space-md);
	padding-inline: var(--space-xl);
	background: var(--color-bg-interactive);
	color: var(--color-fg-interactive);
	border: 1px solid var(--color-border-accent);
}
.btn-outline-light {
	display: inline-flex;
	align-items: center;
	font-family: var(--font-sans);
	font-size: var(--font-size-sm);
	font-weight: var(--font-weight-medium);
	letter-spacing: var(--letter-spacing-wide);
	text-transform: uppercase;
	text-decoration: none;
	padding-block: var(--space-md);
	padding-inline: var(--space-xl);
	background: transparent;
	color: var(--color-fg-on-brand);
	border: 1px solid color-mix(in srgb, var(--color-fg-on-brand) 40%, transparent);
}

.img-fill { width: 100%; height: 100%; object-fit: cover; display: block; }
.img--rounded { border-radius: var(--radius-lg); }

/* ═══════════════════════════════════════════════════════════════════════════
   1 · Full-bleed image / Floating panel
   ══════════════════════════════════════════════════════════════════════════ */
.v1 { padding: 0; }

.v1__image-wrap {
	position: relative;
	width: 100%;
	height: 60vh;
	min-height: 400px;
	overflow: hidden;
}
.v1__img {
	width: 100%;
	height: 100%;
	object-fit: cover;
	display: block;
}

.v1__overlay-row { position: relative; }

.v1__panel {
	background: var(--color-bg-surface);
	padding: var(--space-3xl);
	max-width: 560px;
	margin-block-start: calc(-1 * var(--space-4xl));
	position: relative;
	z-index: 2;

	@media (min-width: 768px) {
		margin-block-start: calc(-1 * var(--space-5xl));
	}
}

/* ═══════════════════════════════════════════════════════════════════════════
   2 · Pure typography / editorial
   ══════════════════════════════════════════════════════════════════════════ */
.v2 { padding-block: var(--space-5xl); }

.v2__grid {
	display: grid;
	grid-template-columns: 1fr;
	gap: var(--space-3xl);
	align-items: start;

	@media (min-width: 900px) {
		grid-template-columns: 5fr 4fr;
		gap: var(--space-4xl);
	}
}

.v2__display {
	font-family: var(--font-serif);
	font-size: clamp(var(--font-size-3xl), 5vw, var(--font-size-6xl));
	font-weight: var(--font-weight-light);
	font-style: italic;
	color: var(--color-fg-default);
	line-height: var(--line-height-tight);
	letter-spacing: var(--letter-spacing-tighter);
	margin-block-start: var(--space-md);
}
.v2__col-left .tag { margin-block-end: var(--space-xs); }

.v2__col-right {
	display: flex;
	flex-direction: column;
	padding-block-start: 0;

	@media (min-width: 900px) {
		padding-block-start: var(--space-4xl);
	}
}

/* ═══════════════════════════════════════════════════════════════════════════
   3 · Diagonal clip split
   ══════════════════════════════════════════════════════════════════════════ */
.v3 { padding: 0; }

.v3__layout {
	display: grid;
	grid-template-columns: 1fr;
	min-height: 600px;

	@media (min-width: 768px) {
		grid-template-columns: 1fr 1fr;
	}
}

.v3__text-side {
	background: var(--color-bg-subtle);
	display: flex;
	align-items: center;
	padding-block: var(--space-5xl);
	clip-path: polygon(0 0, 100% 0, 92% 100%, 0 100%);
	z-index: 1;
	padding-inline-end: var(--space-4xl);
}
.v3__text-inner {
	padding-inline-start: max(var(--space-3xl), calc((100vw - 1280px) / 2));
	padding-inline-end: var(--space-2xl);
	max-width: 560px;
	display: flex;
	flex-direction: column;
}
.v3__image-side {
	overflow: hidden;
	min-height: 500px;
	margin-inline-start: calc(-1 * var(--space-3xl));
}

/* ═══════════════════════════════════════════════════════════════════════════
   4 · Giant number accent / navy
   ══════════════════════════════════════════════════════════════════════════ */
.v4 { padding-block: var(--space-5xl); }

.v4__grid {
	display: grid;
	grid-template-columns: 1fr;
	gap: var(--space-3xl);
	align-items: center;

	@media (min-width: 768px) {
		grid-template-columns: 55fr 45fr;
	}
}

.v4__text { position: relative; display: flex; flex-direction: column; }

.v4__number-wrap {
	position: absolute;
	inset-inline-start: calc(-1 * var(--space-lg));
	inset-block-start: calc(-1 * var(--space-3xl));
	overflow: hidden;
	pointer-events: none;
}

.v4__number {
	font-family: var(--font-serif);
	font-style: italic;
	font-size: var(--font-size-6xl);
	font-weight: var(--font-weight-light);
	color: color-mix(in srgb, var(--color-fg-accent-on-brand) 12%, transparent);
	line-height: 1;
	display: block;
}

.v4__image {
	overflow: hidden;
	min-height: 480px;
	align-self: stretch;
}

/* ═══════════════════════════════════════════════════════════════════════════
   5 · Image bleeds to viewport edge
   ══════════════════════════════════════════════════════════════════════════ */
.v5 { padding: 0; }

.v5__layout {
	display: grid;
	grid-template-columns: 1fr;
	min-height: 560px;

	@media (min-width: 768px) {
		grid-template-columns: 1fr 1fr;
	}
}

.v5__text {
	background: var(--color-bg-subtle);
	padding-block: var(--space-5xl);
	padding-inline-start: max(var(--space-3xl), calc((100vw - 1280px) / 2));
	padding-inline-end: var(--space-3xl);
	display: flex;
	flex-direction: column;
	justify-content: center;
}

.v5__image {
	overflow: hidden;
	min-height: 480px;
}

/* ═══════════════════════════════════════════════════════════════════════════
   6 · White card on navy
   ══════════════════════════════════════════════════════════════════════════ */
.v6 { padding-block: var(--space-5xl); }

.v6__grid {
	display: grid;
	grid-template-columns: 1fr;
	gap: var(--space-3xl);
	align-items: center;

	@media (min-width: 768px) {
		grid-template-columns: 55fr 45fr;
	}
}

.v6__card {
	background: var(--color-bg-surface);
	padding: var(--space-3xl);
	display: flex;
	flex-direction: column;
}

.v6__card .tag { color: var(--color-fg-accent); }
.v6__card .h-serif { color: var(--color-fg-default); }
.v6__card .body { color: var(--color-fg-muted); }
.v6__card .points li { color: var(--color-fg-muted); }
.v6__card .points li::before { color: var(--color-fg-accent); }

.v6__image {
	overflow: hidden;
	min-height: 480px;
	align-self: stretch;
}

/* ═══════════════════════════════════════════════════════════════════════════
   7 · Pull quote dominates
   ══════════════════════════════════════════════════════════════════════════ */
.v7 { padding-block: var(--space-5xl); }

.v7__grid {
	display: grid;
	grid-template-columns: 1fr;
	gap: var(--space-3xl);
	align-items: center;

	@media (min-width: 768px) {
		grid-template-columns: 55fr 45fr;
	}
}

.v7__text { display: flex; flex-direction: column; }

.v7__pull {
	font-family: var(--font-serif);
	font-size: clamp(var(--font-size-2xl), 3.5vw, var(--font-size-4xl));
	font-style: italic;
	font-weight: var(--font-weight-light);
	color: var(--color-fg-default);
	line-height: var(--line-height-tight);
	letter-spacing: var(--letter-spacing-tight);
	margin-block-end: var(--space-2xl);
	border-inline-start: 3px solid var(--color-fg-accent);
	padding-inline-start: var(--space-xl);
}

.v7__image {
	overflow: hidden;
	min-height: 500px;
	align-self: stretch;
}

/* ═══════════════════════════════════════════════════════════════════════════
   8 · Narrow left intro / main right
   ══════════════════════════════════════════════════════════════════════════ */
.v8 { padding-block: var(--space-5xl); }

.v8__grid {
	display: grid;
	grid-template-columns: 1fr;
	gap: var(--space-3xl);
	align-items: start;

	@media (min-width: 768px) {
		grid-template-columns: 28fr 72fr;
		gap: var(--space-4xl);
	}
}

.v8__eyebrow {
	font-family: var(--font-sans);
	font-size: var(--font-size-xs);
	letter-spacing: var(--letter-spacing-widest);
	text-transform: uppercase;
	color: var(--color-fg-accent);
	margin-block-end: var(--space-md);
}
.v8__rule {
	width: var(--space-xl);
	height: 2px;
	background: var(--color-fg-accent);
	margin-block-end: var(--space-lg);
}
.v8__aside-body {
	font-family: var(--font-serif);
	font-size: var(--font-size-base);
	font-style: italic;
	color: var(--color-fg-muted);
	line-height: var(--line-height-relaxed);
}

.v8__main { display: flex; flex-direction: column; gap: var(--space-2xl); }

.v8__main-top {
	display: grid;
	grid-template-columns: 1fr;
	gap: var(--space-2xl);
	align-items: start;

	@media (min-width: 900px) {
		grid-template-columns: 1fr 1fr;
	}
}
.v8__main-text { display: flex; flex-direction: column; }
.v8__main-image { overflow: hidden; min-height: 340px; }

.v8__key-points {
	display: grid;
	grid-template-columns: 1fr;
	gap: var(--space-lg);
	border-block-start: 1px solid var(--color-border-default);
	padding-block-start: var(--space-xl);

	@media (min-width: 600px) {
		grid-template-columns: repeat(3, 1fr);
	}
}
.v8__kp { display: flex; flex-direction: column; gap: var(--space-xs); }
.v8__kp-head {
	font-family: var(--font-sans);
	font-size: var(--font-size-sm);
	font-weight: var(--font-weight-semibold);
	color: var(--color-fg-default);
}
.v8__kp-body {
	font-family: var(--font-sans);
	font-size: var(--font-size-sm);
	color: var(--color-fg-muted);
}

/* ═══════════════════════════════════════════════════════════════════════════
   9 · Three-image mosaic
   ══════════════════════════════════════════════════════════════════════════ */
.v9 { padding-block: var(--space-5xl); }

.v9__grid {
	display: grid;
	grid-template-columns: 1fr;
	gap: var(--space-3xl);
	align-items: center;

	@media (min-width: 768px) {
		grid-template-columns: 55fr 45fr;
	}
}

.v9__mosaic {
	display: flex;
	flex-direction: column;
	gap: var(--space-md);
}
.v9__mosaic-large { overflow: hidden; height: 300px; }
.v9__mosaic-small-grid {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: var(--space-md);
}
.v9__mosaic-small { overflow: hidden; height: 180px; }
.v9__text { display: flex; flex-direction: column; }

/* ═══════════════════════════════════════════════════════════════════════════
   10 · Amber band bisects
   ══════════════════════════════════════════════════════════════════════════ */
.v10 { padding-block: var(--space-5xl); background: var(--color-bg-subtle); }

.v10__amber-band {
	position: absolute;
	inset-block-start: 55%;
	inset-inline: 0;
	height: var(--space-3xl);
	background: var(--color-bg-accent);
	z-index: 0;
}

.v10__grid {
	display: grid;
	grid-template-columns: 1fr;
	gap: var(--space-3xl);
	align-items: center;
	position: relative;
	z-index: 1;

	@media (min-width: 768px) {
		grid-template-columns: 55fr 45fr;
	}
}

.v10__text { display: flex; flex-direction: column; }

.v10__image-wrap {
	overflow: hidden;
	min-height: 480px;
	align-self: stretch;
}
.v10__img { border-radius: var(--radius-lg); }

/* ═══════════════════════════════════════════════════════════════════════════
   11 · Floating caption strip
   ══════════════════════════════════════════════════════════════════════════ */
.v11 { padding-block: var(--space-5xl); }

.v11__grid {
	display: grid;
	grid-template-columns: 1fr;
	gap: var(--space-3xl);
	align-items: center;

	@media (min-width: 768px) {
		grid-template-columns: 55fr 45fr;
	}
}

.v11__text { display: flex; flex-direction: column; }

.v11__image-wrap { position: relative; display: flex; flex-direction: column; }
.v11__image-wrap .img-fill {
	border-radius: var(--radius-lg) var(--radius-lg) 0 0;
	min-height: 440px;
}

.v11__caption-strip {
	background: var(--color-bg-brand);
	padding: var(--space-lg) var(--space-xl);
	display: flex;
	flex-direction: column;
	gap: var(--space-xs);
	border-radius: 0 0 var(--radius-lg) var(--radius-lg);
}
.v11__caption-text {
	font-family: var(--font-serif);
	font-style: italic;
	font-size: var(--font-size-base);
	color: var(--color-fg-on-brand);
}
.v11__caption-sub {
	font-family: var(--font-sans);
	font-size: var(--font-size-xs);
	letter-spacing: var(--letter-spacing-wide);
	text-transform: uppercase;
	color: var(--color-fg-on-brand-muted);
}

/* ═══════════════════════════════════════════════════════════════════════════
   12 · Horizontal process steps
   ══════════════════════════════════════════════════════════════════════════ */
.v12 { padding-block: var(--space-5xl); }

.v12__header { margin-block-end: var(--space-3xl); }

.v12__heading {
	max-width: 600px;
	margin-block-end: 0;
}

.v12__steps-row {
	display: grid;
	grid-template-columns: 1fr;
	gap: var(--space-xl);
	align-items: stretch;
	margin-block-end: var(--space-3xl);

	@media (min-width: 600px) {
		grid-template-columns: repeat(2, 1fr);
	}
	@media (min-width: 900px) {
		grid-template-columns: repeat(4, 1fr) 220px;
	}
}

.v12__step {
	display: flex;
	flex-direction: column;
	gap: var(--space-sm);
	padding-block-start: var(--space-md);
	border-block-start: 2px solid var(--color-border-default);
}
.v12__step:first-child { border-color: var(--color-fg-accent); }

.v12__step-num {
	font-family: var(--font-serif);
	font-style: italic;
	font-size: var(--font-size-2xl);
	color: var(--color-fg-accent);
	line-height: 1;
}
.v12__step-text {
	font-family: var(--font-sans);
	font-size: var(--font-size-sm);
	color: var(--color-fg-muted);
	line-height: var(--line-height-relaxed);
}

.v12__step-image {
	overflow: hidden;
	border-radius: var(--radius-lg);
	min-height: 180px;
}

.v12__cta-row { display: flex; }

/* ═══════════════════════════════════════════════════════════════════════════
   13 · Feature callout box
   ══════════════════════════════════════════════════════════════════════════ */
.v13 { padding-block: var(--space-5xl); }

.v13__grid {
	display: grid;
	grid-template-columns: 1fr;
	gap: var(--space-3xl);
	align-items: center;

	@media (min-width: 768px) {
		grid-template-columns: 55fr 45fr;
	}
}

.v13__text { display: flex; flex-direction: column; }

.v13__callout {
	border: 1px solid var(--color-border-accent);
	padding: var(--space-xl);
	margin-block: var(--space-lg) var(--space-lg);
	display: flex;
	flex-direction: column;
	gap: var(--space-xs);
}
.v13__callout-head {
	font-family: var(--font-sans);
	font-size: var(--font-size-sm);
	font-weight: var(--font-weight-semibold);
	color: var(--color-fg-default);
}
.v13__callout-body {
	font-family: var(--font-sans);
	font-size: var(--font-size-sm);
	color: var(--color-fg-muted);
}

.v13__image { overflow: hidden; min-height: 480px; align-self: stretch; }

/* ═══════════════════════════════════════════════════════════════════════════
   14 · Wide eyebrow dominates
   ══════════════════════════════════════════════════════════════════════════ */
.v14 { padding-block: var(--space-5xl); }

.v14__grid {
	display: grid;
	grid-template-columns: 1fr;
	gap: var(--space-3xl);
	align-items: center;

	@media (min-width: 768px) {
		grid-template-columns: 55fr 45fr;
	}
}
.v14__text { display: flex; flex-direction: column; }

.v14__eyebrow {
	font-family: var(--font-sans);
	font-size: clamp(var(--font-size-lg), 3vw, var(--font-size-3xl));
	font-weight: var(--font-weight-light);
	letter-spacing: var(--letter-spacing-widest);
	text-transform: uppercase;
	color: var(--color-fg-accent-on-brand);
	margin-block-end: var(--space-xl);
	line-height: 1.1;
}

.v14__heading {
	font-family: var(--font-serif);
	font-size: var(--font-size-xl);
	font-weight: var(--font-weight-light);
	font-style: italic;
	color: var(--color-fg-on-brand);
	line-height: var(--line-height-snug);
	margin-block-end: var(--space-lg);
	padding-block-start: var(--space-lg);
	border-block-start: 1px solid color-mix(in srgb, var(--color-fg-on-brand) 20%, transparent);
}

.v14__image { overflow: hidden; min-height: 480px; align-self: stretch; }

/* ═══════════════════════════════════════════════════════════════════════════
   15 · Icon-forward
   ══════════════════════════════════════════════════════════════════════════ */
.v15 { padding-block: var(--space-5xl); }

.v15__grid {
	display: grid;
	grid-template-columns: 1fr;
	gap: var(--space-3xl);
	align-items: start;

	@media (min-width: 768px) {
		grid-template-columns: 1fr 1fr;
	}
}

.v15__text { display: flex; flex-direction: column; }

.v15__icon-wrap {
	width: var(--space-4xl);
	height: var(--space-4xl);
	color: var(--color-fg-accent);
	margin-block-end: var(--space-2xl);
}
.v15__icon-wrap svg {
	width: 100%;
	height: 100%;
}

.v15__aside { display: flex; flex-direction: column; gap: var(--space-xl); }

.v15__kp { display: flex; flex-direction: column; gap: var(--space-xs); }
.v15__kp-rule {
	width: var(--space-lg);
	height: 2px;
	background: var(--color-fg-accent);
	margin-block-end: var(--space-sm);
}
.v15__kp-head {
	font-family: var(--font-sans);
	font-size: var(--font-size-sm);
	font-weight: var(--font-weight-semibold);
	color: var(--color-fg-default);
}
.v15__kp-body {
	font-family: var(--font-sans);
	font-size: var(--font-size-sm);
	color: var(--color-fg-muted);
	line-height: var(--line-height-relaxed);
}

/* ═══════════════════════════════════════════════════════════════════════════
   16 · Filmstrip image / text below
   ══════════════════════════════════════════════════════════════════════════ */
.v16 { padding: 0; }

.v16__filmstrip {
	width: 100%;
	height: 45vh;
	min-height: 280px;
	overflow: hidden;
}
.v16__film-img {
	width: 100%;
	height: 100%;
	object-fit: cover;
	display: block;
}

.v16__body { padding-block: var(--space-4xl); }

.v16__body-grid {
	display: grid;
	grid-template-columns: 1fr;
	gap: var(--space-3xl);
	align-items: start;

	@media (min-width: 768px) {
		grid-template-columns: 55fr 45fr;
	}
}
.v16__body-text { display: flex; flex-direction: column; }

.v16__body-points { display: flex; flex-direction: column; gap: var(--space-xl); }

.v16__kp { display: flex; flex-direction: column; gap: var(--space-xs); border-block-start: 1px solid var(--color-border-default); padding-block-start: var(--space-lg); }
.v16__kp-head {
	font-family: var(--font-sans);
	font-size: var(--font-size-sm);
	font-weight: var(--font-weight-semibold);
	color: var(--color-fg-default);
}
.v16__kp-body {
	font-family: var(--font-sans);
	font-size: var(--font-size-sm);
	color: var(--color-fg-muted);
	line-height: var(--line-height-relaxed);
}

/* ═══════════════════════════════════════════════════════════════════════════
   17 · Stacked image + three-column text below
   ══════════════════════════════════════════════════════════════════════════ */
.v17 { padding: 0; background: var(--color-bg-brand); }

.v17__image-zone { position: relative; overflow: hidden; height: 50vh; min-height: 320px; }
.v17__img { width: 100%; height: 100%; object-fit: cover; display: block; }

.v17__image-caption {
	position: absolute;
	inset-block-end: var(--space-xl);
	inset-inline-start: max(var(--space-lg), calc((100vw - 1280px) / 2));
}
.v17__img-tag {
	font-family: var(--font-sans);
	font-size: var(--font-size-xs);
	letter-spacing: var(--letter-spacing-widest);
	text-transform: uppercase;
