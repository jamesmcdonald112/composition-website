---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { homePageContent } from "../../config/home";
import { buyingAndSellingProperty as svc } from "../../config/services";
import propertyImage from "../../assets/images/new/house-key-and-figurine.webp";
import { Image } from "astro:assets";

const { featuredService } = homePageContent;
const { card } = featuredService;
---

<BaseLayout title="Featured Card Variants" description="Dev — 20 featured card design explorations" canonicalPath="/dev/featured-card-variants">
<div class="dev-page">

	<!-- Context note -->
	<div class="context-note">
		<p>All cards sit on <code>--color-bg-brand-muted</code> — the background they will live on in the A5 layout. CTA sits above the 4-point grid. Points grid has a top border. Icon from config is available.</p>
	</div>

	<div class="card-grid">

		<!-- ─── 1: White card / serif title / amber rule / dash points / amber CTA text -->
		<div class="slot">
			<p class="slot-lbl">1 · White / Serif title / Amber rule / Dash points</p>
			<div class="fc fc1">
				<div class="fc1__image">
					<Image src={propertyImage} alt="" width={600} height={280} class="fc__img" />
				</div>
				<div class="fc1__body">
					<p class="fc1__tag">{card.tag}</p>
					<h3 class="fc1__title">{card.title}</h3>
					<div class="fc1__rule"></div>
					<p class="fc1__body-text">{card.body}</p>
					<a href={card.cta.href} class="fc1__cta">{card.cta.label} →</a>
					<ul class="fc1__points">
						{card.points.map(p => <li>{p}</li>)}
					</ul>
				</div>
			</div>
		</div>

		<!-- ─── 2: Navy card / amber tag / light heading / amber CTA button -->
		<div class="slot">
			<p class="slot-lbl">2 · Navy card / Amber tag / Light serif heading / Amber CTA</p>
			<div class="fc fc2">
				<div class="fc2__image">
					<Image src={propertyImage} alt="" width={600} height={260} class="fc__img" />
				</div>
				<div class="fc2__body">
					<p class="fc2__tag">{card.tag}</p>
					<h3 class="fc2__title">{card.title}</h3>
					<p class="fc2__body-text">{card.body}</p>
					<a href={card.cta.href} class="fc2__cta">{card.cta.label}</a>
					<ul class="fc2__points">
						{card.points.map(p => <li>{p}</li>)}
					</ul>
				</div>
			</div>
		</div>

		<!-- ─── 3: White / icon top-left / no image / clean minimal -->
		<div class="slot">
			<p class="slot-lbl">3 · White / Icon top / No image / Clean minimal</p>
			<div class="fc fc3">
				<div class="fc3__body">
					<div class="fc3__icon-row">
						<div class="fc3__icon" aria-hidden="true">
							<Fragment set:html={card.icon} />
						</div>
						<p class="fc3__tag">{card.tag}</p>
					</div>
					<h3 class="fc3__title">{card.title}</h3>
					<p class="fc3__body-text">{card.body}</p>
					<a href={card.cta.href} class="fc3__cta">{card.cta.label}</a>
					<ul class="fc3__points">
						{card.points.map(p => <li>{p}</li>)}
					</ul>
				</div>
			</div>
		</div>

		<!-- ─── 4: White / image tall left / text right split inside card -->
		<div class="slot slot--wide">
			<p class="slot-lbl">4 · White / Image left inside card / Text right</p>
			<div class="fc fc4">
				<div class="fc4__image">
					<Image src={propertyImage} alt="" width={400} height={520} class="fc__img" />
				</div>
				<div class="fc4__body">
					<p class="fc4__tag">{card.tag}</p>
					<h3 class="fc4__title">{card.title}</h3>
					<p class="fc4__body-text">{card.body}</p>
					<a href={card.cta.href} class="fc4__cta">{card.cta.label}</a>
					<ul class="fc4__points">
						{card.points.map(p => <li>{p}</li>)}
					</ul>
				</div>
			</div>
		</div>

		<!-- ─── 5: Stone / amber left border accent / no image -->
		<div class="slot">
			<p class="slot-lbl">5 · Stone / Amber left border / No image</p>
			<div class="fc fc5">
				<div class="fc5__body">
					<p class="fc5__tag">{card.tag}</p>
					<h3 class="fc5__title">{card.title}</h3>
					<p class="fc5__body-text">{card.body}</p>
					<a href={card.cta.href} class="fc5__cta">{card.cta.label}</a>
					<ul class="fc5__points">
						{card.points.map(p => <li>{p}</li>)}
					</ul>
				</div>
			</div>
		</div>

		<!-- ─── 6: White / image / amber top border accent on card -->
		<div class="slot">
			<p class="slot-lbl">6 · White / Amber top border / Image / Numbered points</p>
			<div class="fc fc6">
				<div class="fc6__image">
					<Image src={propertyImage} alt="" width={600} height={260} class="fc__img" />
				</div>
				<div class="fc6__body">
					<p class="fc6__tag">{card.tag}</p>
					<h3 class="fc6__title">{card.title}</h3>
					<p class="fc6__body-text">{card.body}</p>
					<a href={card.cta.href} class="fc6__cta">{card.cta.label}</a>
					<ol class="fc6__points">
						{card.points.map((p, i) => (
							<li>
								<span class="fc6__num">0{i+1}</span>
								<span>{p}</span>
							</li>
						))}
					</ol>
				</div>
			</div>
		</div>

		<!-- ─── 7: Navy / no image / icon large / amber points markers -->
		<div class="slot">
			<p class="slot-lbl">7 · Navy / Large icon / Amber point markers / No image</p>
			<div class="fc fc7">
				<div class="fc7__body">
					<div class="fc7__icon" aria-hidden="true">
						<Fragment set:html={card.icon} />
					</div>
					<p class="fc7__tag">{card.tag}</p>
					<h3 class="fc7__title">{card.title}</h3>
					<p class="fc7__body-text">{card.body}</p>
					<a href={card.cta.href} class="fc7__cta">{card.cta.label}</a>
					<ul class="fc7__points">
						{card.points.map(p => <li>{p}</li>)}
					</ul>
				</div>
			</div>
		</div>

		<!-- ─── 8: White / image / serif italic title / ghost CTA button -->
		<div class="slot">
			<p class="slot-lbl">8 · White / Serif italic title / Ghost CTA / Image</p>
			<div class="fc fc8">
				<div class="fc8__image">
					<Image src={propertyImage} alt="" width={600} height={260} class="fc__img" />
				</div>
				<div class="fc8__body">
					<p class="fc8__tag">{card.tag}</p>
					<h3 class="fc8__title">{card.title}</h3>
					<p class="fc8__body-text">{card.body}</p>
					<a href={card.cta.href} class="fc8__cta">{card.cta.label}</a>
					<ul class="fc8__points">
						{card.points.map(p => <li>{p}</li>)}
					</ul>
				</div>
			</div>
		</div>

		<!-- ─── 9: Amber card / navy heading / navy points / navy CTA -->
		<div class="slot">
			<p class="slot-lbl">9 · Amber card / Navy heading / Navy CTA</p>
			<div class="fc fc9">
				<div class="fc9__image">
					<Image src={propertyImage} alt="" width={600} height={260} class="fc__img" />
				</div>
				<div class="fc9__body">
					<p class="fc9__tag">{card.tag}</p>
					<h3 class="fc9__title">{card.title}</h3>
					<p class="fc9__body-text">{card.body}</p>
					<a href={card.cta.href} class="fc9__cta">{card.cta.label}</a>
					<ul class="fc9__points">
						{card.points.map(p => <li>{p}</li>)}
					</ul>
				</div>
			</div>
		</div>

		<!-- ─── 10: White / image overlaps top of card (negative margin) -->
		<div class="slot">
			<p class="slot-lbl">10 · White / Image overlaps above card top</p>
			<div class="fc10-wrap">
				<div class="fc10__image">
					<Image src={propertyImage} alt="" width={600} height={220} class="fc__img" />
				</div>
				<div class="fc fc10">
					<div class="fc10__body">
						<p class="fc10__tag">{card.tag}</p>
						<h3 class="fc10__title">{card.title}</h3>
						<p class="fc10__body-text">{card.body}</p>
						<a href={card.cta.href} class="fc10__cta">{card.cta.label}</a>
						<ul class="fc10__points">
							{card.points.map(p => <li>{p}</li>)}
						</ul>
					</div>
				</div>
			</div>
		</div>

		<!-- ─── 11: White / icon + tag inline / amber rule / 2-col points grid -->
		<div class="slot">
			<p class="slot-lbl">11 · White / Icon+tag inline / Amber rule / 2-col points</p>
			<div class="fc fc11">
				<div class="fc11__body">
					<div class="fc11__header">
						<div class="fc11__icon" aria-hidden="true">
							<Fragment set:html={card.icon} />
						</div>
						<div class="fc11__header-text">
							<p class="fc11__tag">{card.tag}</p>
							<h3 class="fc11__title">{card.title}</h3>
						</div>
					</div>
					<div class="fc11__rule"></div>
					<p class="fc11__body-text">{card.body}</p>
					<a href={card.cta.href} class="fc11__cta">{card.cta.label}</a>
					<ul class="fc11__points">
						{card.points.map(p => <li>{p}</li>)}
					</ul>
				</div>
			</div>
		</div>

		<!-- ─── 12: Navy / image / full-width amber CTA button -->
		<div class="slot">
			<p class="slot-lbl">12 · Navy / Image / Full-width amber CTA</p>
			<div class="fc fc12">
				<div class="fc12__image">
					<Image src={propertyImage} alt="" width={600} height={260} class="fc__img" />
				</div>
				<div class="fc12__body">
					<p class="fc12__tag">{card.tag}</p>
					<h3 class="fc12__title">{card.title}</h3>
					<p class="fc12__body-text">{card.body}</p>
					<a href={card.cta.href} class="fc12__cta">{card.cta.label}</a>
					<ul class="fc12__points">
						{card.points.map(p => <li>{p}</li>)}
					</ul>
				</div>
			</div>
		</div>

		<!-- ─── 13: White / image / tag overlaid on image / bottom text -->
		<div class="slot">
			<p class="slot-lbl">13 · White / Tag overlaid on image / Clean body</p>
			<div class="fc fc13">
				<div class="fc13__image-wrap">
					<Image src={propertyImage} alt="" width={600} height={280} class="fc__img" />
					<p class="fc13__tag-overlay">{card.tag}</p>
				</div>
				<div class="fc13__body">
					<h3 class="fc13__title">{card.title}</h3>
					<p class="fc13__body-text">{card.body}</p>
					<a href={card.cta.href} class="fc13__cta">{card.cta.label}</a>
					<ul class="fc13__points">
						{card.points.map(p => <li>{p}</li>)}
					</ul>
				</div>
			</div>
		</div>

		<!-- ─── 14: Stone / no image / numbered 2-col points / amber outline CTA -->
		<div class="slot">
			<p class="slot-lbl">14 · Stone / No image / Numbered 2-col points / Outline CTA</p>
			<div class="fc fc14">
				<div class="fc14__body">
					<p class="fc14__tag">{card.tag}</p>
					<h3 class="fc14__title">{card.title}</h3>
					<p class="fc14__body-text">{card.body}</p>
					<a href={card.cta.href} class="fc14__cta">{card.cta.label}</a>
					<ol class="fc14__points">
						{card.points.map((p, i) => (
							<li>
								<span class="fc14__num">0{i+1}</span>
								<span>{p}</span>
							</li>
						))}
					</ol>
				</div>
			</div>
		</div>

		<!-- ─── 15: White / image / amber bottom strip / white text on strip -->
		<div class="slot">
			<p class="slot-lbl">15 · White / Image / Amber accent bottom strip</p>
			<div class="fc fc15">
				<div class="fc15__image">
					<Image src={propertyImage} alt="" width={600} height={260} class="fc__img" />
				</div>
				<div class="fc15__body">
					<p class="fc15__tag">{card.tag}</p>
					<h3 class="fc15__title">{card.title}</h3>
					<p class="fc15__body-text">{card.body}</p>
					<a href={card.cta.href} class="fc15__cta">{card.cta.label}</a>
					<ul class="fc15__points">
						{card.points.map(p => <li>{p}</li>)}
					</ul>
				</div>
				<div class="fc15__strip">
					<span class="fc15__strip-text">Over 46 years of Kilkenny property transactions</span>
				</div>
			</div>
		</div>

		<!-- ─── 16: White / image / large serif title / text-only CTA -->
		<div class="slot">
			<p class="slot-lbl">16 · White / Image / Large serif italic title / Text CTA</p>
			<div class="fc fc16">
				<div class="fc16__image">
					<Image src={propertyImage} alt="" width={600} height={240} class="fc__img" />
				</div>
				<div class="fc16__body">
					<p class="fc16__tag">{card.tag}</p>
					<h3 class="fc16__title">{card.title}</h3>
					<p class="fc16__body-text">{card.body}</p>
					<a href={card.cta.href} class="fc16__cta">{card.cta.label} <span aria-hidden="true">→</span></a>
					<ul class="fc16__points">
						{card.points.map(p => <li>{p}</li>)}
					</ul>
				</div>
			</div>
		</div>

		<!-- ─── 17: Navy / icon row / serif title / amber filled CTA -->
		<div class="slot">
			<p class="slot-lbl">17 · Navy / Icon row / Serif title / Amber filled CTA</p>
			<div class="fc fc17">
				<div class="fc17__body">
					<div class="fc17__top">
						<div class="fc17__icon" aria-hidden="true">
							<Fragment set:html={card.icon} />
						</div>
						<p class="fc17__tag">{card.tag}</p>
					</div>
					<h3 class="fc17__title">{card.title}</h3>
					<p class="fc17__body-text">{card.body}</p>
					<a href={card.cta.href} class="fc17__cta">{card.cta.label}</a>
					<ul class="fc17__points">
						{card.points.map(p => <li>{p}</li>)}
					</ul>
				</div>
			</div>
		</div>

		<!-- ─── 18: White / image / amber right border on card / tag top-right -->
		<div class="slot">
			<p class="slot-lbl">18 · White / Amber right border / Image / Tag right-aligned</p>
			<div class="fc fc18">
				<div class="fc18__image">
					<Image src={propertyImage} alt="" width={600} height={260} class="fc__img" />
				</div>
				<div class="fc18__body">
					<p class="fc18__tag">{card.tag}</p>
					<h3 class="fc18__title">{card.title}</h3>
					<p class="fc18__body-text">{card.body}</p>
					<a href={card.cta.href} class="fc18__cta">{card.cta.label}</a>
					<ul class="fc18__points">
						{card.points.map(p => <li>{p}</li>)}
					</ul>
				</div>
			</div>
		</div>

		<!-- ─── 19: White / image / two-tone: image area navy tint / body white -->
		<div class="slot">
			<p class="slot-lbl">19 · Two-tone / Navy image zone / White body zone</p>
			<div class="fc fc19">
				<div class="fc19__image-zone">
					<Image src={propertyImage} alt="" width={600} height={260} class="fc__img" />
					<div class="fc19__image-footer">
						<p class="fc19__tag">{card.tag}</p>
					</div>
				</div>
				<div class="fc19__body">
					<h3 class="fc19__title">{card.title}</h3>
					<p class="fc19__body-text">{card.body}</p>
					<a href={card.cta.href} class="fc19__cta">{card.cta.label}</a>
					<ul class="fc19__points">
						{card.points.map(p => <li>{p}</li>)}
					</ul>
				</div>
			</div>
		</div>

		<!-- ─── 20: White / image / amber shadow / sans title / filled amber CTA -->
		<div class="slot">
			<p class="slot-lbl">20 · White / Amber shadow / Sans title / Filled amber CTA</p>
			<div class="fc fc20">
				<div class="fc20__image">
					<Image src={propertyImage} alt="" width={600} height={260} class="fc__img" />
				</div>
				<div class="fc20__body">
					<p class="fc20__tag">{card.tag}</p>
					<h3 class="fc20__title">{card.title}</h3>
					<p class="fc20__body-text">{card.body}</p>
					<a href={card.cta.href} class="fc20__cta">{card.cta.label}</a>
					<ul class="fc20__points">
						{card.points.map(p => <li>{p}</li>)}
					</ul>
				</div>
			</div>
		</div>

	</div><!-- /card-grid -->
</div>
</BaseLayout>

<style>
/* ── Page ─────────────────────────────────────────────────────────────────── */
.dev-page {
	background: var(--color-bg-brand-muted);
	min-height: 100vh;
	padding-block: var(--space-4xl);
}

.context-note {
	max-width: 800px;
	margin-inline: auto;
	margin-block-end: var(--space-3xl);
	padding-inline: var(--space-lg);
	font-family: var(--font-sans);
	font-size: var(--font-size-sm);
	color: var(--color-fg-on-brand-muted);
}
.context-note code {
	background: color-mix(in srgb, var(--color-fg-on-brand) 10%, transparent);
	padding: var(--space-2xs) var(--space-xs);
	font-size: var(--font-size-xs);
}

.card-grid {
	display: grid;
	grid-template-columns: 1fr;
	gap: var(--space-4xl);
	padding-inline: var(--space-lg);
	max-width: 1000px;
	margin-inline: auto;

	@media (min-width: 700px) {
		grid-template-columns: repeat(2, 1fr);
	}
}

.slot {
	display: flex;
	flex-direction: column;
	gap: var(--space-md);
}
.slot--wide {
	@media (min-width: 700px) { grid-column: span 2; }
}
.slot-lbl {
	font-family: var(--font-sans);
	font-size: var(--font-size-xs);
	letter-spacing: var(--letter-spacing-wider);
	text-transform: uppercase;
	color: var(--color-fg-on-brand-muted);
	opacity: 0.5;
}

/* ── Shared image utility ─────────────────────────────────────────────────── */
.fc__img { width: 100%; height: 100%; object-fit: cover; display: block; }

/* ── Shared point structures ──────────────────────────────────────────────── */
/* All cards share the same basic point grid layout below the CTA */

/* ═══════════════════════════════════════════════════════════════════════════
   1 · White / Serif title / Amber rule / Dash points
   ══════════════════════════════════════════════════════════════════════════ */
.fc1 {
	background: var(--color-bg-surface);
	border-radius: var(--radius-lg);
	overflow: hidden;
	box-shadow: var(--shadow-lg);
}
.fc1__image { height: 220px; overflow: hidden; }
.fc1__body { padding: var(--space-xl); display: flex; flex-direction: column; }
.fc1__tag { font-family: var(--font-sans); font-size: var(--font-size-xs); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-accent); margin-block-end: var(--space-xs); }
.fc1__title { font-family: var(--font-serif); font-size: var(--font-size-2xl); font-weight: var(--font-weight-light); font-style: italic; color: var(--color-fg-default); line-height: var(--line-height-tight); margin-block-end: var(--space-md); }
.fc1__rule { height: 2px; width: var(--space-xl); background: var(--color-fg-accent); margin-block-end: var(--space-lg); }
.fc1__body-text { font-family: var(--font-sans); font-size: var(--font-size-sm); line-height: var(--line-height-relaxed); color: var(--color-fg-muted); margin-block-end: var(--space-lg); }
.fc1__cta { display: inline-flex; font-family: var(--font-sans); font-size: var(--font-size-sm); font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-wide); text-transform: uppercase; color: var(--color-fg-accent); text-decoration: none; margin-block-end: var(--space-xl); }
.fc1__points { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-sm); border-block-start: 1px solid var(--color-border-default); padding-block-start: var(--space-lg); }
.fc1__points li { font-family: var(--font-sans); font-size: var(--font-size-xs); color: var(--color-fg-muted); padding-inline-start: var(--space-lg); position: relative; }
.fc1__points li::before { content: "—"; position: absolute; inset-inline-start: 0; color: var(--color-fg-accent); }

/* ═══════════════════════════════════════════════════════════════════════════
   2 · Navy card / Amber tag / Light serif heading
   ══════════════════════════════════════════════════════════════════════════ */
.fc2 { background: var(--color-bg-brand); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-xl); }
.fc2__image { height: 200px; overflow: hidden; }
.fc2__body { padding: var(--space-xl); display: flex; flex-direction: column; }
.fc2__tag { font-family: var(--font-sans); font-size: var(--font-size-xs); letter-spacing: var(--letter-spacing-widest); text-transform: uppercase; color: var(--color-fg-accent-on-brand); margin-block-end: var(--space-sm); }
.fc2__title { font-family: var(--font-serif); font-size: var(--font-size-xl); font-weight: var(--font-weight-light); font-style: italic; color: var(--color-fg-on-brand); line-height: var(--line-height-snug); margin-block-end: var(--space-lg); }
