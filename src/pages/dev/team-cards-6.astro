			<div class="wrapper wrapper--wide">
				<p class="dev-label">08 — xl radius card, strip has gold top line + taller peek</p>
				<div class="tc-grid">
					{m.map((p) => (
						<div class="v08">
							<div class="v08__mobile">
								<div class="v08__m-img-wrap">
									<Image src={p.photo} alt={p.name} width={120} height={140} class="v08__m-img" />
								</div>
								<div class="v08__m-text">
									<p class="v08__m-role">{p.role}</p>
									<h3 class="v08__m-name">{p.name}</h3>
									<p class="v08__m-bio">{p.bio}</p>
								</div>
							</div>
							<div class="v08__desktop">
								<div class="v08__img-wrap">
									<Image src={p.photo} alt={p.name} width={360} height={480} class="v08__img" />
									<div class="v08__strip">
										<div class="v08__static">
											<p class="v08__role">{p.role}</p>
											<h3 class="v08__name">{p.name}</h3>
										</div>
										<p class="v08__bio">{p.bio}</p>
									</div>
								</div>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─── 09: Mobile circle avatar + text, desktop v03 ────────────────── -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">09 — Mobile: circle avatar; Desktop: v03 portrait strip</p>
				<div class="tc-grid">
					{m.map((p) => (
						<div class="v09">
							<div class="v09__mobile">
								<div class="v09__m-circle">
									<Image src={p.photo} alt={p.name} width={80} height={80} class="v09__m-img" />
								</div>
								<div class="v09__m-text">
									<p class="v09__m-role">{p.role}</p>
									<h3 class="v09__m-name">{p.name}</h3>
									<p class="v09__m-bio">{p.bio}</p>
								</div>
							</div>
							<div class="v09__desktop">
								<div class="v09__img-wrap">
									<Image src={p.photo} alt={p.name} width={360} height={480} class="v09__img" />
									<div class="v09__strip">
										<div class="v09__static">
											<p class="v09__role">{p.role}</p>
											<h3 class="v09__name">{p.name}</h3>
										</div>
										<p class="v09__bio">{p.bio}</p>
									</div>
								</div>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─── 10: Mobile P-style (stroke + role), desktop v03 ─────────────── -->
		<section class="dev-section dev-section--alt">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">10 — Mobile: P-style vertical stroke; Desktop: v03 strip</p>
				<div class="tc-grid">
					{m.map((p) => (
						<div class="v10">
							<div class="v10__mobile">
								<div class="v10__m-img-wrap">
									<Image src={p.photo} alt={p.name} width={120} height={140} class="v10__m-img" />
								</div>
								<div class="v10__m-text">
									<div class="v10__m-header">
										<div class="v10__m-stroke" aria-hidden="true"></div>
										<p class="v10__m-role">{p.role}</p>
									</div>
									<h3 class="v10__m-name">{p.name}</h3>
									<p class="v10__m-bio">{p.bio}</p>
								</div>
							</div>
							<div class="v10__desktop">
								<div class="v10__img-wrap">
									<Image src={p.photo} alt={p.name} width={360} height={480} class="v10__img" />
									<div class="v10__strip">
										<div class="v10__static">
											<p class="v10__role">{p.role}</p>
											<h3 class="v10__name">{p.name}</h3>
										</div>
										<p class="v10__bio">{p.bio}</p>
									</div>
								</div>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─── 11: Strip peek shows role only (minimal), name in bio reveal ── -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">11 — Peek shows role only; name + bio reveal together</p>
				<div class="tc-grid">
					{m.map((p) => (
						<div class="v11">
							<div class="v11__mobile">
								<div class="v11__m-img-wrap">
									<Image src={p.photo} alt={p.name} width={120} height={140} class="v11__m-img" />
								</div>
								<div class="v11__m-text">
									<p class="v11__m-role">{p.role}</p>
									<h3 class="v11__m-name">{p.name}</h3>
									<p class="v11__m-bio">{p.bio}</p>
								</div>
							</div>
							<div class="v11__desktop">
								<div class="v11__img-wrap">
									<Image src={p.photo} alt={p.name} width={360} height={480} class="v11__img" />
									<div class="v11__strip">
										<div class="v11__static">
											<p class="v11__role">{p.role}</p>
										</div>
										<h3 class="v11__name">{p.name}</h3>
										<p class="v11__bio">{p.bio}</p>
									</div>
								</div>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─── 12: Strip with large display name, role small above ─────────── -->
