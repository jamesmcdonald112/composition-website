									<p class="v12__m-bio">{p.bio}</p>
								</div>
							</div>
							<div class="v12__desktop">
								<div class="v12__img-wrap">
									<Image src={p.photo} alt={p.name} width={360} height={480} class="v12__img" />
									<div class="v12__strip">
										<div class="v12__static">
											<p class="v12__role">{p.role}</p>
											<h3 class="v12__name">{p.name}</h3>
										</div>
										<p class="v12__bio">{p.bio}</p>
									</div>
								</div>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─── 13: Strip full-opacity brand, no transparency ───────────────── -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">13 — Strip fully opaque brand colour, no transparency</p>
				<div class="tc-grid">
					{m.map((p) => (
						<div class="v13">
							<div class="v13__mobile">
