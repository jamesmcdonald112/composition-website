										<div class="v13__static">
											<p class="v13__role">{p.role}</p>
											<h3 class="v13__name">{p.name}</h3>
										</div>
										<p class="v13__bio">{p.bio}</p>
									</div>
								</div>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─── 14: Desktop peek taller (name + first line of bio visible) ──── -->
		<section class="dev-section dev-section--alt">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">14 — Taller default peek: role + name + partial bio visible</p>
				<div class="tc-grid">
