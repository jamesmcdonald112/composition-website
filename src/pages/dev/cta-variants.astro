---

<BaseLayout
	title="CTA Panel Colour Variants"
	description="Dev page — 20 colour variant explorations for CTA panel"
	canonicalPath="/dev/cta-variants"
>
	<div class="dev-page">
		{variants.map((v) => (
			<section
				class="cta-variant"
				style={`
					background-color: ${v.bg};
					--variant-intro: ${v.introColor};
					--variant-em: ${v.emColor};
				`}
			>
				<div class="variant-label">{v.label}</div>
				<div class="cta-variant__inner wrapper wrapper--wide">
					<div class="cta-variant__text">
						<SectionHeader
							eyebrow={eyebrow}
							heading={heading}
							intro={body}
							eyebrowColor={v.eyebrowColor}
							ruleColor={v.ruleColor}
							headingColor={v.headingColor}
							noMargin
						/>
					</div>
					<div class="cta-variant__ctas">
						<CtaLink
							href={booking.href}
							label={booking.label}
							variant={v.btn1}
							calLink={booking.calLink}
							calNamespace={booking.calNamespace}
							calConfig={booking.calConfig}
						/>
						<CtaLink
							href="/contact"
							label="Contact Us"
							variant={v.btn2}
							icon="arrow"
						/>
					</div>
				</div>
			</section>
		))}
	</div>
</BaseLayout>

<style>
	.dev-page {
		display: flex;
		flex-direction: column;
	}

	.cta-variant {
		padding-block: var(--space-4xl);
		position: relative;
	}

	.variant-label {
		position: absolute;
		top: var(--space-sm);
		left: var(--space-lg);
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		letter-spacing: var(--letter-spacing-wider);
		text-transform: uppercase;
		opacity: 0.4;
		color: currentColor;
	}

	.cta-variant__inner {
		display: grid;
		grid-template-columns: 1fr;

		@media (min-width: 1024px) {
			grid-template-columns: 1fr 1fr;
			align-items: center;
		}
	}

	.cta-variant__text {
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
	}

	/* Override intro colour per variant */
	.cta-variant :global(.section-header__intro) {
		color: var(--variant-intro);
	}

	/* Override em colour per variant */
	.cta-variant :global(.section-header__heading em) {
		color: var(--variant-em);
	}

	.cta-variant__ctas {
		display: flex;
		flex-direction: column;
		gap: var(--space-lg);
		margin-block-start: var(--space-2xl);

		@media (min-width: 640px) {
			flex-direction: row;
			flex-wrap: wrap;
			align-items: center;
		}

		@media (min-width: 1024px) {
			margin-block-start: 0;
			justify-content: flex-end;
		}
	}
</style>
