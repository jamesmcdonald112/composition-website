---
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import maryPhoto from "../../assets/team/maryCropped.webp";
import nicholasPhoto from "../../assets/team/nicholas.webp";
import richardPhoto from "../../assets/team/richard.webp";
import dukePhoto from "../../assets/team/duke.webp";

const m = [
	{ name: "Mary Molloy", role: "Principal Solicitor", bio: "Mary leads the firm with over four decades of experience advising clients on property and private client matters throughout Kilkenny. She is known for her practical guidance, straightforward advice and personal approach to each case.", photo: maryPhoto, initial: "M" },
	{ name: "Nicholas O'Shea", role: "Solicitor", bio: "Nicholas works across property and private client matters, supporting clients with clear communication and efficient case progression. He focuses on responsiveness, clarity and maintaining consistent contact throughout the legal process.", photo: nicholasPhoto, initial: "N" },
	{ name: "Richard O'Shea", role: "Solicitor", bio: "Richard advises clients on buying and selling property, conveyancing and probate matters. He brings a steady, detail-focused approach to ensure each transaction progresses efficiently from first instruction to final completion.", photo: richardPhoto, initial: "R" },
	{ name: "Duke", role: "Office Companion", bio: "Providing daily morale support to the team and a friendly welcome to visitors.", photo: dukePhoto, initial: "D" },
] as const;
---

<BaseLayout
	title="Team Cards — Round 3"
	description="Dev page — team card explorations round 3"
	canonicalPath="/dev/team-cards-3"
>
	<div class="dev-page">
		<div class="dev-page__header wrapper wrapper--wide">
			<h1 class="dev-page__title">Team Cards — Round 3</h1>
			<p class="dev-page__sub">Based on C, M, N (fixed), P — adventurous colour</p>
		</div>

		<!-- ─── 01: C variant — slide reveal, accent bg top ─────────────────── -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">01 — C: slide-up, accent-tinted top section</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="v01">
							<div class="v01__img-wrap">
								<Image src={p.photo} alt={p.name} width={360} height={460} class="v01__img" />
								<div class="v01__panel">
									<p class="v01__role">{p.role}</p>
									<h3 class="v01__name">{p.name}</h3>
									<div class="v01__rule" aria-hidden="true"></div>
									<p class="v01__bio">{p.bio}</p>
								</div>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─── 02: C variant — slide from left, portrait crop ───────────────── -->
		<section class="dev-section dev-section--alt">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">02 — C: panel slides from left edge</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="v02">
							<div class="v02__img-wrap">
								<Image src={p.photo} alt={p.name} width={360} height={460} class="v02__img" />
								<div class="v02__panel">
									<p class="v02__role">{p.role}</p>
									<h3 class="v02__name">{p.name}</h3>
									<p class="v02__bio">{p.bio}</p>
								</div>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─── 03: C variant — split bottom third always visible ────────────── -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">03 — C: always-visible name strip, bio reveals up</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="v03">
							<div class="v03__img-wrap">
								<Image src={p.photo} alt={p.name} width={360} height={480} class="v03__img" />
								<div class="v03__strip">
									<div class="v03__static">
										<p class="v03__role">{p.role}</p>
										<h3 class="v03__name">{p.name}</h3>
									</div>
									<p class="v03__bio">{p.bio}</p>
								</div>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─── 04: M variant — flanked rules, brand bg, gold centred role ───── -->
		<section class="dev-section dev-section--brand">
			<div class="wrapper wrapper--wide">
				<p class="dev-label dev-label--light">04 — M: on dark brand, gold flanked rule</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="v04">
							<div class="v04__img-wrap">
								<Image src={p.photo} alt={p.name} width={300} height={260} class="v04__img" />
							</div>
							<div class="v04__body">
								<div class="v04__eyebrow">
									<span class="v04__rule-side" aria-hidden="true"></span>
									<p class="v04__role">{p.role}</p>
									<span class="v04__rule-side" aria-hidden="true"></span>
								</div>
								<h3 class="v04__name">{p.name}</h3>
								<p class="v04__bio">{p.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─── 05: M variant — wide 2-col, role rules, large serif name ──────── -->
		<section class="dev-section dev-section--alt">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">05 — M: wide 2-col, portrait left, rules centred</p>
				<div class="grid-2">
					{m.map((p) => (
						<div class="v05">
							<div class="v05__img-col">
								<Image src={p.photo} alt={p.name} width={220} height={260} class="v05__img" />
							</div>
							<div class="v05__text-col">
								<div class="v05__eyebrow">
									<span class="v05__rule-side" aria-hidden="true"></span>
									<p class="v05__role">{p.role}</p>
									<span class="v05__rule-side" aria-hidden="true"></span>
								</div>
								<h3 class="v05__name">{p.name}</h3>
								<p class="v05__bio">{p.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─── 06: N fixed — gradient footer bio integrated in card ──────────── -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">06 — N fixed: bio in accent-bg panel, part of card</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="v06">
							<div class="v06__img-wrap">
								<Image src={p.photo} alt={p.name} width={340} height={380} class="v06__img" />
								<div class="v06__name-bar">
									<p class="v06__role">{p.role}</p>
									<h3 class="v06__name">{p.name}</h3>
								</div>
							</div>
							<div class="v06__bio-panel">
								<p class="v06__bio">{p.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─── 07: N fixed — photo + gradient + bio all in one contained card ── -->
		<section class="dev-section dev-section--alt">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">07 — N: full-bleed photo, gradient dissolves into bio panel</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="v07">
							<div class="v07__photo">
								<Image src={p.photo} alt={p.name} width={340} height={320} class="v07__img" />
								<div class="v07__fade" aria-hidden="true"></div>
							</div>
							<div class="v07__body">
								<div class="v07__meta">
									<h3 class="v07__name">{p.name}</h3>
									<p class="v07__role">{p.role}</p>
								</div>
								<p class="v07__bio">{p.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─── 08: P variant — inset shadow, horizontal gold bar top ────────── -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">08 — P: gold top bar, inset shadow, accent bg</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="v08">
							<div class="v08__bar" aria-hidden="true"></div>
							<div class="v08__img-wrap">
								<Image src={p.photo} alt={p.name} width={280} height={240} class="v08__img" />
							</div>
							<div class="v08__body">
								<div class="v08__header">
									<p class="v08__role">{p.role}</p>
								</div>
								<h3 class="v08__name">{p.name}</h3>
								<p class="v08__bio">{p.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─── 09: P variant — dark, vertical gold stroke, brand-muted bg ───── -->
		<section class="dev-section dev-section--brand">
			<div class="wrapper wrapper--wide">
				<p class="dev-label dev-label--light">09 — P: dark version, vertical stroke, brand-muted</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="v09">
							<div class="v09__img-wrap">
								<Image src={p.photo} alt={p.name} width={280} height={240} class="v09__img" />
							</div>
							<div class="v09__body">
								<div class="v09__header">
									<div class="v09__stroke" aria-hidden="true"></div>
									<p class="v09__role">{p.role}</p>
								</div>
								<h3 class="v09__name">{p.name}</h3>
								<p class="v09__bio">{p.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─── 10: Adventure — tertiary colour (sage/green), circle, ruled ───── -->
		<section class="dev-section dev-section--alt">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">10 — Tertiary colour: sage border, circle photo</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="v10">
							<div class="v10__circle">
								<Image src={p.photo} alt={p.name} width={200} height={200} class="v10__img" />
							</div>
							<div class="v10__body">
								<p class="v10__role">{p.role}</p>
								<h3 class="v10__name">{p.name}</h3>
								<p class="v10__bio">{p.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─── 11: Adventure — brand-subtle bg, no border, generous padding ──── -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">11 — Brand-subtle tint bg, square photo, spacious</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="v11">
							<div class="v11__img-wrap">
								<Image src={p.photo} alt={p.name} width={260} height={260} class="v11__img" />
							</div>
							<div class="v11__eyebrow">
								<span class="v11__rule" aria-hidden="true"></span>
								<p class="v11__role">{p.role}</p>
							</div>
							<h3 class="v11__name">{p.name}</h3>
							<p class="v11__bio">{p.bio}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─── 12: Adventure — accent-bg card (amber tint), dark text ────────── -->
		<section class="dev-section dev-section--alt">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">12 — Accent-tinted card bg (amber), strong contrast</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="v12">
							<div class="v12__img-wrap">
								<Image src={p.photo} alt={p.name} width={280} height={240} class="v12__img" />
							</div>
							<div class="v12__body">
								<p class="v12__role">{p.role}</p>
								<h3 class="v12__name">{p.name}</h3>
								<p class="v12__bio">{p.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─── 13: C + M hybrid — slide-up with centred flanked rule inside panel -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">13 — C+M hybrid: flanked rule inside slide panel</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="v13">
							<div class="v13__img-wrap">
								<Image src={p.photo} alt={p.name} width={360} height={460} class="v13__img" />
								<div class="v13__panel">
									<div class="v13__eyebrow">
										<span class="v13__rule-side" aria-hidden="true"></span>
										<p class="v13__role">{p.role}</p>
										<span class="v13__rule-side" aria-hidden="true"></span>
									</div>
									<h3 class="v13__name">{p.name}</h3>
									<p class="v13__bio">{p.bio}</p>
								</div>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─── 14: N + P hybrid — gradient footer + vertical stroke left ──────── -->
		<section class="dev-section dev-section--alt">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">14 — N+P: gradient name bar + vertical stroke in bio</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="v14">
							<div class="v14__photo-area">
								<Image src={p.photo} alt={p.name} width={340} height={360} class="v14__img" />
								<div class="v14__name-bar">
									<p class="v14__role">{p.role}</p>
									<h3 class="v14__name">{p.name}</h3>
								</div>
							</div>
							<div class="v14__bio-row">
								<div class="v14__stroke" aria-hidden="true"></div>
								<p class="v14__bio">{p.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─── 15: Adventure — stark white card, thick brand border top ────────── -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">15 — Bold brand border-top, white card, large name</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="v15">
							<div class="v15__img-wrap">
								<Image src={p.photo} alt={p.name} width={280} height={240} class="v15__img" />
							</div>
							<div class="v15__body">
								<p class="v15__role">{p.role}</p>
								<h3 class="v15__name">{p.name}</h3>
								<p class="v15__bio">{p.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─── 16: Adventure — large square, role as watermark behind name ──────── -->
		<section class="dev-section dev-section--alt">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">16 — Role as oversized watermark text behind name</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="v16">
							<div class="v16__img-wrap">
								<Image src={p.photo} alt={p.name} width={280} height={260} class="v16__img" />
							</div>
							<div class="v16__body">
								<div class="v16__watermark-wrap">
									<span class="v16__watermark" aria-hidden="true">{p.role}</span>
									<h3 class="v16__name">{p.name}</h3>
								</div>
								<p class="v16__bio">{p.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─── 17: C + brand-subtle — slide panel on brand-subtle bg card ──────── -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">17 — C: slide panel, brand-subtle card bg, no border</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="v17">
							<div class="v17__img-wrap">
								<Image src={p.photo} alt={p.name} width={360} height={440} class="v17__img" />
								<div class="v17__panel">
									<p class="v17__role">{p.role}</p>
									<h3 class="v17__name">{p.name}</h3>
									<p class="v17__bio">{p.bio}</p>
								</div>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─── 18: M + circle — flanked rules above a circle portrait ───────────── -->
		<section class="dev-section dev-section--alt">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">18 — M+circle: flanked rule above, centred circle</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="v18">
							<div class="v18__eyebrow">
								<span class="v18__rule-side" aria-hidden="true"></span>
								<p class="v18__role">{p.role}</p>
								<span class="v18__rule-side" aria-hidden="true"></span>
							</div>
							<div class="v18__circle">
								<Image src={p.photo} alt={p.name} width={200} height={200} class="v18__img" />
							</div>
							<h3 class="v18__name">{p.name}</h3>
							<p class="v18__bio">{p.bio}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─── 19: P + slide — letterpress card with slide reveal on hover ──────── -->
		<section class="dev-section">
			<div class="wrapper wrapper--wide">
				<p class="dev-label">19 — P+C: letterpress card, bio reveals on hover</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="v19">
							<div class="v19__img-wrap">
								<Image src={p.photo} alt={p.name} width={280} height={260} class="v19__img" />
							</div>
							<div class="v19__body">
								<div class="v19__header">
									<div class="v19__stroke" aria-hidden="true"></div>
									<p class="v19__role">{p.role}</p>
								</div>
								<h3 class="v19__name">{p.name}</h3>
								<div class="v19__bio-wrap">
									<p class="v19__bio">{p.bio}</p>
								</div>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ─── 20: Grand finale — C+M+P all features, accent bg, max drama ──────── -->
		<section class="dev-section dev-section--brand">
			<div class="wrapper wrapper--wide">
				<p class="dev-label dev-label--light">20 — Full drama: C slide + M rules + P stroke, dark bg</p>
				<div class="grid-4">
					{m.map((p) => (
						<div class="v20">
							<div class="v20__img-wrap">
								<Image src={p.photo} alt={p.name} width={360} height={460} class="v20__img" />
								<div class="v20__panel">
									<div class="v20__eyebrow">
										<span class="v20__rule-side" aria-hidden="true"></span>
										<p class="v20__role">{p.role}</p>
										<span class="v20__rule-side" aria-hidden="true"></span>
									</div>
									<div class="v20__name-row">
										<div class="v20__stroke" aria-hidden="true"></div>
										<h3 class="v20__name">{p.name}</h3>
									</div>
									<p class="v20__bio">{p.bio}</p>
								</div>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

	</div>
</BaseLayout>

<style>
	/* ── Dev shell ──────────────────────────────────────────────────────────── */
	.dev-page { padding-block-start: var(--space-5xl); }
	.dev-page__header { margin-block-end: var(--space-4xl); }
	.dev-page__title {
		font-family: var(--font-serif);
		font-size: clamp(var(--font-size-3xl), 4vw, var(--font-size-5xl));
		font-weight: var(--font-weight-light); color: var(--color-fg-default);
		letter-spacing: var(--letter-spacing-tight);
	}
	.dev-page__sub {
		font-family: var(--font-sans); font-size: var(--font-size-sm);
		color: var(--color-fg-muted); margin-block-start: var(--space-sm);
	}
	.dev-section { padding-block: var(--space-5xl); }
	.dev-section--alt { background: var(--color-bg-subtle); }
	.dev-section--brand { background: var(--color-bg-brand); }
	.dev-label {
		font-family: var(--font-sans); font-size: var(--font-size-xs);
		font-weight: var(--font-weight-medium); letter-spacing: var(--letter-spacing-widest);
		text-transform: uppercase; color: var(--color-fg-subtle); margin-block-end: var(--space-3xl);
	}
	.dev-label--light { color: var(--color-fg-on-brand-subtle); }
	.grid-4 {
		display: grid; grid-template-columns: 1fr; gap: var(--space-xl);
		@media (min-width: 640px) { grid-template-columns: 1fr 1fr; }
		@media (min-width: 1024px) { grid-template-columns: repeat(4, 1fr); }
	}
	.grid-2 {
		display: grid; grid-template-columns: 1fr; gap: var(--space-xl);
		@media (min-width: 768px) { grid-template-columns: 1fr 1fr; }
	}

	/* ── Shared role / name / bio atoms ─────────────────────────────────────── */
	/* (each card defines its own — no bleed) */

	/* ══ 01 — C: accent-tinted slide panel ══════════════════════════════════ */
	.v01 { border-radius: var(--radius-lg); overflow: hidden; }
	.v01__img-wrap { position: relative; aspect-ratio: 3 / 4; overflow: hidden; }
	.v01__img {
		width: 100%; height: 100%; object-fit: cover; display: block;
		transition: transform var(--duration-slow) var(--ease-smooth);
		.v01:hover & { transform: scale(1.04); }
	}
	.v01__panel {
		position: absolute; inset-inline: 0; inset-block-end: 0;
		padding: var(--space-xl);
		background: color-mix(in srgb, var(--color-bg-accent) 95%, transparent);
		transform: translateY(calc(100% - var(--space-5xl)));
		transition: transform var(--duration-slow) var(--ease-smooth);
		.v01:hover & { transform: translateY(0); }
	}
	.v01__role {
		font-family: var(--font-sans); font-size: var(--font-size-xs);
